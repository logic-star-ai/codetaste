diff --git a/cpp/cmake_modules/BuildUtils.cmake b/cpp/cmake_modules/BuildUtils.cmake
index 90839cb..0af5747 100644
--- a/cpp/cmake_modules/BuildUtils.cmake
+++ b/cpp/cmake_modules/BuildUtils.cmake
@@ -953,12 +953,41 @@ function(ARROW_INSTALL_ALL_HEADERS PATH)
   endif()
   file(GLOB CURRENT_DIRECTORY_HEADERS ${ARG_PATTERN})
 
+  # Some directories intentionally export testing helpers, but most "test" headers
+  # are private implementation details and should not be installed.
+  set(ARROW_INSTALL_ALL_HEADERS_ALLOW_TESTING_HEADERS FALSE)
+  if(PATH MATCHES "^arrow/testing$")
+    set(ARROW_INSTALL_ALL_HEADERS_ALLOW_TESTING_HEADERS TRUE)
+  endif()
+
   set(PUBLIC_HEADERS)
   foreach(HEADER ${CURRENT_DIRECTORY_HEADERS})
     get_filename_component(HEADER_BASENAME ${HEADER} NAME)
     if(HEADER_BASENAME MATCHES "internal")
       continue()
     endif()
+    # Precompiled header stubs are build-only implementation details.
+    if(HEADER_BASENAME STREQUAL "pch.h" OR HEADER_BASENAME STREQUAL "pch.hpp")
+      continue()
+    endif()
+    if(NOT ARROW_INSTALL_ALL_HEADERS_ALLOW_TESTING_HEADERS)
+      # Keep module-private test helpers out of the public install interface.
+      if(HEADER_BASENAME MATCHES "^test_.*\\.(h|hpp)$")
+        continue()
+      endif()
+      if(HEADER_BASENAME MATCHES ".*_test\\.(h|hpp)$")
+        continue()
+      endif()
+      if(HEADER_BASENAME MATCHES ".*_test_util\\.(h|hpp)$")
+        continue()
+      endif()
+      if(HEADER_BASENAME STREQUAL "test_common.h" OR HEADER_BASENAME STREQUAL "test_common.hpp")
+        continue()
+      endif()
+      if(HEADER_BASENAME STREQUAL "testing.h" OR HEADER_BASENAME STREQUAL "testing.hpp")
+        continue()
+      endif()
+    endif()
     list(APPEND PUBLIC_HEADERS ${HEADER})
   endforeach()
   install(FILES ${PUBLIC_HEADERS} DESTINATION "${CMAKE_INSTALL_INCLUDEDIR}/${PATH}")
