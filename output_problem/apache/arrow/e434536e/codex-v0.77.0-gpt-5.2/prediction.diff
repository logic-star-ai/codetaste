+# specific language governing permissions and limitations
+# under the License.
+
+import os
+import subprocess
+import sys
+
+def test_import_does_not_eagerly_import_pandas():
+    # Many tests import pandas; run this check in a clean subprocess.
+    module_root = os.path.abspath(os.path.join(os.path.dirname(__file__), ".."))
+    env = os.environ.copy()
+    existing_pythonpath = env.get("PYTHONPATH", "")
+    env["PYTHONPATH"] = (
+        module_root if not existing_pythonpath else os.pathsep.join((module_root, existing_pythonpath))
+    )
+
+    subprocess.check_call(
+        [
+            sys.executable,
+            "-c",
+            "import sys; import pyarrow as pa; assert 'pandas' not in sys.modules",
+        ],
+        env=env,
+    )
