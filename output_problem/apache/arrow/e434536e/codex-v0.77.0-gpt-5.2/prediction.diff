+++ b/python/scripts/leak_check.py
@@ -0,0 +1,98 @@
+#!/usr/bin/env python
+
+# Licensed to the Apache Software Foundation (ASF) under one
+# or more contributor license agreements.  See the NOTICE file
+# distributed with this work for additional information
+# regarding copyright ownership.  The ASF licenses this file
+# to you under the Apache License, Version 2.0 (the
+# "License"); you may not use this file except in compliance
+# with the License.  You may obtain a copy of the License at
+#
+#   http://www.apache.org/licenses/LICENSE-2.0
+#
+# Unless required by applicable law or agreed to in writing,
+# software distributed under the License is distributed on an
+# "AS IS" BASIS, WITHOUT WARRANTIES OR CONDITIONS OF ANY
+# KIND, either express or implied.  See the License for the
+# specific language governing permissions and limitations
+# under the License.
+
+import io
+
+import gc
+import numpy as np
+import pandas as pd
+import pyarrow as pa
+from pyarrow.tests.util import memory_leak_check, rands
+
+
+def check_does_not_leak(f, iterations=10, check_interval=1, tolerance_mb=5):
+    memory_leak_check(
+        f,
+        metric="rss",
+        threshold=int(tolerance_mb * (1 << 20)),
+        iterations=iterations,
+        check_interval=check_interval,
+    )
+
+
+def leak_check_table_to_pandas():
+    data = [pa.array(np.concatenate([np.random.randn(100000)] * 1000))]
+    table = pa.Table.from_arrays(data, ["foo"])
+    check_does_not_leak(lambda: table.to_pandas())
+
+
+def leak_check_ipc_roundtrip():
+    data = [pa.array(np.concatenate([np.random.randn(100000)] * 10))]
+    table = pa.Table.from_arrays(data, ["foo"])
+
+    def action():
+        df = table.to_pandas()
+        batch = pa.RecordBatch.from_pandas(df)
+
+        sink = io.BytesIO()
+        with pa.RecordBatchFileWriter(sink, batch.schema) as writer:
+            writer.write_batch(batch)
+
+        reader = pa.open_file(pa.BufferReader(sink.getvalue()))
+        reader.read_all()
+
+    check_does_not_leak(action, iterations=50, tolerance_mb=50)
+
+
+def leak_check_parquet_writer():
+    import pyarrow.parquet as pq
+
+    df = pd.DataFrame({f"a{i}": [1, 2, 3, 4] for i in range(50)})
+    table = pa.Table.from_pandas(df, preserve_index=False)
+
+    # Ensure resources are cleaned up even if the leak check raises.
+    writer = pq.ParquetWriter(f"leak_test_{rands(5)}.parquet", table.schema)
+    try:
+
+        def action():
+            writer.write_table(table, row_group_size=len(table))
+
+        # This does not "leak" per se but we do want to have this use as little memory
+        # as possible.
+        check_does_not_leak(action, iterations=500, check_interval=50, tolerance_mb=20)
+    finally:
+        writer.close()
+        gc.collect()
+
+
+def leak_check_arrow_8801():
+    x = pd.to_datetime(
+        np.random.randint(0, 2**32, size=2**20, dtype=np.int64), unit="ms", utc=True
+    )
+    table = pa.table(pd.DataFrame({"x": x}))
+    check_does_not_leak(
+        lambda: table.to_pandas(split_blocks=False),
+        iterations=1000,
+        check_interval=50,
+        tolerance_mb=1000,
+    )
+
+
+if __name__ == "__main__":
+    leak_check_arrow_8801()
