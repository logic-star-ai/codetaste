--- a/pkg/k8s/config.go
+++ b/pkg/k8s/config.go
@@ -4,9 +4,28 @@
 // Package k8s abstracts all Kubernetes specific behaviour
 package k8s
 
+import (
+	"os"
+	"sync/atomic"
+)
+
+var k8sEnabled atomic.Bool
+
+// SetEnabled sets whether Kubernetes support is available.
+//
+// This is set by the Kubernetes client cell when it starts and stops.
+func SetEnabled(enabled bool) {
+	k8sEnabled.Store(enabled)
+}
+
 // IsEnabled checks if Cilium is being used in tandem with Kubernetes.
 func IsEnabled() bool {
-	// If clients have been set, then consider k8s enabled regardless
-	// of config.
-	return k8sCLI.Interface != nil
+	// Prefer the explicitly-managed runtime state (set by the k8s client cell),
+	// but fall back to in-cluster detection for legacy callers that do not have
+	// direct access to a clientset.
+	if k8sEnabled.Load() {
+		return true
+	}
+	return (os.Getenv("KUBERNETES_SERVICE_HOST") != "" && os.Getenv("KUBERNETES_SERVICE_PORT") != "") ||
+		os.Getenv("K8S_NODE_NAME") != ""
 }
