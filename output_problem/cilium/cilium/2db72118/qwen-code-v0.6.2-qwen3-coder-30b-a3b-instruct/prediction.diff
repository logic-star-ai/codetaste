diff --git a/pkg/k8s/client.go b/pkg/k8s/client.go
index 87af20c7..c74884ef 100644
--- a/pkg/k8s/client.go
+++ b/pkg/k8s/client.go
@@ -12,6 +12,61 @@ import (
 	slimclientset "github.com/cilium/cilium/pkg/k8s/slim/k8s/client/clientset/versioned"
 )
 
+// K8sClients holds all the Kubernetes clients in a struct, replacing global variables
+type K8sClients struct {
+	// k8sCLI is the default client.
+	k8sCLI *K8sClient
+
+	// k8sWatcherCLI is the client dedicated k8s structure watchers.
+	k8sWatcherCLI *K8sSlimClient
+
+	// k8sCiliumCLI is the default Cilium client.
+	k8sCiliumCLI *K8sCiliumClient
+
+	// k8sAPIExtCLI is the dedicated apiextensions client.
+	k8sAPIExtCLI *K8sAPIExtensionsClient
+
+	// k8sAPIExtWatcherCLI is the client dedicated to API Extensions watchers.
+	k8sAPIExtWatcherCLI *K8sAPIExtensionsClient
+}
+
+// NewK8sClients creates a new K8sClients struct with the given clients.
+func NewK8sClients(normal kubernetes.Interface, slim slimclientset.Interface, cilium clientset.Interface, apiext apiextclientset.Interface) *K8sClients {
+	return &K8sClients{
+		k8sCLI:              &K8sClient{Interface: normal},
+		k8sWatcherCLI:       &K8sSlimClient{Interface: slim},
+		k8sCiliumCLI:        &K8sCiliumClient{Interface: cilium},
+		k8sAPIExtCLI:        &K8sAPIExtensionsClient{apiext},
+		k8sAPIExtWatcherCLI: &K8sAPIExtensionsClient{apiext},
+	}
+}
+
+// Client returns the default Kubernetes client.
+func (k *K8sClients) Client() *K8sClient {
+	return k.k8sCLI
+}
+
+// WatcherClient returns the client dedicated to K8s watchers.
+func (k *K8sClients) WatcherClient() *K8sSlimClient {
+	return k.k8sWatcherCLI
+}
+
+// CiliumClient returns the default Cilium Kubernetes client.
+func (k *K8sClients) CiliumClient() *K8sCiliumClient {
+	return k.k8sCiliumCLI
+}
+
+// APIExtClient returns the default API Extension client.
+func (k *K8sClients) APIExtClient() *K8sAPIExtensionsClient {
+	return k.k8sAPIExtCLI
+}
+
+// WatcherAPIExtClient returns the client dedicated to API Extensions watchers.
+func (k *K8sClients) WatcherAPIExtClient() *K8sAPIExtensionsClient {
+	return k.k8sAPIExtWatcherCLI
+}
+
+// We maintain backward compatibility functions for existing code that calls k8s.Client() directly.
 var (
 	// k8sCLI is the default client.
 	k8sCLI = &K8sClient{}
@@ -61,3 +116,4 @@ func APIExtClient() *K8sAPIExtensionsClient {
 func WatcherAPIExtClient() *K8sAPIExtensionsClient {
 	return k8sAPIExtWatcherCLI
 }
