 // Package k8s abstracts all Kubernetes specific behaviour
 package k8s
 
+import (
+	"github.com/cilium/cilium/pkg/option"
+)
+
 // IsEnabled checks if Cilium is being used in tandem with Kubernetes.
 func IsEnabled() bool {
 	// If clients have been set, then consider k8s enabled regardless
 	// of config.
-	return k8sCLI.Interface != nil
+	// Use the global client check instead of the old global variable
+	return Client().Interface != nil
+}
+
+// IsK8sEnabled checks if the K8s option is set to enabled or default.
+func IsK8sEnabled() bool {
+	// When using K8s in default mode, the user has to specify it explicitly.
+	// If the user has K8s explicitly enabled, always return true.
+	// If the option is set to default, the user hasn't explicitly enabled it.
+	// In this case check whether the global client is set to determine if
+	// we are in a K8s environment.
+	if option.Config.K8sEnable {
+		return true
+	}
+
+	// Default to checking k8s client
+	return IsEnabled()
 }
