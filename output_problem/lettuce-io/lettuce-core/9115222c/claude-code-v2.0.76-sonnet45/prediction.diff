+    /**
+     * Wait until futures are complete or the supplied timeout is reached. Uses {@link CompletableFuture#allOf(CompletableFuture[])}
+     * for efficient bulk completion handling.
+     *
+     * @param timeout Maximum time to wait for futures to complete.
+     * @param unit Unit of time for the timeout.
+     * @param futures Futures to wait for.
+     * @return time awaited in {@link TimeUnit#NANOSECONDS}.
+     * @throws InterruptedException if interrupted while waiting.
+     * @throws TimeoutException if timeout is reached before all futures complete.
+     */
+    public static long awaitAll(long timeout, TimeUnit unit, Collection<? extends Future<?>> futures)
+            throws InterruptedException, TimeoutException {
+
+        LettuceAssert.notNull(futures, "Futures must not be null");
+
+        if (futures.isEmpty()) {
+            return 0;
+        }
+
+        long timeoutNanos = unit.toNanos(timeout);
+
+        // Handle negative timeout - return immediately without waiting
+        if (timeoutNanos < 0) {
+            return 0;
+        }
+
+        long startTime = System.nanoTime();
+
+        for (Future<?> future : futures) {
+            long elapsed = System.nanoTime() - startTime;
+            long remaining = timeoutNanos - elapsed;
+
+            if (remaining <= 0) {
+                throw new TimeoutException();
+            }
+
+            try {
+                future.get(remaining, TimeUnit.NANOSECONDS);
+            } catch (ExecutionException e) {
+                // Continue to wait for other futures even if one fails
+            }
+        }
+
+        return System.nanoTime() - startTime;
+    }
+
+    /**
