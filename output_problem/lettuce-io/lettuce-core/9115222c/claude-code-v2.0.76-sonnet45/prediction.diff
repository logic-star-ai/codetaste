+     *
+     * @param future the future to extract exception from.
+     * @return the exception cause, or {@literal null} if the future completed successfully.
+     */
+    public static Throwable getException(Future<?> future) {
+
+        LettuceAssert.notNull(future, "Future must not be null");
+
+        try {
+            future.get();
+        } catch (InterruptedException e) {
+            Thread.currentThread().interrupt();
+            return e;
+        } catch (ExecutionException e) {
+            return e.getCause();
+        }
+
+        return null;
