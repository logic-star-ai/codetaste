+package io.lettuce.core;
+
+import java.util.concurrent.TimeUnit;
+
+import io.lettuce.core.api.StatefulConnection;
+import io.lettuce.core.api.StatefulRedisConnection;
+import io.lettuce.core.internal.AbstractInvocationHandler;
+import io.lettuce.core.internal.TimeoutProvider;
+import io.lettuce.core.protocol.RedisCommand;
+
+/**
+ * Base class for synchronization invocation handlers that convert async API calls to synchronous ones.
+ * Provides common functionality for handling {@link RedisFuture}s, timeouts, and transaction state.
+ *
+ * @author Mark Paluch
+ */
+abstract class AbstractFutureSyncInvocationHandler extends AbstractInvocationHandler {
+
+    private final StatefulConnection<?, ?> connection;
+    private final TimeoutProvider timeoutProvider;
+
+    protected AbstractFutureSyncInvocationHandler(StatefulConnection<?, ?> connection) {
+        this.connection = connection;
+        this.timeoutProvider = new TimeoutProvider(
+            () -> connection.getOptions().getTimeoutOptions(),
+            () -> connection.getTimeout().toNanos()
+        );
+    }
+
+    /**
+     * Synchronously await the completion of a {@link RedisFuture}.
+     *
+     * @param command the future to await
+     * @param <T> result type
+     * @return the result value
+     */
+    protected <T> T awaitFuture(RedisFuture<T> command) {
+        long timeout = getTimeoutNs(command);
+        return LettuceFutures.awaitOrCancel(command, timeout, TimeUnit.NANOSECONDS);
+    }
+
+    /**
+     * Get the timeout in nanoseconds for a command.
+     *
+     * @param command the command
+     * @return timeout in nanoseconds
+     */
+    protected long getTimeoutNs(RedisFuture<?> command) {
+        if (command instanceof RedisCommand) {
+            return timeoutProvider.getTimeoutNs((RedisCommand<?, ?, ?>) command);
+        }
+        return connection.getTimeout().toNanos();
+    }
+
+    /**
+     * Check if a transaction is currently active.
+     *
+     * @return {@literal true} if a transaction is active
+     */
+    protected boolean isTransactionActive() {
+        return connection instanceof StatefulRedisConnection
+            && ((StatefulRedisConnection<?, ?>) connection).isMulti();
+    }
+
+    /**
+     * Check if the method name is NOT a transaction control method.
+     *
+     * @param methodName the method name
+     * @return {@literal true} if the method is not exec, multi, or discard
+     */
+    protected boolean isNonTxControlMethod(String methodName) {
+        return !methodName.equals("exec")
+            && !methodName.equals("multi")
+            && !methodName.equals("discard");
+    }
+
+    /**
+     * Get the underlying connection.
+     *
+     * @return the connection
+     */
+    protected StatefulConnection<?, ?> getConnection() {
+        return connection;
+    }
+}
