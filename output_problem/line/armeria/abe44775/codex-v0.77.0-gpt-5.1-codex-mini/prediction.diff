+package com.linecorp.armeria.client;
+
+import static org.hamcrest.MatcherAssert.assertThat;
+import static org.hamcrest.Matchers.is;
+import static org.hamcrest.Matchers.notNullValue;
+import static org.mockito.Mockito.mock;
+
+import java.time.Duration;
+import java.util.Optional;
+import java.util.function.Consumer;
+
+import javax.net.ssl.TrustManagerFactory;
+
+import org.junit.Test;
+
+import io.netty.channel.EventLoopGroup;
+import io.netty.handler.ssl.SslContextBuilder;
+
+public class ClientFactoryOptionsTest {
+
+    @Test
+    public void defaultValues() {
+        ClientFactoryOptions options = ClientFactoryOptions.DEFAULT;
+        assertThat(options.connectTimeout(), is(notNullValue()));
+        assertThat(options.idleTimeout(), is(notNullValue()));
+        assertThat(options.trustManagerFactory(), is(Optional.empty()));
+    }
+
+    @Test
+    public void builderOverrides() {
+        Duration connectionTimeout = Duration.ofMillis(10);
+        Duration idleTimeout = Duration.ofMillis(200);
+        EventLoopGroup eventLoopGroup = mock(EventLoopGroup.class);
+        TrustManagerFactory trustManagerFactory = mock(TrustManagerFactory.class);
+        Consumer<SslContextBuilder> sslContextCustomizer = builder ->
+                builder.trustManager(trustManagerFactory);
+
+        ClientFactoryOptions options = ClientFactoryOptions.builder()
+                .connectTimeout(connectionTimeout)
+                .idleTimeout(idleTimeout)
+                .eventLoopGroup(eventLoopGroup)
+                .sslContextCustomizer(sslContextCustomizer)
+                .useHttp2Preface(true)
+                .useHttp1Pipelining(false)
+                .build();
+
+        assertThat(options.connectTimeout(), is(connectionTimeout));
+        assertThat(options.idleTimeout(), is(idleTimeout));
+        assertThat(options.eventLoopGroup(), is(Optional.of(eventLoopGroup)));
+        assertThat(options.sslContextCustomizer().isPresent(), is(true));
+        assertThat(options.useHttp2Preface(), is(true));
+        assertThat(options.useHttp1Pipelining(), is(false));
+    }
+
+    @Test(expected = IllegalArgumentException.class)
+    public void validateConnectTimeout() {
+        ClientFactoryOptions.builder().connectTimeout(Duration.ZERO);
+    }
+
+    @Test(expected = IllegalArgumentException.class)
+    public void validateIdleTimeout() {
+        ClientFactoryOptions.builder().idleTimeout(Duration.ofMillis(-1));
+    }
+
+}
