+package com.linecorp.armeria.client;
+
+import static java.util.Objects.requireNonNull;
+
+import java.net.InetSocketAddress;
+import java.time.Duration;
+import java.util.Objects;
+import java.util.Optional;
+import java.util.function.Consumer;
+import java.util.function.Function;
+
+import javax.net.ssl.TrustManagerFactory;
+
+import com.linecorp.armeria.client.pool.KeyedChannelPoolHandler;
+import com.linecorp.armeria.client.pool.PoolKey;
+import com.linecorp.armeria.common.Flags;
+import com.linecorp.armeria.common.SessionProtocol;
+
+import io.netty.channel.EventLoopGroup;
+import io.netty.handler.ssl.SslContextBuilder;
+import io.netty.resolver.AddressResolverGroup;
+
+/**
+ * Configuration options shared by all clients created by a {@link ClientFactory}.
+ *
+ * <p>These options only target HTTP protocols because Armeria no longer supports other transport families.
+ */
+public final class ClientFactoryOptions {
+
+    private static final Duration DEFAULT_CONNECTION_TIMEOUT = Duration.ofMillis(3200);
+    private static final Duration DEFAULT_IDLE_TIMEOUT = Duration.ofSeconds(10);
+
+    /**
+     * The default {@link ClientFactoryOptions}.
+     */
+    public static final ClientFactoryOptions DEFAULT = builder().build();
+
+    private final Duration connectTimeout;
+    private final Duration idleTimeout;
+    private final boolean useHttp2Preface;
+    private final boolean useHttp1Pipelining;
+    private final EventLoopGroup eventLoopGroup;
+    private final AddressResolverGroup<? extends InetSocketAddress> addressResolverGroup;
+    private final Function<KeyedChannelPoolHandler<PoolKey>, KeyedChannelPoolHandler<PoolKey>> poolHandlerDecorator;
+    private final Consumer<SslContextBuilder> sslContextCustomizer;
+    private final TrustManagerFactory trustManagerFactory;
+
+    private ClientFactoryOptions(Builder builder) {
+        connectTimeout = builder.connectTimeout;
+        idleTimeout = builder.idleTimeout;
+        useHttp2Preface = builder.useHttp2Preface;
+        useHttp1Pipelining = builder.useHttp1Pipelining;
+        eventLoopGroup = builder.eventLoopGroup;
+        addressResolverGroup = builder.addressResolverGroup;
+        poolHandlerDecorator = builder.poolHandlerDecorator;
+        sslContextCustomizer = builder.sslContextCustomizer;
+        trustManagerFactory = builder.trustManagerFactory;
+    }
+
+    /**
+     * Returns a new {@link Builder} with default settings.
+     */
+    public static Builder builder() {
+        return new Builder();
+    }
+
+    /**
+     * Returns a new {@link Builder} pre-populated with the values from the specified {@link ClientFactoryOptions}.
+     */
+    public static Builder builder(ClientFactoryOptions baseOptions) {
+        requireNonNull(baseOptions, "baseOptions");
+        return new Builder(baseOptions);
+    }
+
+    /**
+     * Returns the timeout of a socket connection attempt.
+     */
+    public Duration connectTimeout() {
+        return connectTimeout;
+    }
+
+    /**
+     * Returns the timeout of a socket connection attempt in milliseconds.
+     */
+    public long connectTimeoutMillis() {
+        return connectTimeout().toMillis();
+    }
+
+    /**
+     * Returns the idle timeout of a socket connection.
+     */
+    public Duration idleTimeout() {
+        return idleTimeout;
+    }
+
+    /**
+     * Returns the idle timeout of a socket connection in milliseconds.
+     */
+    public long idleTimeoutMillis() {
+        return idleTimeout().toMillis();
+    }
+
+    /**
+     * Returns the {@link EventLoopGroup} that will provide the {@link SessionProtocol} event loops.
+     */
+    public Optional<EventLoopGroup> eventLoopGroup() {
+        return Optional.ofNullable(eventLoopGroup);
+    }
+
+    /**
+     * Returns the {@link AddressResolverGroup} used to resolve remote addresses.
+     */
+    public Optional<AddressResolverGroup<InetSocketAddress>> addressResolverGroup() {
+        @SuppressWarnings("unchecked")
+        final AddressResolverGroup<InetSocketAddress> group =
+                (AddressResolverGroup<InetSocketAddress>) addressResolverGroup;
+        return Optional.ofNullable(group);
+    }
+
+    /**
+     * Returns the decorator for the {@link KeyedChannelPoolHandler}.
+     */
+    public Function<KeyedChannelPoolHandler<PoolKey>, KeyedChannelPoolHandler<PoolKey>> poolHandlerDecorator() {
+        return poolHandlerDecorator;
+    }
+
+    /**
+     * Returns a {@link Consumer} that customizes the {@link SslContextBuilder} used by the client.
+     */
+    public Optional<Consumer<SslContextBuilder>> sslContextCustomizer() {
+        return Optional.ofNullable(sslContextCustomizer);
+    }
+
+    /**
+     * Returns the {@link TrustManagerFactory} used by the client if set.
+     *
+     * @deprecated Use {@link #sslContextCustomizer()} instead.
+     */
+    @Deprecated
+    public Optional<TrustManagerFactory> trustManagerFactory() {
+        return Optional.ofNullable(trustManagerFactory);
+    }
+
+    /**
+     * Returns whether an HTTP/2 preface is enabled for cleartext HTTP/2 connections.
+     */
+    public boolean useHttp2Preface() {
+        return useHttp2Preface;
+    }
+
+    /**
+     * Returns whether HTTP/1 pipelining is enabled for HTTP/1 clients.
+     */
+    public boolean useHttp1Pipelining() {
+        return useHttp1Pipelining;
+    }
+
+    /**
+     * A builder for {@link ClientFactoryOptions}.
+     */
+    public static final class Builder {
+
+        private Duration connectTimeout = DEFAULT_CONNECTION_TIMEOUT;
+        private Duration idleTimeout = DEFAULT_IDLE_TIMEOUT;
+        private boolean useHttp2Preface = Flags.defaultUseHttp2Preface();
+        private boolean useHttp1Pipelining = Flags.defaultUseHttp1Pipelining();
+        private EventLoopGroup eventLoopGroup;
+        private AddressResolverGroup<? extends InetSocketAddress> addressResolverGroup;
+        private Function<KeyedChannelPoolHandler<PoolKey>, KeyedChannelPoolHandler<PoolKey>> poolHandlerDecorator =
+                Function.identity();
+        private Consumer<SslContextBuilder> sslContextCustomizer;
+        private TrustManagerFactory trustManagerFactory;
+
+        private Builder() {}
+
+        private Builder(ClientFactoryOptions baseOptions) {
+            connectTimeout = baseOptions.connectTimeout;
+            idleTimeout = baseOptions.idleTimeout;
+            useHttp2Preface = baseOptions.useHttp2Preface;
+            useHttp1Pipelining = baseOptions.useHttp1Pipelining;
+            eventLoopGroup = baseOptions.eventLoopGroup;
+            addressResolverGroup = baseOptions.addressResolverGroup;
+            poolHandlerDecorator = baseOptions.poolHandlerDecorator;
+            sslContextCustomizer = baseOptions.sslContextCustomizer;
+            trustManagerFactory = baseOptions.trustManagerFactory;
+        }
+
+        /**
+         * Sets the timeout of a socket connection attempt.
+         */
+        public Builder connectTimeout(Duration connectTimeout) {
+            this.connectTimeout = validateConnectionTimeout(connectTimeout);
+            return this;
+        }
+
+        /**
+         * Sets the idle timeout of a socket connection.
+         */
+        public Builder idleTimeout(Duration idleTimeout) {
+            this.idleTimeout = validateIdleTimeout(idleTimeout);
+            return this;
+        }
+
+        /**
+         * Sets the {@link EventLoopGroup} that will provide the {@link SessionProtocol} event loops.
+         */
+        public Builder eventLoopGroup(EventLoopGroup eventLoopGroup) {
+            this.eventLoopGroup = requireNonNull(eventLoopGroup, "eventLoopGroup");
+            return this;
+        }
+
+        /**
+         * Sets the {@link AddressResolverGroup} used to resolve remote addresses.
+         */
+        public Builder addressResolverGroup(AddressResolverGroup<? extends InetSocketAddress> group) {
+            addressResolverGroup = requireNonNull(group, "group");
+            return this;
+        }
+
+        /**
+         * Sets a decorator for the {@link KeyedChannelPoolHandler}.
+         */
+        public Builder poolHandlerDecorator(
+                Function<KeyedChannelPoolHandler<PoolKey>, KeyedChannelPoolHandler<PoolKey>> decorator) {
+            poolHandlerDecorator = requireNonNull(decorator, "decorator");
+            return this;
+        }
+
+        /**
+         * Sets a {@link Consumer} that customizes the {@link SslContextBuilder}.
+         */
+        public Builder sslContextCustomizer(Consumer<SslContextBuilder> sslContextCustomizer) {
+            this.sslContextCustomizer = requireNonNull(sslContextCustomizer, "sslContextCustomizer");
+            return this;
+        }
+
+        /**
+         * Sets the {@link TrustManagerFactory} on which SSL handshakes rely.
+         *
+         * @deprecated Use {@link #sslContextCustomizer(Consumer)} instead.
+         */
+        @Deprecated
+        public Builder trustManagerFactory(TrustManagerFactory trustManagerFactory) {
+            this.trustManagerFactory = requireNonNull(trustManagerFactory, "trustManagerFactory");
+            return this;
+        }
+
+        /**
+         * Sets whether an HTTP/2 preface is enabled for cleartext HTTP/2 connections.
+         */
+        public Builder useHttp2Preface(boolean useHttp2Preface) {
+            this.useHttp2Preface = useHttp2Preface;
+            return this;
+        }
+
+        /**
+         * Sets whether HTTP/1 pipelining is enabled for HTTP/1 clients.
+         */
+        public Builder useHttp1Pipelining(boolean useHttp1Pipelining) {
+            this.useHttp1Pipelining = useHttp1Pipelining;
+            return this;
+        }
+
+        /**
+         * Builds the {@link ClientFactoryOptions}.
+         */
+        public ClientFactoryOptions build() {
+            requireNonNull(connectTimeout, "connectTimeout");
+            requireNonNull(idleTimeout, "idleTimeout");
+            requireNonNull(poolHandlerDecorator, "poolHandlerDecorator");
+            return new ClientFactoryOptions(this);
+        }
+    }
+
+    private static Duration validateConnectionTimeout(Duration connectionTimeout) {
+        requireNonNull(connectionTimeout, "connectionTimeout");
+        if (connectionTimeout.isNegative() || connectionTimeout.isZero()) {
+            throw new IllegalArgumentException(
+                    "connectTimeout: " + connectionTimeout + " (expected: > 0)");
+        }
+        return connectionTimeout;
+    }
+
+    private static Duration validateIdleTimeout(Duration idleTimeout) {
+        requireNonNull(idleTimeout, "idleTimeout");
+        if (idleTimeout.isNegative()) {
+            throw new IllegalArgumentException(
+                    "idleTimeout: " + idleTimeout + " (expected: >= 0)");
+        }
+        return idleTimeout;
+    }
+
+    @Override
+    public String toString() {
+        return "ClientFactoryOptions{" +
+               "connectTimeout=" + connectTimeout +
+               ", idleTimeout=" + idleTimeout +
+               ", useHttp2Preface=" + useHttp2Preface +
+               ", useHttp1Pipelining=" + useHttp1Pipelining +
+               ", eventLoopGroup=" + eventLoopGroup +
+               ", addressResolverGroup=" + addressResolverGroup +
+               ", poolHandlerDecorator=" + poolHandlerDecorator +
+               ", sslContextCustomizer=" + sslContextCustomizer +
+               ", trustManagerFactory=" + trustManagerFactory +
+               '}';
+    }
+}
