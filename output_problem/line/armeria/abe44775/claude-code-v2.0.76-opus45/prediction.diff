+package com.linecorp.armeria.client;
+
+import static java.util.Objects.requireNonNull;
+
+import java.net.InetSocketAddress;
+import java.time.Duration;
+import java.util.Optional;
+import java.util.function.Consumer;
+import java.util.function.Function;
+
+import javax.annotation.Nullable;
+import javax.net.ssl.TrustManagerFactory;
+
+import com.linecorp.armeria.client.pool.KeyedChannelPoolHandler;
+import com.linecorp.armeria.client.pool.PoolKey;
+import com.linecorp.armeria.common.Flags;
+
+import io.netty.channel.EventLoopGroup;
+import io.netty.handler.ssl.SslContextBuilder;
+import io.netty.resolver.AddressResolverGroup;
+
+/**
+ * Options that affect the HTTP session management of a {@link ClientFactory}.
+ */
+public final class ClientFactoryOptions {
+
+    private static final Duration DEFAULT_CONNECT_TIMEOUT = Duration.ofMillis(3200);
+    private static final Duration DEFAULT_IDLE_TIMEOUT = Duration.ofSeconds(10);
+
+    /**
+     * The default {@link ClientFactoryOptions}.
+     */
+    public static final ClientFactoryOptions DEFAULT = new ClientFactoryOptions(
+            DEFAULT_CONNECT_TIMEOUT,
+            DEFAULT_IDLE_TIMEOUT,
+            null,
+            null,
+            null,
+            null,
+            null,
+            Flags.defaultUseHttp2Preface(),
+            Flags.defaultUseHttp1Pipelining()
+    );
+
+    private final Duration connectTimeout;
+    private final Duration idleTimeout;
+    @Nullable
+    private final TrustManagerFactory trustManagerFactory;
+    @Nullable
+    private final Consumer<SslContextBuilder> sslContextCustomizer;
+    @Nullable
+    private final AddressResolverGroup<? extends InetSocketAddress> addressResolverGroup;
+    @Nullable
+    private final EventLoopGroup eventLoopGroup;
+    @Nullable
+    private final Function<KeyedChannelPoolHandler<PoolKey>, KeyedChannelPoolHandler<PoolKey>> poolHandlerDecorator;
+    private final boolean useHttp2Preface;
+    private final boolean useHttp1Pipelining;
+
+    private ClientFactoryOptions(
+            Duration connectTimeout,
+            Duration idleTimeout,
+            @Nullable TrustManagerFactory trustManagerFactory,
+            @Nullable Consumer<SslContextBuilder> sslContextCustomizer,
+            @Nullable AddressResolverGroup<? extends InetSocketAddress> addressResolverGroup,
+            @Nullable EventLoopGroup eventLoopGroup,
+            @Nullable Function<KeyedChannelPoolHandler<PoolKey>, KeyedChannelPoolHandler<PoolKey>> poolHandlerDecorator,
+            boolean useHttp2Preface,
+            boolean useHttp1Pipelining) {
+        this.connectTimeout = connectTimeout;
+        this.idleTimeout = idleTimeout;
+        this.trustManagerFactory = trustManagerFactory;
+        this.sslContextCustomizer = sslContextCustomizer;
+        this.addressResolverGroup = addressResolverGroup;
+        this.eventLoopGroup = eventLoopGroup;
+        this.poolHandlerDecorator = poolHandlerDecorator;
+        this.useHttp2Preface = useHttp2Preface;
+        this.useHttp1Pipelining = useHttp1Pipelining;
+    }
+
+    /**
+     * Returns a new {@link ClientFactoryOptionsBuilder}.
+     */
+    public static ClientFactoryOptionsBuilder builder() {
+        return new ClientFactoryOptionsBuilder();
+    }
+
+    /**
+     * Returns a new {@link ClientFactoryOptionsBuilder} initialized with this options.
+     */
+    public ClientFactoryOptionsBuilder toBuilder() {
+        return new ClientFactoryOptionsBuilder(this);
+    }
+
+    /**
+     * Returns the timeout of a socket connection attempt.
+     */
+    public Duration connectTimeout() {
+        return connectTimeout;
+    }
+
+    /**
+     * Returns the timeout of a socket connection attempt as milliseconds.
+     */
+    public long connectTimeoutMillis() {
+        return connectTimeout.toMillis();
+    }
+
+    /**
+     * Returns the idle timeout of a socket connection. The connection is closed if there is no invocation
+     * in progress for this amount of time.
+     */
+    public Duration idleTimeout() {
+        return idleTimeout;
+    }
+
+    /**
+     * Returns the idle timeout of a socket connection as milliseconds.
+     */
+    public long idleTimeoutMillis() {
+        return idleTimeout.toMillis();
+    }
+
+    /**
+     * Returns the {@link TrustManagerFactory} of a TLS connection.
+     *
+     * @deprecated Use {@link #sslContextCustomizer()} instead.
+     */
+    @Deprecated
+    public Optional<TrustManagerFactory> trustManagerFactory() {
+        return Optional.ofNullable(trustManagerFactory);
+    }
+
+    /**
+     * Returns the {@link Consumer} which can arbitrarily configure the {@link SslContextBuilder} that will
+     * be applied to the factory's SSL context.
+     */
+    public Optional<Consumer<SslContextBuilder>> sslContextCustomizer() {
+        return Optional.ofNullable(sslContextCustomizer);
+    }
+
+    /**
+     * Returns the {@link AddressResolverGroup} to use to resolve remote addresses into
+     * {@link InetSocketAddress}es.
+     */
+    public Optional<AddressResolverGroup<InetSocketAddress>> addressResolverGroup() {
+        @SuppressWarnings("unchecked")
+        final AddressResolverGroup<InetSocketAddress> castValue =
+                (AddressResolverGroup<InetSocketAddress>) addressResolverGroup;
+        return Optional.ofNullable(castValue);
+    }
+
+    /**
+     * Returns the {@link EventLoopGroup} that will provide the {@link io.netty.channel.EventLoop} for I/O
+     * and asynchronous invocations.
+     */
+    public Optional<EventLoopGroup> eventLoopGroup() {
+        return Optional.ofNullable(eventLoopGroup);
+    }
+
+    /**
+     * Returns the {@link Function} that decorates the {@link KeyedChannelPoolHandler}.
+     */
+    public Function<KeyedChannelPoolHandler<PoolKey>, KeyedChannelPoolHandler<PoolKey>> poolHandlerDecorator() {
+        return poolHandlerDecorator != null ? poolHandlerDecorator : Function.identity();
+    }
+
+    /**
+     * Returns whether to send an HTTP/2 preface string instead of an HTTP/1 upgrade request to negotiate
+     * the protocol version of a cleartext HTTP connection.
+     */
+    public boolean useHttp2Preface() {
+        return useHttp2Preface;
+    }
+
+    /**
+     * Returns whether to use HTTP pipelining for HTTP/1 connections.
+     */
+    public boolean useHttp1Pipelining() {
+        return useHttp1Pipelining;
+    }
+
+    @Override
+    public String toString() {
+        return "ClientFactoryOptions{" +
+               "connectTimeout=" + connectTimeout +
+               ", idleTimeout=" + idleTimeout +
+               ", trustManagerFactory=" + trustManagerFactory +
+               ", sslContextCustomizer=" + sslContextCustomizer +
+               ", addressResolverGroup=" + addressResolverGroup +
+               ", eventLoopGroup=" + eventLoopGroup +
+               ", poolHandlerDecorator=" + poolHandlerDecorator +
+               ", useHttp2Preface=" + useHttp2Preface +
+               ", useHttp1Pipelining=" + useHttp1Pipelining +
+               '}';
+    }
+
+    /**
+     * A builder for {@link ClientFactoryOptions}.
+     */
+    public static final class ClientFactoryOptionsBuilder {
+
+        private Duration connectTimeout = DEFAULT_CONNECT_TIMEOUT;
+        private Duration idleTimeout = DEFAULT_IDLE_TIMEOUT;
+        @Nullable
+        private TrustManagerFactory trustManagerFactory;
+        @Nullable
+        private Consumer<SslContextBuilder> sslContextCustomizer;
+        @Nullable
+        private AddressResolverGroup<? extends InetSocketAddress> addressResolverGroup;
+        @Nullable
+        private EventLoopGroup eventLoopGroup;
+        @Nullable
+        private Function<KeyedChannelPoolHandler<PoolKey>, KeyedChannelPoolHandler<PoolKey>> poolHandlerDecorator;
+        private boolean useHttp2Preface = Flags.defaultUseHttp2Preface();
+        private boolean useHttp1Pipelining = Flags.defaultUseHttp1Pipelining();
+
+        ClientFactoryOptionsBuilder() {}
+
+        ClientFactoryOptionsBuilder(ClientFactoryOptions options) {
+            connectTimeout = options.connectTimeout;
+            idleTimeout = options.idleTimeout;
+            trustManagerFactory = options.trustManagerFactory;
+            sslContextCustomizer = options.sslContextCustomizer;
+            addressResolverGroup = options.addressResolverGroup;
+            eventLoopGroup = options.eventLoopGroup;
+            poolHandlerDecorator = options.poolHandlerDecorator;
+            useHttp2Preface = options.useHttp2Preface;
+            useHttp1Pipelining = options.useHttp1Pipelining;
+        }
+
+        /**
+         * Sets the timeout of a socket connection attempt.
+         */
+        public ClientFactoryOptionsBuilder connectTimeout(Duration connectTimeout) {
+            requireNonNull(connectTimeout, "connectTimeout");
+            if (connectTimeout.isNegative() || connectTimeout.isZero()) {
+                throw new IllegalArgumentException("connectTimeout: " + connectTimeout + " (expected: > 0)");
+            }
+            this.connectTimeout = connectTimeout;
+            return this;
+        }
+
+        /**
+         * Sets the timeout of a socket connection attempt in milliseconds.
+         */
+        public ClientFactoryOptionsBuilder connectTimeoutMillis(long connectTimeoutMillis) {
+            return connectTimeout(Duration.ofMillis(connectTimeoutMillis));
+        }
+
+        /**
+         * Sets the idle timeout of a socket connection.
+         */
+        public ClientFactoryOptionsBuilder idleTimeout(Duration idleTimeout) {
+            requireNonNull(idleTimeout, "idleTimeout");
+            if (idleTimeout.isNegative()) {
+                throw new IllegalArgumentException("idleTimeout: " + idleTimeout + " (expected: >= 0)");
+            }
+            this.idleTimeout = idleTimeout;
+            return this;
+        }
+
+        /**
+         * Sets the idle timeout of a socket connection in milliseconds.
+         */
+        public ClientFactoryOptionsBuilder idleTimeoutMillis(long idleTimeoutMillis) {
+            return idleTimeout(Duration.ofMillis(idleTimeoutMillis));
+        }
+
+        /**
+         * Sets the {@link TrustManagerFactory} of a TLS connection.
+         *
+         * @deprecated Use {@link #sslContextCustomizer(Consumer)} instead.
+         */
+        @Deprecated
+        public ClientFactoryOptionsBuilder trustManagerFactory(TrustManagerFactory trustManagerFactory) {
+            this.trustManagerFactory = requireNonNull(trustManagerFactory, "trustManagerFactory");
+            return this;
+        }
+
+        /**
+         * Sets a {@link Consumer} which can arbitrarily configure the {@link SslContextBuilder} that will
+         * be applied to the factory's SSL context.
+         */
+        public ClientFactoryOptionsBuilder sslContextCustomizer(
+                Consumer<SslContextBuilder> sslContextCustomizer) {
+            this.sslContextCustomizer = requireNonNull(sslContextCustomizer, "sslContextCustomizer");
+            return this;
+        }
+
+        /**
+         * Sets the {@link AddressResolverGroup} to use to resolve remote addresses.
+         */
+        public ClientFactoryOptionsBuilder addressResolverGroup(
+                AddressResolverGroup<? extends InetSocketAddress> addressResolverGroup) {
+            this.addressResolverGroup = requireNonNull(addressResolverGroup, "addressResolverGroup");
+            return this;
+        }
+
+        /**
+         * Sets the {@link EventLoopGroup} to use for I/O and asynchronous invocations.
+         */
+        public ClientFactoryOptionsBuilder eventLoopGroup(EventLoopGroup eventLoopGroup) {
+            this.eventLoopGroup = requireNonNull(eventLoopGroup, "eventLoopGroup");
+            return this;
+        }
+
+        /**
+         * Sets a {@link Function} that decorates the {@link KeyedChannelPoolHandler}.
+         */
+        public ClientFactoryOptionsBuilder poolHandlerDecorator(
+                Function<KeyedChannelPoolHandler<PoolKey>, KeyedChannelPoolHandler<PoolKey>> poolHandlerDecorator) {
+            this.poolHandlerDecorator = requireNonNull(poolHandlerDecorator, "poolHandlerDecorator");
+            return this;
+        }
+
+        /**
+         * Sets whether to send an HTTP/2 preface string instead of an HTTP/1 upgrade request.
+         */
+        public ClientFactoryOptionsBuilder useHttp2Preface(boolean useHttp2Preface) {
+            this.useHttp2Preface = useHttp2Preface;
+            return this;
+        }
+
+        /**
+         * Sets whether to use HTTP pipelining for HTTP/1 connections.
+         */
+        public ClientFactoryOptionsBuilder useHttp1Pipelining(boolean useHttp1Pipelining) {
+            this.useHttp1Pipelining = useHttp1Pipelining;
+            return this;
+        }
+
+        /**
+         * Returns a newly created {@link ClientFactoryOptions} with the configured options.
+         */
+        public ClientFactoryOptions build() {
+            return new ClientFactoryOptions(
+                    connectTimeout,
+                    idleTimeout,
+                    trustManagerFactory,
+                    sslContextCustomizer,
+                    addressResolverGroup,
+                    eventLoopGroup,
+                    poolHandlerDecorator,
+                    useHttp2Preface,
+                    useHttp1Pipelining
+            );
+        }
+    }
+}
