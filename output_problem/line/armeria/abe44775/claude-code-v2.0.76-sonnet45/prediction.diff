+package com.linecorp.armeria.client;
+
+import static java.util.Objects.requireNonNull;
+
+import java.net.InetSocketAddress;
+import java.time.Duration;
+import java.util.Optional;
+import java.util.function.Consumer;
+import java.util.function.Function;
+
+import javax.annotation.Nullable;
+import javax.net.ssl.TrustManagerFactory;
+
+import com.linecorp.armeria.client.pool.KeyedChannelPoolHandler;
+import com.linecorp.armeria.client.pool.PoolKey;
+import com.linecorp.armeria.common.Flags;
+
+import io.netty.channel.EventLoopGroup;
+import io.netty.handler.ssl.SslContextBuilder;
+import io.netty.resolver.AddressResolverGroup;
+
+/**
+ * HTTP session configuration for {@link ClientFactory}.
+ */
+public final class HttpSessionConfig {
+
+    private static final Duration DEFAULT_CONNECTION_TIMEOUT = Duration.ofMillis(3200);
+    private static final Duration DEFAULT_IDLE_TIMEOUT = Duration.ofSeconds(10);
+
+    /**
+     * The default {@link HttpSessionConfig}.
+     */
+    public static final HttpSessionConfig DEFAULT = builder().build();
+
+    private final Duration connectTimeout;
+    private final Duration idleTimeout;
+    @Nullable
+    private final TrustManagerFactory trustManagerFactory;
+    @Nullable
+    private final Consumer<SslContextBuilder> sslContextCustomizer;
+    @Nullable
+    private final AddressResolverGroup<? extends InetSocketAddress> addressResolverGroup;
+    @Nullable
+    private final EventLoopGroup eventLoopGroup;
+    @Nullable
+    private final Function<KeyedChannelPoolHandler<PoolKey>, KeyedChannelPoolHandler<PoolKey>> poolHandlerDecorator;
+    private final boolean useHttp2Preface;
+    private final boolean useHttp1Pipelining;
+
+    private HttpSessionConfig(Duration connectTimeout,
+                              Duration idleTimeout,
+                              @Nullable TrustManagerFactory trustManagerFactory,
+                              @Nullable Consumer<SslContextBuilder> sslContextCustomizer,
+                              @Nullable AddressResolverGroup<? extends InetSocketAddress> addressResolverGroup,
+                              @Nullable EventLoopGroup eventLoopGroup,
+                              @Nullable Function<KeyedChannelPoolHandler<PoolKey>,
+                                      KeyedChannelPoolHandler<PoolKey>> poolHandlerDecorator,
+                              boolean useHttp2Preface,
+                              boolean useHttp1Pipelining) {
+        this.connectTimeout = connectTimeout;
+        this.idleTimeout = idleTimeout;
+        this.trustManagerFactory = trustManagerFactory;
+        this.sslContextCustomizer = sslContextCustomizer;
+        this.addressResolverGroup = addressResolverGroup;
+        this.eventLoopGroup = eventLoopGroup;
+        this.poolHandlerDecorator = poolHandlerDecorator;
+        this.useHttp2Preface = useHttp2Preface;
+        this.useHttp1Pipelining = useHttp1Pipelining;
+    }
+
+    /**
+     * Returns a new {@link Builder}.
+     */
+    public static Builder builder() {
+        return new Builder();
+    }
+
+    /**
+     * Returns a new {@link Builder} initialized with this configuration.
+     */
+    public Builder toBuilder() {
+        final Builder builder = new Builder();
+        builder.connectTimeout(connectTimeout);
+        builder.idleTimeout(idleTimeout);
+        builder.trustManagerFactory(trustManagerFactory);
+        builder.sslContextCustomizer(sslContextCustomizer);
+        builder.addressResolverGroup(addressResolverGroup);
+        builder.eventLoopGroup(eventLoopGroup);
+        builder.poolHandlerDecorator(poolHandlerDecorator);
+        builder.useHttp2Preface(useHttp2Preface);
+        builder.useHttp1Pipelining(useHttp1Pipelining);
+        return builder;
+    }
+
+    /**
+     * Returns the connection timeout.
+     */
+    public Duration connectTimeout() {
+        return connectTimeout;
+    }
+
+    /**
+     * Returns the connection timeout in milliseconds.
+     */
+    public long connectTimeoutMillis() {
+        return connectTimeout.toMillis();
+    }
+
+    /**
+     * Returns the idle timeout.
+     */
+    public Duration idleTimeout() {
+        return idleTimeout;
+    }
+
+    /**
+     * Returns the idle timeout in milliseconds.
+     */
+    public long idleTimeoutMillis() {
+        return idleTimeout.toMillis();
+    }
+
+    /**
+     * Returns the {@link TrustManagerFactory} if specified.
+     *
+     * @deprecated Use {@link #sslContextCustomizer()} instead.
+     */
+    @Deprecated
+    public Optional<TrustManagerFactory> trustManagerFactory() {
+        return Optional.ofNullable(trustManagerFactory);
+    }
+
+    /**
+     * Returns the SSL context customizer if specified.
+     */
+    public Optional<Consumer<SslContextBuilder>> sslContextCustomizer() {
+        return Optional.ofNullable(sslContextCustomizer);
+    }
+
+    /**
+     * Returns the {@link AddressResolverGroup} if specified.
+     */
+    public Optional<AddressResolverGroup<InetSocketAddress>> addressResolverGroup() {
+        @SuppressWarnings("unchecked")
+        final Optional<AddressResolverGroup<InetSocketAddress>> castValue =
+                (Optional<AddressResolverGroup<InetSocketAddress>>) (Optional<?>) Optional.ofNullable(addressResolverGroup);
+        return castValue;
+    }
+
+    /**
+     * Returns the {@link EventLoopGroup} if specified.
+     */
+    public Optional<EventLoopGroup> eventLoopGroup() {
+        return Optional.ofNullable(eventLoopGroup);
+    }
+
+    /**
+     * Returns the pool handler decorator.
+     */
+    public Function<KeyedChannelPoolHandler<PoolKey>, KeyedChannelPoolHandler<PoolKey>> poolHandlerDecorator() {
+        return poolHandlerDecorator != null ? poolHandlerDecorator : Function.identity();
+    }
+
+    /**
+     * Returns whether to use HTTP/2 preface.
+     */
+    public boolean useHttp2Preface() {
+        return useHttp2Preface;
+    }
+
+    /**
+     * Returns whether to use HTTP/1 pipelining.
+     */
+    public boolean useHttp1Pipelining() {
+        return useHttp1Pipelining;
+    }
+
+    /**
+     * A builder for {@link HttpSessionConfig}.
+     */
+    public static final class Builder {
+
+        @Nullable
+        private Duration connectTimeout;
+        @Nullable
+        private Duration idleTimeout;
+        @Nullable
+        private TrustManagerFactory trustManagerFactory;
+        @Nullable
+        private Consumer<SslContextBuilder> sslContextCustomizer;
+        @Nullable
+        private AddressResolverGroup<? extends InetSocketAddress> addressResolverGroup;
+        @Nullable
+        private EventLoopGroup eventLoopGroup;
+        @Nullable
+        private Function<KeyedChannelPoolHandler<PoolKey>, KeyedChannelPoolHandler<PoolKey>> poolHandlerDecorator;
+        @Nullable
+        private Boolean useHttp2Preface;
+        @Nullable
+        private Boolean useHttp1Pipelining;
+
+        private Builder() {}
+
+        /**
+         * Sets the connection timeout.
+         */
+        public Builder connectTimeout(Duration connectTimeout) {
+            requireNonNull(connectTimeout, "connectTimeout");
+            if (connectTimeout.isNegative() || connectTimeout.isZero()) {
+                throw new IllegalArgumentException(
+                        "connectTimeout: " + connectTimeout + " (expected: > 0)");
+            }
+            this.connectTimeout = connectTimeout;
+            return this;
+        }
+
+        /**
+         * Sets the idle timeout.
+         */
+        public Builder idleTimeout(Duration idleTimeout) {
+            requireNonNull(idleTimeout, "idleTimeout");
+            if (idleTimeout.isNegative()) {
+                throw new IllegalArgumentException(
+                        "idleTimeout: " + idleTimeout + " (expected: >= 0)");
+            }
+            this.idleTimeout = idleTimeout;
+            return this;
+        }
+
+        /**
+         * Sets the {@link TrustManagerFactory}.
+         *
+         * @deprecated Use {@link #sslContextCustomizer(Consumer)} instead.
+         */
+        @Deprecated
+        public Builder trustManagerFactory(@Nullable TrustManagerFactory trustManagerFactory) {
+            this.trustManagerFactory = trustManagerFactory;
+            return this;
+        }
+
+        /**
+         * Sets the SSL context customizer.
+         */
+        public Builder sslContextCustomizer(@Nullable Consumer<SslContextBuilder> sslContextCustomizer) {
+            this.sslContextCustomizer = sslContextCustomizer;
+            return this;
+        }
+
+        /**
+         * Sets the {@link AddressResolverGroup}.
+         */
+        public Builder addressResolverGroup(
+                @Nullable AddressResolverGroup<? extends InetSocketAddress> addressResolverGroup) {
+            this.addressResolverGroup = addressResolverGroup;
+            return this;
+        }
+
+        /**
+         * Sets the {@link EventLoopGroup}.
+         */
+        public Builder eventLoopGroup(@Nullable EventLoopGroup eventLoopGroup) {
+            this.eventLoopGroup = eventLoopGroup;
+            return this;
+        }
+
+        /**
+         * Sets the pool handler decorator.
+         */
+        public Builder poolHandlerDecorator(
+                @Nullable Function<KeyedChannelPoolHandler<PoolKey>,
+                        KeyedChannelPoolHandler<PoolKey>> poolHandlerDecorator) {
+            this.poolHandlerDecorator = poolHandlerDecorator;
+            return this;
+        }
+
+        /**
+         * Sets whether to use HTTP/2 preface.
+         */
+        public Builder useHttp2Preface(boolean useHttp2Preface) {
+            this.useHttp2Preface = useHttp2Preface;
+            return this;
+        }
+
+        /**
+         * Sets whether to use HTTP/1 pipelining.
+         */
+        public Builder useHttp1Pipelining(boolean useHttp1Pipelining) {
+            this.useHttp1Pipelining = useHttp1Pipelining;
+            return this;
+        }
+
+        /**
+         * Builds a new {@link HttpSessionConfig}.
+         */
+        public HttpSessionConfig build() {
+            return new HttpSessionConfig(
+                    connectTimeout != null ? connectTimeout : DEFAULT_CONNECTION_TIMEOUT,
+                    idleTimeout != null ? idleTimeout : DEFAULT_IDLE_TIMEOUT,
+                    trustManagerFactory,
+                    sslContextCustomizer,
+                    addressResolverGroup,
+                    eventLoopGroup,
+                    poolHandlerDecorator,
