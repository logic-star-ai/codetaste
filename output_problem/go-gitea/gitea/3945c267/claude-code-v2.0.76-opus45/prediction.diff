diff --git a/modules/templates/util_link.go b/modules/templates/util_link.go
new file mode 100644
index 0000000..a286f03
--- /dev/null
+++ b/modules/templates/util_link.go
@@ -0,0 +1,110 @@
+// Copyright 2024 The Gitea Authors. All rights reserved.
+// SPDX-License-Identifier: MIT
+
+package templates
+
+import (
+	"context"
+
+	activities_model "code.gitea.io/gitea/models/activities"
+	issues_model "code.gitea.io/gitea/models/issues"
+	project_model "code.gitea.io/gitea/models/project"
+)
+
+// LinkUtils provides template functions for generating links with context
+type LinkUtils struct {
+	ctx context.Context
+}
+
+// NewLinkUtils creates a new LinkUtils with the given context
+func NewLinkUtils(ctx context.Context) *LinkUtils {
+	return &LinkUtils{ctx: ctx}
+}
+
+// ProjectLink returns the relative URL for a project
+func (lu *LinkUtils) ProjectLink(p *project_model.Project) string {
+	if p == nil {
+		return ""
+	}
+	return p.Link(lu.ctx)
+}
+
+// CommentLink returns the relative URL for a comment
+func (lu *LinkUtils) CommentLink(c *issues_model.Comment) string {
+	if c == nil {
+		return ""
+	}
+	return c.Link(lu.ctx)
+}
+
+// CommentHTMLURL returns the absolute URL for a comment
+func (lu *LinkUtils) CommentHTMLURL(c *issues_model.Comment) string {
+	if c == nil {
+		return ""
+	}
+	return c.HTMLURL(lu.ctx)
+}
+
+// IssueAPIURL returns the API URL for an issue
+func (lu *LinkUtils) IssueAPIURL(i *issues_model.Issue) string {
+	if i == nil {
+		return ""
+	}
+	return i.APIURL(lu.ctx)
+}
+
+// NotificationLink returns the relative URL for a notification
+func (lu *LinkUtils) NotificationLink(n *activities_model.Notification) string {
+	if n == nil {
+		return ""
+	}
+	return n.Link(lu.ctx)
+}
+
+// NotificationHTMLURL returns the absolute URL for a notification
+func (lu *LinkUtils) NotificationHTMLURL(n *activities_model.Notification) string {
+	if n == nil {
+		return ""
+	}
+	return n.HTMLURL(lu.ctx)
+}
+
+// ActionGetIssueTitle returns the title of the issue associated with an action
+func (lu *LinkUtils) ActionGetIssueTitle(a *activities_model.Action) string {
+	if a == nil {
+		return ""
+	}
+	return a.GetIssueTitle(lu.ctx)
+}
+
+// ActionGetCommentLink returns the link to the comment associated with an action
+func (lu *LinkUtils) ActionGetCommentLink(a *activities_model.Action) string {
+	if a == nil {
+		return ""
+	}
+	return a.GetCommentLink(lu.ctx)
+}
+
+// CommentRefCommentLink returns the relative URL for the comment that created a reference
+func (lu *LinkUtils) CommentRefCommentLink(c *issues_model.Comment) string {
+	if c == nil {
+		return ""
+	}
+	return c.RefCommentLink(lu.ctx)
+}
+
+// CommentRefIssueLink returns the relative URL of the issue where this reference was created
+func (lu *LinkUtils) CommentRefIssueLink(c *issues_model.Comment) string {
+	if c == nil {
+		return ""
+	}
+	return c.RefIssueLink(lu.ctx)
+}
+
+// ReviewHTMLURL returns the absolute URL for a review
+func (lu *LinkUtils) ReviewHTMLURL(r *issues_model.Review) string {
+	if r == nil {
+		return ""
+	}
+	return r.HTMLURL(lu.ctx)
+}
