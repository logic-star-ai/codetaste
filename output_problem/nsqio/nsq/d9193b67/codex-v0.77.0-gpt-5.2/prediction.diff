+package stringutil
+
+func StringAdd(s []string, a string) []string {
+	for _, existing := range s {
+		if a == existing {
+			return s
+		}
+	}
+	return append(s, a)
+}
+
+func StringUnion(s []string, a []string) []string {
+	for _, entry := range a {
+		found := false
+		for _, existing := range s {
+			if entry == existing {
+				found = true
+				break
+			}
+		}
+		if !found {
+			s = append(s, entry)
+		}
+	}
+	return s
+}
+
