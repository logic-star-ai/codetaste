diff --git a/internal/format/byte_base10.go b/internal/format/byte_base10.go
new file mode 100644
index 0000000..8810a7f
--- /dev/null
+++ b/internal/format/byte_base10.go
@@ -0,0 +1,29 @@
+package format
+
+import (
+	"errors"
+)
+
+var errBase10 = errors.New("failed to convert to Base10")
+
+func ByteToBase10(b []byte) (n uint64, err error) {
+	base := uint64(10)
+
+	n = 0
+	for i := 0; i < len(b); i++ {
+		var v byte
+		d := b[i]
+		switch {
+		case '0' <= d && d <= '9':
+			v = d - '0'
+		default:
+			n = 0
+			err = errBase10
+			return
+		}
+		n *= base
+		n += uint64(v)
+	}
+
+	return n, err
+}
