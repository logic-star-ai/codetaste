diff --git a/nsqlookupd/wait_group_wrapper.go b/nsqlookupd/wait_group_wrapper.go
new file mode 100644
index 0000000..eafcb38
--- /dev/null
+++ b/nsqlookupd/wait_group_wrapper.go
@@ -0,0 +1,17 @@
+package nsqlookupd
+
+import (
+	"sync"
+)
+
+type WaitGroupWrapper struct {
+	sync.WaitGroup
+}
+
+func (w *WaitGroupWrapper) Wrap(cb func()) {
+	w.Add(1)
+	go func() {
+		cb()
+		w.Done()
+	}()
+}
