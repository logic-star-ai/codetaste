+#!/usr/bin/env python
+"""Check for actual circular import problems."""
+import sys
+import subprocess
+
+# Try to import all major MNE submodules
+modules_to_test = [
+    "mne",
+    "mne._fiff",
+    "mne._fiff.meas_info",
+    "mne._fiff.pick",
+    "mne._fiff.proj",
+    "mne._fiff.ctf_comp",
+    "mne.channels",
+    "mne.channels.channels",
+    "mne.channels.montage",
+    "mne.channels.layout",
+    "mne.viz",
+    "mne.viz.utils",
+    "mne.viz.topomap",
+    "mne.viz.evoked",
+    "mne.viz.ica",
+    "mne.viz._3d",
+    "mne.preprocessing",
+    "mne.preprocessing.ica",
+    "mne.preprocessing.maxwell",
+    "mne.evoked",
+    "mne.epochs",
+    "mne.cov",
+    "mne.rank",
+    "mne.source_estimate",
+    "mne.label",
+    "mne.source_space",
+    "mne.dipole",
+    "mne.bem",
+    "mne.surface",
+    "mne.transforms",
+    "mne.coreg",
+    "mne._freesurfer",
+    "mne.filter",
+    "mne.annotations",
+    "mne.time_frequency",
+    "mne.time_frequency.spectrum",
+    "mne.time_frequency.tfr",
+    "mne.minimum_norm",
+    "mne.minimum_norm.inverse",
+    "mne.morph",
+    "mne.forward",
+    "mne.io",
+    "mne.utils",
+    "mne.utils.config",
+    "mne.utils.check",
+    "mne.utils.docs",
+    "mne.utils._logging",
+]
+
+print("Testing imports for circular dependency issues...")
+print("=" * 70)
+
+errors = []
+for module in modules_to_test:
+    # Test each module in a fresh Python process to avoid state contamination
+    code = f"import {module}; print('OK')"
+    result = subprocess.run(
+        [sys.executable, "-c", code],
+        capture_output=True,
+        text=True,
+        timeout=10
+    )
+
+    if result.returncode == 0:
+        print(f"✓ {module}")
+    else:
+        print(f"✗ {module}")
+        errors.append((module, result.stderr))
+        if "circular" in result.stderr.lower():
+            print(f"  CIRCULAR IMPORT DETECTED!")
+        print(f"  Error: {result.stderr[:200]}")
+
+print("\n" + "=" * 70)
+if errors:
+    print(f"FAILED: {len(errors)} modules had import errors")
+    print("\nModules with errors:")
+    for module, error in errors:
+        print(f"  - {module}")
+        if "circular" in error.lower():
+            print(f"    ** CIRCULAR IMPORT **")
+    sys.exit(1)
+else:
+    print(f"SUCCESS: All {len(modules_to_test)} modules imported correctly")
+    print("No circular import issues detected")
+    sys.exit(0)
