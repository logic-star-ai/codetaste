+#!/usr/bin/env python
+"""
+Script to detect actual circular import issues in the MNE codebase.
+This will attempt to import all modules and catch any ImportError due to circular dependencies.
+"""
+import sys
+import os
+import importlib
+import traceback
+from pathlib import Path
+
+def find_all_python_modules(root_dir):
+    """Find all Python modules in the given directory."""
+    modules = []
+    root_path = Path(root_dir)
+
+    for py_file in root_path.rglob("*.py"):
+        # Skip test files and setup files
+        if "test" in str(py_file) or "setup.py" in str(py_file):
+            continue
+
+        # Convert file path to module name
+        rel_path = py_file.relative_to(root_path.parent)
+        module_parts = list(rel_path.parts[:-1]) + [rel_path.stem]
+
+        # Skip __pycache__ and similar
+        if any(part.startswith("__") and part.endswith("__") for part in module_parts[:-1]):
+            continue
+
+        if module_parts[-1] == "__init__":
+            module_parts = module_parts[:-1]
+
+        if module_parts:  # Make sure we have a valid module path
+            module_name = ".".join(module_parts)
+            modules.append((module_name, str(py_file)))
+
+    return modules
+
+def test_import_module(module_name, file_path):
+    """Test if a module can be imported without circular import errors."""
+    try:
+        # Clear any previous import
+        if module_name in sys.modules:
+            del sys.modules[module_name]
+
+        importlib.import_module(module_name)
+        return True, None
+    except ImportError as e:
+        if "circular" in str(e).lower() or "cannot import" in str(e).lower():
+            return False, str(e)
+        # Some imports might fail for other reasons (missing dependencies, etc.)
+        return None, str(e)
+    except Exception as e:
+        return None, f"{type(e).__name__}: {str(e)}"
+
+def main():
+    print("Detecting circular imports in MNE codebase...")
+    print("=" * 80)
+
+    mne_dir = "/testbed/mne"
+    modules = find_all_python_modules(mne_dir)
+
+    print(f"Found {len(modules)} modules to test\n")
+
+    circular_import_errors = []
+    other_errors = []
+    successful = []
+
+    for module_name, file_path in sorted(modules):
+        success, error = test_import_module(module_name, file_path)
+
+        if success is True:
+            successful.append(module_name)
+        elif success is False:
+            circular_import_errors.append((module_name, file_path, error))
+            print(f"✗ CIRCULAR IMPORT: {module_name}")
+            print(f"  File: {file_path}")
+            print(f"  Error: {error}\n")
+        else:
+            other_errors.append((module_name, file_path, error))
+
+    print("\n" + "=" * 80)
+    print("SUMMARY")
+    print("=" * 80)
+    print(f"Total modules tested: {len(modules)}")
+    print(f"Successfully imported: {len(successful)}")
+    print(f"Circular import errors: {len(circular_import_errors)}")
+    print(f"Other errors: {len(other_errors)}")
+
+    if circular_import_errors:
+        print("\n" + "!" * 80)
+        print("CIRCULAR IMPORT ISSUES FOUND:")
+        print("!" * 80)
+        for module_name, file_path, error in circular_import_errors:
+            print(f"\n{module_name}")
+            print(f"  {file_path}")
+            print(f"  {error}")
+        return 1
+    else:
+        print("\n✓ NO CIRCULAR IMPORT ISSUES FOUND")
+        return 0
+
+if __name__ == "__main__":
+    sys.exit(main())
