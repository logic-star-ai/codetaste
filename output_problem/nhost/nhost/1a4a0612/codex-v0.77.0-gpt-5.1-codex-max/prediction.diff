+import EditWorkspaceNameForm from '@/components/home/EditWorkspaceNameForm';
+import EditUserForm from '@/components/users/EditUserForm';
+import type { CreateColumnFormProps } from '@/components/dataBrowser/CreateColumnForm';
+import type { CreateRecordFormProps } from '@/components/dataBrowser/CreateRecordForm';
+import type { CreateTableFormProps } from '@/components/dataBrowser/CreateTableForm';
+import type { EditColumnFormProps } from '@/components/dataBrowser/EditColumnForm';
+import type { EditPermissionsFormProps } from '@/components/dataBrowser/EditPermissionsForm';
+import type { EditTableFormProps } from '@/components/dataBrowser/EditTableForm';
+import ActivityIndicator from '@/ui/v2/ActivityIndicator';
+import dynamic from 'next/dynamic';
+import type {
+  ComponentProps,
+  DetailedHTMLProps,
+  HTMLProps,
+} from 'react';
+import { twMerge } from 'tailwind-merge';
+import CreateForeignKeyForm from '@/components/dataBrowser/CreateForeignKeyForm';
+import EditForeignKeyForm from '@/components/dataBrowser/EditForeignKeyForm';
+import CreateRoleForm from '@/components/settings/roles/CreateRoleForm';
+import EditRoleForm from '@/components/settings/roles/EditRoleForm';
+import CreateUserForm from '@/components/users/CreateUserForm';
+import CreatePermissionVariableForm from '@/components/settings/permissions/CreatePermissionVariableForm';
+import EditPermissionVariableForm from '@/components/settings/permissions/EditPermissionVariableForm';
+import CreateEnvironmentVariableForm from '@/components/settings/environmentVariables/CreateEnvironmentVariableForm';
+import EditEnvironmentVariableForm from '@/components/settings/environmentVariables/EditEnvironmentVariableForm';
+import EditUserPasswordForm from '@/components/users/EditUserPasswordForm';
+import EditJwtSecretForm from '@/components/settings/environmentVariables/EditJwtSecretForm';
+
+function LoadingComponent({
+  className,
+  ...props
+}: DetailedHTMLProps<HTMLProps<HTMLDivElement>, HTMLDivElement> = {}) {
+  return (
+    <div
+      {...props}
+      className={twMerge(
+        'grid items-center justify-center px-6 py-4',
+        className,
+      )}
+    >
+      <ActivityIndicator
+        circularProgressProps={{ className: 'w-5 h-5' }}
+        label="Loading form..."
+      />
+    </div>
+  );
+}
+
+const CreateRecordForm = dynamic<CreateRecordFormProps>(
+  () => import('@/components/dataBrowser/CreateRecordForm'),
+  { ssr: false, loading: () => <LoadingComponent /> },
+);
+
+const CreateColumnForm = dynamic<CreateColumnFormProps>(
+  () => import('@/components/dataBrowser/CreateColumnForm'),
+  { ssr: false, loading: () => <LoadingComponent /> },
+);
+
+const EditColumnForm = dynamic<EditColumnFormProps>(
+  () => import('@/components/dataBrowser/EditColumnForm'),
+  { ssr: false, loading: () => <LoadingComponent /> },
+);
+
+const CreateTableForm = dynamic<CreateTableFormProps>(
+  () => import('@/components/dataBrowser/CreateTableForm'),
+  { ssr: false, loading: () => <LoadingComponent /> },
+);
+
+const EditTableForm = dynamic<EditTableFormProps>(
+  () => import('@/components/dataBrowser/EditTableForm'),
+  { ssr: false, loading: () => <LoadingComponent /> },
+);
+
+const EditPermissionsForm = dynamic<EditPermissionsFormProps>(
+  () => import('@/components/dataBrowser/EditPermissionsForm'),
+  { ssr: false, loading: () => <LoadingComponent /> },
+);
+
+export const dialogComponents = {
+  EDIT_WORKSPACE_NAME: EditWorkspaceNameForm,
+  CREATE_FOREIGN_KEY: CreateForeignKeyForm,
+  EDIT_FOREIGN_KEY: EditForeignKeyForm,
+  CREATE_ROLE: CreateRoleForm,
+  EDIT_ROLE: EditRoleForm,
+  CREATE_USER: CreateUserForm,
+  CREATE_PERMISSION_VARIABLE: CreatePermissionVariableForm,
+  EDIT_PERMISSION_VARIABLE: EditPermissionVariableForm,
+  CREATE_ENVIRONMENT_VARIABLE: CreateEnvironmentVariableForm,
+  EDIT_ENVIRONMENT_VARIABLE: EditEnvironmentVariableForm,
+  EDIT_USER_PASSWORD: EditUserPasswordForm,
+  EDIT_JWT_SECRET: EditJwtSecretForm,
+} as const;
+
+export const drawerComponents = {
+  CREATE_RECORD: CreateRecordForm,
+  CREATE_COLUMN: CreateColumnForm,
+  EDIT_COLUMN: EditColumnForm,
+  CREATE_TABLE: CreateTableForm,
+  EDIT_TABLE: EditTableForm,
+  EDIT_PERMISSIONS: EditPermissionsForm,
+  EDIT_USER: EditUserForm,
+} as const;
+
+export type DialogType = keyof typeof dialogComponents;
+export type DrawerType = keyof typeof drawerComponents;
+
+type DialogActionHandlers = {
+  onSubmit?: (...args: any[]) => any;
+  onCancel?: (event?: any) => any;
+};
+
+export type DialogPayload<TType extends string> = TType extends DialogType
+  ? ComponentProps<(typeof dialogComponents)[TType]> & DialogActionHandlers
+  : TType extends DrawerType
+    ? ComponentProps<(typeof drawerComponents)[TType]> & DialogActionHandlers
+    : DialogActionHandlers;
+
+export { LoadingComponent };
