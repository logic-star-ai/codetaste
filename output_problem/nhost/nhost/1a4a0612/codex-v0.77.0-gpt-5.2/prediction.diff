+
+function LoadingComponent({
+  className,
+  ...props
+}: DetailedHTMLProps<HTMLProps<HTMLDivElement>, HTMLDivElement> = {}) {
+  return (
+    <div
+      {...props}
+      className={twMerge(
+        'grid items-center justify-center px-6 py-4',
+        className,
+      )}
+    >
+      <ActivityIndicator
+        circularProgressProps={{ className: 'w-5 h-5' }}
+        label="Loading form..."
+      />
+    </div>
+  );
+}
+
+type DialogHelpers = {
+  closeDialog: VoidFunction;
+  closeDialogWithDirtyGuard: VoidFunction;
+};
+
+type DrawerHelpers = {
+  closeDrawer: VoidFunction;
+  closeDrawerWithDirtyGuard: VoidFunction;
+};
+
+type DialogRendererMap = {
+  [K in DialogId]: (
+    payload: DialogPayloads[K] | undefined,
+    helpers: DialogHelpers,
+  ) => JSX.Element;
+};
+
+type DrawerRendererMap = {
+  [K in DrawerId]: (
+    payload: DrawerPayloads[K] | undefined,
+    helpers: DrawerHelpers,
+  ) => JSX.Element;
+};
+
+const EditWorkspaceNameForm = dynamic(
+  () => import('@/components/home/EditWorkspaceNameForm'),
+  { ssr: false, loading: () => LoadingComponent() },
+);
