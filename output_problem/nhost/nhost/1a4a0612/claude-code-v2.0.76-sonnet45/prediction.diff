+import { useCallback } from 'react';
+import type { DialogConfig } from './DialogContext';
+import { useDialog } from './useDialog';
+
+/**
+ * Create a type-safe hook for opening a specific dialog.
+ * This is useful for creating reusable dialog hooks with proper typing.
+ *
+ * @example
+ * ```typescript
+ * // Define your dialog payload type
+ * interface CreateUserPayload {
+ *   onSubmit: (values: any) => void;
+ *   defaultEmail?: string;
+ * }
+ *
+ * // Create a typed hook
+ * const useCreateUserDialog = createDialogHook<CreateUserPayload>('CREATE_USER');
+ *
+ * // Use it in your component
+ * function MyComponent() {
+ *   const openCreateUser = useCreateUserDialog();
+ *
+ *   const handleClick = () => {
+ *     openCreateUser({
+ *       title: 'Create User',
+ *       payload: {
+ *         onSubmit: (values) => console.log(values),
+ *         defaultEmail: 'user@example.com',
+ *       },
+ *     });
+ *   };
+ *
+ *   return <button onClick={handleClick}>Create User</button>;
+ * }
+ * ```
+ */
+export function createDialogHook<TPayload = unknown>(dialogKey: string) {
+  return function useSpecificDialog() {
+    const { openDialog } = useDialog();
+
+    return useCallback(
+      (config?: DialogConfig<TPayload>) => {
+        openDialog(dialogKey, config);
+      },
+      [openDialog],
+    );
+  };
+}
+
+/**
+ * Create a type-safe hook for opening a specific drawer.
+ * This is useful for creating reusable drawer hooks with proper typing.
+ *
+ * @example
+ * ```typescript
+ * interface EditUserPayload {
+ *   userId: string;
+ *   onSubmit: () => void;
+ * }
+ *
+ * const useEditUserDrawer = createDrawerHook<EditUserPayload>('EDIT_USER');
+ *
+ * function MyComponent() {
+ *   const openEditUser = useEditUserDrawer();
+ *
+ *   const handleClick = () => {
+ *     openEditUser({
+ *       title: 'Edit User',
+ *       payload: {
+ *         userId: '123',
+ *         onSubmit: () => console.log('Submitted'),
+ *       },
+ *     });
+ *   };
+ *
+ *   return <button onClick={handleClick}>Edit User</button>;
+ * }
+ * ```
+ */
+export function createDrawerHook<TPayload = unknown>(drawerKey: string) {
+  return function useSpecificDrawer() {
+    const { openDrawer } = useDialog();
+
+    return useCallback(
+      (config?: DialogConfig<TPayload>) => {
+        openDrawer(drawerKey, config);
+      },
+      [openDrawer],
+    );
+  };
+}
