@@ -0,0 +1,107 @@
+import type { ComponentType } from 'react';
+
+/**
+ * Configuration for a dialog in the registry.
+ */
+export interface DialogRegistryConfig<TProps = any> {
+  /**
+   * The component to render for this dialog.
+   */
+  component: ComponentType<TProps>;
+  /**
+   * Whether this dialog should be lazy loaded.
+   * @default false
+   */
+  lazy?: boolean;
+  /**
+   * Loading component to show while lazy loading.
+   */
+  loadingComponent?: ComponentType;
+}
+
+/**
+ * Global registry for dialog components.
+ * Maps dialog type keys to their component configurations.
+ */
+class DialogRegistry {
+  private registry = new Map<string, DialogRegistryConfig>();
+
+  /**
+   * Register a dialog component with a unique key.
+   */
+  register<TProps = any>(
+    key: string,
+    config: DialogRegistryConfig<TProps>,
+  ): void {
+    if (this.registry.has(key)) {
+      console.warn(
+        `Dialog with key "${key}" is already registered. Overwriting.`,
+      );
+    }
+    this.registry.set(key, config);
+  }
+
+  /**
+   * Get the configuration for a registered dialog.
+   */
+  get(key: string): DialogRegistryConfig | undefined {
+    return this.registry.get(key);
+  }
+
+  /**
+   * Check if a dialog is registered.
+   */
+  has(key: string): boolean {
+    return this.registry.has(key);
+  }
+
+  /**
+   * Get all registered dialog keys.
+   */
+  getKeys(): string[] {
+    return Array.from(this.registry.keys());
+  }
+
+  /**
+   * Unregister a dialog.
+   */
+  unregister(key: string): boolean {
+    return this.registry.delete(key);
+  }
+
+  /**
+   * Clear all registered dialogs.
+   */
+  clear(): void {
+    this.registry.clear();
+  }
+}
+
+// Export singleton instance
+export const dialogRegistry = new DialogRegistry();
+
+/**
+ * Helper function to register a dialog.
+ */
+export function registerDialog<TProps = any>(
+  key: string,
+  config: DialogRegistryConfig<TProps>,
+): void {
+  dialogRegistry.register(key, config);
+}
+
+/**
+ * Helper function to create a lazy-loaded dialog registration.
+ */
+export function registerLazyDialog<TProps = any>(
+  key: string,
+  importFn: () => Promise<{ default: ComponentType<TProps> }>,
+  loadingComponent?: ComponentType,
+): void {
+  // We'll handle the lazy loading in the DialogProvider
+  dialogRegistry.register(key, {
+    component: importFn as any,
+    lazy: true,
+    loadingComponent,
+  });
+}
