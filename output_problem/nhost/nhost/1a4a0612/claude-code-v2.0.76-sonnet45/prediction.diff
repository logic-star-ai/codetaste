+# Dialog Provider Examples
+
+This file contains comprehensive examples of using the Dialog Provider system.
+
+## Basic Usage Examples
+
+### Example 1: Simple Dialog
+
+```typescript
+import { useDialog, DIALOG_KEYS } from '@/components/common/DialogProvider';
+
+function CreateUserButton() {
+  const { openDialog } = useDialog();
+
+  return (
+    <button
+      onClick={() =>
+        openDialog(DIALOG_KEYS.CREATE_USER, {
+          title: 'Create New User',
+          payload: {
+            onSubmit: async (values) => {
+              console.log('User created:', values);
+            },
+          },
+        })
+      }
+    >
+      Create User
+    </button>
+  );
+}
+```
+
+### Example 2: Drawer with Data
+
+```typescript
+import { useDialog, DRAWER_KEYS } from '@/components/common/DialogProvider';
+
+function EditUserButton({ userId }: { userId: string }) {
+  const { openDrawer } = useDialog();
+
+  return (
+    <button
+      onClick={() =>
+        openDrawer(DRAWER_KEYS.EDIT_USER, {
+          title: 'Edit User',
+          payload: {
+            userId,
+            onSubmit: async () => {
+              console.log('User updated');
+              await refetchUsers();
+            },
+          },
+        })
+      }
+    >
+      Edit User
+    </button>
+  );
+}
+```
+
+## Advanced Usage Examples
+
+### Example 3: Custom Dialog Hook
+
+Create a reusable hook for a specific dialog:
+
+```typescript
+// hooks/useCreateUserDialog.ts
+import { createDialogHook } from '@/components/common/DialogProvider';
+
+interface CreateUserPayload {
+  defaultEmail?: string;
+  onSubmit: (values: { email: string; password: string }) => Promise<void>;
+}
+
+export const useCreateUserDialog = createDialogHook<CreateUserPayload>('CREATE_USER');
+
+// Usage in component
+function MyComponent() {
+  const openCreateUser = useCreateUserDialog();
+  const { refetch } = useUsers();
+
+  const handleCreateUser = () => {
+    openCreateUser({
+      title: 'Create New User',
+      payload: {
+        defaultEmail: 'user@example.com',
+        onSubmit: async (values) => {
+          await createUser(values);
+          await refetch();
+        },
+      },
+    });
+  };
+
+  return <button onClick={handleCreateUser}>Create User</button>;
+}
+```
+
+### Example 4: Dynamic Dialog with Custom Props
+
+```typescript
+import { useDialog } from '@/components/common/DialogProvider';
+
+function CustomDialogExample() {
+  const { openDialog } = useDialog();
+
+  const handleClick = () => {
+    openDialog('MY_CUSTOM_DIALOG', {
+      title: 'Custom Dialog',
+      // Pass custom props to the dialog wrapper
+      props: {
+        maxWidth: 'lg',
+        fullWidth: true,
+        PaperProps: {
+          className: 'custom-dialog-paper',
+        },
+      },
+      payload: {
+        customData: 'Any data you need',
+      },
+    });
+  };
+
+  return <button onClick={handleClick}>Open Custom Dialog</button>;
+}
+```
+
+### Example 5: Dialog with Confirmation
+
+```typescript
+import { useDialog } from '@/components/common/DialogProvider';
+
+function DeleteUserButton({ userId }: { userId: string }) {
+  const { openAlertDialog, openDrawer, closeDrawer } = useDialog();
+
+  const handleDelete = () => {
+    openAlertDialog({
+      title: 'Confirm Delete',
+      payload: 'Are you sure you want to delete this user?',
+      props: {
+        primaryButtonText: 'Delete',
+        primaryButtonColor: 'error',
+        secondaryButtonText: 'Cancel',
+        onPrimaryAction: async () => {
+          await deleteUser(userId);
+          closeDrawer(); // Close any open drawer
+        },
+      },
+    });
+  };
+
+  return (
+    <button onClick={handleDelete} className="text-red-600">
+      Delete User
+    </button>
+  );
+}
+```
+
+### Example 6: Chained Dialogs
+
+Open a dialog from within another dialog:
+
+```typescript
+import { useDialog, DIALOG_KEYS } from '@/components/common/DialogProvider';
+
+function MyForm() {
+  const { openDialog } = useDialog();
+
+  const handleCreateRole = () => {
+    openDialog(DIALOG_KEYS.CREATE_ROLE, {
+      title: 'Create New Role',
+      payload: {
+        onSubmit: async (values) => {
+          console.log('Role created:', values);
+          // Can open another dialog if needed
+        },
+      },
+    });
+  };
+
+  return (
+    <div>
+      <p>Select a role or create a new one:</p>
+      <button onClick={handleCreateRole}>Create New Role</button>
+    </div>
+  );
+}
+```
+
+## Plugin/Extension Examples
+
+### Example 7: Registering Custom Dialog at Runtime
+
+```typescript
+// plugins/MyPlugin.tsx
+import { registerDialog } from '@/components/common/DialogProvider';
+import MyCustomDialog from './MyCustomDialog';
+
+export function initializePlugin() {
+  // Register your custom dialog
+  registerDialog('MY_PLUGIN_DIALOG', {
+    component: MyCustomDialog,
+  });
+
+  console.log('Plugin initialized and dialog registered');
+}
+
+// Usage in app
+initializePlugin();
+
+// Now you can use it anywhere
+const { openDialog } = useDialog();
+openDialog('MY_PLUGIN_DIALOG', { title: 'Plugin Dialog' });
+```
+
+### Example 8: Lazy-Loaded Plugin Dialog
+
+```typescript
+import { registerLazyDialog } from '@/components/common/DialogProvider';
+
+export function initializeHeavyPlugin() {
+  // Register a lazy-loaded dialog for better performance
+  registerLazyDialog('HEAVY_PLUGIN_DIALOG', () =>
+    import('./HeavyPluginDialog'),
+  );
+}
+```
+
+## Form Integration Examples
+
+### Example 9: Dialog with React Hook Form
+
+```typescript
+// MyFormDialog.tsx
+import { useForm } from 'react-hook-form';
+import Button from '@/ui/v2/Button';
+
+interface MyFormDialogProps {
+  onSubmit: (values: any) => void;
+  onCancel: () => void;
+}
+
+export default function MyFormDialog({ onSubmit, onCancel }: MyFormDialogProps) {
+  const { register, handleSubmit } = useForm();
+
+  return (
+    <form onSubmit={handleSubmit(onSubmit)} className="p-6">
+      <input {...register('name')} placeholder="Name" className="w-full mb-4" />
+      <div className="flex gap-2">
+        <Button type="submit">Submit</Button>
+        <Button type="button" onClick={onCancel} variant="outlined">
+          Cancel
+        </Button>
+      </div>
+    </form>
+  );
+}
+
+// Register it
+registerDialog('MY_FORM_DIALOG', { component: MyFormDialog });
+
+// Use it
+function MyComponent() {
+  const { openDialog } = useDialog();
+
+  const handleClick = () => {
+    openDialog('MY_FORM_DIALOG', {
+      title: 'Fill the Form',
+      payload: {
+        onSubmit: (values) => console.log(values),
+      },
+    });
+  };
+
+  return <button onClick={handleClick}>Open Form</button>;
+}
+```
+
+### Example 10: Dialog with Dirty State Tracking
+
+```typescript
+import { useDialog } from '@/components/common/DialogProvider';
+import { useEffect } from 'react';
+import { useForm } from 'react-hook-form';
+
+interface FormDialogProps {
+  onSubmit: (values: any) => void;
+  onCancel: () => void;
+}
+
+export default function FormWithDirtyTracking({ onSubmit, onCancel }: FormDialogProps) {
+  const { onDirtyStateChange } = useDialog();
+  const { register, handleSubmit, formState: { isDirty } } = useForm();
+
+  // Track dirty state
+  useEffect(() => {
+    onDirtyStateChange(isDirty, 'dialog');
+  }, [isDirty, onDirtyStateChange]);
+
+  return (
+    <form onSubmit={handleSubmit(onSubmit)} className="p-6">
+      <input {...register('email')} placeholder="Email" className="w-full mb-4" />
+      <button type="submit">Submit</button>
+    </form>
+  );
+}
+```
+
+## TypeScript Type Safety Examples
+
+### Example 11: Strongly Typed Dialog
+
+```typescript
+// Define strict types for your dialog
+interface CreateUserDialogPayload {
+  defaultEmail?: string;
+  mode: 'create' | 'invite';
+  onSubmit: (values: {
+    email: string;
+    password: string;
+    roles: string[];
+  }) => Promise<void>;
+}
+
+// Create a typed hook
+import { useCallback } from 'react';
+import { useDialog, type DialogConfig } from '@/components/common/DialogProvider';
+
+export function useCreateUserDialog() {
+  const { openDialog } = useDialog();
+
+  return useCallback(
+    (config: DialogConfig<CreateUserDialogPayload>) => {
+      openDialog('CREATE_USER', config);
+    },
+    [openDialog],
+  );
+}
+
+// Usage with full type safety
+function MyComponent() {
+  const openCreateUser = useCreateUserDialog();
+
+  const handleClick = () => {
+    openCreateUser({
+      title: 'Create User',
+      payload: {
+        // TypeScript will enforce these types
+        mode: 'create',
+        defaultEmail: 'user@example.com',
+        onSubmit: async (values) => {
+          // values is fully typed here
+          console.log(values.email, values.password, values.roles);
+        },
+      },
+    });
+  };
+
+  return <button onClick={handleClick}>Create User</button>;
+}
+```
+
+## Testing Examples
+
+### Example 12: Testing Components with Dialogs
+
+```typescript
+// MyComponent.test.tsx
+import { render, screen, fireEvent } from '@testing-library/react';
+import { DialogContext } from '@/components/common/DialogProvider';
+import MyComponent from './MyComponent';
+
+describe('MyComponent', () => {
+  it('opens dialog when button clicked', () => {
+    const mockOpenDialog = jest.fn();
+
+    render(
+      <DialogContext.Provider
+        value={{
+          openDialog: mockOpenDialog,
+          openDrawer: jest.fn(),
+          openAlertDialog: jest.fn(),
+          closeDialog: jest.fn(),
+          closeDrawer: jest.fn(),
+          closeDialogWithDirtyGuard: jest.fn(),
+          closeDrawerWithDirtyGuard: jest.fn(),
+          closeAlertDialog: jest.fn(),
+          onDirtyStateChange: jest.fn(),
+          openDirtyConfirmation: jest.fn(),
+        }}
+      >
+        <MyComponent />
+      </DialogContext.Provider>
+    );
+
+    fireEvent.click(screen.getByText('Create User'));
+
+    expect(mockOpenDialog).toHaveBeenCalledWith('CREATE_USER', {
+      title: 'Create New User',
+      payload: expect.any(Object),
+    });
+  });
+});
+```
+
+## Migration Examples
+
+### Example 13: Gradual Migration
+
+```typescript
+// Old code (still works)
+import { useDialog } from '@/components/common/DialogProvider';
+
+function OldComponent() {
+  const { openDialog } = useDialog();
+
+  const handleClick = () => {
+    openDialog('CREATE_USER', { title: 'Create User' }); // String literal
+  };
+
+  return <button onClick={handleClick}>Create User</button>;
+}
+
+// New code (with type safety)
+import { useDialog, DIALOG_KEYS } from '@/components/common/DialogProvider';
+
+function NewComponent() {
+  const { openDialog } = useDialog();
+
+  const handleClick = () => {
+    openDialog(DIALOG_KEYS.CREATE_USER, { title: 'Create User' }); // Typed constant
+  };
+
+  return <button onClick={handleClick}>Create User</button>;
+}
+```
+
+Both approaches work identically at runtime - the new approach just provides better IDE support and compile-time checking!
