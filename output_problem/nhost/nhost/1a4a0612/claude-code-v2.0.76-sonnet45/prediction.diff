+  ...DIALOG_KEYS,
+  ...DRAWER_KEYS,
+} as const;
+
+// Type for all dialog keys
+export type DialogKeyType = typeof ALL_DIALOG_KEYS[keyof typeof ALL_DIALOG_KEYS];
