+import type { ComponentType } from 'react';
+
+/**
+ * Base props that all dialog/drawer forms receive.
+ */
+export interface BaseFormProps {
+  onSubmit: (values?: any) => Promise<void>;
+  onCancel: () => void;
+}
+
+/**
+ * Configuration for a registered dialog form.
+ * Uses ComponentType<any> to allow forms with varying prop signatures
+ * while maintaining the core onSubmit/onCancel contract.
+ */
+export interface DialogFormConfig {
+  /**
+   * The form component to render. Components receive BaseFormProps plus
+   * any additional props passed via the dialog payload.
+   */
+  component: ComponentType<any>;
+  /**
+   * Whether this form should be rendered in a drawer (true) or dialog (false).
+   */
+  isDrawer?: boolean;
+  /**
+   * Whether to use dynamic import with SSR disabled.
+   */
+  isDynamic?: boolean;
+}
+
+/**
+ * Registry type that maps dialog type strings to their form configurations.
+ * This provides type safety between dialog types and their associated components.
+ */
+export type DialogFormRegistry = Map<string, DialogFormConfig>;
+
+/**
+ * Create a new dialog form registry.
+ */
+export function createDialogFormRegistry(): DialogFormRegistry {
+  return new Map();
+}
+
+/**
+ * Register a dialog form component.
+ *
+ * @param registry - The registry to add the form to.
+ * @param type - The unique dialog type identifier.
+ * @param config - The form configuration.
+ */
+export function registerDialogForm(
+  registry: DialogFormRegistry,
+  type: string,
+  config: DialogFormConfig,
+): void {
+  registry.set(type, config);
+}
+
+/**
+ * Get a registered dialog form configuration.
+ *
+ * @param registry - The registry to look up.
+ * @param type - The dialog type to find.
+ * @returns The form configuration or undefined if not found.
+ */
+export function getDialogForm(
+  registry: DialogFormRegistry,
+  type: string,
+): DialogFormConfig | undefined {
+  return registry.get(type);
+}
+
+/**
+ * Check if a dialog type is registered.
+ *
+ * @param registry - The registry to check.
+ * @param type - The dialog type to check.
+ * @returns True if the type is registered.
+ */
+export function hasDialogForm(
+  registry: DialogFormRegistry,
+  type: string,
+): boolean {
+  return registry.has(type);
+}
+
+/**
+ * Get all registered dialog types.
+ *
+ * @param registry - The registry to get types from.
+ * @returns Array of registered dialog type strings.
+ */
+export function getRegisteredDialogTypes(registry: DialogFormRegistry): string[] {
+  return Array.from(registry.keys());
+}
