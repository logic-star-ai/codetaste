+/**
+ * Renders a form component from the registry based on the active type.
+ */
+function renderFormFromRegistry(
+  registry: DialogFormRegistry,
+  activeType: string | undefined,
+  sharedProps: Record<string, unknown>,
+  payload: Record<string, unknown> | undefined,
+  mode: 'dialog' | 'drawer',
+): React.ReactNode {
+  if (!activeType) {
+    return null;
+  }
+
+  const config = registry.get(activeType) as DialogFormConfig | undefined;
+
+  if (!config) {
+    return null;
+  }
+
+  // Check if this form matches the render mode
+  const isDrawerForm = config.isDrawer ?? false;
+  if (mode === 'drawer' && !isDrawerForm) {
+    return null;
+  }
+  if (mode === 'dialog' && isDrawerForm) {
+    return null;
+  }
+
+  const FormComponent = config.component;
+  const formProps = {
+    ...payload,
+    ...sharedProps,
+  };
+
+  return <FormComponent {...formProps} />;
+}
 
