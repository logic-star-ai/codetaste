+import type { BaseForeignKeyFormValues } from '@/components/dataBrowser/BaseForeignKeyForm';
+import type { CreateColumnFormProps } from '@/components/dataBrowser/CreateColumnForm/CreateColumnForm';
+import type { CreateForeignKeyFormProps } from '@/components/dataBrowser/CreateForeignKeyForm/CreateForeignKeyForm';
+import type { CreateRecordFormProps } from '@/components/dataBrowser/CreateRecordForm/CreateRecordForm';
+import type { CreateTableFormProps } from '@/components/dataBrowser/CreateTableForm/CreateTableForm';
+import type { EditColumnFormProps } from '@/components/dataBrowser/EditColumnForm/EditColumnForm';
+import type { EditForeignKeyFormProps } from '@/components/dataBrowser/EditForeignKeyForm/EditForeignKeyForm';
+import type { EditPermissionsFormProps } from '@/components/dataBrowser/EditPermissionsForm/EditPermissionsForm';
+import type { EditTableFormProps } from '@/components/dataBrowser/EditTableForm/EditTableForm';
+import type { CreateEnvironmentVariableFormProps } from '@/components/settings/environmentVariables/CreateEnvironmentVariableForm/CreateEnvironmentVariableForm';
+import type { EditEnvironmentVariableFormProps } from '@/components/settings/environmentVariables/EditEnvironmentVariableForm/EditEnvironmentVariableForm';
+import type { EditJwtSecretFormProps } from '@/components/settings/environmentVariables/EditJwtSecretForm/EditJwtSecretForm';
+import type { CreatePermissionVariableFormProps } from '@/components/settings/permissions/CreatePermissionVariableForm/CreatePermissionVariableForm';
+import type { EditPermissionVariableFormProps } from '@/components/settings/permissions/EditPermissionVariableForm/EditPermissionVariableForm';
+import type { CreateRoleFormProps } from '@/components/settings/roles/CreateRoleForm/CreateRoleForm';
+import type { EditRoleFormProps } from '@/components/settings/roles/EditRoleForm/EditRoleForm';
+import type { CreateUserFormProps } from '@/components/users/CreateUserForm/CreateUserForm';
+import type { EditUserFormProps } from '@/components/users/EditUserForm/EditUserForm';
+import type {
+  EditUserPasswordFormProps,
+  EditUserPasswordFormValues,
+} from '@/components/users/EditUserPasswordForm/EditUserPasswordForm';
+import type { EditWorkspaceNameFormProps } from '@/components/home/EditWorkspaceNameForm/EditWorkspaceNameForm';
+
+export const drawerDialogTypes = [
+  'CREATE_RECORD',
+  'CREATE_COLUMN',
+  'EDIT_COLUMN',
+  'CREATE_TABLE',
+  'EDIT_TABLE',
+  'EDIT_PERMISSIONS',
+  'EDIT_USER',
+] as const;
+
+export type DrawerDialogType = (typeof drawerDialogTypes)[number];
+
+type DialogPayloadWithValues<Values = void> = {
+  /**
+   * Additional form submit hook executed after the dialog is confirmed.
+   */
+  onSubmit?: (values: Values) => Promise<void>;
+};
+
+export interface DialogPayloadMap {
+  EDIT_WORKSPACE_NAME: DialogPayloadWithValues<void> &
+    Partial<
+      Pick<EditWorkspaceNameFormProps, 'currentWorkspaceId' | 'currentWorkspaceName'>
+    >;
+  CREATE_RECORD: DialogPayloadWithValues<void> &
+    Pick<CreateRecordFormProps, 'columns'>;
+  CREATE_COLUMN: DialogPayloadWithValues<void> & Pick<CreateColumnFormProps, never>;
+  EDIT_COLUMN: DialogPayloadWithValues<void> & Pick<EditColumnFormProps, 'column'>;
+  CREATE_TABLE: DialogPayloadWithValues<void> & Pick<CreateTableFormProps, 'schema'>;
+  EDIT_TABLE: DialogPayloadWithValues<void> &
+    Pick<EditTableFormProps, 'schema' | 'table'>;
+  EDIT_PERMISSIONS: DialogPayloadWithValues<void> &
+    Pick<EditPermissionsFormProps, 'schema' | 'table' | 'disabled'>;
+  CREATE_FOREIGN_KEY: DialogPayloadWithValues<BaseForeignKeyFormValues> &
+    Pick<
+      CreateForeignKeyFormProps,
+      'availableColumns' | 'selectedColumn'
+    >;
+  EDIT_FOREIGN_KEY: DialogPayloadWithValues<BaseForeignKeyFormValues> &
+    Pick<
+      EditForeignKeyFormProps,
+      'foreignKeyRelation' | 'availableColumns' | 'selectedColumn'
+    >;
+  CREATE_ROLE: DialogPayloadWithValues<void> & Pick<CreateRoleFormProps, never>;
+  EDIT_ROLE: DialogPayloadWithValues<void> &
+    Pick<EditRoleFormProps, 'originalRole'>;
+  CREATE_USER: DialogPayloadWithValues<void> &
+    Pick<CreateUserFormProps, 'onSuccess'>;
+  CREATE_PERMISSION_VARIABLE: DialogPayloadWithValues<void> &
+    Pick<CreatePermissionVariableFormProps, never>;
+  EDIT_PERMISSION_VARIABLE: DialogPayloadWithValues<void> &
+    Pick<EditPermissionVariableFormProps, 'originalVariable'>;
+  CREATE_ENVIRONMENT_VARIABLE: DialogPayloadWithValues<void> &
+    Pick<CreateEnvironmentVariableFormProps, never>;
+  EDIT_ENVIRONMENT_VARIABLE: DialogPayloadWithValues<void> &
+    Pick<EditEnvironmentVariableFormProps, 'originalEnvironmentVariable'>;
+  EDIT_USER: DialogPayloadWithValues<void> &
+    Pick<
+      EditUserFormProps,
+      'user' | 'onEditUser' | 'onDeleteUser' | 'roles' | 'onSuccessfulAction'
+    >;
+  EDIT_USER_PASSWORD: DialogPayloadWithValues<EditUserPasswordFormValues> &
+    Pick<EditUserPasswordFormProps, 'user'>;
+  EDIT_JWT_SECRET: DialogPayloadWithValues<void> &
+    Pick<EditJwtSecretFormProps, 'jwtSecret' | 'disabled'>;
+}
+
+export type DialogType = keyof DialogPayloadMap;
+export type DialogDisplayType = Exclude<DialogType, DrawerDialogType>;
