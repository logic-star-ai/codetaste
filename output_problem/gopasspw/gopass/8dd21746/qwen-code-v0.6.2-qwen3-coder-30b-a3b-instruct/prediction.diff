@@ -58,3 +60,16 @@ func newAction(ctx context.Context, cfg *config.Config, sv semver.Version) (*Act
 func (s *Action) String() string {
 	return s.Store.String()
 }
+
+// WithGlobalFlags adds global flags to a context
+func (s *Action) WithGlobalFlags(ctx context.Context, c *cli.Context) context.Context {
+	if c.Bool("yes") {
+		ctx = ctxutil.WithAlwaysYes(ctx, true)
+	}
+	ctx = ctxutil.WithClip(ctx, c.Bool("clip"))
+	ctx = ctxutil.WithAlsoclip(ctx, c.Bool("alsoclip"))
+	if c.IsSet("store") {
+		ctx = ctxutil.WithStore(ctx, c.String("store"))
+	}
+	return ctx
+}
