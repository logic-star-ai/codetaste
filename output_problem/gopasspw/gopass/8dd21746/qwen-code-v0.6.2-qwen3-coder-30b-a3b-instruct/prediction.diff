+// getAllCommands returns a list of all CLI commands organized in modules
+func getAllCommands(ctx context.Context, action *ap.Action, app *cli.App) []*cli.Command {
+	var commands []*cli.Command
+
+	// Core commands that don't have dedicated packages
+	commands = append(commands, audit.Commands(ctx, action)...)
+	commands = append(commands, binary.Commands(ctx, action)...)
+	commands = append(commands, clone.Commands(ctx, action)...)
+	commands = append(commands, completion.Commands(ctx, action, app)...)
+	commands = append(commands, config.Commands(ctx, action)...)
+	commands = append(commands, copy.Commands(ctx, action)...)
+	commands = append(commands, create.Commands(ctx, action)...)
+	commands = append(commands, delete.Commands(ctx, action)...)
+	commands = append(commands, edit.Commands(ctx, action)...)
+	commands = append(commands, find.Commands(ctx, action)...)
+	commands = append(commands, fsck.Commands(ctx, action)...)
+	commands = append(commands, generate.Commands(ctx, action)...)
+	commands = append(commands, git.Commands(ctx, action)...)
+	commands = append(commands, grep.Commands(ctx, action)...)
+	commands = append(commands, history.Commands(ctx, action)...)
+	commands = append(commands, init.Commands(ctx, action)...)
+	commands = append(commands, insert.Commands(ctx, action)...)
+	commands = append(commands, jsonapi.Commands(ctx, action)...)
+	commands = append(commands, list.Commands(ctx, action)...)
+	commands = append(commands, mount.Commands(ctx, action)...)
+	commands = append(commands, move.Commands(ctx, action)...)
+	commands = append(commands, otp.Commands(ctx, action)...)
+	commands = append(commands, recipients.Commands(ctx, action)...)
+	commands = append(commands, show.Commands(ctx, action)...)
+	commands = append(commands, sync.Commands(ctx, action)...)
+	commands = append(commands, templates.Commands(ctx, action)...)
+	commands = append(commands, unclip.Commands(ctx, action)...)
+	commands = append(commands, update.Commands(ctx, action)...)
+	commands = append(commands, version.Commands(ctx, action)...)
+
+	return commands
+}
