+					Flags: []cli.Flag{
+						&cli.StringFlag{
+							Name:  "store",
+							Usage: "Store to use for removing recipient",
+						},
+					},
+				},
+				{
+					Name:  "list",
+					Usage: "List recipients",
+					Description: "" +
+						"This command lists all recipients for a store. " +
