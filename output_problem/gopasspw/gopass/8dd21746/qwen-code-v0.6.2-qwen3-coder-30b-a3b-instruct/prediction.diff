+					Name:  "remove",
+					Usage: "Remove a recipient",
+					Description: "" +
+						"This command removes a recipient from a store. " +
+						"The target recipient is the GPG key ID or email address to " +
+						"remove.",
+					Before: func(c *cli.Context) error { return action.Initialized(action.WithGlobalFlags(ctx, c), c) },
