+import dagger.Module
+import dagger.Provides
+import dagger.hilt.InstallIn
+import dagger.hilt.android.components.ApplicationComponent
+import dagger.hilt.android.qualifiers.ApplicationContext
+import javax.inject.Singleton
+
+/**
+ * Created by charlag on 3/21/18.
+ */
+
+@Module
+@InstallIn(ApplicationComponent::class)
+object HiltAppModule {
+
+    @Provides
+    @Singleton
+    fun provideAppTheme(
+        sharedPreferences: android.content.SharedPreferences,
+        @ApplicationContext context: android.content.Context
+    ): AppTheme {
+        val theme = sharedPreferences.getString(PrefKeys.APP_THEME, AppTheme.DEFAULT.value)
+        setAppNightMode(theme)
+        return AppTheme.fromValue(theme)
+    }
+
+    @Provides
+    @Singleton
+    fun provideSharedPreferences(@ApplicationContext context: android.content.Context): android.content.SharedPreferences {
+        return android.preference.PreferenceManager.getDefaultSharedPreferences(context)
+    }
+
+    @Provides
+    @Singleton
+    fun provideLocaleManager(
+        @ApplicationContext context: android.content.Context,
+        sharedPreferences: android.content.SharedPreferences
+    ): LocaleManager {
+        return LocaleManager(context, sharedPreferences)
+    }
+
+    @Provides
+    @Singleton
+    fun provideWorkerFactory(
+        @ApplicationContext context: android.content.Context,
+        sharedPreferences: android.content.SharedPreferences
+    ): WorkerFactory {
+        return WorkerFactory(
+            context,
+            sharedPreferences
+        )
+    }
+}
