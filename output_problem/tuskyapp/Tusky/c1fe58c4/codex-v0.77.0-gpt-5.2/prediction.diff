diff --git a/app/src/main/java/com/keylesspalace/tusky/di/AppComponentAccess.kt b/app/src/main/java/com/keylesspalace/tusky/di/AppComponentAccess.kt
new file mode 100644
index 0000000..568216f
--- /dev/null
+++ b/app/src/main/java/com/keylesspalace/tusky/di/AppComponentAccess.kt
@@ -0,0 +1,38 @@
+package com.keylesspalace.tusky.di
+
+import android.content.Context
+import com.keylesspalace.tusky.TuskyApplication
+import java.lang.reflect.Method
+
+val Context.appComponent: AppComponent
+    get() = (applicationContext as TuskyApplication).appComponent
+
+object AppComponentInjector {
+    @JvmStatic
+    fun inject(target: Any) {
+        val context = target as? Context
+            ?: error("AppComponentInjector.inject(target) requires target to be a Context (was ${target::class.java.name})")
+        inject(target, context)
+    }
+
+    @JvmStatic
+    fun inject(target: Any, context: Context) {
+        val component = context.appComponent
+        val method = findInjectMethod(component, target::class.java)
+            ?: error("No AppComponent.inject(...) method found for ${target::class.java.name}")
+        method.invoke(component, target)
+    }
+
+    private fun findInjectMethod(component: AppComponent, targetClass: Class<*>): Method? {
+        var current: Class<*>? = targetClass
+        while (current != null) {
+            try {
+                return component.javaClass.getMethod("inject", current)
+            } catch (_: NoSuchMethodException) {
+                current = current.superclass
+            }
+        }
+        return null
+    }
+}
+
