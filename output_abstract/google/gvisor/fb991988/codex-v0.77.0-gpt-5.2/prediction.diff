diff --git a/pkg/sentry/mm/private_memory_refs.go b/pkg/sentry/mm/private_memory_refs.go
new file mode 100644
index 0000000..b2fa75a
--- /dev/null
+++ b/pkg/sentry/mm/private_memory_refs.go
@@ -0,0 +1,115 @@
