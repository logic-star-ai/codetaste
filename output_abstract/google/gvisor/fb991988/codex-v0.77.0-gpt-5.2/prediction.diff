+// limitations under the License.
+
+package mm
+
+import (
+	"sync"
+
+	"gvisor.googlesource.com/gvisor/pkg/sentry/platform"
+)
+
+// privateMemoryRefs tracks reference counts for private anonymous memory pages
+// (i.e. pages owned by one or more pmas, rather than a memmap.Mappable).
+//
+// It maintains a per-page reference count keyed by offsets into
+// platform.Platform.Memory().
+//
+// +stateify savable
+type privateMemoryRefs struct {
+	mu sync.Mutex `state:"nosave"`
+
+	// refs maps offsets into Platform.Memory() to the number of pmas (or,
+	// equivalently, MemoryManagers) that share ownership of the memory at that
+	// offset.
+	refs fileRefcountSet
+}
+
+// Inc acquires a reference on private pages in fr.
+func (pr *privateMemoryRefs) Inc(fr platform.FileRange) {
+	pr.mu.Lock()
+	defer pr.mu.Unlock()
+	refSet := &pr.refs
+	seg, gap := refSet.Find(fr.Start)
+	for {
+		switch {
+		case seg.Ok() && seg.Start() < fr.End:
+			seg = refSet.Isolate(seg, fr)
+			seg.SetValue(seg.Value() + 1)
+			seg, gap = seg.NextNonEmpty()
+		case gap.Ok() && gap.Start() < fr.End:
+			seg, gap = refSet.InsertWithoutMerging(gap, gap.Range().Intersect(fr), 1).NextNonEmpty()
+		default:
+			refSet.MergeAdjacent(fr)
+			return
+		}
+	}
+}
+
+// Dec releases a reference on private pages in fr and returns FileRanges for
+// which the refcount reached zero. Callers should release the corresponding
+// owner references on platform.Platform.Memory() for those ranges.
+func (pr *privateMemoryRefs) Dec(fr platform.FileRange) []platform.FileRange {
+	var freed []platform.FileRange
+
+	pr.mu.Lock()
+	refSet := &pr.refs
+	seg := refSet.LowerBoundSegment(fr.Start)
+	for seg.Ok() && seg.Start() < fr.End {
+		seg = refSet.Isolate(seg, fr)
+		if old := seg.Value(); old == 1 {
+			freed = append(freed, seg.Range())
+			seg = refSet.Remove(seg).NextSegment()
+		} else {
+			seg.SetValue(old - 1)
+			seg = seg.NextSegment()
+		}
+	}
+	refSet.MergeAdjacent(fr)
+	pr.mu.Unlock()
+
+	return freed
+}
+
+// IsSoleRef returns true if all offsets in fr currently have a refcount of 1.
+//
+// IsSoleRef relies on pr.refs being kept fully merged by Inc/Dec.
+func (pr *privateMemoryRefs) IsSoleRef(fr platform.FileRange) bool {
+	pr.mu.Lock()
+	defer pr.mu.Unlock()
+	rseg := pr.refs.FindSegment(fr.Start)
+	return rseg.Ok() && rseg.Value() == 1 && fr.End <= rseg.End()
+}
+
+// fileRefcountSetFunctions implements segment.Functions for fileRefcountSet.
+type fileRefcountSetFunctions struct{}
+
+func (fileRefcountSetFunctions) MinKey() uint64 {
+	return 0
+}
+
+func (fileRefcountSetFunctions) MaxKey() uint64 {
+	return ^uint64(0)
+}
+
+func (fileRefcountSetFunctions) ClearValue(_ *int32) {
+}
+
+func (fileRefcountSetFunctions) Merge(_ platform.FileRange, rc1 int32, _ platform.FileRange, rc2 int32) (int32, bool) {
+	return rc1, rc1 == rc2
+}
+
+func (fileRefcountSetFunctions) Split(_ platform.FileRange, rc int32, _ uint64) (int32, int32) {
+	return rc, rc
+}
