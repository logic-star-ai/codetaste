+// See the License for the specific language governing permissions and
+// limitations under the License.
+
+package mm
+
+import (
+	"testing"
+
+	"gvisor.googlesource.com/gvisor/pkg/sentry/platform"
+	"gvisor.googlesource.com/gvisor/pkg/sentry/usermem"
+)
+
+func TestPrivateMemoryRefsSoleRefAndDec(t *testing.T) {
+	var pr privateMemoryRefs
+
+	p0 := uint64(0)
+	p1 := uint64(usermem.PageSize)
+	p2 := uint64(2 * usermem.PageSize)
+
+	all := platform.FileRange{Start: p0, End: p2}
+	first := platform.FileRange{Start: p0, End: p1}
+	second := platform.FileRange{Start: p1, End: p2}
+
+	pr.Inc(all)
+	if !pr.IsSoleRef(all) {
+		t.Fatalf("expected sole ref for %v after single Inc", all)
+	}
+
+	pr.Inc(second)
+	if pr.IsSoleRef(all) {
+		t.Fatalf("expected non-sole ref for %v after second page Inc", all)
+	}
+	if !pr.IsSoleRef(first) {
+		t.Fatalf("expected sole ref for %v after second page Inc", first)
+	}
+
+	freed := pr.Dec(first)
+	if len(freed) != 1 || freed[0] != first {
+		t.Fatalf("Dec(%v) freed=%v, want [%v]", first, freed, first)
+	}
+	if !pr.IsSoleRef(second) {
+		t.Fatalf("expected sole ref for %v after Dec(first)", second)
+	}
+
+	freed = pr.Dec(second)
+	if len(freed) != 0 {
+		t.Fatalf("Dec(%v) freed=%v, want empty (refcount should be 1)", second, freed)
+	}
+
+	freed = pr.Dec(second)
+	if len(freed) != 1 || freed[0] != second {
+		t.Fatalf("Dec(%v) freed=%v, want [%v]", second, freed, second)
+	}
+}
