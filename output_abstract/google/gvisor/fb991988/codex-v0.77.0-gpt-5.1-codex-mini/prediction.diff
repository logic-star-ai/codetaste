+
+package mm
+
+import (
+	"testing"
+
+	"gvisor.googlesource.com/gvisor/pkg/sentry/platform"
+)
+
+func TestPrivateRefsMergeSoleOwnerAndFree(t *testing.T) {
+	var pr privateRefs
+
+	fr0 := platform.FileRange{Start: 0x0, End: 0x3000}
+	fr1 := platform.FileRange{Start: 0x3000, End: 0x4000}
+	full := platform.FileRange{Start: 0x0, End: 0x4000}
+
+	pr.inc(fr0)
+	if !pr.soleOwner(fr0) {
+		t.Fatalf("soleOwner(%v) = false, want true", fr0)
+	}
+
+	// Ensure that adjacent ranges with identical refcounts are merged, since
+	// soleOwner() relies on the refcount set being fully merged.
+	pr.inc(fr1)
+	if !pr.soleOwner(full) {
+		t.Fatalf("soleOwner(%v) = false, want true (expected merged refcount segments)", full)
+	}
+
+	// Create a refcount split: [0,0x3000) => 2, [0x3000,0x4000) => 1.
+	pr.inc(fr0)
+	if pr.soleOwner(fr0) {
+		t.Fatalf("soleOwner(%v) = true, want false (refcount > 1)", fr0)
+	}
+	if pr.soleOwner(full) {
+		t.Fatalf("soleOwner(%v) = true, want false (mixed refcounts)", full)
+	}
+
+	// Drop back to a single owner, which should re-merge.
+	if freed := pr.dec(fr0); len(freed) != 0 {
+		t.Fatalf("dec(%v) freed %v, want none", fr0, freed)
+	}
+	if !pr.soleOwner(full) {
+		t.Fatalf("soleOwner(%v) = false, want true (expected re-merged refcount segments)", full)
+	}
+
+	// Release the final reference; the full range should be freed.
+	freed := pr.dec(full)
+	if len(freed) != 1 || freed[0] != full {
+		t.Fatalf("dec(%v) freed %v, want [%v]", full, freed, full)
+	}
+	if pr.soleOwner(full) {
+		t.Fatalf("soleOwner(%v) = true, want false (no references remain)", full)
+	}
+}
