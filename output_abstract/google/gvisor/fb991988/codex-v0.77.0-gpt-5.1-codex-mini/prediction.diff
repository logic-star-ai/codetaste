new file mode 100644
index 0000000..041fb8d
--- /dev/null
+++ b/pkg/sentry/mm/private_memory.go
@@ -0,0 +1,94 @@
+// Copyright 2018 Google LLC
+//
+// Licensed under the Apache License, Version 2.0 (the "License");
+// you may not use this file except in compliance with the License.
+// You may obtain a copy of the License at
+//
+//     http://www.apache.org/licenses/LICENSE-2.0
+//
+// Unless required by applicable law or agreed to in writing, software
+// distributed under the License is distributed on an "AS IS" BASIS,
+// WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.
+// See the License for the specific language governing permissions and
+// limitations under the License.
+
+package mm
+
+import (
+	"sync"
+
+	"gvisor.googlesource.com/gvisor/pkg/sentry/platform"
+)
+
+// privateMemory tracks "ownership" references for platform.Memory ranges used
+// as private (anonymous or COW-copied) pages.
+//
+// This ownership is distinct from pma.file references, which track active pmas
+// (resident mappings) for those same pages.
+//
+// +stateify savable
+type privateMemory struct {
+	mu sync.Mutex `state:"nosave"`
+
+	// refs maps offsets into Platform.Memory() to the number of MemoryManagers
+	// that share ownership of the memory at that offset.
+	refs fileRefcountSet
+}
+
+// Inc acquires an ownership reference on private pages in fr.
+func (pm *privateMemory) Inc(fr platform.FileRange) {
+	pm.mu.Lock()
+	defer pm.mu.Unlock()
+
+	refSet := &pm.refs
+	seg, gap := refSet.Find(fr.Start)
+	for {
+		switch {
+		case seg.Ok() && seg.Start() < fr.End:
+			seg = refSet.Isolate(seg, fr)
+			seg.SetValue(seg.Value() + 1)
+			seg, gap = seg.NextNonEmpty()
+		case gap.Ok() && gap.Start() < fr.End:
+			seg, gap = refSet.InsertWithoutMerging(gap, gap.Range().Intersect(fr), 1).NextNonEmpty()
+		default:
+			refSet.MergeAdjacent(fr)
+			return
+		}
+	}
+}
+
+// Dec releases an ownership reference on private pages in fr.
+func (pm *privateMemory) Dec(mem platform.Memory, fr platform.FileRange) {
+	var freed []platform.FileRange
+
+	pm.mu.Lock()
+	refSet := &pm.refs
+	seg := refSet.LowerBoundSegment(fr.Start)
+	for seg.Ok() && seg.Start() < fr.End {
+		seg = refSet.Isolate(seg, fr)
+		if old := seg.Value(); old == 1 {
+			freed = append(freed, seg.Range())
+			seg = refSet.Remove(seg).NextSegment()
+		} else {
+			seg.SetValue(old - 1)
+			seg = seg.NextSegment()
+		}
+	}
+	refSet.MergeAdjacent(fr)
+	pm.mu.Unlock()
+
+	for _, freedFR := range freed {
+		mem.DecRef(freedFR)
+	}
+}
+
+// IsSoleOwner returns true if the calling MemoryManager is the only owner of
+// the private pages in fr.
+func (pm *privateMemory) IsSoleOwner(fr platform.FileRange) bool {
+	pm.mu.Lock()
+	defer pm.mu.Unlock()
+
+	// This relies on pm.refs being kept fully merged.
+	rseg := pm.refs.FindSegment(fr.Start)
+	return rseg.Ok() && rseg.Value() == 1 && fr.End <= rseg.End()
+}
