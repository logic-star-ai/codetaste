+// limitations under the License.
+
+package mm
+
+import "gvisor.googlesource.com/gvisor/pkg/sentry/platform"
+
+// inc acquires a reference on private pages in fr.
+func (pr *privateRefs) inc(fr platform.FileRange) {
+	pr.mu.Lock()
+	defer pr.mu.Unlock()
+
+	refSet := &pr.refs
+	seg, gap := refSet.Find(fr.Start)
+	for {
+		switch {
+		case seg.Ok() && seg.Start() < fr.End:
+			seg = refSet.Isolate(seg, fr)
+			seg.SetValue(seg.Value() + 1)
+			seg, gap = seg.NextNonEmpty()
+		case gap.Ok() && gap.Start() < fr.End:
+			seg, gap = refSet.InsertWithoutMerging(gap, gap.Range().Intersect(fr), 1).NextNonEmpty()
+		default:
+			refSet.MergeAdjacent(fr)
+			return
+		}
+	}
+}
+
+// dec releases a reference on private pages in fr, returning the ranges that
+// should have their references released on platform.Platform.Memory().
+func (pr *privateRefs) dec(fr platform.FileRange) []platform.FileRange {
+	var freed []platform.FileRange
+
+	pr.mu.Lock()
+	refSet := &pr.refs
+	seg := refSet.LowerBoundSegment(fr.Start)
+	for seg.Ok() && seg.Start() < fr.End {
+		seg = refSet.Isolate(seg, fr)
+		if old := seg.Value(); old == 1 {
+			freed = append(freed, seg.Range())
+			seg = refSet.Remove(seg).NextSegment()
+		} else {
+			seg.SetValue(old - 1)
+			seg = seg.NextSegment()
+		}
+	}
+	refSet.MergeAdjacent(fr)
+	pr.mu.Unlock()
+
+	return freed
+}
+
+// soleOwner returns true if exactly one reference is held on all pages in fr.
+func (pr *privateRefs) soleOwner(fr platform.FileRange) bool {
+	pr.mu.Lock()
+	defer pr.mu.Unlock()
+
+	// This check relies on pr.refs being kept fully merged.
+	rseg := pr.refs.FindSegment(fr.Start)
+	return rseg.Ok() && rseg.Value() == 1 && fr.End <= rseg.End()
+}
