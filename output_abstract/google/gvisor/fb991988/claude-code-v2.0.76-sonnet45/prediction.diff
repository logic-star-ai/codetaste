+// markDirtyRange marks a file range as dirty for incremental UpdateUsage scans.
+// Precondition: f.mu must be held.
+func (f *FileMem) markDirtyRange(fr platform.FileRange) {
+	// Track dirty chunks at chunk granularity to limit map size
+	startChunk := fr.Start >> chunkShift
+	endChunk := (fr.End + chunkMask) >> chunkShift
+	for chunk := startChunk; chunk < endChunk; chunk++ {
+		f.usageDirty[chunk] = true
+	}
+}
+
+// clearDirtyRange clears dirty tracking for a file range.
+// Precondition: f.mu must be held.
+func (f *FileMem) clearDirtyRange(fr platform.FileRange) {
+	startChunk := fr.Start >> chunkShift
+	endChunk := (fr.End + chunkMask) >> chunkShift
+	for chunk := startChunk; chunk < endChunk; chunk++ {
+		delete(f.usageDirty, chunk)
+	}
 }
 
