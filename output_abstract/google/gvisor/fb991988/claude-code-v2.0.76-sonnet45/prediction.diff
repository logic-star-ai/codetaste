+package refs
+
+import (
+	"testing"
+)
+
+// TestWeakRefPoolStats tests that weak reference pool statistics are tracked correctly.
+func TestWeakRefPoolStats(t *testing.T) {
+	// Reset stats
+	poolStats.mu.Lock()
+	poolStats.gets = 0
+	poolStats.puts = 0
+	poolStats.news = 0
+	poolStats.currentInPool = 0
+	poolStats.mu.Unlock()
+
+	// Create a ref-counted object
+	rc := &AtomicRefCount{}
+	rc.IncRef()
+
+	// Get initial stats
+	initialStats := GetWeakRefPoolStats()
+
+	// Create a weak reference
+	wr := NewWeakRef(rc, nil)
+
+	// Verify gets increased
+	stats := GetWeakRefPoolStats()
+	if stats.Gets <= initialStats.Gets {
+		t.Errorf("Expected Gets to increase, got %d -> %d", initialStats.Gets, stats.Gets)
+	}
+
+	// Drop the weak reference
+	wr.Drop()
+
+	// Verify puts increased
+	stats = GetWeakRefPoolStats()
+	if stats.Puts <= initialStats.Puts {
+		t.Errorf("Expected Puts to increase, got %d -> %d", initialStats.Puts, stats.Puts)
+	}
+
+	rc.DecRef()
+}
+
+// TestWeakRefPoolSizeLimit tests that the pool size limit is enforced.
+func TestWeakRefPoolSizeLimit(t *testing.T) {
+	// Reset stats
+	poolStats.mu.Lock()
+	poolStats.gets = 0
+	poolStats.puts = 0
+	poolStats.news = 0
+	poolStats.currentInPool = 0
+	poolStats.maxPoolSize = 0
+	poolStats.mu.Unlock()
+
+	// Create many weak references and drop them
+	const numRefs = 100
+	rcs := make([]*AtomicRefCount, numRefs)
+	wrs := make([]*WeakRef, numRefs)
+
+	for i := 0; i < numRefs; i++ {
+		rcs[i] = &AtomicRefCount{}
+		rcs[i].IncRef()
+		wrs[i] = NewWeakRef(rcs[i], nil)
+	}
+
+	// Drop all weak references
+	for i := 0; i < numRefs; i++ {
+		wrs[i].Drop()
+		rcs[i].DecRef()
+	}
+
+	// Verify pool stats were tracked
+	stats := GetWeakRefPoolStats()
+	if stats.MaxPoolSize == 0 {
+		t.Error("Expected MaxPoolSize to be tracked")
+	}
+
+	// The current pool size should be reasonable (not unbounded)
+	if stats.CurrentInPool > 10000 {
+		t.Errorf("Pool size too large: %d (max allowed is 10000)", stats.CurrentInPool)
+	}
+}
+
+// TestWeakRefPoolReuse tests that weak references are reused from the pool.
+func TestWeakRefPoolReuse(t *testing.T) {
+	// Reset stats
+	poolStats.mu.Lock()
+	oldNews := poolStats.news
+	poolStats.mu.Unlock()
+
+	// Create and drop a weak reference
+	rc1 := &AtomicRefCount{}
+	rc1.IncRef()
+	wr1 := NewWeakRef(rc1, nil)
+	wr1.Drop()
+	rc1.DecRef()
+
+	// Create another weak reference
+	rc2 := &AtomicRefCount{}
+	rc2.IncRef()
+	wr2 := NewWeakRef(rc2, nil)
+
+	// Check if we reused from pool (news should not have increased by 2)
+	poolStats.mu.Lock()
+	newNews := poolStats.news
+	poolStats.mu.Unlock()
+
+	newsIncrease := newNews - oldNews
+	if newsIncrease > 2 {
+		t.Logf("Warning: Pool may not be reusing objects efficiently (news increased by %d)", newsIncrease)
+	}
+
+	wr2.Drop()
+	rc2.DecRef()
+}
+
+// BenchmarkWeakRefPoolGetPut benchmarks the overhead of pool operations with tracking.
+func BenchmarkWeakRefPoolGetPut(b *testing.B) {
+	rc := &AtomicRefCount{}
+	rc.IncRef()
+	defer rc.DecRef()
+
+	b.ResetTimer()
+	for i := 0; i < b.N; i++ {
+		wr := NewWeakRef(rc, nil)
+		wr.Drop()
+	}
+}
+
+// BenchmarkWeakRefPoolStats benchmarks getting pool statistics.
+func BenchmarkWeakRefPoolStats(b *testing.B) {
+	b.ResetTimer()
+	for i := 0; i < b.N; i++ {
+		_ = GetWeakRefPoolStats()
+	}
+}
