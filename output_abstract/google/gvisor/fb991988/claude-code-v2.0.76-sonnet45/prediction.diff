+// putWeakRefInPool returns a weak reference to the pool with tracking.
+func putWeakRefInPool(w *WeakRef) {
+	poolStats.mu.Lock()
+	poolStats.puts++
+	poolStats.currentInPool++
+	if poolStats.currentInPool > poolStats.maxPoolSize {
+		poolStats.maxPoolSize = poolStats.currentInPool
+	}
