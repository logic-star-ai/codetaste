+// MemoryAccountingStats tracks statistics about memory accounting operations.
+type MemoryAccountingStats struct {
+	mu                sync.Mutex
+	incOperations     uint64
+	decOperations     uint64
+	moveOperations    uint64
+	totalIncBytes     uint64
+	totalDecBytes     uint64
+	largestInc        uint64
+	largestDec        uint64
+	errors            uint64
+	lastErrorMsg      string
+}
+
+var accountingStats MemoryAccountingStats
+
+// RecordInc records an increment operation.
+func (m *MemoryLocked) RecordInc(val uint64, kind MemoryKind) {
+	accountingStats.mu.Lock()
+	accountingStats.incOperations++
+	accountingStats.totalIncBytes += val
+	if val > accountingStats.largestInc {
+		accountingStats.largestInc = val
+	}
+	accountingStats.mu.Unlock()
+	m.Inc(val, kind)
+}
+
+// RecordDec records a decrement operation.
+func (m *MemoryLocked) RecordDec(val uint64, kind MemoryKind) {
+	accountingStats.mu.Lock()
+	accountingStats.decOperations++
+	accountingStats.totalDecBytes += val
+	if val > accountingStats.largestDec {
+		accountingStats.largestDec = val
+	}
+	accountingStats.mu.Unlock()
+	m.Dec(val, kind)
+}
+
+// RecordMove records a move operation.
+func (m *MemoryLocked) RecordMove(val uint64, to MemoryKind, from MemoryKind) {
+	accountingStats.mu.Lock()
+	accountingStats.moveOperations++
+	accountingStats.mu.Unlock()
+	m.Move(val, to, from)
+}
+
+// MemoryAccountingStatsSnapshot represents a snapshot of memory accounting statistics.
+type MemoryAccountingStatsSnapshot struct {
+	IncOperations  uint64
+	DecOperations  uint64
+	MoveOperations uint64
+	TotalIncBytes  uint64
+	TotalDecBytes  uint64
+	LargestInc     uint64
+	LargestDec     uint64
+	Errors         uint64
+	LastErrorMsg   string
+}
+
+// GetMemoryAccountingStats returns a snapshot of memory accounting statistics.
+func GetMemoryAccountingStats() MemoryAccountingStatsSnapshot {
+	accountingStats.mu.Lock()
+	defer accountingStats.mu.Unlock()
+	return MemoryAccountingStatsSnapshot{
+		IncOperations:  accountingStats.incOperations,
+		DecOperations:  accountingStats.decOperations,
+		MoveOperations: accountingStats.moveOperations,
+		TotalIncBytes:  accountingStats.totalIncBytes,
+		TotalDecBytes:  accountingStats.totalDecBytes,
+		LargestInc:     accountingStats.largestInc,
+		LargestDec:     accountingStats.largestDec,
+		Errors:         accountingStats.errors,
+		LastErrorMsg:   accountingStats.lastErrorMsg,
+	}
+}
