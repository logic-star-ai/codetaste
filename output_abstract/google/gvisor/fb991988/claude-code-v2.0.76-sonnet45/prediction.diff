+// TestDecommitStatsTracking tests that decommit statistics are properly tracked.
+func TestDecommitStatsTracking(t *testing.T) {
+	f, err := New("filemem-test")
+	if err != nil {
+		t.Fatalf("Failed to create FileMem: %v", err)
+	}
+	defer f.Destroy()
+
+	// Allocate some memory
+	fr, err := f.Allocate(usermem.PageSize, usage.Anonymous)
+	if err != nil {
+		t.Fatalf("Allocate failed: %v", err)
+	}
+
+	// Get initial stats
+	initialStats := f.GetDecommitStats()
+
+	// Decommit the memory
+	if err := f.Decommit(fr); err != nil {
+		t.Fatalf("Decommit failed: %v", err)
+	}
+
+	// Verify stats were updated
+	newStats := f.GetDecommitStats()
+	if newStats.TotalAttempts <= initialStats.TotalAttempts {
+		t.Errorf("Expected TotalAttempts to increase, got %d -> %d",
+			initialStats.TotalAttempts, newStats.TotalAttempts)
+	}
+}
+
+// TestDirtyTracking tests that dirty page tracking works correctly.
+func TestDirtyTracking(t *testing.T) {
+	f, err := New("filemem-test")
+	if err != nil {
+		t.Fatalf("Failed to create FileMem: %v", err)
+	}
+	defer f.Destroy()
+
+	// Allocate memory - should mark as dirty
+	fr, err := f.Allocate(chunkSize, usage.Anonymous)
+	if err != nil {
+		t.Fatalf("Allocate failed: %v", err)
+	}
+
+	f.mu.Lock()
+	chunk := fr.Start >> chunkShift
+	if !f.usageDirty[chunk] {
+		t.Errorf("Expected chunk %d to be marked dirty after allocation", chunk)
+	}
+	f.mu.Unlock()
+
+	// Decommit - should still be marked dirty
+	if err := f.Decommit(fr); err != nil {
+		t.Fatalf("Decommit failed: %v", err)
+	}
+
+	f.mu.Lock()
+	if !f.usageDirty[chunk] {
+		t.Errorf("Expected chunk %d to remain dirty after decommit", chunk)
+	}
+	f.mu.Unlock()
+}
+
+// TestMarkDirtyRange tests the markDirtyRange function.
+func TestMarkDirtyRange(t *testing.T) {
+	f, err := New("filemem-test")
+	if err != nil {
+		t.Fatalf("Failed to create FileMem: %v", err)
+	}
+	defer f.Destroy()
+
+	tests := []struct {
+		name      string
+		fr        platform.FileRange
+		wantChunks []uint64
+	}{
+		{
+			name: "Single chunk",
+			fr:   platform.FileRange{Start: 0, End: usermem.PageSize},
+			wantChunks: []uint64{0},
+		},
+		{
+			name: "Multiple chunks",
+			fr:   platform.FileRange{Start: 0, End: 2 * chunkSize},
+			wantChunks: []uint64{0, 1},
+		},
+		{
+			name: "Partial chunks",
+			fr:   platform.FileRange{Start: chunkSize - usermem.PageSize, End: chunkSize + usermem.PageSize},
+			wantChunks: []uint64{0, 1},
+		},
+	}
+
+	for _, tt := range tests {
+		t.Run(tt.name, func(t *testing.T) {
+			f.mu.Lock()
+			f.usageDirty = make(map[uint64]bool)
+			f.markDirtyRange(tt.fr)
+
+			for _, chunk := range tt.wantChunks {
+				if !f.usageDirty[chunk] {
+					t.Errorf("Expected chunk %d to be marked dirty", chunk)
+				}
+			}
+
+			if len(f.usageDirty) != len(tt.wantChunks) {
+				t.Errorf("Expected %d dirty chunks, got %d", len(tt.wantChunks), len(f.usageDirty))
+			}
+			f.mu.Unlock()
+		})
+	}
+}
+
+// TestClearDirtyRange tests the clearDirtyRange function.
+func TestClearDirtyRange(t *testing.T) {
+	f, err := New("filemem-test")
+	if err != nil {
+		t.Fatalf("Failed to create FileMem: %v", err)
+	}
+	defer f.Destroy()
+
+	fr := platform.FileRange{Start: 0, End: 2 * chunkSize}
+
+	f.mu.Lock()
+	f.usageDirty = make(map[uint64]bool)
+	f.markDirtyRange(fr)
+
+	if len(f.usageDirty) != 2 {
+		t.Fatalf("Expected 2 dirty chunks, got %d", len(f.usageDirty))
+	}
+
+	f.clearDirtyRange(fr)
+
+	if len(f.usageDirty) != 0 {
+		t.Errorf("Expected all dirty chunks to be cleared, got %d remaining", len(f.usageDirty))
+	}
+	f.mu.Unlock()
+}
+
+// TestDecommitBackoff tests that exponential backoff works on repeated failures.
+func TestDecommitBackoff(t *testing.T) {
+	// This test is more of a smoke test since we can't easily force decommit failures
+	// Just verify the code compiles and the basic flow works
+	f, err := New("filemem-test")
+	if err != nil {
+		t.Fatalf("Failed to create FileMem: %v", err)
+	}
+	defer f.Destroy()
+
+	// Allocate and free memory to trigger reclaim path
+	fr, err := f.Allocate(usermem.PageSize, usage.Anonymous)
+	if err != nil {
+		t.Fatalf("Allocate failed: %v", err)
+	}
+
+	f.DecRef(fr)
+
+	// Give reclaimer a chance to run
+	// In a real scenario, we'd wait for reclaim, but for testing we just verify no panic
+}
+
+// BenchmarkDirtyTracking benchmarks the overhead of dirty tracking.
+func BenchmarkDirtyTracking(b *testing.B) {
+	f, err := New("filemem-bench")
+	if err != nil {
+		b.Fatalf("Failed to create FileMem: %v", err)
+	}
+	defer f.Destroy()
+
+	fr := platform.FileRange{Start: 0, End: chunkSize}
+
+	b.ResetTimer()
+	for i := 0; i < b.N; i++ {
+		f.mu.Lock()
+		f.markDirtyRange(fr)
+		f.clearDirtyRange(fr)
+		f.mu.Unlock()
+	}
+}
