+// TestPageTablesMemoryKind tests that the PageTables memory kind is properly defined.
+func TestPageTablesMemoryKind(t *testing.T) {
+	// Verify PageTables is a valid memory kind
+	m := &MemoryLocked{
+		RTMemoryStats: &RTMemoryStats{},
+	}
+
+	// Test Inc/Dec for PageTables
+	m.Inc(4096, PageTables)
+	if m.PageTables != 4096 {
+		t.Errorf("Expected PageTables to be 4096, got %d", m.PageTables)
+	}
+
+	m.Dec(2048, PageTables)
+	if m.PageTables != 2048 {
+		t.Errorf("Expected PageTables to be 2048 after Dec, got %d", m.PageTables)
+	}
+
+	// Test Move involving PageTables
+	m.Inc(1024, Anonymous)
+	m.Move(512, PageTables, Anonymous)
+
+	if m.PageTables != 2560 {
+		t.Errorf("Expected PageTables to be 2560 after Move, got %d", m.PageTables)
+	}
+	if m.Anonymous != 512 {
+		t.Errorf("Expected Anonymous to be 512 after Move, got %d", m.Anonymous)
+	}
+}
+
+// TestMemoryAccountingStats tests that accounting statistics are tracked.
+func TestMemoryAccountingStats(t *testing.T) {
+	// Reset stats
+	accountingStats.mu.Lock()
+	accountingStats.incOperations = 0
+	accountingStats.decOperations = 0
+	accountingStats.moveOperations = 0
+	accountingStats.totalIncBytes = 0
+	accountingStats.totalDecBytes = 0
+	accountingStats.largestInc = 0
+	accountingStats.largestDec = 0
+	accountingStats.mu.Unlock()
+
+	m := &MemoryLocked{
+		RTMemoryStats: &RTMemoryStats{},
+	}
+
+	// Test RecordInc
+	m.RecordInc(4096, Anonymous)
+	stats := GetMemoryAccountingStats()
+	if stats.IncOperations != 1 {
+		t.Errorf("Expected 1 inc operation, got %d", stats.IncOperations)
+	}
+	if stats.TotalIncBytes != 4096 {
+		t.Errorf("Expected 4096 total inc bytes, got %d", stats.TotalIncBytes)
+	}
+	if stats.LargestInc != 4096 {
+		t.Errorf("Expected largest inc to be 4096, got %d", stats.LargestInc)
+	}
+
+	// Test RecordDec
+	m.RecordDec(2048, Anonymous)
+	stats = GetMemoryAccountingStats()
+	if stats.DecOperations != 1 {
+		t.Errorf("Expected 1 dec operation, got %d", stats.DecOperations)
+	}
+	if stats.TotalDecBytes != 2048 {
+		t.Errorf("Expected 2048 total dec bytes, got %d", stats.TotalDecBytes)
+	}
+
+	// Test RecordMove
+	m.RecordInc(1024, PageCache)
+	m.RecordMove(512, Tmpfs, PageCache)
+	stats = GetMemoryAccountingStats()
+	if stats.MoveOperations != 1 {
+		t.Errorf("Expected 1 move operation, got %d", stats.MoveOperations)
+	}
+}
