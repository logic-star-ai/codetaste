+package org.apache.shenyu.infra.consul.config;
+
+import java.util.Objects;
+
+public class ConsulConfig {
+
+    private String host;
+
+    private int port;
+
+    private String token;
+
+    private int waitTime;
+
+    private int watchDelay;
+
+    /**
+     * get host.
+     *
+     * @return host
+     */
+    public String getHost() {
+        return host;
+    }
+
+    /**
+     * set host.
+     *
+     * @param host host
+     */
+    public void setHost(final String host) {
+        this.host = host;
+    }
+
+    /**
+     * get port.
+     *
+     * @return port
+     */
+    public int getPort() {
+        return port;
+    }
+
+    /**
+     * set port.
+     *
+     * @param port port
+     */
+    public void setPort(final int port) {
+        this.port = port;
+    }
+
+    /**
+     * get token.
+     *
+     * @return token
+     */
+    public String getToken() {
+        return token;
+    }
+
+    /**
+     * set token.
+     *
+     * @param token token
+     */
+    public void setToken(final String token) {
+        this.token = token;
+    }
+
+    /**
+     * get waitTime.
+     *
+     * @return waitTime
+     */
+    public int getWaitTime() {
+        return waitTime;
+    }
+
+    /**
+     * set waitTime.
+     *
+     * @param waitTime waitTime
+     */
+    public void setWaitTime(final int waitTime) {
+        this.waitTime = waitTime;
+    }
+
+    /**
+     * get watchDelay.
+     *
+     * @return watchDelay
+     */
+    public int getWatchDelay() {
+        return watchDelay;
+    }
+
+    /**
+     * set watchDelay.
+     *
+     * @param watchDelay watchDelay
+     */
+    public void setWatchDelay(final int watchDelay) {
+        this.watchDelay = watchDelay;
+    }
+
+    @Override
+    public boolean equals(final Object o) {
+        if (this == o) {
+            return true;
+        }
+        if (Objects.isNull(o) || getClass() != o.getClass()) {
+            return false;
+        }
+        ConsulConfig that = (ConsulConfig) o;
+        return port == that.port
+                && waitTime == that.waitTime
+                && watchDelay == that.watchDelay
+                && Objects.equals(host, that.host)
+                && Objects.equals(token, that.token);
+    }
+
+    @Override
+    public int hashCode() {
+        return Objects.hash(host, port, token, waitTime, watchDelay);
+    }
+
+    @Override
+    public String toString() {
+        return "ConsulConfig{"
+                + "host='"
+                + host
+                + '\''
+                + ", port="
+                + port
+                + ", token='"
+                + token
+                + '\''
+                + ", waitTime="
+                + waitTime
+                + ", watchDelay="
+                + watchDelay
+                + '}';
+    }
+}
