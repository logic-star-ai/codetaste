-        for (Map.Entry<K, V> entry : from.entrySet()) {
-            K newKey = entry.getKey() == null ? null : keySerializer.copy(entry.getKey());
-            V newValue = entry.getValue() == null ? null : valueSerializer.copy(entry.getValue());
-
-            newMap.put(newKey, newValue);
-        }
