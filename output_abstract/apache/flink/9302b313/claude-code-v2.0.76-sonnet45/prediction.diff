-    /** Builder for creating a {@link TableSchema}. */
-    @PublicEvolving
-    public static class Builder {
-
-        private List<TableColumn> columns;
-
-        private final List<WatermarkSpec> watermarkSpecs;
-
-        private UniqueConstraint primaryKey;
