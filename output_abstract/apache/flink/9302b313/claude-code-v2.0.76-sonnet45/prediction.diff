-
-            nextToken(TokenType.LITERAL);
-            final String className = token().literal;
-
-            nextToken(TokenType.END);
-
-            final Class<?> clazz = EncodingUtils.loadClass(className);
-            return Types.POJO(clazz);
-        }
-
-        private TypeInformation<?> convertMap() {
