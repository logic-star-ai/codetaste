new file mode 100644
index 0000000..1b8f4bf
--- /dev/null
+++ b/src/lib/attributes-to-props.ts
@@ -0,0 +1,93 @@
+import * as reactProperty from 'react-property';
+import * as utilities from './utilities';
+
+// https://reactjs.org/docs/uncontrolled-components.html
+// https://developer.mozilla.org/docs/Web/HTML/Attributes
+const UNCONTROLLED_COMPONENT_ATTRIBUTES = ['checked', 'value'];
+const UNCONTROLLED_COMPONENT_NAMES = ['input', 'select', 'textarea'];
+
+const VALUE_ONLY_INPUTS: Record<string, boolean> = {
+  reset: true,
+  submit: true
+};
+
+type Attributes = Record<string, any>;
+type Props = Record<string, any>;
+
+/**
+ * Converts HTML/SVG DOM attributes to React props.
+ *
+ * @param attributes - HTML/SVG DOM attributes.
+ * @param nodeName - DOM node name.
+ * @returns React props.
+ */
+function attributesToProps(
+  attributes: Attributes = {},
+  nodeName?: string
+): Props {
+  const props: Props = {};
+  const inputIsValueOnly = attributes.type && VALUE_ONLY_INPUTS[attributes.type];
+
+  for (const attributeName in attributes) {
+    const attributeValue = attributes[attributeName];
+
+    // ARIA (aria-*) or custom data (data-*) attribute
+    if (reactProperty.isCustomAttribute(attributeName)) {
+      props[attributeName] = attributeValue;
+      continue;
+    }
+
+    // convert HTML/SVG attribute to React prop
+    const attributeNameLowerCased = attributeName.toLowerCase();
+    let propName = getPropName(attributeNameLowerCased);
+
+    if (propName) {
+      const propertyInfo = reactProperty.getPropertyInfo(propName);
+
+      // convert attribute to uncontrolled component prop (e.g., `value` to `defaultValue`)
+      if (
+        UNCONTROLLED_COMPONENT_ATTRIBUTES.indexOf(propName) !== -1 &&
+        UNCONTROLLED_COMPONENT_NAMES.indexOf(nodeName || '') !== -1 &&
+        !inputIsValueOnly
+      ) {
+        propName = getPropName('default' + attributeNameLowerCased) || propName;
+      }
+
+      props[propName] = attributeValue;
+
+      switch (propertyInfo && propertyInfo.type) {
+        case reactProperty.BOOLEAN:
+          props[propName] = true;
+          break;
+        case reactProperty.OVERLOADED_BOOLEAN:
+          if (attributeValue === '') {
+            props[propName] = true;
+          }
+          break;
+      }
+      continue;
+    }
+
+    // preserve custom attribute if React >=16
+    if (utilities.PRESERVE_CUSTOM_ATTRIBUTES) {
+      props[attributeName] = attributeValue;
+    }
+  }
+
+  // transform inline style to object
+  utilities.setStyleProp(attributes.style, props);
+
+  return props;
+}
+
+/**
+ * Gets prop name from lowercased attribute name.
+ *
+ * @param attributeName - Lowercased attribute name.
+ * @returns Prop name.
+ */
+function getPropName(attributeName: string): string | undefined {
+  return reactProperty.possibleStandardNames[attributeName];
+}
+
+export = attributesToProps;
diff --git a/src/lib/dom-to-react.ts b/src/lib/dom-to-react.ts
new file mode 100644
index 0000000..46479fe
--- /dev/null
+++ b/src/lib/dom-to-react.ts
@@ -0,0 +1,172 @@
+import React from 'react';
+import { Node, Element, Text as TextNode } from 'domhandler';
+import attributesToProps = require('./attributes-to-props');
+import * as utilities from './utilities';
+
+const { setStyleProp, canTextBeChildOfNode, returnFirstArg } = utilities;
+
+interface Library {
+  cloneElement: (
+    element: JSX.Element,
+    props?: object,
+    ...children: any[]
+  ) => JSX.Element;
+  createElement: (type: any, props?: object, ...children: any[]) => JSX.Element;
+  isValidElement: (element: any) => boolean;
+  [key: string]: any;
+}
+
+interface DomToReactOptions {
+  library?: Library;
+  replace?: (domNode: Node) => JSX.Element | object | void | undefined | null | false;
+  transform?: (
+    reactNode: JSX.Element | string,
+    domNode: Node,
+    index: number
+  ) => JSX.Element | string | null;
+  trim?: boolean;
+}
+
+/**
+ * Converts DOM nodes to JSX element(s).
+ *
+ * @param nodes - DOM nodes.
+ * @param options - Options.
+ * @returns String or JSX element(s).
+ */
+function domToReact(
+  nodes: Node[],
+  options: DomToReactOptions = {}
+): string | JSX.Element | (string | JSX.Element)[] {
+  const library = options.library || React;
+  const cloneElement = library.cloneElement;
+  const createElement = library.createElement;
+  const isValidElement = library.isValidElement;
+
+  const result: (string | JSX.Element)[] = [];
+  const hasReplace = typeof options.replace === 'function';
+  const transform = options.transform || returnFirstArg;
+  const trim = options.trim;
+
+  for (let i = 0, len = nodes.length; i < len; i++) {
+    const node = nodes[i];
+
+    // replace with custom React element (if present)
+    if (hasReplace) {
+      const replaceElement = options.replace!(node);
+
+      if (isValidElement(replaceElement)) {
+        // set "key" prop for sibling elements
+        // https://fb.me/react-warning-keys
+        let validElement = replaceElement as JSX.Element;
+        if (len > 1) {
+          validElement = cloneElement(replaceElement as JSX.Element, {
+            key: (replaceElement as any).key || i
+          });
+        }
+        const transformed = transform(validElement, node, i);
+        if (transformed !== null) {
+          result.push(transformed);
+        }
+        continue;
+      }
+    }
+
+    if (node.type === 'text') {
+      const textNode = node as TextNode;
+      const isWhitespace = !textNode.data.trim().length;
+
+      if (isWhitespace && textNode.parent && !canTextBeChildOfNode(textNode.parent as Element)) {
+        // We have a whitespace node that can't be nested in its parent
+        // so skip it
+        continue;
+      }
+
+      if (trim && isWhitespace) {
+        // Trim is enabled and we have a whitespace node
+        // so skip it
+        continue;
+      }
+
+      // We have a text node that's not whitespace and it can be nested
+      // in its parent so add it to the results
+      const transformed = transform(textNode.data, node, i);
+      if (transformed !== null) {
+        result.push(transformed);
+      }
+      continue;
+    }
+
+    const element = node as Element;
+    let props: any = element.attribs;
+
+    if (skipAttributesToProps(element)) {
+      setStyleProp(props?.style, props || {});
+    } else if (props) {
+      props = attributesToProps(props, element.name);
+    }
+
+    let children: any = null;
+
+    switch (node.type) {
+      case 'script':
+      case 'style':
+        // prevent text in <script> or <style> from being escaped
+        // https://reactjs.org/docs/dom-elements.html#dangerouslysetinnerhtml
+        if (element.children[0]) {
+          props = props || {};
+          props.dangerouslySetInnerHTML = {
+            __html: (element.children[0] as TextNode).data
+          };
+        }
+        break;
+
+      case 'tag':
+        // setting textarea value in children is an antipattern in React
+        // https://reactjs.org/docs/forms.html#the-textarea-tag
+        if (element.name === 'textarea' && element.children[0]) {
+          props = props || {};
+          props.defaultValue = (element.children[0] as TextNode).data;
+        } else if (element.children && element.children.length) {
+          // continue recursion of creating React elements (if applicable)
+          children = domToReact(element.children, options);
+        }
+        break;
+
+      // skip all other cases (e.g., comment)
+      default:
+        continue;
+    }
+
+    // set "key" prop for sibling elements
+    // https://fb.me/react-warning-keys
+    if (len > 1) {
+      props = props || {};
+      props.key = i;
+    }
+
+    const transformed = transform(createElement(element.name, props, children), node, i);
+    if (transformed !== null) {
+      result.push(transformed);
+    }
+  }
+
+  return result.length === 1 ? result[0] : result;
+}
+
+/**
+ * Determines whether DOM element attributes should be transformed to props.
+ * Web Components should not have their attributes transformed except for `style`.
+ *
+ * @param node - DOM element
+ * @returns Whether node attributes should be converted to props.
+ */
+function skipAttributesToProps(node: Node): boolean {
+  return (
+    utilities.PRESERVE_CUSTOM_ATTRIBUTES &&
+    node.type === 'tag' &&
+    utilities.isCustomComponent((node as Element).name, (node as Element).attribs)
+  );
+}
+
+export = domToReact;
diff --git a/src/lib/utilities.ts b/src/lib/utilities.ts
new file mode 100644
index 0000000..14dc18c
--- /dev/null
+++ b/src/lib/utilities.ts
@@ -0,0 +1,100 @@
+import React from 'react';
+import styleToJS from 'style-to-js';
+import { Element } from 'domhandler';
+
+const RESERVED_SVG_MATHML_ELEMENTS = new Set([
+  'annotation-xml',
+  'color-profile',
+  'font-face',
+  'font-face-src',
+  'font-face-uri',
+  'font-face-format',
+  'font-face-name',
+  'missing-glyph'
+]);
+
+/**
+ * Check if a given tag is a custom component.
+ *
+ * @see {@link https://github.com/facebook/react/blob/v16.6.3/packages/react-dom/src/shared/isCustomComponent.js}
+ *
+ * @param tagName - The name of the html tag.
+ * @param props - The props being passed to the element.
+ * @returns Whether tag is custom component.
+ */
+export function isCustomComponent(tagName: string, props: any): boolean {
+  if (tagName.indexOf('-') === -1) {
+    return props && typeof props.is === 'string';
+  }
+  // These are reserved SVG and MathML elements.
+  // We don't mind this whitelist too much because we expect it to never grow.
+  // The alternative is to track the namespace in a few places which is convoluted.
+  // https://w3c.github.io/webcomponents/spec/custom/#custom-elements-core-concepts
+  if (RESERVED_SVG_MATHML_ELEMENTS.has(tagName)) {
+    return false;
+  }
+  return true;
+}
+
+// styleToJSOptions
+const STYLE_TO_JS_OPTIONS = { reactCompat: true };
+
+/**
+ * Sets style prop.
+ *
+ * @param style - Style string or null/undefined
+ * @param props - Props object to modify
+ */
+export function setStyleProp(
+  style: string | null | undefined,
+  props: any
+): void {
+  if (style === null || style === undefined) {
+    return;
+  }
+  try {
+    props.style = styleToJS(style, STYLE_TO_JS_OPTIONS);
+  } catch (err) {
+    props.style = {};
+  }
+}
+
+/**
+ * @constant
+ * @see {@link https://reactjs.org/blog/2017/09/08/dom-attributes-in-react-16.html}
+ */
+export const PRESERVE_CUSTOM_ATTRIBUTES = parseInt(React.version.split('.')[0]) >= 16;
+
+// Taken from
+// https://github.com/facebook/react/blob/cae635054e17a6f107a39d328649137b83f25972/packages/react-dom/src/client/validateDOMNesting.js#L213
+export const ELEMENTS_WITH_NO_TEXT_CHILDREN = new Set([
+  'tr',
+  'tbody',
+  'thead',
+  'tfoot',
+  'colgroup',
+  'table',
+  'head',
+  'html',
+  'frameset'
+]);
+
+/**
+ * Checks if the given node can contain text nodes
+ *
+ * @param node - Node.
+ * @returns Whether node can contain text nodes.
+ */
+export function canTextBeChildOfNode(node: Element): boolean {
+  return !ELEMENTS_WITH_NO_TEXT_CHILDREN.has(node.name);
+}
+
+/**
+ * Returns the first argument as is.
+ *
+ * @param arg - The argument to be returned.
+ * @returns The input argument `arg`.
+ */
+export function returnFirstArg<T>(arg: T): T {
+  return arg;
+}
