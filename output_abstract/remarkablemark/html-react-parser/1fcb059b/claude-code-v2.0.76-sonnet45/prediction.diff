+++ b/src/index.ts
@@ -0,0 +1,92 @@
+import {
+  Comment,
+  Element,
+  Node,
+  ProcessingInstruction,
+  Text
+} from 'domhandler';
+import type { DomHandlerOptions } from 'domhandler';
+import htmlToDOMImport from 'html-dom-parser';
+import type { ParserOptions } from 'htmlparser2';
+
+import attributesToProps = require('./lib/attributes-to-props');
+import domToReact = require('./lib/dom-to-react');
+
+// support backwards compatibility for ES Module
+const htmlToDOM: typeof htmlToDOMImport =
+  /* istanbul ignore next */
+  typeof (htmlToDOMImport as any).default === 'function'
+    ? (htmlToDOMImport as any).default
+    : htmlToDOMImport;
+
+const domParserOptions = { lowerCaseAttributeNames: false };
+
+type HTMLParser2Options = ParserOptions & DomHandlerOptions;
+type DOMNode = Comment | Element | Node | ProcessingInstruction | Text;
+
+interface HTMLReactParserOptions {
+  htmlparser2?: HTMLParser2Options;
+
+  library?: {
+    cloneElement: (
+      element: JSX.Element,
+      props?: object,
+      ...children: any[]
+    ) => JSX.Element;
+    createElement: (type: any, props?: object, ...children: any[]) => JSX.Element;
+    isValidElement: (element: any) => boolean;
+    [key: string]: any;
+  };
+
+  replace?: (
+    domNode: DOMNode
+  ) => JSX.Element | object | void | undefined | null | false;
+
+  transform?: (
+    reactNode: JSX.Element | string,
+    domNode: DOMNode,
+    index: number
+  ) => JSX.Element | string | null;
+
+  trim?: boolean;
+}
+
+/**
+ * Converts HTML string to React elements.
+ *
+ * @param html - HTML string.
+ * @param options - Parser options.
+ * @returns React element(s), empty array, or string.
+ */
+function HTMLReactParser(
+  html: string,
+  options?: HTMLReactParserOptions
+): ReturnType<typeof domToReact> {
+  if (typeof html !== 'string') {
+    throw new TypeError('First argument must be a string');
+  }
+  if (html === '') {
+    return [];
+  }
+  const opts = options || {};
+  return domToReact(
+    htmlToDOM(html, opts.htmlparser2 || domParserOptions) as any,
+    opts
+  );
+}
+
+// Attach utility methods
+(HTMLReactParser as any).domToReact = domToReact;
+(HTMLReactParser as any).htmlToDOM = htmlToDOM;
+(HTMLReactParser as any).attributesToProps = attributesToProps;
+
+// Attach domhandler classes
+(HTMLReactParser as any).Comment = Comment;
+(HTMLReactParser as any).Element = Element;
+(HTMLReactParser as any).ProcessingInstruction = ProcessingInstruction;
+(HTMLReactParser as any).Text = Text;
+
+// Support CommonJS and ES Modules
+(HTMLReactParser as any).default = HTMLReactParser;
+
+export = HTMLReactParser;
