+import fs from 'node:fs/promises';
+import path from 'node:path';
+import { fileURLToPath } from 'node:url';
+import prettier from 'prettier';
+
+const rootDir = new URL('..', import.meta.url);
+
+async function copyFile(fromUrl, toUrl) {
+  const fromPath = fileURLToPath(fromUrl);
+  const toPath = fileURLToPath(toUrl);
+  await fs.mkdir(path.dirname(toPath), { recursive: true });
+  await fs.copyFile(fromPath, toPath);
+}
+
+async function formatFile(fileUrl) {
+  const filePath = fileURLToPath(fileUrl);
+  const input = await fs.readFile(filePath, 'utf8');
+  const config = (await prettier.resolveConfig(filePath)) ?? {};
+  const output = await prettier.format(input, { ...config, filepath: filePath });
+  if (output !== input) {
+    await fs.writeFile(filePath, output);
+  }
+}
+
+const libTypesDir = new URL('./dist/types/lib/', rootDir);
+const libEntries = await fs.readdir(libTypesDir);
+
+const distTypesIndex = new URL('./dist/types/index.d.ts', rootDir);
+const distLibTypeFiles = libEntries
+  .filter((name) => name.endsWith('.d.ts'))
+  .map((name) => new URL(`./dist/types/lib/${name}`, rootDir));
+
+await Promise.all([formatFile(distTypesIndex), ...distLibTypeFiles.map(formatFile)]);
+
+await copyFile(distTypesIndex, new URL('./index.d.ts', rootDir));
+
+await Promise.all(
+  distLibTypeFiles.map((fileUrl) =>
+    copyFile(fileUrl, new URL(`./lib/${path.basename(fileURLToPath(fileUrl))}`, rootDir))
+  )
+);
