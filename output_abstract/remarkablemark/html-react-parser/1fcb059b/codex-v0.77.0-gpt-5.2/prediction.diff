--- /dev/null
+++ b/src/index.ts
@@ -0,0 +1,106 @@
+import {
+  Comment,
+  Element,
+  type DomHandlerOptions,
+  type Node,
+  ProcessingInstruction,
+  Text
+} from 'domhandler';
+import htmlToDOMImport from 'html-dom-parser';
+import type { ParserOptions } from 'htmlparser2';
+
+import attributesToProps from './lib/attributes-to-props';
+import domToReact from './lib/dom-to-react';
+
+export type HTMLParser2Options = ParserOptions & DomHandlerOptions;
+export type DOMNode = Comment | Element | Node | ProcessingInstruction | Text;
+
+export interface HTMLReactParserOptions {
+  htmlparser2?: HTMLParser2Options;
+
+  library?: {
+    cloneElement: (
+      element: JSX.Element,
+      props?: object,
+      ...children: any
+    ) => JSX.Element;
+    createElement: (type: any, props?: object, ...children: any) => JSX.Element;
+    isValidElement: (element: any) => boolean;
+    [key: string]: any;
+  };
+
+  replace?: (
+    domNode: DOMNode
+  ) => JSX.Element | object | void | undefined | null | false;
+
+  transform?: (
+    reactNode: JSX.Element | string,
+    domNode: DOMNode,
+    index: number
+  ) => JSX.Element | string | null;
+
+  trim?: boolean;
+}
+
+type HTMLToDOM = (html: string, options?: unknown) => DOMNode[];
+
+const htmlToDOM = (
+  typeof (htmlToDOMImport as unknown as { default?: unknown }).default ===
+  'function'
+    ? (htmlToDOMImport as unknown as { default: HTMLToDOM }).default
+    : (htmlToDOMImport as unknown as HTMLToDOM)
+) satisfies HTMLToDOM;
+
+const domParserOptions = { lowerCaseAttributeNames: false } as const;
+
+export interface HTMLReactParser {
+  (
+    html: string,
+    options?: HTMLReactParserOptions
+  ): ReturnType<typeof domToReact>;
+  domToReact: typeof domToReact;
+  htmlToDOM: typeof htmlToDOM;
+  attributesToProps: typeof attributesToProps;
+  Comment: typeof Comment;
+  Element: typeof Element;
+  ProcessingInstruction: typeof ProcessingInstruction;
+  Text: typeof Text;
+  default: HTMLReactParser;
+}
+
+/**
+ * Converts HTML string to React elements.
+ */
+const HTMLReactParser = ((
+  html: string,
+  options?: HTMLReactParserOptions
+): ReturnType<typeof domToReact> => {
+  if (typeof html !== 'string') {
+    throw new TypeError('First argument must be a string');
+  }
+  if (html === '') {
+    return [];
+  }
+  const resolvedOptions = options ?? {};
+  return domToReact(
+    htmlToDOM(html, resolvedOptions.htmlparser2 ?? domParserOptions),
+    resolvedOptions
+  );
+}) as HTMLReactParser;
+
+HTMLReactParser.domToReact = domToReact;
+HTMLReactParser.htmlToDOM = htmlToDOM;
+HTMLReactParser.attributesToProps = attributesToProps;
+
+// domhandler
+HTMLReactParser.Comment = Comment;
+HTMLReactParser.Element = Element;
+HTMLReactParser.ProcessingInstruction = ProcessingInstruction;
+HTMLReactParser.Text = Text;
+
+HTMLReactParser.default = HTMLReactParser;
+
+export { attributesToProps, domToReact, htmlToDOM };
+export { Comment, Element, ProcessingInstruction, Text };
+
+export default HTMLReactParser;
diff --git a/src/lib/attributes-to-props.ts b/src/lib/attributes-to-props.ts
new file mode 100644
index 0000000..a5b7169
--- /dev/null
+++ b/src/lib/attributes-to-props.ts
@@ -0,0 +1,101 @@
+import * as reactProperty from 'react-property';
+
+import { PRESERVE_CUSTOM_ATTRIBUTES, setStyleProp } from './utilities';
+
+export type Attributes = Record<string, string>;
+export type Props = Record<string, unknown> & {
+  style?: Record<string, string | number>;
+};
+
+const UNCONTROLLED_COMPONENT_ATTRIBUTES = ['checked', 'value'] as const;
+const UNCONTROLLED_COMPONENT_NAMES = ['input', 'select', 'textarea'] as const;
+
+const VALUE_ONLY_INPUTS: Record<string, true> = {
+  reset: true,
+  submit: true
+};
+
+/**
+ * Converts HTML/SVG DOM attributes to React props.
+ */
+export default function attributesToProps(
+  attributes: Attributes = {},
+  nodeName?: string
+): Props {
+  let attributeName: string;
+  let attributeValue: string;
+  let propName: string | undefined;
+  let propertyInfo: { type?: unknown } | null | undefined;
+
+  const props: Props = {};
+
+  const inputIsValueOnly =
+    typeof attributes.type === 'string' && VALUE_ONLY_INPUTS[attributes.type];
+
+  for (attributeName in attributes) {
+    attributeValue = attributes[attributeName];
+
+    // ARIA (aria-*) or custom data (data-*) attribute
+    if (reactProperty.isCustomAttribute(attributeName)) {
+      props[attributeName] = attributeValue;
+      continue;
+    }
+
+    const attributeNameLowerCased = attributeName.toLowerCase();
+    propName = getPropName(attributeNameLowerCased);
+
+    if (propName) {
+      propertyInfo = reactProperty.getPropertyInfo(propName);
+
+      let resolvedPropName = propName;
+
+      // convert attribute to uncontrolled component prop (e.g., `value` to `defaultValue`)
+      if (
+        UNCONTROLLED_COMPONENT_ATTRIBUTES.includes(
+          propName as (typeof UNCONTROLLED_COMPONENT_ATTRIBUTES)[number]
+        ) &&
+        UNCONTROLLED_COMPONENT_NAMES.includes(
+          nodeName as (typeof UNCONTROLLED_COMPONENT_NAMES)[number]
+        ) &&
+        !inputIsValueOnly
+      ) {
+        const uncontrolledPropName = getPropName(
+          `default${attributeNameLowerCased}`
+        );
+        if (uncontrolledPropName) {
+          resolvedPropName = uncontrolledPropName;
+        }
+      }
+
+      props[resolvedPropName] = attributeValue;
+
+      switch (propertyInfo && propertyInfo.type) {
+        case reactProperty.BOOLEAN:
+          props[resolvedPropName] = true;
+          break;
+        case reactProperty.OVERLOADED_BOOLEAN:
+          if (attributeValue === '') {
+            props[resolvedPropName] = true;
+          }
+          break;
+      }
+      continue;
+    }
+
+    // preserve custom attribute if React >=16
+    if (PRESERVE_CUSTOM_ATTRIBUTES) {
+      props[attributeName] = attributeValue;
+    }
+  }
+
+  // transform inline style to object
+  setStyleProp(attributes.style, props);
+
+  return props;
+}
+
+function getPropName(attributeName: string): string | undefined {
+  return reactProperty.possibleStandardNames[
+    attributeName as keyof typeof reactProperty.possibleStandardNames
+  ];
+}
diff --git a/src/lib/dom-to-react.ts b/src/lib/dom-to-react.ts
new file mode 100644
index 0000000..f41a605
--- /dev/null
+++ b/src/lib/dom-to-react.ts
@@ -0,0 +1,158 @@
+import React from 'react';
+import type {
+  AnyNode,
+  Element as DomElement,
+  Text as DomText
+} from 'domhandler';
+
+import attributesToProps from './attributes-to-props';
+import {
+  canTextBeChildOfNode,
+  isCustomComponent,
+  PRESERVE_CUSTOM_ATTRIBUTES,
+  returnFirstArg,
+  setStyleProp
+} from './utilities';
+
+import type { DOMNode, HTMLReactParserOptions } from '../index';
+export type { DOMNode, HTMLReactParserOptions };
+
+/**
+ * Converts DOM nodes to JSX element(s).
+ */
+export default function domToReact(
+  nodes: DOMNode[],
+  options: HTMLReactParserOptions = {}
+): string | JSX.Element | JSX.Element[] {
+  const library = options.library || React;
+  const cloneElement = library.cloneElement;
+  const createElement = library.createElement;
+  const isValidElement = library.isValidElement;
+
+  const result: Array<JSX.Element | string | null> = [];
+  const hasReplace = typeof options.replace === 'function';
+  const transform = options.transform || returnFirstArg;
+  const trim = options.trim;
+
+  for (let i = 0, len = nodes.length; i < len; i++) {
+    const node = nodes[i] as unknown as AnyNode;
+
+    // replace with custom React element (if present)
+    if (hasReplace) {
+      const replaceElement = options.replace?.(node as unknown as DOMNode);
+      let reactElement = replaceElement as any;
+
+      if (isValidElement(reactElement)) {
+        // set "key" prop for sibling elements
+        // https://fb.me/react-warning-keys
+        if (len > 1) {
+          reactElement = cloneElement(reactElement, {
+            key: reactElement.key || i
+          });
+        }
+        result.push(
+          transform(reactElement, node as unknown as DOMNode, i) as
+            | JSX.Element
+            | string
+            | null
+        );
+        continue;
+      }
+    }
+
+    if (node.type === 'text') {
+      const textNode = node as DomText;
+      const isWhitespace = !textNode.data.trim().length;
+
+      if (
+        isWhitespace &&
+        textNode.parent &&
+        !canTextBeChildOfNode(textNode.parent)
+      ) {
+        continue;
+      }
+
+      if (trim && isWhitespace) {
+        continue;
+      }
+
+      result.push(
+        transform(textNode.data, node as unknown as DOMNode, i) as
+          | JSX.Element
+          | string
+          | null
+      );
+      continue;
+    }
+
+    const elementNode = node as DomElement;
+    let props: Record<string, unknown> = elementNode.attribs;
+
+    if (skipAttributesToProps(elementNode)) {
+      setStyleProp(props.style as null | undefined | string, props);
+    } else if (props) {
+      props = attributesToProps(
+        props as Record<string, string>,
+        elementNode.name
+      );
+    }
+
+    let children: string | JSX.Element | JSX.Element[] | null = null;
+
+    switch (node.type) {
+      case 'script':
+      case 'style':
+        if (
+          elementNode.children[0] &&
+          elementNode.children[0].type === 'text'
+        ) {
+          props.dangerouslySetInnerHTML = {
+            __html: (elementNode.children[0] as DomText).data
+          };
+        }
+        break;
+
+      case 'tag':
+        if (
+          elementNode.name === 'textarea' &&
+          elementNode.children[0]?.type === 'text'
+        ) {
+          props.defaultValue = (elementNode.children[0] as DomText).data;
+        } else if (elementNode.children && elementNode.children.length) {
+          children = domToReact(
+            elementNode.children as unknown as DOMNode[],
+            options
+          );
+        }
+        break;
+
+      default:
+        continue;
+    }
+
+    if (len > 1) {
+      props.key = i;
+    }
+
+    result.push(
+      transform(
+        createElement(elementNode.name, props, children),
+        node as unknown as DOMNode,
+        i
+      ) as JSX.Element | string | null
+    );
+  }
+
+  return (result.length === 1 ? result[0] : result) as unknown as
+    | string
+    | JSX.Element
+    | JSX.Element[];
+}
+
+function skipAttributesToProps(node: DomElement): boolean {
+  return (
+    PRESERVE_CUSTOM_ATTRIBUTES &&
+    node.type === 'tag' &&
+    isCustomComponent(node.name, node.attribs)
+  );
+}
diff --git a/src/lib/utilities.ts b/src/lib/utilities.ts
new file mode 100644
index 0000000..4b61d41
--- /dev/null
+++ b/src/lib/utilities.ts
@@ -0,0 +1,68 @@
+import React from 'react';
+import styleToJS from 'style-to-js';
+
+const RESERVED_SVG_MATHML_ELEMENTS = new Set([
+  'annotation-xml',
+  'color-profile',
+  'font-face',
+  'font-face-src',
+  'font-face-uri',
+  'font-face-format',
+  'font-face-name',
+  'missing-glyph'
+]);
+
+export function isCustomComponent(
+  tagName: string,
+  props: Record<string, unknown> | undefined
+): boolean {
+  if (tagName.indexOf('-') === -1) {
+    return !!(props && typeof props.is === 'string');
+  }
+  if (RESERVED_SVG_MATHML_ELEMENTS.has(tagName)) {
+    return false;
+  }
+  return true;
+}
+
+const STYLE_TO_JS_OPTIONS = { reactCompat: true } as const;
+
+export function setStyleProp(
+  style: null | undefined | string,
+  props: Record<string, unknown>
+): void {
+  if (style === null || style === undefined) {
+    return;
+  }
+  try {
+    props.style = styleToJS(style, STYLE_TO_JS_OPTIONS);
+  } catch {
+    props.style = {};
+  }
+}
+
+export const PRESERVE_CUSTOM_ATTRIBUTES =
+  Number(React.version.split('.')[0]) >= 16;
+
+export const ELEMENTS_WITH_NO_TEXT_CHILDREN = new Set([
+  'tr',
+  'tbody',
+  'thead',
+  'tfoot',
+  'colgroup',
+  'table',
+  'head',
+  'html',
+  'frameset'
+]);
+
+export function canTextBeChildOfNode(node: unknown): boolean {
+  const name = (node as { name?: unknown } | null | undefined)?.name;
+  return !ELEMENTS_WITH_NO_TEXT_CHILDREN.has(
+    typeof name === 'string' ? name : ''
+  );
+}
+
+export function returnFirstArg<T>(arg: T): T {
+  return arg;
+}
