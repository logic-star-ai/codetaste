+import utilities from './utilities';
+
+const reactProperty =
+  require('react-property') as typeof import('react-property');
+
+// https://reactjs.org/docs/uncontrolled-components.html
+// https://developer.mozilla.org/docs/Web/HTML/Attributes
+const UNCONTROLLED_COMPONENT_ATTRIBUTES = ['checked', 'value'] as const;
+const UNCONTROLLED_COMPONENT_NAMES = ['input', 'select', 'textarea'] as const;
+
+const VALUE_ONLY_INPUTS: Record<string, true> = {
+  reset: true,
+  submit: true
+};
+
+export type Attributes = Record<string, string>;
+export type Props = Record<string, string> & {
+  style: Record<string, string>;
+};
+
+/**
+ * Converts HTML/SVG DOM attributes to React props.
+ *
+ * @param attributes - HTML/SVG DOM attributes.
+ * @param nodeName - DOM node name.
+ * @returns - React props.
+ */
+function attributesToProps(attributes: Attributes, nodeName?: string): Props {
+  const safeAttributes = attributes || ({} as Attributes);
+
+  let attributeName: string;
+  let attributeNameLowerCased: string;
+  let attributeValue: string;
+  let propName: string | undefined;
+  let propertyInfo: any;
+  const props: any = {};
+  const inputIsValueOnly =
+    safeAttributes.type && VALUE_ONLY_INPUTS[safeAttributes.type];
+
+  // eslint-disable-next-line guard-for-in
+  for (attributeName in safeAttributes) {
+    attributeValue = safeAttributes[attributeName];
+
+    // ARIA (aria-*) or custom data (data-*) attribute
+    if (reactProperty.isCustomAttribute(attributeName)) {
+      props[attributeName] = attributeValue;
+      continue;
+    }
+
+    // convert HTML/SVG attribute to React prop
+    attributeNameLowerCased = attributeName.toLowerCase();
+    propName = getPropName(attributeNameLowerCased);
+
+    if (propName) {
+      let resolvedPropName: string | undefined = propName;
+      propertyInfo = reactProperty.getPropertyInfo(resolvedPropName);
+
+      // convert attribute to uncontrolled component prop (e.g., `value` to `defaultValue`)
+      if (
+        UNCONTROLLED_COMPONENT_ATTRIBUTES.includes(
+          propName as (typeof UNCONTROLLED_COMPONENT_ATTRIBUTES)[number]
+        ) &&
+        UNCONTROLLED_COMPONENT_NAMES.includes(
+          (nodeName || '') as (typeof UNCONTROLLED_COMPONENT_NAMES)[number]
+        ) &&
+        !inputIsValueOnly
+      ) {
+        resolvedPropName = getPropName('default' + attributeNameLowerCased);
+      }
+
+      if (!resolvedPropName) {
+        continue;
+      }
+
+      props[resolvedPropName] = attributeValue as any;
+
+      switch (propertyInfo && propertyInfo.type) {
+        case reactProperty.BOOLEAN:
+          props[resolvedPropName] = true as any;
+          break;
+        case reactProperty.OVERLOADED_BOOLEAN:
+          if (attributeValue === '') {
+            props[resolvedPropName] = true as any;
+          }
+          break;
+      }
+      continue;
+    }
+
+    // preserve custom attribute if React >=16
+    if (utilities.PRESERVE_CUSTOM_ATTRIBUTES) {
+      props[attributeName] = attributeValue;
+    }
+  }
+
+  // transform inline style to object
+  utilities.setStyleProp((safeAttributes as any).style, props);
+
+  return props as Props;
+}
+
+export default attributesToProps;
+
+module.exports = attributesToProps;
+(module.exports as any).default = attributesToProps;
+
+/**
+ * Gets prop name from lowercased attribute name.
+ *
+ * @param attributeName - Lowercased attribute name.
+ * @returns - Prop name.
+ */
+function getPropName(attributeName: string) {
+  return (reactProperty as any).possibleStandardNames[attributeName] as
+    | string
+    | undefined;
+}
