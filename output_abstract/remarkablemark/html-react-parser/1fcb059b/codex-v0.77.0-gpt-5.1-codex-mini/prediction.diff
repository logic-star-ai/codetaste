+  domToReact: typeof domToReact;
+  htmlToDOM: HtmlToDOM;
+  attributesToProps: typeof attributesToProps;
+  Comment: typeof domhandler.Comment;
+  Element: typeof domhandler.Element;
+  ProcessingInstruction: typeof domhandler.ProcessingInstruction;
