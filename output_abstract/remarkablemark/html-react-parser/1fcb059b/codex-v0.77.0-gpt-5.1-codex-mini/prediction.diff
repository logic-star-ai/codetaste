+import * as domhandler from 'domhandler';
+import type { DomHandlerOptions } from 'domhandler';
+import htmlToDOMImport from 'html-dom-parser';
+import type { ParserOptions } from 'htmlparser2';
+
+import attributesToProps from './lib/attributes-to-props';
+import domToReact from './lib/dom-to-react';
+
+export type HTMLParser2Options = ParserOptions & DomHandlerOptions;
+export type DOMNode =
+  | domhandler.Comment
+  | domhandler.Element
+  | domhandler.Node
+  | domhandler.ProcessingInstruction
+  | domhandler.Text;
+
+export interface HTMLReactParserOptions {
+  htmlparser2?: HTMLParser2Options;
+
+  library?: {
+    cloneElement: (
+      element: JSX.Element,
+      props?: object,
+      ...children: any[]
+    ) => JSX.Element;
+    createElement: (
+      type: any,
+      props?: object,
+      ...children: any[]
+    ) => JSX.Element;
+    isValidElement: (element: any) => boolean;
+    [key: string]: any;
+  };
+
+  replace?: (
+    domNode: DOMNode
+  ) => JSX.Element | object | void | undefined | null | false;
+
+  transform?: (
+    reactNode: JSX.Element | string,
+    domNode: DOMNode,
+    index: number
+  ) => JSX.Element | string | null;
+
+  trim?: boolean;
+}
+
+export { attributesToProps, domToReact };
+export const Comment = domhandler.Comment;
+export const Element = domhandler.Element;
+export const ProcessingInstruction = domhandler.ProcessingInstruction;
+export const Text = domhandler.Text;
+
+type HtmlToDOM = (html: string, options?: unknown) => DOMNode[];
+
+const htmlToDOM: HtmlToDOM =
+  typeof (htmlToDOMImport as any).default === 'function'
+    ? (htmlToDOMImport as any).default
+    : (htmlToDOMImport as any);
+
+export { htmlToDOM };
+
+const domParserOptions = { lowerCaseAttributeNames: false };
+
+interface HTMLReactParserExport {
+  (
+    html: string,
+    options?: HTMLReactParserOptions
