+import type { DomHandlerOptions } from 'domhandler';
+import type {
+  Comment as DomComment,
+  Element as DomElement,
+  Node as DomNode,
+  ProcessingInstruction as DomProcessingInstruction,
+  Text as DomText
+} from 'domhandler';
+import type htmlToDOMType from 'html-dom-parser';
+import type { ParserOptions } from 'htmlparser2';
+
+import attributesToProps from './lib/attributes-to-props';
+import domToReact from './lib/dom-to-react';
+
+const domhandler = require('domhandler') as typeof import('domhandler');
+const htmlToDOMModule = require('html-dom-parser') as unknown as {
+  default?: typeof htmlToDOMType;
+};
+
+const domParserOptions = { lowerCaseAttributeNames: false };
+
+const htmlToDOM =
+  /* istanbul ignore next */
+  typeof htmlToDOMModule.default === 'function'
+    ? htmlToDOMModule.default
+    : (htmlToDOMModule as unknown as typeof htmlToDOMType);
+
+export type HTMLParser2Options = ParserOptions & DomHandlerOptions;
+export type DOMNode =
+  | DomComment
+  | DomElement
+  | DomNode
+  | DomProcessingInstruction
+  | DomText;
+
+export interface HTMLReactParserOptions {
+  htmlparser2?: HTMLParser2Options;
+
+  library?: {
+    cloneElement: (
+      element: JSX.Element,
+      props?: object,
+      ...children: any
+    ) => JSX.Element;
+    createElement: (type: any, props?: object, ...children: any) => JSX.Element;
+    isValidElement: (element: any) => boolean;
+    [key: string]: any;
+  };
+
+  replace?: (
+    domNode: DOMNode
+  ) => JSX.Element | object | void | undefined | null | false;
+
+  transform?: (
+    reactNode: JSX.Element | string,
+    domNode: DOMNode,
+    index: number
+  ) => JSX.Element | string | null;
+
+  trim?: boolean;
+}
+
+/**
+ * Converts HTML string to React elements.
+ *
+ * @param html - HTML string.
+ * @param options - Parser options.
+ * @returns - React element(s), empty array, or string.
+ */
+function HTMLReactParser(
+  html: string,
+  options?: HTMLReactParserOptions
+): ReturnType<typeof domToReact> {
+  if (typeof html !== 'string') {
+    throw new TypeError('First argument must be a string');
+  }
+  if (html === '') {
+    return [];
+  }
+  const mergedOptions = options || {};
+  return domToReact(
+    htmlToDOM(
+      html,
+      (mergedOptions.htmlparser2 || domParserOptions) as HTMLParser2Options
+    ),
+    mergedOptions
+  );
+}
+
+const htmlReactParserWithStatics = HTMLReactParser as any;
+htmlReactParserWithStatics.domToReact = domToReact;
+htmlReactParserWithStatics.htmlToDOM = htmlToDOM;
+htmlReactParserWithStatics.attributesToProps = attributesToProps;
+
+// domhandler
+htmlReactParserWithStatics.Comment = domhandler.Comment;
+htmlReactParserWithStatics.Element = domhandler.Element;
+htmlReactParserWithStatics.ProcessingInstruction =
+  domhandler.ProcessingInstruction;
+htmlReactParserWithStatics.Text = domhandler.Text;
+
+export { attributesToProps, domToReact, htmlToDOM };
+export const Comment = domhandler.Comment;
+export const Element = domhandler.Element;
+export const ProcessingInstruction = domhandler.ProcessingInstruction;
+export const Text = domhandler.Text;
+
+export default HTMLReactParser;
+
+// support CommonJS and ES Modules
+module.exports = HTMLReactParser;
+(module.exports as any).default = HTMLReactParser;
