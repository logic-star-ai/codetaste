+"""
+Simplified product-attribute relationship models.
+
+This module contains a streamlined version of the attribute system that reduces
+complexity while maintaining all core functionality.
+"""
+
+from django.db import models
+
+from ...core.models import ModelWithMetadata, ModelWithExternalReference, SortableModel
+from ...product.models import Product, ProductType, ProductVariant
+from .base import Attribute, AttributeValue
+
+
+class ProductAttributeAssignment(SortableModel):
+    """
+    Simplified link between products and their assigned attributes.
+    
+    Instead of having separate models for ProductType->Attribute and 
+    Product->ProductAttributeAssignment, we directly link products to attributes
+    with values.
+    """
+    product = models.ForeignKey(
+        Product, related_name="simple_attributes", on_delete=models.CASCADE
+    )
+    attribute = models.ForeignKey(
+        Attribute, related_name="product_assignments", on_delete=models.CASCADE
+    )
+    values = models.ManyToManyField(
+        AttributeValue,
+        blank=True,
+        related_name="assigned_to_products"
+    )
+    
+    class Meta:
+        unique_together = (("product", "attribute"),)
+        ordering = ("sort_order", "pk")
+
+
+class VariantAttributeAssignment(SortableModel):
+    """
+    Simplified link between product variants and their assigned attributes.
+    """
+    variant = models.ForeignKey(
+        ProductVariant, related_name="simple_attributes", on_delete=models.CASCADE
+    )
+    attribute = models.ForeignKey(
+        Attribute, related_name="variant_assignments", on_delete=models.CASCADE
+    )
+    values = models.ManyToManyField(
+        AttributeValue,
+        blank=True,
+        related_name="assigned_to_variants"
+    )
+    
+    class Meta:
+        unique_together = (("variant", "attribute"),)
+        ordering = ("sort_order", "pk")
+
+
+class ProductTypeAttributeAssignment(SortableModel):
+    """
+    Simplified link between product types and their available attributes.
+    """
+    product_type = models.ForeignKey(
+        ProductType, related_name="simple_attributes", on_delete=models.CASCADE
+    )
+    attribute = models.ForeignKey(
+        Attribute, related_name="assigned_to_types", on_delete=models.CASCADE
+    )
+    
+    class Meta:
+        unique_together = (("product_type", "attribute"),)
+        ordering = ("sort_order", "pk")
