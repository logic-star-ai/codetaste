+"""
+Template tags and context processors to simplify attribute access in templates.
+"""
+
+from django import template
+from saleor.product.utils.attribute_simplifier import (
+    get_product_attributes_with_values,
+    get_variant_attributes_with_values
+)
+
+register = template.Library()
+
+
+@register.filter
+def product_attributes_simple(product):
+    """Get simplified attribute information for a product."""
+    return get_product_attributes_with_values(product)
+
+
+@register.filter
+def variant_attributes_simple(variant):
+    """Get simplified attribute information for a variant."""
+    return get_variant_attributes_with_values(variant)
+
+
+@register.simple_tag
+def get_attribute_values_for_product_type(product_type_id):
+    """Get attribute values for a product type."""
+    from saleor.product.utils.attribute_simplifier import get_attribute_values_for_product_type
+    return get_attribute_values_for_product_type(product_type_id)
