+"""
+Utility functions to simplify product-attribute relationships in Saleor.
+
+This module provides helper functions and managers to make working with
+product attributes more intuitive and less complex.
+"""
+
+from typing import Dict, List, Optional, Tuple, Union
+from django.db import models
+from django.db.models import Q
+from saleor.attribute.models import Attribute, AttributeValue
+from saleor.product.models import Product, ProductVariant
+
+
+def get_product_attributes_with_values(product: Product) -> List[Dict]:
+    """
+    Get all attributes with their values for a given product in a simplified format.
+    
+    Returns:
+        List of dictionaries containing attribute information with values
+    """
+    # Get all attribute assignments for this product
+    assignments = product.attributes.select_related('assignment__attribute').prefetch_related(
+        'values__attribute'
+    )
+    
+    result = []
+    for assignment in assignments:
+        attribute = assignment.assignment.attribute
+        values = list(assignment.values.all())
+        
+        result.append({
+            'attribute': attribute,
+            'values': values,
+            'attribute_name': attribute.name,
+            'values_names': [v.name for v in values]
+        })
+    
+    return result
+
+
+def get_variant_attributes_with_values(variant: ProductVariant) -> List[Dict]:
+    """
+    Get all attributes with their values for a given product variant in a simplified format.
+    
+    Returns:
+        List of dictionaries containing attribute information with values
+    """
+    # Get all attribute assignments for this variant
+    assignments = variant.attributes.select_related('assignment__attribute').prefetch_related(
+        'values__attribute'
+    )
+    
+    result = []
+    for assignment in assignments:
+        attribute = assignment.assignment.attribute
+        values = list(assignment.values.all())
+        
+        result.append({
+            'attribute': attribute,
+            'values': values,
+            'attribute_name': attribute.name,
+            'values_names': [v.name for v in values]
+        })
+    
+    return result
+
+
+def get_products_with_attribute_filter(
+    queryset: models.QuerySet,
+    attribute_id: int,
+    value_ids: List[int]
+) -> models.QuerySet:
+    """
+    Filter products by attribute values in a simplified way.
+    
+    Args:
+        queryset: Base product queryset
+        attribute_id: ID of the attribute to filter by
+        value_ids: List of attribute value IDs to match
+        
+    Returns:
+        Filtered queryset
+    """
+    # This approach avoids complex joins by using a more straightforward filter
+    return queryset.filter(
+        attributes__assignment__attribute_id=attribute_id,
+        attributes__values__in=value_ids
+    ).distinct()
+
+
+def get_attribute_values_for_product_type(
+    product_type_id: int
+) -> Dict[int, List[AttributeValue]]:
+    """
+    Get all attribute values for a product type in a simplified dictionary format.
+    
+    Returns:
+        Dictionary mapping attribute IDs to lists of attribute values
+    """
+    from saleor.attribute.models import AttributeProduct
+    
+    # Get all attributes assigned to this product type
+    assigned_attrs = AttributeProduct.objects.filter(
+        product_type_id=product_type_id
+    ).select_related('attribute')
+    
+    result = {}
+    for assigned_attr in assigned_attrs:
+        attr_id = assigned_attr.attribute_id
+        values = list(assigned_attr.attribute.values.all())
+        result[attr_id] = values
+    
+    return result
+
+
+def get_product_attribute_summary(product: Product) -> Dict[str, Union[str, List]]:
+    """
+    Get a simplified summary of a product's attributes.
+    
+    Returns:
+        Dictionary with product attribute summary
+    """
+    attributes_info = get_product_attributes_with_values(product)
+    
+    summary = {
+        'product_id': product.id,
+        'product_name': product.name,
+        'attributes': []
+    }
+    
+    for attr_info in attributes_info:
+        summary['attributes'].append({
+            'name': attr_info['attribute_name'],
+            'values': attr_info['values_names']
+        })
+    
+    return summary
+
+
+# Manager extension for Product model
+class SimplifiedProductManager(models.Manager):
+    """
+    Enhanced product manager with simplified attribute methods.
+    """
+    
+    def with_attribute_summary(self, *args, **kwargs):
+        """
+        Annotate products with a simplified attribute summary.
+        """
+        # This would be implemented in a more advanced version
+        pass
+    
+    def filter_by_attributes(self, attribute_filters: Dict[int, List[int]]):
+        """
+        Filter products by attribute filters.
+        
+        Args:
+            attribute_filters: Dictionary mapping attribute IDs to value IDs to filter by
+        """
+        queryset = self.get_queryset()
+        for attr_id, value_ids in attribute_filters.items():
+            queryset = queryset.filter(
+                attributes__assignment__attribute_id=attr_id,
+                attributes__values__in=value_ids
+            ).distinct()
+        return queryset
