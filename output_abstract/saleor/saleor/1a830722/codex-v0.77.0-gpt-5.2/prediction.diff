+
+    search_vectors: list[NoValidationSearchVector] = []
+    attribute_id_to_values_map: dict[int, list] = {}
+    attribute_id_to_attribute_map: dict[int, object] = {}
+    attribute_order: list[int] = []
+    for value_assignment in assigned_values:
+        attribute = value_assignment.value.attribute
+        attribute_id = attribute.pk
+        if attribute_id not in attribute_id_to_values_map:
+            attribute_id_to_values_map[attribute_id] = []
+            attribute_id_to_attribute_map[attribute_id] = attribute
+            attribute_order.append(attribute_id)
+        attribute_id_to_values_map[attribute_id].append(value_assignment.value)
+
+    for attribute_id in attribute_order[: settings.PRODUCT_MAX_INDEXED_ATTRIBUTES]:
+        attribute = attribute_id_to_attribute_map[attribute_id]
+        values = attribute_id_to_values_map[attribute_id][
+            : settings.PRODUCT_MAX_INDEXED_ATTRIBUTE_VALUES
+        ]
+        search_vectors += _generate_attribute_values_search_vector_value(attribute, values)
+
+    return search_vectors
+
+
+def _generate_attribute_values_search_vector_value(
+    attribute, values
+) -> list[NoValidationSearchVector]:
+    input_type = attribute.input_type
+    if input_type in [AttributeInputType.DROPDOWN, AttributeInputType.MULTISELECT]:
+        return [
+            NoValidationSearchVector(Value(value.name), config="simple", weight="B")
+            for value in values
+        ]
+    if input_type == AttributeInputType.RICH_TEXT:
+        return [
+            NoValidationSearchVector(
+                Value(clean_editor_js(value.rich_text, to_string=True)),
+                config="simple",
+                weight="B",
+            )
+            for value in values
+        ]
+    if input_type == AttributeInputType.PLAIN_TEXT:
+        return [
+            NoValidationSearchVector(Value(value.plain_text), config="simple", weight="B")
+            for value in values
+        ]
+    if input_type == AttributeInputType.NUMERIC:
+        unit = attribute.unit
+        return [
+            NoValidationSearchVector(
+                Value(value.name + " " + unit if unit else value.name),
+                config="simple",
+                weight="B",
+            )
+            for value in values
+        ]
+    if input_type in [AttributeInputType.DATE, AttributeInputType.DATE_TIME]:
+        return [
+            NoValidationSearchVector(
+                Value(value.date_time.strftime("%Y-%m-%d %H:%M:%S")),
+                config="simple",
+                weight="B",
+            )
+            for value in values
+        ]
+    return []
+
