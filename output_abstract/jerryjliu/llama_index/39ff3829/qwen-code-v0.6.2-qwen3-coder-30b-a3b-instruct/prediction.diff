--- /dev/null
+++ b/llama_index/prompts/template_registry.py
@@ -0,0 +1,65 @@
+"""Centralized registry for prompt templates."""
+
+from typing import Dict, Optional, TypeVar, Generic
+from abc import ABC, abstractmethod
+
+from llama_index.prompts.base import Prompt
+from llama_index.prompts.prompt_type import PromptType
+
+T = TypeVar('T')
+
+class PromptTemplate(Generic[T]):
+    """Generic class for storing prompt template information."""
+    
+    def __init__(self, template: str, prompt_type: PromptType, **kwargs):
+        self.template = template
+        self.prompt_type = prompt_type
+        self.kwargs = kwargs
+
+class PromptTemplateRegistry:
+    """Registry for managing prompt templates."""
+    
+    _instance = None
+    _templates: Dict[str, PromptTemplate] = {}
+    
+    def __new__(cls):
+        if cls._instance is None:
+            cls._instance = super().__new__(cls)
+        return cls._instance
+    
+    def register_template(self, name: str, template: str, prompt_type: PromptType, **kwargs) -> None:
+        """Register a new prompt template."""
+        self._templates[name] = PromptTemplate(template, prompt_type, **kwargs)
+    
+    def get_template(self, name: str) -> PromptTemplate:
+        """Get a registered prompt template."""
+        if name not in self._templates:
+            raise KeyError(f"Template '{name}' not found in registry")
+        return self._templates[name]
+    
+    def get_prompt(self, name: str, **kwargs) -> Prompt:
+        """Get a prompt instance from a registered template."""
+        template_info = self.get_template(name)
+        # Merge template kwargs with provided kwargs
+        prompt_kwargs = {**template_info.kwargs, **kwargs}
+        return Prompt(
+            template=template_info.template,
+            prompt_type=template_info.prompt_type,
+            **prompt_kwargs
+        )
+    
+    def unregister_template(self, name: str) -> None:
+        """Remove a template from the registry."""
+        if name in self._templates:
+            del self._templates[name]
+    
+    def list_templates(self) -> list:
+        """List all registered templates."""
+        return list(self._templates.keys())
+    
+    def has_template(self, name: str) -> bool:
+        """Check if a template is registered."""
+        return name in self._templates
+
+# Global registry instance
+registry = PromptTemplateRegistry()
