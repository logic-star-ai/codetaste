+def test_llm_predictor_system_and_query_wrapper_do_not_mutate_prompt() -> None:
+    """Ensure system/query wrapper are applied without mutating the Prompt object."""
+    llm_predictor = LLMPredictor(llm=MockLLM())
+    llm_predictor.system_prompt = "SYSTEM"
+    llm_predictor.query_wrapper_prompt = SimpleInputPrompt("Wrapped({query_str})")
+
+    base_prompt = SimpleInputPrompt("Q: {query_str}")
+    output = llm_predictor.predict(base_prompt, query_str="hello")
+
+    # MockLLM echoes the prompt, so we can verify exact formatting.
+    assert output == "SYSTEM\n\nQ: Wrapped(hello)"
+    # Prompt should remain unchanged across calls.
+    assert base_prompt.format(query_str="hello") == "Q: hello"
+
+
