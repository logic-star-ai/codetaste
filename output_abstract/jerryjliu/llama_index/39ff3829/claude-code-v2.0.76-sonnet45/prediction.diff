@@ -0,0 +1,230 @@
+"""Prompt registry for centralized prompt management."""
+from typing import Dict, List, Optional, Set
+import warnings
+
+from llama_index.prompts.base import Prompt
+from llama_index.prompts.prompt_type import PromptType
+
+
+class PromptRegistry:
+    """Centralized registry for managing prompts across LlamaIndex.
+
+    Provides a single source of truth for all prompts, enabling:
+    - Easy discovery of available prompts
+    - Consistent prompt versioning
+    - Prompt reuse across components
+    - Documentation generation
+    """
+
+    def __init__(self) -> None:
+        """Initialize the prompt registry."""
+        self._prompts: Dict[str, Prompt] = {}
+        self._prompt_metadata: Dict[str, Dict[str, str]] = {}
+        self._prompt_categories: Dict[PromptType, Set[str]] = {}
+
+    def register(
+        self,
+        name: str,
+        prompt: Prompt,
+        description: Optional[str] = None,
+        category: Optional[PromptType] = None,
+        overwrite: bool = False,
+    ) -> None:
+        """Register a prompt in the registry.
+
+        Args:
+            name: Unique identifier for the prompt
+            prompt: The Prompt instance to register
+            description: Optional description of the prompt's purpose
+            category: Optional category (PromptType) for organization
+            overwrite: Whether to overwrite existing prompt with same name
+
+        Raises:
+            ValueError: If prompt with same name already exists and overwrite=False
+        """
+        if name in self._prompts and not overwrite:
+            raise ValueError(
+                f"Prompt '{name}' already registered. Use overwrite=True to replace."
+            )
+
+        self._prompts[name] = prompt
+        self._prompt_metadata[name] = {
+            "description": description or "",
+            "category": category or PromptType.CUSTOM,
+        }
+
+        # Add to category index
+        prompt_category = category or PromptType.CUSTOM
+        if prompt_category not in self._prompt_categories:
+            self._prompt_categories[prompt_category] = set()
+        self._prompt_categories[prompt_category].add(name)
+
+    def get(self, name: str) -> Optional[Prompt]:
+        """Get a prompt by name.
+
+        Args:
+            name: The name of the prompt to retrieve
+
+        Returns:
+            The Prompt instance if found, None otherwise
+        """
+        return self._prompts.get(name)
+
+    def get_required(self, name: str) -> Prompt:
+        """Get a prompt by name, raising error if not found.
+
+        Args:
+            name: The name of the prompt to retrieve
+
+        Returns:
+            The Prompt instance
+
+        Raises:
+            KeyError: If prompt not found
+        """
+        if name not in self._prompts:
+            raise KeyError(
+                f"Prompt '{name}' not found in registry. "
+                f"Available prompts: {', '.join(self.list_prompts())}"
+            )
+        return self._prompts[name]
+
+    def unregister(self, name: str) -> bool:
+        """Unregister a prompt from the registry.
+
+        Args:
+            name: The name of the prompt to remove
+
+        Returns:
+            True if prompt was removed, False if it didn't exist
+        """
+        if name not in self._prompts:
+            return False
+
+        # Remove from category index
+        category = self._prompt_metadata[name].get("category", PromptType.CUSTOM)
+        if category in self._prompt_categories:
+            self._prompt_categories[category].discard(name)
+
+        del self._prompts[name]
+        del self._prompt_metadata[name]
+        return True
+
+    def list_prompts(self, category: Optional[PromptType] = None) -> List[str]:
+        """List all registered prompt names.
+
+        Args:
+            category: Optional category filter
+
+        Returns:
+            List of prompt names, optionally filtered by category
+        """
+        if category is None:
+            return sorted(self._prompts.keys())
+
+        return sorted(self._prompt_categories.get(category, set()))
+
+    def list_categories(self) -> List[PromptType]:
+        """List all prompt categories that have registered prompts.
+
+        Returns:
+            List of PromptType categories
+        """
+        return sorted(
+            self._prompt_categories.keys(),
+            key=lambda x: x.value if hasattr(x, 'value') else str(x)
+        )
+
+    def get_metadata(self, name: str) -> Optional[Dict[str, str]]:
+        """Get metadata for a registered prompt.
+
+        Args:
+            name: The name of the prompt
+
+        Returns:
+            Dictionary containing description and category, or None if not found
+        """
+        return self._prompt_metadata.get(name)
+
+    def search(self, query: str) -> List[str]:
+        """Search for prompts by name or description.
+
+        Args:
+            query: Search query string (case-insensitive)
+
+        Returns:
+            List of prompt names matching the query
+        """
+        query_lower = query.lower()
+        results = []
+
+        for name, metadata in self._prompt_metadata.items():
+            if (query_lower in name.lower() or
+                query_lower in metadata.get("description", "").lower()):
+                results.append(name)
+
+        return sorted(results)
+
+    def clear(self) -> None:
+        """Clear all prompts from the registry."""
+        self._prompts.clear()
+        self._prompt_metadata.clear()
+        self._prompt_categories.clear()
+
+    def __len__(self) -> int:
+        """Return the number of registered prompts."""
+        return len(self._prompts)
+
+    def __contains__(self, name: str) -> bool:
+        """Check if a prompt is registered."""
+        return name in self._prompts
+
+    def __repr__(self) -> str:
+        """Return string representation of the registry."""
+        return f"PromptRegistry(prompts={len(self._prompts)})"
+
+
+# Global default registry instance
+_DEFAULT_REGISTRY = PromptRegistry()
+
+
+def get_default_registry() -> PromptRegistry:
+    """Get the default global prompt registry.
+
+    Returns:
+        The default PromptRegistry instance
+    """
+    return _DEFAULT_REGISTRY
+
+
+def register_prompt(
+    name: str,
+    prompt: Prompt,
+    description: Optional[str] = None,
+    category: Optional[PromptType] = None,
+    overwrite: bool = False,
+) -> None:
+    """Register a prompt in the default global registry.
+
+    Convenience function for registering prompts without accessing the registry directly.
+
+    Args:
+        name: Unique identifier for the prompt
+        prompt: The Prompt instance to register
+        description: Optional description of the prompt's purpose
+        category: Optional category (PromptType) for organization
+        overwrite: Whether to overwrite existing prompt with same name
+    """
+    _DEFAULT_REGISTRY.register(name, prompt, description, category, overwrite)
+
+
+def get_prompt(name: str) -> Optional[Prompt]:
+    """Get a prompt from the default global registry.
+
+    Args:
+        name: The name of the prompt to retrieve
+
+    Returns:
+        The Prompt instance if found, None otherwise
+    """
+    return _DEFAULT_REGISTRY.get(name)
