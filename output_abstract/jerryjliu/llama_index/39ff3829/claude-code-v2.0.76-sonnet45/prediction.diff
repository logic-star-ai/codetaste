+"""Tests for PromptRegistry."""
+
+import pytest
+
+from llama_index.prompts.base import Prompt
+from llama_index.prompts.prompt_registry import (
+    PromptRegistry,
+    get_default_registry,
+    get_prompt,
+    register_prompt,
+)
+from llama_index.prompts.prompt_type import PromptType
+
+
+def test_registry_creation():
+    """Test creating a new registry."""
+    registry = PromptRegistry()
+    assert len(registry) == 0
+
+
+def test_register_and_get_prompt():
+    """Test registering and retrieving a prompt."""
+    registry = PromptRegistry()
+    prompt = Prompt(template="Test {var}")
+
+    registry.register("test_prompt", prompt, description="A test prompt")
+    retrieved = registry.get("test_prompt")
+
+    assert retrieved is prompt
+
+
+def test_register_duplicate_raises_error():
+    """Test that registering duplicate name raises error."""
+    registry = PromptRegistry()
+    prompt = Prompt(template="Test {var}")
+
+    registry.register("test_prompt", prompt)
+
+    with pytest.raises(ValueError, match="already registered"):
+        registry.register("test_prompt", prompt)
+
+
+def test_register_duplicate_with_overwrite():
+    """Test that overwrite=True allows duplicate names."""
+    registry = PromptRegistry()
+    prompt1 = Prompt(template="Test {var1}")
+    prompt2 = Prompt(template="Test {var2}")
+
+    registry.register("test_prompt", prompt1)
+    registry.register("test_prompt", prompt2, overwrite=True)
+
+    retrieved = registry.get("test_prompt")
+    assert retrieved is prompt2
+
+
+def test_get_nonexistent_returns_none():
+    """Test that getting nonexistent prompt returns None."""
+    registry = PromptRegistry()
+    result = registry.get("nonexistent")
+    assert result is None
+
+
+def test_get_required_raises_on_missing():
+    """Test that get_required raises KeyError for missing prompt."""
+    registry = PromptRegistry()
+
+    with pytest.raises(KeyError, match="not found"):
+        registry.get_required("nonexistent")
+
+
+def test_get_required_returns_prompt():
+    """Test that get_required returns prompt when it exists."""
+    registry = PromptRegistry()
+    prompt = Prompt(template="Test {var}")
+
+    registry.register("test_prompt", prompt)
+    retrieved = registry.get_required("test_prompt")
+
+    assert retrieved is prompt
+
+
+def test_unregister_prompt():
+    """Test unregistering a prompt."""
+    registry = PromptRegistry()
+    prompt = Prompt(template="Test {var}")
+
+    registry.register("test_prompt", prompt)
+    assert len(registry) == 1
+
+    success = registry.unregister("test_prompt")
+    assert success
+    assert len(registry) == 0
+
+
+def test_unregister_nonexistent():
+    """Test unregistering nonexistent prompt returns False."""
+    registry = PromptRegistry()
+    success = registry.unregister("nonexistent")
+    assert not success
+
+
+def test_list_prompts():
+    """Test listing all prompts."""
+    registry = PromptRegistry()
+    prompt1 = Prompt(template="Test {var1}")
+    prompt2 = Prompt(template="Test {var2}")
+
+    registry.register("prompt1", prompt1)
+    registry.register("prompt2", prompt2)
+
+    prompts = registry.list_prompts()
+    assert "prompt1" in prompts
+    assert "prompt2" in prompts
+    assert len(prompts) == 2
+
+
+def test_list_prompts_by_category():
+    """Test listing prompts filtered by category."""
+    registry = PromptRegistry()
+    qa_prompt = Prompt(template="Q: {query}")
+    summary_prompt = Prompt(template="Summarize: {context}")
+
+    registry.register("qa", qa_prompt, category=PromptType.QUESTION_ANSWER)
+    registry.register("summary", summary_prompt, category=PromptType.SUMMARY)
+
+    qa_prompts = registry.list_prompts(category=PromptType.QUESTION_ANSWER)
+    assert "qa" in qa_prompts
+    assert "summary" not in qa_prompts
+
+
+def test_list_categories():
+    """Test listing all categories."""
+    registry = PromptRegistry()
+    qa_prompt = Prompt(template="Q: {query}")
+    summary_prompt = Prompt(template="Summarize: {context}")
+
+    registry.register("qa", qa_prompt, category=PromptType.QUESTION_ANSWER)
+    registry.register("summary", summary_prompt, category=PromptType.SUMMARY)
+
+    categories = registry.list_categories()
+    assert PromptType.QUESTION_ANSWER in categories
+    assert PromptType.SUMMARY in categories
+
+
+def test_get_metadata():
+    """Test getting prompt metadata."""
+    registry = PromptRegistry()
+    prompt = Prompt(template="Test {var}")
+
+    registry.register(
+        "test_prompt",
+        prompt,
+        description="A test prompt",
+        category=PromptType.CUSTOM,
+    )
+
+    metadata = registry.get_metadata("test_prompt")
+    assert metadata is not None
+    assert metadata["description"] == "A test prompt"
+    assert metadata["category"] == PromptType.CUSTOM
+
+
+def test_get_metadata_nonexistent():
+    """Test getting metadata for nonexistent prompt."""
+    registry = PromptRegistry()
+    metadata = registry.get_metadata("nonexistent")
+    assert metadata is None
+
+
+def test_search_by_name():
+    """Test searching prompts by name."""
+    registry = PromptRegistry()
+    prompt1 = Prompt(template="Test {var1}")
+    prompt2 = Prompt(template="Test {var2}")
+
+    registry.register("test_qa_prompt", prompt1)
+    registry.register("summary_prompt", prompt2)
+
+    results = registry.search("qa")
+    assert "test_qa_prompt" in results
+    assert "summary_prompt" not in results
+
+
+def test_search_by_description():
+    """Test searching prompts by description."""
+    registry = PromptRegistry()
+    prompt1 = Prompt(template="Test {var1}")
+
+    registry.register("prompt1", prompt1, description="Question answering prompt")
+
+    results = registry.search("question")
+    assert "prompt1" in results
+
+
+def test_search_case_insensitive():
+    """Test that search is case-insensitive."""
+    registry = PromptRegistry()
+    prompt = Prompt(template="Test {var}")
+
+    registry.register("TestPrompt", prompt, description="Test Description")
+
+    results = registry.search("test")
+    assert "TestPrompt" in results
+
+    results = registry.search("TEST")
+    assert "TestPrompt" in results
+
+
+def test_clear_registry():
+    """Test clearing all prompts from registry."""
+    registry = PromptRegistry()
+    prompt1 = Prompt(template="Test {var1}")
+    prompt2 = Prompt(template="Test {var2}")
+
+    registry.register("prompt1", prompt1)
+    registry.register("prompt2", prompt2)
+
+    assert len(registry) == 2
+
+    registry.clear()
+    assert len(registry) == 0
+
+
+def test_contains_operator():
+    """Test __contains__ operator."""
+    registry = PromptRegistry()
+    prompt = Prompt(template="Test {var}")
+
+    registry.register("test_prompt", prompt)
+
+    assert "test_prompt" in registry
+    assert "nonexistent" not in registry
+
+
+def test_repr():
+    """Test __repr__ method."""
+    registry = PromptRegistry()
+    prompt = Prompt(template="Test {var}")
+
+    registry.register("test_prompt", prompt)
+
+    repr_str = repr(registry)
+    assert "PromptRegistry" in repr_str
+    assert "prompts=1" in repr_str
+
+
+def test_default_registry():
+    """Test getting the default global registry."""
+    registry = get_default_registry()
+    assert isinstance(registry, PromptRegistry)
+
+
+def test_register_prompt_function():
+    """Test the global register_prompt function."""
+    # Clear the default registry first
+    registry = get_default_registry()
+    original_count = len(registry)
+
+    prompt = Prompt(template="Test {var}")
+    register_prompt("test_global", prompt, description="Global test")
+
+    retrieved = get_prompt("test_global")
+    assert retrieved is prompt
+
+    # Clean up
+    registry.unregister("test_global")
+
+
+def test_get_prompt_function():
+    """Test the global get_prompt function."""
+    registry = get_default_registry()
+    prompt = Prompt(template="Test {var}")
+
+    registry.register("test_global2", prompt)
+
+    retrieved = get_prompt("test_global2")
+    assert retrieved is prompt
+
+    # Clean up
+    registry.unregister("test_global2")
