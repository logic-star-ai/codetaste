diff --git a/llama_index/prompts/base_templates.py b/llama_index/prompts/base_templates.py
new file mode 100644
index 0000000..7501d02
--- /dev/null
+++ b/llama_index/prompts/base_templates.py
@@ -0,0 +1,170 @@
+"""Lightweight prompt template primitives (no LangChain dependency)."""
+
+from __future__ import annotations
+
+import string
+from abc import ABC, abstractmethod
+from dataclasses import dataclass
+from typing import Any, Iterable, List, Sequence
+
+from llama_index.llms.base import ChatMessage, MessageRole
+
+
+def _get_template_vars(template: str) -> List[str]:
+    """Extract format variables from a Python `str.format` template."""
+
+    formatter = string.Formatter()
+    vars_in_order: List[str] = []
+    seen = set()
+    for _, field_name, _, _ in formatter.parse(template):
+        if not field_name:
+            continue
+        # `field_name` can include attribute/index access: `foo.bar` / `foo[0]`
+        base_name = field_name.split(".", 1)[0].split("[", 1)[0]
+        if base_name and base_name not in seen:
+            seen.add(base_name)
+            vars_in_order.append(base_name)
+    return vars_in_order
+
+
+class BasePromptTemplate(ABC):
+    """Base prompt template interface."""
+
+    @property
+    @abstractmethod
+    def input_variables(self) -> List[str]:
+        raise NotImplementedError
+
+    @abstractmethod
+    def format(self, **kwargs: Any) -> str:
+        raise NotImplementedError
+
+
+class PromptTemplate(BasePromptTemplate):
+    """A simple `str.format` prompt template."""
+
+    def __init__(self, *, input_variables: Sequence[str], template: str) -> None:
+        self._input_variables = list(input_variables)
+        self.template = template
+
+    @classmethod
+    def from_template(cls, template: str, **_: Any) -> "PromptTemplate":
+        return cls(input_variables=_get_template_vars(template), template=template)
+
+    def format(self, **kwargs: Any) -> str:
+        return self.template.format(**kwargs)
+
+    @property
+    def input_variables(self) -> List[str]:
+        return list(self._input_variables)
+
+
+class BaseMessagePromptTemplate(ABC):
+    """Base message prompt template interface."""
+
+    @property
+    @abstractmethod
+    def input_variables(self) -> List[str]:
+        raise NotImplementedError
+
+    @abstractmethod
+    def format_messages(self, **kwargs: Any) -> List[ChatMessage]:
+        raise NotImplementedError
+
+
+class _RoleMessagePromptTemplate(BaseMessagePromptTemplate):
+    def __init__(self, *, role: MessageRole, prompt: PromptTemplate) -> None:
+        self._role = role
+        self._prompt = prompt
+
+    @classmethod
+    def from_template(cls, template: str, **kwargs: Any) -> "_RoleMessagePromptTemplate":
+        role = kwargs.pop("role", None)
+        if role is None:
+            raise ValueError("`role` is required")
+        return cls(role=role, prompt=PromptTemplate.from_template(template))
+
+    @property
+    def input_variables(self) -> List[str]:
+        return self._prompt.input_variables
+
+    def format_messages(self, **kwargs: Any) -> List[ChatMessage]:
+        return [ChatMessage(role=self._role, content=self._prompt.format(**kwargs))]
+
+
+class SystemMessagePromptTemplate(_RoleMessagePromptTemplate):
+    @classmethod
+    def from_template(cls, template: str, **_: Any) -> "SystemMessagePromptTemplate":
+        return cls(role=MessageRole.SYSTEM, prompt=PromptTemplate.from_template(template))
+
+
+class HumanMessagePromptTemplate(_RoleMessagePromptTemplate):
+    @classmethod
+    def from_template(cls, template: str, **_: Any) -> "HumanMessagePromptTemplate":
+        return cls(role=MessageRole.USER, prompt=PromptTemplate.from_template(template))
+
+
+class AIMessagePromptTemplate(_RoleMessagePromptTemplate):
+    @classmethod
+    def from_template(cls, template: str, **_: Any) -> "AIMessagePromptTemplate":
+        return cls(
+            role=MessageRole.ASSISTANT, prompt=PromptTemplate.from_template(template)
+        )
+
+
+@dataclass(frozen=True)
+class ChatPromptValue:
+    _messages: List[ChatMessage]
+
+    def to_messages(self) -> List[ChatMessage]:
+        return list(self._messages)
+
+
+class ChatPromptTemplate(BasePromptTemplate):
+    """A chat prompt built from message templates."""
+
+    def __init__(self, *, messages: Sequence[BaseMessagePromptTemplate]) -> None:
+        self.messages = list(messages)
+
+    @classmethod
+    def from_messages(
+        cls, messages: Sequence[BaseMessagePromptTemplate]
+    ) -> "ChatPromptTemplate":
+        return cls(messages=messages)
+
+    @property
+    def input_variables(self) -> List[str]:
+        vars_in_order: List[str] = []
+        seen = set()
+        for msg in self.messages:
+            for var in msg.input_variables:
+                if var not in seen:
+                    seen.add(var)
+                    vars_in_order.append(var)
+        return vars_in_order
+
+    def format_prompt(self, **kwargs: Any) -> ChatPromptValue:
+        formatted: List[ChatMessage] = []
+        for msg in self.messages:
+            formatted.extend(msg.format_messages(**kwargs))
+        return ChatPromptValue(formatted)
+
+    def format_messages(self, **kwargs: Any) -> List[ChatMessage]:
+        return self.format_prompt(**kwargs).to_messages()
+
+    def format(self, **kwargs: Any) -> str:
+        messages = self.format_messages(**kwargs)
+        return "\n\n".join(f"{m.role.value}: {m.content or ''}" for m in messages)
+
+
+def iter_input_variables(templates: Iterable[BasePromptTemplate]) -> List[str]:
+    """Return a union of `input_variables`, preserving first-seen order."""
+
+    vars_in_order: List[str] = []
+    seen = set()
+    for tmpl in templates:
+        for var in tmpl.input_variables:
+            if var not in seen:
+                seen.add(var)
+                vars_in_order.append(var)
+    return vars_in_order
