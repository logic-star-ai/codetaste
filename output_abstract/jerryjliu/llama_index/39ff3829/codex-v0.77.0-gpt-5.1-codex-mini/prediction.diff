diff --git a/llama_index/prompts/template_utils.py b/llama_index/prompts/template_utils.py
new file mode 100644
index 0000000..53a611c
--- /dev/null
+++ b/llama_index/prompts/template_utils.py
@@ -0,0 +1,65 @@
+"""Utilities for working with prompt template strings.
+
+LlamaIndex prompts primarily use Python's `str.format` template syntax (e.g. `{var}`),
+which supports escaping literal braces via `{{` and `}}`.
+
+Some downstream integrations (e.g. Vellum, Guidance) use other templating syntaxes.
+These helpers centralize conversions while correctly handling escaped braces.
+"""
+
+from __future__ import annotations
+
+import string
+from typing import Iterable, Tuple
+
+
+def _iter_python_format_parts(template: str) -> Iterable[Tuple[str, str | None]]:
+    """Yield `(literal_text, field_name)` pairs from a Python format string.
+
+    `literal_text` already includes any escaped braces as literal `{` / `}`.
+    """
+
+    formatter = string.Formatter()
+    for literal_text, field_name, format_spec, conversion in formatter.parse(template):
+        if field_name == "":
+            raise ValueError(
+                "Anonymous format fields ('{}') are not supported in prompt templates."
+            )
+
+        if format_spec or conversion:
+            # We intentionally ignore format spec / conversion for cross-template
+            # conversions since syntaxes vary; callers can reject these if needed.
+            pass
+
+        yield literal_text, field_name
+
+
+def python_format_to_handlebars(template: str) -> str:
+    """Convert a Python format string into a Handlebars-style template.
+
+    - `{var}` becomes `{{var}}`
+    - Escaped braces `{{`/`}}` remain literal `{`/`}`.
+    """
+
+    out_parts: list[str] = []
+    for literal_text, field_name in _iter_python_format_parts(template):
+        out_parts.append(literal_text)
+        if field_name is not None:
+            out_parts.append("{{" + field_name + "}}")
+    return "".join(out_parts)
+
+
+def python_format_to_jinja(template: str) -> str:
+    """Convert a Python format string into a Jinja-style template.
+
+    - `{var}` becomes `{{ var }}`
+    - Escaped braces `{{`/`}}` remain literal `{`/`}`.
+    """
+
+    out_parts: list[str] = []
+    for literal_text, field_name in _iter_python_format_parts(template):
+        out_parts.append(literal_text)
+        if field_name is not None:
+            out_parts.append("{{ " + field_name + " }}")
+    return "".join(out_parts)
+
diff --git a/tests/prompts/test_template_utils.py b/tests/prompts/test_template_utils.py
new file mode 100644
index 0000000..5b6ab1e
--- /dev/null
+++ b/tests/prompts/test_template_utils.py
@@ -0,0 +1,21 @@
+from llama_index.prompts.template_utils import (
+    python_format_to_handlebars,
+    python_format_to_jinja,
+)
+
+
+def test_python_format_to_handlebars__escaped_braces() -> None:
+    template = 'A {var} and a literal dict: {{"k": "v"}}.'
+    assert (
+        python_format_to_handlebars(template)
+        == 'A {{var}} and a literal dict: {"k": "v"}.'
+    )
+
+
+def test_python_format_to_jinja__escaped_braces() -> None:
+    template = 'A {var} and a literal dict: {{"k": "v"}}.'
+    assert (
+        python_format_to_jinja(template)
+        == 'A {{ var }} and a literal dict: {"k": "v"}.'
+    )
+
