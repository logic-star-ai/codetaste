diff --git a/llama_index/prompts/template_utils.py b/llama_index/prompts/template_utils.py
new file mode 100644
index 0000000..6f01c0b
--- /dev/null
+++ b/llama_index/prompts/template_utils.py
@@ -0,0 +1,59 @@
+"""Utilities for working with prompt templates.
+
+These helpers focus on Python `str.format`-style templates (LangChain's default),
+and provide safe conversions to other templating syntaxes.
+"""
+
+from __future__ import annotations
+
+from string import Formatter
+from typing import Optional
+
+
+def python_format_to_jinja(template: str) -> str:
+    """Convert a Python `str.format` template to a Jinja2 template.
+
+    - `{var}` -> `{{ var }}`
+    - Escaped braces `{{` / `}}` are preserved as literal braces.
+
+    Note: format specs / conversions (e.g. `{x!r}` or `{x:.2f}`) are not preserved.
+    """
+
+    formatter = Formatter()
+    chunks: list[str] = []
+    for literal_text, field_name, _format_spec, _conversion in formatter.parse(
+        template
+    ):
+        chunks.append(literal_text)
+        if field_name is not None:
+            # `field_name` may contain attribute/index access; Jinja can handle most.
+            chunks.append("{{ " + field_name + " }}")
+    return "".join(chunks)
+
+
+def python_format_to_handlebars(template: str) -> str:
+    """Convert a Python `str.format` template to a Handlebars template.
+
+    - `{var}` -> `{{var}}`
+    - Escaped braces `{{` / `}}` are preserved as literal braces.
+    """
+
+    formatter = Formatter()
+    chunks: list[str] = []
+    for literal_text, field_name, _format_spec, _conversion in formatter.parse(
+        template
+    ):
+        chunks.append(literal_text)
+        if field_name is not None:
+            chunks.append("{{" + field_name + "}}")
+    return "".join(chunks)
+
+
+def as_chat_role_prefix(role: str) -> Optional[str]:
+    """Normalize a role name into a stable, human-readable prefix."""
+
+    role_upper = role.upper()
+    if role_upper in {"SYSTEM", "USER", "ASSISTANT", "TOOL"}:
+        return role_upper
+    return None
+
