@@ -0,0 +1,20 @@
+import { DialogTitle } from '@/ui/v2/Dialog';
+import type { DialogTitleProps } from '@/ui/v2/Dialog';
+
+export interface DrawerTitleProps extends DialogTitleProps {}
+
+function DrawerTitle({ sx, ...props }: DrawerTitleProps) {
+  return (
+    <DialogTitle
+      sx={{
+        padding: (theme) => theme.spacing(2.5, 3),
+        ...(Array.isArray(sx) ? sx : [sx]),
+      }}
+      {...props}
+    />
+  );
+}
+
+DrawerTitle.displayName = 'NhostDrawerTitle';
+
+export default DrawerTitle;
