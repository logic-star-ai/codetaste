+/*
+ * Copyright (c) 2007 Mockito contributors
+ * This program is made available under the terms of the MIT License.
+ */
+package org.mockito.internal.invocation;
+
+import java.io.Serializable;
+import java.lang.reflect.Method;
+import java.util.Arrays;
+import java.util.List;
+
+import org.mockito.internal.MockitoException;
+
+public class Invocation implements Serializable {
+    private static final long serialVersionUID = 1L;
+
+    private final Object mock;
+    private final Method method;
+    private final Object[] arguments;
+    private final long sequenceNumber;
+    private final long timestamp;
+
+    public Invocation(Object mock, Method method, Object[] arguments, long sequenceNumber) {
+        this.mock = mock;
+        this.method = method;
+        this.arguments = arguments != null ? arguments.clone() : new Object[0];
+        this.sequenceNumber = sequenceNumber;
+        this.timestamp = System.currentTimeMillis();
+    }
+
+    public Object getMock() {
+        return mock;
+    }
+
+    public Method getMethod() {
+        return method;
+    }
+
+    public Object[] getArguments() {
+        return arguments.clone();
+    }
+
+    public long getSequenceNumber() {
+        return sequenceNumber;
+    }
+
+    public long getTimestamp() {
+        return timestamp;
+    }
+
+    public boolean isEquals(Object obj) {
+        if (this == obj) {
+            return true;
+        }
+        if (obj == null || getClass() != obj.getClass()) {
+            return false;
+        }
+
+        Invocation invocation = (Invocation) obj;
+
+        if (sequenceNumber != invocation.sequenceNumber) {
+            return false;
+        }
+        if (method == null ? invocation.method != null : !method.equals(invocation.method)) {
+            return false;
+        }
+        if (mock == null ? invocation.mock != null : !mock.equals(invocation.mock)) {
+            return false;
+        }
+        return Arrays.equals(arguments, invocation.arguments);
+    }
+
+    @Override
+    public int hashCode() {
+        int result = mock != null ? mock.hashCode() : 0;
+        result = 31 * result + (method != null ? method.hashCode() : 0);
+        result = 31 * result + Arrays.hashCode(arguments);
+        result = 31 * result + (int) (sequenceNumber ^ (sequenceNumber >>> 32));
+        return result;
+    }
+
+    @Override
+    public boolean equals(Object obj) {
+        return isEquals(obj);
+    }
+
+    @Override
+    public String toString() {
+        return "Invocation{" +
+                "mock=" + mock +
+                ", method=" + method +
+                ", arguments=" + Arrays.toString(arguments) +
+                ", sequenceNumber=" + sequenceNumber +
+                ", timestamp=" + timestamp +
+                '}';
+    }
+}
