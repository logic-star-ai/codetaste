+"""Handler for tenant and database operations."""
+
+from chromadb.api.handlers.base_handler import BaseHandler
+from chromadb.config import DEFAULT_DATABASE, DEFAULT_TENANT
+from chromadb.telemetry.opentelemetry import (
+    OpenTelemetryGranularity,
+    trace_method,
+)
+import chromadb.types as t
+from uuid import uuid4
+
+
+class TenantDatabaseHandler(BaseHandler):
+    """Handles tenant and database lifecycle operations."""
+
+    @trace_method("TenantDatabaseHandler.create_database", OpenTelemetryGranularity.OPERATION)
+    def create_database(self, name: str, tenant: str = DEFAULT_TENANT) -> None:
+        """Create a new database.
+
+        Args:
+            name: Database name (must be at least 3 characters)
+            tenant: Tenant name (defaults to DEFAULT_TENANT)
+
+        Raises:
+            ValueError: If database name is too short
+        """
+        if len(name) < 3:
+            raise ValueError("Database name must be at least 3 characters long")
+
+        self._sysdb.create_database(
+            id=uuid4(),
+            name=name,
+            tenant=tenant,
+        )
+
+    @trace_method("TenantDatabaseHandler.get_database", OpenTelemetryGranularity.OPERATION)
+    def get_database(self, name: str, tenant: str = DEFAULT_TENANT) -> t.Database:
+        """Get database by name.
+
+        Args:
+            name: Database name
+            tenant: Tenant name (defaults to DEFAULT_TENANT)
+
+        Returns:
+            Database object
+        """
+        return self._sysdb.get_database(name=name, tenant=tenant)
+
+    @trace_method("TenantDatabaseHandler.create_tenant", OpenTelemetryGranularity.OPERATION)
+    def create_tenant(self, name: str) -> None:
+        """Create a new tenant.
+
+        Args:
+            name: Tenant name (must be at least 3 characters)
+
+        Raises:
+            ValueError: If tenant name is too short
+        """
+        if len(name) < 3:
+            raise ValueError("Tenant name must be at least 3 characters long")
+
+        self._sysdb.create_tenant(name=name)
+
+    @trace_method("TenantDatabaseHandler.get_tenant", OpenTelemetryGranularity.OPERATION)
+    def get_tenant(self, name: str) -> t.Tenant:
+        """Get tenant by name.
+
+        Args:
+            name: Tenant name
+
+        Returns:
+            Tenant object
+        """
+        return self._sysdb.get_tenant(name=name)
diff --git a/chromadb/api/handlers/utils.py b/chromadb/api/handlers/utils.py
new file mode 100644
index 0000000..ad792f3
--- /dev/null
+++ b/chromadb/api/handlers/utils.py
@@ -0,0 +1,123 @@
+"""Utility functions for data transformation."""
+
+from typing import Optional, Generator, List
+import chromadb.types as t
+from chromadb.api.types import (
+    IDs,
+    Embeddings,
+    Metadatas,
+    Documents,
+    URIs,
+)
+
+
+def records_from_batch(
+    operation: t.Operation,
+    ids: IDs,
+    embeddings: Optional[Embeddings] = None,
+    metadatas: Optional[Metadatas] = None,
+    documents: Optional[Documents] = None,
+    uris: Optional[URIs] = None,
+) -> Generator[t.OperationRecord, None, None]:
+    """Convert parallel lists to a sequence of OperationRecords.
+
+    Args:
+        operation: The operation type (ADD, UPDATE, UPSERT, DELETE)
+        ids: List of record IDs
+        embeddings: Optional list of embeddings
+        metadatas: Optional list of metadata dicts
+        documents: Optional list of documents
+        uris: Optional list of URIs
+
+    Yields:
+        OperationRecord instances
+    """
+    for i, id in enumerate(ids):
+        metadata = None
+        if metadatas:
+            metadata = metadatas[i]
+
+        if documents:
+            document = documents[i]
+            if metadata:
+                metadata = {**metadata, "chroma:document": document}
+            else:
+                metadata = {"chroma:document": document}
+
+        if uris:
+            uri = uris[i]
+            if metadata:
+                metadata = {**metadata, "chroma:uri": uri}
+            else:
+                metadata = {"chroma:uri": uri}
+
+        record = t.OperationRecord(
+            id=id,
+            embedding=embeddings[i] if embeddings else None,
+            encoding=t.ScalarEncoding.FLOAT32,
+            metadata=metadata,
+            operation=operation,
+        )
+        yield record
+
+
+def extract_document(metadata: Optional[t.Metadata]) -> Optional[str]:
+    """Retrieve the document (if any) from a Metadata map.
+
+    Args:
+        metadata: Metadata dictionary
+
+    Returns:
+        Document string if present, None otherwise
+    """
+    if metadata and "chroma:document" in metadata:
+        return str(metadata["chroma:document"])
+    return None
+
+
+def extract_uri(metadata: Optional[t.Metadata]) -> Optional[str]:
+    """Retrieve the URI (if any) from a Metadata map.
+
+    Args:
+        metadata: Metadata dictionary
+
+    Returns:
+        URI string if present, None otherwise
+    """
+    if metadata and "chroma:uri" in metadata:
+        return str(metadata["chroma:uri"])
+    return None
+
+
+def clean_metadata(metadata: Optional[t.Metadata]) -> Optional[t.Metadata]:
+    """Remove chroma-specific metadata keys from a metadata map.
+
+    Args:
+        metadata: Metadata dictionary
+
+    Returns:
+        Cleaned metadata without chroma:* keys
+    """
+    if not metadata:
+        return None
+    result = {}
+    for k, v in metadata.items():
+        if not k.startswith("chroma:"):
+            result[k] = v
+    if len(result) == 0:
+        return None
+    return result
+
+
+def clean_metadatas(
+    metadata: List[Optional[t.Metadata]],
+) -> List[Optional[t.Metadata]]:
+    """Remove chroma-specific metadata keys from a list of metadata maps.
+
+    Args:
+        metadata: List of metadata dictionaries
+
+    Returns:
+        List of cleaned metadata dictionaries
+    """
+    return [clean_metadata(m) for m in metadata]
