+"""Telemetry aspect for method tracing and instrumentation."""
+
+import functools
+from typing import Callable, TypeVar, Any
+from chromadb.telemetry.opentelemetry import (
+    trace_method,
+    OpenTelemetryGranularity,
+)
+
+F = TypeVar("F", bound=Callable[..., Any])
+
+
+class TelemetryAspect:
+    """Aspect for adding telemetry to methods.
+
+    This class provides a pluggable interface for telemetry that can
+    be easily replaced or disabled for testing.
+    """
+
+    def __init__(self, enabled: bool = True):
+        """Initialize telemetry aspect.
+
+        Args:
+            enabled: Whether telemetry is enabled
+        """
+        self.enabled = enabled
+
+    def trace(
+        self,
+        method_name: str,
+        granularity: OpenTelemetryGranularity = OpenTelemetryGranularity.OPERATION,
+    ) -> Callable[[F], F]:
+        """Decorator to add tracing to a method.
+
+        Args:
+            method_name: Name of the method for trace identification
+            granularity: Telemetry granularity level
+
+        Returns:
+            Decorator function
+        """
+        if not self.enabled:
+            # Return a no-op decorator
+            def no_op_decorator(func: F) -> F:
+                return func
+
+            return no_op_decorator
+
+        # Use existing trace_method decorator
+        return trace_method(method_name, granularity)
+
+
+# Global telemetry aspect instance
+_telemetry_aspect = TelemetryAspect()
+
+
+def telemetry(
+    method_name: str,
+    granularity: OpenTelemetryGranularity = OpenTelemetryGranularity.OPERATION,
+) -> Callable[[F], F]:
+    """Simplified decorator for method telemetry.
+
+    This provides a cleaner interface than using trace_method directly.
+
+    Args:
+        method_name: Name of the method for trace identification
+        granularity: Telemetry granularity level
+
+    Returns:
+        Decorator function
+
+    Example:
+        @telemetry("MyClass.my_method")
+        def my_method(self):
+            pass
+    """
+    return _telemetry_aspect.trace(method_name, granularity)
+
+
+def set_telemetry_aspect(aspect: TelemetryAspect) -> None:
+    """Set the global telemetry aspect instance.
+
+    This allows for easy testing and customization.
+
+    Args:
+        aspect: The telemetry aspect to use globally
+    """
+    global _telemetry_aspect
+    _telemetry_aspect = aspect
+
+
+def get_telemetry_aspect() -> TelemetryAspect:
+    """Get the current global telemetry aspect.
+
+    Returns:
+        Current telemetry aspect instance
+    """
+    return _telemetry_aspect
