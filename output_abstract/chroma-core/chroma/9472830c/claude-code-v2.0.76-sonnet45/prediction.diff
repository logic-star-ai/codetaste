+## Usage Examples
+
+### Before (Original API - Still Works)
+```python
+from chromadb import PersistentClient
+
+client = PersistentClient(path="./data")
+collection = client.create_collection("my_collection")
+collection.add(
+    ids=["id1", "id2"],
+    embeddings=[[1.0, 2.0], [3.0, 4.0]],
+)
+```
+
+### After (New Modular API - Recommended)
+```python
+from chromadb.factory import ClientFactory
+
+# Create client using builder
+client = ClientFactory().persistent(path="./data").build()
+
+# Or use handlers directly for advanced use cases
+from chromadb.api.handlers import CollectionHandler, EmbeddingHandler
+from chromadb.core import System
+from chromadb.config import Settings
+
+system = System(Settings())
+coll_handler = CollectionHandler(system)
+emb_handler = EmbeddingHandler(system)
+
+collection = coll_handler.create_collection("my_collection")
+emb_handler.add(
+    ids=["id1", "id2"],
+    collection_id=collection.id,
+    embeddings=[[1.0, 2.0], [3.0, 4.0]],
+)
+```
+
+### Aspect Usage
+```python
+from chromadb.aspects import telemetry
+
+class MyClass:
+    @telemetry("MyClass.my_method")
+    def my_method(self):
+        # Automatically traced
+        pass
+
+# Disable for testing
+from chromadb.aspects.telemetry import set_telemetry_aspect, TelemetryAspect
+set_telemetry_aspect(TelemetryAspect(enabled=False))
+```
