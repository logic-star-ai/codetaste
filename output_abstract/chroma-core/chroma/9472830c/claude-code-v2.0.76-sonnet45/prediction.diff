+++ b/chromadb/api/handlers/validation.py
@@ -0,0 +1,72 @@
+"""Validation utilities for API handlers."""
+
+import re
+from typing import Optional
+from uuid import UUID
+import chromadb.types as t
+from chromadb.errors import InvalidDimensionException, InvalidCollectionException
+
+
+def check_index_name(index_name: str) -> None:
+    """Validate collection name according to S3 bucket requirements.
+
+    Args:
+        index_name: The collection name to validate
+
+    Raises:
+        ValueError: If the name doesn't meet requirements
+    """
+    msg = (
+        "Expected collection name that "
+        "(1) contains 3-63 characters, "
+        "(2) starts and ends with an alphanumeric character, "
+        "(3) otherwise contains only alphanumeric characters, underscores or hyphens (-), "
+        "(4) contains no two consecutive periods (..) and "
+        "(5) is not a valid IPv4 address, "
+        f"got {index_name}"
+    )
+    if len(index_name) < 3 or len(index_name) > 63:
+        raise ValueError(msg)
+    if not re.match("^[a-zA-Z0-9][a-zA-Z0-9._-]*[a-zA-Z0-9]$", index_name):
+        raise ValueError(msg)
+    if ".." in index_name:
+        raise ValueError(msg)
+    if re.match("^[0-9]{1,3}\\.[0-9]{1,3}\\.[0-9]{1,3}\\.[0-9]{1,3}$", index_name):
+        raise ValueError(msg)
+
+
+def validate_dimension(
+    collection: t.Collection, dim: int, update_fn=None
+) -> None:
+    """Validate that a collection supports records of the given dimension.
+
+    Args:
+        collection: The collection to validate against
+        dim: The embedding dimension to validate
+        update_fn: Optional callback to update collection dimension if needed
+
+    Raises:
+        InvalidDimensionException: If dimensions don't match
+    """
+    if collection["dimension"] is None:
+        if update_fn:
+            update_fn(collection, dim)
+    elif collection["dimension"] != dim:
+        raise InvalidDimensionException(
+            f"Embedding dimension {dim} does not match collection "
+            f"dimensionality {collection['dimension']}"
+        )
+
+
+def validate_embedding_record(
+    collection: t.Collection, record: t.OperationRecord, validate_dim_fn
+) -> None:
+    """Validate the dimension of an embedding record.
+
+    Args:
+        collection: The target collection
+        record: The operation record to validate
+        validate_dim_fn: Function to call for dimension validation
+    """
+    if record["embedding"]:
+        validate_dim_fn(collection, len(record["embedding"]), update=True)
