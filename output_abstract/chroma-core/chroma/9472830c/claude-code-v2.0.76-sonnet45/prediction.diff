+"""Quota enforcement aspect."""
+
+import functools
+from typing import Callable, TypeVar, Any
+
+F = TypeVar("F", bound=Callable[..., Any])
+
+
+class QuotaAspect:
+    """Aspect for quota enforcement on methods.
+
+    Provides a pluggable interface for quota checking that can be
+    easily configured or disabled.
+    """
+
+    def __init__(self, enabled: bool = True):
+        """Initialize quota aspect.
+
+        Args:
+            enabled: Whether quota enforcement is enabled
+        """
+        self.enabled = enabled
+
+    def check(self, resource_type: str) -> Callable[[F], F]:
+        """Decorator to add quota checking to a method.
+
+        Args:
+            resource_type: Type of resource to check quota for
+
+        Returns:
+            Decorator function
+        """
+
+        def decorator(func: F) -> F:
+            if not self.enabled:
+                return func
+
+            @functools.wraps(func)
+            def wrapper(*args, **kwargs):
+                # Quota checking logic would go here
+                # For now, just pass through
+                return func(*args, **kwargs)
+
+            return wrapper  # type: ignore
+
+        return decorator
+
+
+# Global quota aspect
+_quota_aspect = QuotaAspect()
+
+
+def quota_check(resource_type: str) -> Callable[[F], F]:
+    """Simplified decorator for quota enforcement.
+
+    Args:
+        resource_type: Type of resource to check quota for
+
+    Returns:
+        Decorator function
+
+    Example:
+        @quota_check("embeddings")
+        def add_embeddings(self, ...):
+            pass
+    """
+    return _quota_aspect.check(resource_type)
+
+
+def set_quota_aspect(aspect: QuotaAspect) -> None:
+    """Set the global quota aspect instance.
+
+    Args:
+        aspect: The quota aspect to use globally
+    """
+    global _quota_aspect
+    _quota_aspect = aspect
+
+
+def get_quota_aspect() -> QuotaAspect:
+    """Get the current global quota aspect.
+
+    Returns:
+        Current quota aspect instance
+    """
+    return _quota_aspect
