+"""Cache management for segments."""
+
+from typing import Optional, Dict, Any
+from uuid import UUID
+from collections import OrderedDict
+
+
+class SegmentCache:
+    """LRU cache for segment instances.
+
+    Separates caching logic from segment management for better
+    modularity and testability.
+    """
+
+    def __init__(self, max_size: int = 100):
+        """Initialize segment cache.
+
+        Args:
+            max_size: Maximum number of segments to cache
+        """
+        self._max_size = max_size
+        self._cache: OrderedDict[str, Any] = OrderedDict()
+
+    def get(self, key: str) -> Optional[Any]:
+        """Get a segment from the cache.
+
+        Args:
+            key: Cache key
+
+        Returns:
+            Cached segment or None if not found
+        """
+        if key in self._cache:
+            # Move to end (most recently used)
+            self._cache.move_to_end(key)
+            return self._cache[key]
+        return None
+
+    def put(self, key: str, segment: Any) -> None:
+        """Put a segment in the cache.
+
+        Args:
+            key: Cache key
+            segment: Segment to cache
+        """
+        if key in self._cache:
+            # Update and move to end
+            self._cache.move_to_end(key)
+        else:
+            # Add new entry
+            if len(self._cache) >= self._max_size:
+                # Remove least recently used
+                self._cache.popitem(last=False)
+            self._cache[key] = segment
+
+    def remove(self, key: str) -> None:
+        """Remove a segment from the cache.
+
+        Args:
+            key: Cache key
+        """
+        if key in self._cache:
+            del self._cache[key]
+
+    def clear(self) -> None:
+        """Clear the entire cache."""
+        self._cache.clear()
+
+    def size(self) -> int:
+        """Get current cache size.
+
+        Returns:
+            Number of items in cache
+        """
+        return len(self._cache)
+
+    def contains(self, key: str) -> bool:
+        """Check if a key is in the cache.
+
+        Args:
+            key: Cache key
+
+        Returns:
+            True if key is cached, False otherwise
+        """
+        return key in self._cache
