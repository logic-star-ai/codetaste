+"""Base handler class with common functionality."""
+
+from chromadb.config import Settings, System
+from chromadb.db.system import SysDB
+from chromadb.segment import SegmentManager
+from chromadb.ingest import Producer
+from chromadb.quota import QuotaEnforcer
+from chromadb.telemetry.opentelemetry import OpenTelemetryClient
+from chromadb.telemetry.product import ProductTelemetryClient
+from typing import Dict
+from uuid import UUID
+import chromadb.types as t
+
+
+class BaseHandler:
+    """Base class for all handlers with common dependencies."""
+
+    def __init__(self, system: System):
+        """Initialize handler with system dependencies.
+
+        Args:
+            system: The system instance providing component access
+        """
+        self._settings: Settings = system.settings
+        self._sysdb: SysDB = system.require(SysDB)
+        self._manager: SegmentManager = system.require(SegmentManager)
+        self._quota: QuotaEnforcer = system.require(QuotaEnforcer)
+        self._product_telemetry_client: ProductTelemetryClient = system.require(
+            ProductTelemetryClient
+        )
+        self._opentelemetry_client: OpenTelemetryClient = system.require(
+            OpenTelemetryClient
+        )
+        self._producer: Producer = system.require(Producer)
+        self._collection_cache: Dict[UUID, t.Collection] = {}
