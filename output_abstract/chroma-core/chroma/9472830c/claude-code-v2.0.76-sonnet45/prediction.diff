+"""Handler for collection operations."""
+
+from chromadb.api.handlers.base_handler import BaseHandler
+from chromadb.api.handlers.validation import check_index_name
+from chromadb.api.configuration import CollectionConfigurationInternal
+from chromadb.config import DEFAULT_DATABASE, DEFAULT_TENANT
+from chromadb.errors import InvalidCollectionException
+from chromadb.telemetry.opentelemetry import (
+    add_attributes_to_current_span,
+    OpenTelemetryGranularity,
+    trace_method,
+)
+from chromadb.telemetry.product.events import ClientCreateCollectionEvent
+from chromadb.api.types import (
+    CollectionMetadata,
+    validate_metadata,
+    validate_update_metadata,
+)
+import chromadb.types as t
+from typing import Optional, Sequence
+from uuid import UUID, uuid4
+import logging
+
+logger = logging.getLogger(__name__)
+
+
+class CollectionHandler(BaseHandler):
+    """Handles collection lifecycle and metadata operations."""
+
+    @trace_method("CollectionHandler.create_collection", OpenTelemetryGranularity.OPERATION)
+    def create_collection(
+        self,
+        name: str,
+        configuration: Optional[CollectionConfigurationInternal] = None,
+        metadata: Optional[CollectionMetadata] = None,
+        get_or_create: bool = False,
+        tenant: str = DEFAULT_TENANT,
+        database: str = DEFAULT_DATABASE,
+    ) -> t.Collection:
+        """Create a new collection.
+
+        Args:
+            name: Collection name
+            configuration: Optional collection configuration
+            metadata: Optional collection metadata
+            get_or_create: If True, return existing collection instead of error
+            tenant: Tenant name
+            database: Database name
+
+        Returns:
+            Created or existing collection
+
+        Raises:
+            ValueError: If collection name is invalid or metadata is invalid
+        """
+        if metadata is not None:
+            validate_metadata(metadata)
+
+        check_index_name(name)
+
+        id = uuid4()
+
+        model = t.Collection(
+            id=id,
+            name=name,
+            metadata=metadata,
+            configuration=configuration
+            if configuration is not None
+            else CollectionConfigurationInternal(),
+            tenant=tenant,
+            database=database,
+            dimension=None,
+        )
+
+        coll, created = self._sysdb.create_collection(
+            id=model.id,
+            name=model.name,
+            configuration=model.get_configuration(),
+            metadata=model.metadata,
+            dimension=None,  # Lazily populated on first add
+            get_or_create=get_or_create,
+            tenant=tenant,
+            database=database,
+        )
+
+        if created:
+            segments = self._manager.create_segments(coll)
+            for segment in segments:
+                self._sysdb.create_segment(segment)
+        else:
+            logger.debug(
+                f"Collection {name} already exists, returning existing collection."
+            )
+
+        self._product_telemetry_client.capture(
+            ClientCreateCollectionEvent(collection_uuid=str(id))
+        )
+        add_attributes_to_current_span({"collection_uuid": str(id)})
+
+        return coll
+
+    @trace_method("CollectionHandler.get_or_create_collection", OpenTelemetryGranularity.OPERATION)
+    def get_or_create_collection(
+        self,
+        name: str,
+        configuration: Optional[CollectionConfigurationInternal] = None,
+        metadata: Optional[CollectionMetadata] = None,
+        tenant: str = DEFAULT_TENANT,
+        database: str = DEFAULT_DATABASE,
+    ) -> t.Collection:
+        """Get or create a collection.
+
+        Args:
+            name: Collection name
+            configuration: Optional collection configuration
+            metadata: Optional collection metadata
+            tenant: Tenant name
+            database: Database name
+
+        Returns:
+            Existing or newly created collection
+        """
+        return self.create_collection(
+            name=name,
+            metadata=metadata,
+            configuration=configuration,
+            get_or_create=True,
+            tenant=tenant,
+            database=database,
+        )
+
+    @trace_method("CollectionHandler.get_collection", OpenTelemetryGranularity.OPERATION)
+    def get_collection(
+        self,
+        name: Optional[str] = None,
+        id: Optional[UUID] = None,
+        tenant: str = DEFAULT_TENANT,
+        database: str = DEFAULT_DATABASE,
+    ) -> t.Collection:
+        """Get a collection by name or ID.
+
+        Args:
+            name: Collection name
+            id: Collection ID
+            tenant: Tenant name
+            database: Database name
+
+        Returns:
+            The requested collection
+
+        Raises:
+            ValueError: If both or neither name and id are specified
+            InvalidCollectionException: If collection doesn't exist
+        """
+        if id is None and name is None or (id is not None and name is not None):
+            raise ValueError("Name or id must be specified, but not both")
+
+        existing = self._sysdb.get_collections(
+            id=id, name=name, tenant=tenant, database=database
+        )
+
+        if existing:
+            return existing[0]
+        else:
+            raise InvalidCollectionException(f"Collection {name} does not exist.")
+
+    @trace_method("CollectionHandler.list_collections", OpenTelemetryGranularity.OPERATION)
+    def list_collections(
+        self,
+        limit: Optional[int] = None,
+        offset: Optional[int] = None,
+        tenant: str = DEFAULT_TENANT,
+        database: str = DEFAULT_DATABASE,
+    ) -> Sequence[t.Collection]:
+        """List all collections.
+
+        Args:
+            limit: Maximum number of collections to return
+            offset: Number of collections to skip
+            tenant: Tenant name
+            database: Database name
+
+        Returns:
+            List of collections
+        """
+        return self._sysdb.get_collections(
+            limit=limit, offset=offset, tenant=tenant, database=database
+        )
+
+    @trace_method("CollectionHandler.count_collections", OpenTelemetryGranularity.OPERATION)
+    def count_collections(
+        self,
+        tenant: str = DEFAULT_TENANT,
+        database: str = DEFAULT_DATABASE,
+    ) -> int:
+        """Count collections.
+
+        Args:
+            tenant: Tenant name
+            database: Database name
+
+        Returns:
+            Number of collections
+        """
+        collection_count = len(
+            self._sysdb.get_collections(tenant=tenant, database=database)
+        )
+        return collection_count
+
+    @trace_method("CollectionHandler.modify_collection", OpenTelemetryGranularity.OPERATION)
+    def modify_collection(
+        self,
+        id: UUID,
+        new_name: Optional[str] = None,
+        new_metadata: Optional[CollectionMetadata] = None,
+    ) -> None:
+        """Modify a collection's name or metadata.
+
+        Args:
+            id: Collection ID
+            new_name: New collection name
+            new_metadata: New collection metadata
+
+        Raises:
+            ValueError: If new_name is invalid or new_metadata is invalid
+        """
+        if new_name:
+            check_index_name(new_name)
+
+        if new_metadata:
+            validate_update_metadata(new_metadata)
+
+        self.validate_collection_exists(id)
+
+        if new_name and new_metadata:
+            self._sysdb.update_collection(id, name=new_name, metadata=new_metadata)
+        elif new_name:
+            self._sysdb.update_collection(id, name=new_name)
+        elif new_metadata:
+            self._sysdb.update_collection(id, metadata=new_metadata)
+
+    @trace_method("CollectionHandler.delete_collection", OpenTelemetryGranularity.OPERATION)
+    def delete_collection(
+        self,
+        name: str,
+        tenant: str = DEFAULT_TENANT,
+        database: str = DEFAULT_DATABASE,
+    ) -> None:
+        """Delete a collection.
+
+        Args:
+            name: Collection name
+            tenant: Tenant name
+            database: Database name
+
+        Raises:
+            ValueError: If collection doesn't exist
+        """
+        existing = self._sysdb.get_collections(
+            name=name, tenant=tenant, database=database
+        )
+
+        if existing:
+            self._sysdb.delete_collection(
+                existing[0].id, tenant=tenant, database=database
+            )
+            for s in self._manager.delete_segments(existing[0].id):
+                self._sysdb.delete_segment(s)
+            if existing and existing[0].id in self._collection_cache:
+                del self._collection_cache[existing[0].id]
+        else:
+            raise ValueError(f"Collection {name} does not exist.")
+
+    @trace_method("CollectionHandler.get_collection_cached", OpenTelemetryGranularity.ALL)
+    def get_collection_cached(self, collection_id: UUID) -> t.Collection:
+        """Get collection with read-through cache.
+
+        Args:
+            collection_id: Collection ID
+
+        Returns:
+            Collection data
+
+        Raises:
+            InvalidCollectionException: If collection doesn't exist
+        """
+        if collection_id not in self._collection_cache:
+            collections = self._sysdb.get_collections(id=collection_id)
+            if not collections:
+                raise InvalidCollectionException(
+                    f"Collection {collection_id} does not exist."
+                )
+            self._collection_cache[collection_id] = collections[0]
+        return self._collection_cache[collection_id]
+
+    def validate_collection_exists(self, collection_id: UUID) -> None:
+        """Validate that a collection exists.
+
+        Args:
+            collection_id: Collection ID
+
+        Raises:
+            InvalidCollectionException: If collection doesn't exist
+        """
+        self.get_collection_cached(collection_id)
