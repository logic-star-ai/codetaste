+"""Handler for embedding operations (add, update, upsert, delete)."""
+
+from chromadb.api.handlers.base_handler import BaseHandler
+from chromadb.api.handlers.utils import records_from_batch
+from chromadb.api.handlers.validation import validate_embedding_record
+from chromadb.errors import InvalidDimensionException
+from chromadb.quota import Resource
+from chromadb.rate_limiting import rate_limit
+from chromadb.telemetry.opentelemetry import (
+    add_attributes_to_current_span,
+    OpenTelemetryGranularity,
+    trace_method,
+)
+from chromadb.telemetry.product.events import (
+    CollectionAddEvent,
+    CollectionDeleteEvent,
+    CollectionUpdateEvent,
+)
+from chromadb.api.types import (
+    IDs,
+    Embeddings,
+    Metadatas,
+    Documents,
+    URIs,
+    Where,
+    WhereDocument,
+    validate_batch,
+    validate_where,
+    validate_where_document,
+)
+from chromadb.segment import MetadataReader
+import chromadb.types as t
+from typing import Optional
+from uuid import UUID
+
+
+class EmbeddingHandler(BaseHandler):
+    """Handles embedding CRUD operations."""
+
+    @trace_method("EmbeddingHandler.add", OpenTelemetryGranularity.OPERATION)
+    @rate_limit(subject="collection_id", resource=Resource.ADD_PER_MINUTE)
+    def add(
+        self,
+        ids: IDs,
+        collection_id: UUID,
+        embeddings: Embeddings,
+        metadatas: Optional[Metadatas] = None,
+        documents: Optional[Documents] = None,
+        uris: Optional[URIs] = None,
+    ) -> bool:
+        """Add embeddings to a collection.
+
+        Args:
+            ids: List of IDs
+            collection_id: Collection UUID
+            embeddings: List of embeddings
+            metadatas: Optional list of metadata dicts
+            documents: Optional list of documents
+            uris: Optional list of URIs
+
+        Returns:
+            True on success
+        """
+        self._quota.static_check(metadatas, documents, embeddings, str(collection_id))
+        coll = self._get_collection_cached(collection_id)
+        self._manager.hint_use_collection(collection_id, t.Operation.ADD)
+        validate_batch(
+            (ids, embeddings, metadatas, documents, uris),
+            {"max_batch_size": self._get_max_batch_size()},
+        )
+
+        records_to_submit = []
+        for r in records_from_batch(
+            t.Operation.ADD,
+            ids=ids,
+            embeddings=embeddings,
+            metadatas=metadatas,
+            documents=documents,
+            uris=uris,
+        ):
+            self._validate_embedding_record(coll, r)
+            records_to_submit.append(r)
+        self._producer.submit_embeddings(collection_id, records_to_submit)
+
+        self._product_telemetry_client.capture(
+            CollectionAddEvent(
+                collection_uuid=str(collection_id),
+                add_amount=len(ids),
+                with_metadata=len(ids) if metadatas is not None else 0,
+                with_documents=len(ids) if documents is not None else 0,
+                with_uris=len(ids) if uris is not None else 0,
+            )
+        )
+        return True
+
+    @trace_method("EmbeddingHandler.update", OpenTelemetryGranularity.OPERATION)
+    def update(
+        self,
+        collection_id: UUID,
+        ids: IDs,
+        embeddings: Optional[Embeddings] = None,
+        metadatas: Optional[Metadatas] = None,
+        documents: Optional[Documents] = None,
+        uris: Optional[URIs] = None,
+    ) -> bool:
+        """Update embeddings in a collection.
+
+        Args:
+            collection_id: Collection UUID
+            ids: List of IDs to update
+            embeddings: Optional list of new embeddings
+            metadatas: Optional list of new metadata dicts
+            documents: Optional list of new documents
+            uris: Optional list of new URIs
+
+        Returns:
+            True on success
+        """
+        self._quota.static_check(metadatas, documents, embeddings, str(collection_id))
+        coll = self._get_collection_cached(collection_id)
+        self._manager.hint_use_collection(collection_id, t.Operation.UPDATE)
+        validate_batch(
+            (ids, embeddings, metadatas, documents, uris),
+            {"max_batch_size": self._get_max_batch_size()},
+        )
+
+        records_to_submit = []
+        for r in records_from_batch(
+            t.Operation.UPDATE,
+            ids=ids,
+            embeddings=embeddings,
+            metadatas=metadatas,
+            documents=documents,
+            uris=uris,
+        ):
+            self._validate_embedding_record(coll, r)
+            records_to_submit.append(r)
+        self._producer.submit_embeddings(collection_id, records_to_submit)
+
+        self._product_telemetry_client.capture(
+            CollectionUpdateEvent(
+                collection_uuid=str(collection_id),
+                update_amount=len(ids),
+                with_embeddings=len(embeddings) if embeddings else 0,
+                with_metadata=len(metadatas) if metadatas else 0,
+                with_documents=len(documents) if documents else 0,
+                with_uris=len(uris) if uris else 0,
+            )
+        )
+        return True
+
+    @trace_method("EmbeddingHandler.upsert", OpenTelemetryGranularity.OPERATION)
+    def upsert(
+        self,
+        collection_id: UUID,
+        ids: IDs,
+        embeddings: Embeddings,
+        metadatas: Optional[Metadatas] = None,
+        documents: Optional[Documents] = None,
+        uris: Optional[URIs] = None,
+    ) -> bool:
+        """Upsert embeddings into a collection.
+
+        Args:
+            collection_id: Collection UUID
+            ids: List of IDs
+            embeddings: List of embeddings
+            metadatas: Optional list of metadata dicts
+            documents: Optional list of documents
+            uris: Optional list of URIs
+
+        Returns:
+            True on success
+        """
+        self._quota.static_check(metadatas, documents, embeddings, str(collection_id))
+        coll = self._get_collection_cached(collection_id)
+        self._manager.hint_use_collection(collection_id, t.Operation.UPSERT)
+        validate_batch(
+            (ids, embeddings, metadatas, documents, uris),
+            {"max_batch_size": self._get_max_batch_size()},
+        )
+
+        records_to_submit = []
+        for r in records_from_batch(
+            t.Operation.UPSERT,
+            ids=ids,
+            embeddings=embeddings,
+            metadatas=metadatas,
+            documents=documents,
+            uris=uris,
+        ):
+            self._validate_embedding_record(coll, r)
+            records_to_submit.append(r)
+        self._producer.submit_embeddings(collection_id, records_to_submit)
+
+        return True
+
+    @trace_method("EmbeddingHandler.delete", OpenTelemetryGranularity.OPERATION)
+    def delete(
+        self,
+        collection_id: UUID,
+        ids: Optional[IDs] = None,
+        where: Optional[Where] = None,
+        where_document: Optional[WhereDocument] = None,
+    ) -> IDs:
+        """Delete embeddings from a collection.
+
+        Args:
+            collection_id: Collection UUID
+            ids: Optional list of IDs to delete
+            where: Optional metadata filter
+            where_document: Optional document filter
+
+        Returns:
+            List of deleted IDs
+
+        Raises:
+            ValueError: If no deletion criteria specified
+        """
+        add_attributes_to_current_span(
+            {
+                "collection_id": str(collection_id),
+                "ids_count": len(ids) if ids else 0,
+            }
+        )
+
+        where = validate_where(where) if where is not None and len(where) > 0 else None
+        where_document = (
+            validate_where_document(where_document)
+            if where_document is not None and len(where_document) > 0
+            else None
+        )
+
+        # Require at least one deletion criterion
+        if (
+            (ids is None or (ids is not None and len(ids) == 0))
+            and (where is None or (where is not None and len(where) == 0))
+            and (
+                where_document is None
+                or (where_document is not None and len(where_document) == 0)
+            )
+        ):
+            raise ValueError(
+                """
+                You must provide either ids, where, or where_document to delete. If
+                you want to delete all data in a collection you can delete the
+                collection itself using the delete_collection method. Or alternatively,
+                you can get() all the relevant ids and then delete them.
+                """
+            )
+
+        coll = self._get_collection_cached(collection_id)
+        self._manager.hint_use_collection(collection_id, t.Operation.DELETE)
+
+        if (where or where_document) or not ids:
+            metadata_segment = self._manager.get_segment(collection_id, MetadataReader)
+            records = metadata_segment.get_metadata(
+                where=where, where_document=where_document, ids=ids
+            )
+            ids_to_delete = [r["id"] for r in records]
+        else:
+            ids_to_delete = ids
+
+        if len(ids_to_delete) == 0:
+            return []
+
+        records_to_submit = []
+        for r in records_from_batch(operation=t.Operation.DELETE, ids=ids_to_delete):
+            self._validate_embedding_record(coll, r)
+            records_to_submit.append(r)
+        self._producer.submit_embeddings(collection_id, records_to_submit)
+
+        self._product_telemetry_client.capture(
+            CollectionDeleteEvent(
+                collection_uuid=str(collection_id), delete_amount=len(ids_to_delete)
+            )
+        )
+        return ids_to_delete
+
+    @trace_method("EmbeddingHandler.count", OpenTelemetryGranularity.OPERATION)
+    def count(self, collection_id: UUID) -> int:
+        """Count embeddings in a collection.
+
+        Args:
+            collection_id: Collection UUID
+
+        Returns:
+            Number of embeddings
+        """
+        add_attributes_to_current_span({"collection_id": str(collection_id)})
+        self._validate_collection_exists(collection_id)
+
+        metadata_segment = self._manager.get_segment(collection_id, MetadataReader)
+        return metadata_segment.count()
+
+    # Helper methods
+
+    def _get_collection_cached(self, collection_id: UUID) -> t.Collection:
+        """Get collection from cache."""
+        # Import to avoid circular dependency
+        from chromadb.api.handlers.collection_handler import CollectionHandler
+
+        # This is a temporary approach - ideally we'd inject the collection handler
+        handler = CollectionHandler(self._settings.require(type(self._settings).__bases__[0]))
+        # For now, use the same cache
+        handler._collection_cache = self._collection_cache
+        handler._sysdb = self._sysdb
+        return handler.get_collection_cached(collection_id)
+
+    def _validate_collection_exists(self, collection_id: UUID) -> None:
+        """Validate collection exists."""
+        self._get_collection_cached(collection_id)
+
+    def _validate_embedding_record(
+        self, collection: t.Collection, record: t.OperationRecord
+    ) -> None:
+        """Validate embedding record dimension."""
+        add_attributes_to_current_span({"collection_id": str(collection["id"])})
+        if record["embedding"]:
+            self._validate_dimension(collection, len(record["embedding"]), update=True)
+
+    @trace_method("EmbeddingHandler.validate_dimension", OpenTelemetryGranularity.ALL)
+    def _validate_dimension(
+        self, collection: t.Collection, dim: int, update: bool
+    ) -> None:
+        """Validate collection dimension."""
+        if collection["dimension"] is None:
+            if update:
+                id = collection.id
+                self._sysdb.update_collection(id=id, dimension=dim)
+                self._collection_cache[id]["dimension"] = dim
+        elif collection["dimension"] != dim:
+            raise InvalidDimensionException(
+                f"Embedding dimension {dim} does not match collection "
+                f"dimensionality {collection['dimension']}"
+            )
+
+    def _get_max_batch_size(self) -> int:
+        """Get maximum batch size from settings."""
+        # This would normally come from settings
+        return getattr(self._settings, "chroma_server_max_batch_size", 41666)
diff --git a/chromadb/api/handlers/query_handler.py b/chromadb/api/handlers/query_handler.py
