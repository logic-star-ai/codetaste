new file mode 100644
index 0000000..34bf5b2
--- /dev/null
+++ b/chromadb/core/component.py
@@ -0,0 +1,80 @@
+"""Component base class for dependency injection system."""
+
+import logging
+from abc import ABC
+from typing import Set, Type, TypeVar
+from overrides import EnforceOverrides, override
+
+logger = logging.getLogger(__name__)
+
+T = TypeVar("T", bound="Component")
+
+
+class Component(ABC, EnforceOverrides):
+    """Base class for all injectable components in the system.
+
+    Components participate in dependency injection and have lifecycle
+    management (start/stop/reset).
+    """
+
+    _dependencies: Set["Component"]
+    _system: "System"  # type: ignore
+    _running: bool
+
+    def __init__(self, system: "System"):  # type: ignore
+        """Initialize component with system reference.
+
+        Args:
+            system: The system managing this component
+        """
+        self._dependencies = set()
+        self._system = system
+        self._running = False
+
+    def require(self, type: Type[T]) -> T:
+        """Get a Component instance of the given type.
+
+        This method registers this component as dependent on the returned instance.
+
+        Args:
+            type: The component type to retrieve
+
+        Returns:
+            Instance of the requested component type
+        """
+        inst = self._system.instance(type)
+        self._dependencies.add(inst)
+        return inst
+
+    def dependencies(self) -> Set["Component"]:
+        """Return the full set of components this component depends on.
+
+        Returns:
+            Set of component dependencies
+        """
+        return self._dependencies
+
+    def stop(self) -> None:
+        """Idempotently stop this component's execution.
+
+        Frees all associated resources. Subclasses should override to
+        perform cleanup.
+        """
+        logger.debug(f"Stopping component {self.__class__.__name__}")
+        self._running = False
+
+    def start(self) -> None:
+        """Idempotently start this component's execution.
+
+        Subclasses should override to perform initialization.
+        """
+        logger.debug(f"Starting component {self.__class__.__name__}")
+        self._running = True
+
+    def reset_state(self) -> None:
+        """Reset this component's state to its initial blank state.
+
+        Only intended to be called from tests. Subclasses should override
+        to clear any state.
+        """
+        logger.debug(f"Resetting component {self.__class__.__name__}")
