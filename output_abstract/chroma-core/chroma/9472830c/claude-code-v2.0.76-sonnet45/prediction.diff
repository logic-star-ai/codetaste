+"""Router for directing queries to appropriate segments."""
+
+from typing import Type, Optional
+from uuid import UUID
+import chromadb.types as t
+from chromadb.segment import SegmentImplementation, MetadataReader, VectorReader
+
+
+class SegmentRouter:
+    """Routes queries to the appropriate segment.
+
+    Separates query routing logic from segment management for
+    better modularity and single responsibility.
+    """
+
+    def route_query(
+        self,
+        collection_id: UUID,
+        operation: t.Operation,
+        segment_type: Type[SegmentImplementation],
+    ) -> str:
+        """Route a query to the appropriate segment.
+
+        Args:
+            collection_id: Collection UUID
+            operation: Operation type
+            segment_type: Type of segment needed
+
+        Returns:
+            Segment identifier
+        """
+        # This is a simplified routing logic
+        # Real implementation would be more sophisticated
+        if segment_type == MetadataReader:
+            return f"metadata_{collection_id}"
+        elif segment_type == VectorReader:
+            return f"vector_{collection_id}"
+        else:
+            return f"segment_{collection_id}"
+
+    def should_cache(
+        self,
+        collection_id: UUID,
+        operation: t.Operation,
+    ) -> bool:
+        """Determine if a segment should be cached.
+
+        Args:
+            collection_id: Collection UUID
+            operation: Operation type
+
+        Returns:
+            True if should cache, False otherwise
+        """
+        # Cache frequently accessed operations
+        return operation in [
+            t.Operation.ADD,
+            t.Operation.QUERY,
+            t.Operation.GET,
+        ]
+
+    def get_priority(
+        self,
+        collection_id: UUID,
+        operation: t.Operation,
+    ) -> int:
+        """Get cache priority for a segment.
+
+        Args:
+            collection_id: Collection UUID
+            operation: Operation type
+
+        Returns:
+            Priority level (higher = more important to cache)
+        """
+        # Query operations have higher priority
+        priority_map = {
+            t.Operation.QUERY: 10,
+            t.Operation.GET: 8,
+            t.Operation.ADD: 5,
+            t.Operation.UPDATE: 5,
+            t.Operation.UPSERT: 5,
+            t.Operation.DELETE: 3,
+        }
+        return priority_map.get(operation, 1)
