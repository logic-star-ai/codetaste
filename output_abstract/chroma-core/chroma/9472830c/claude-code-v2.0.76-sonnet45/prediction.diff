+"""Client factory using Builder pattern."""
+
+from typing import Optional, Dict, Any
+from chromadb.config import Settings
+
+
+class ClientFactory:
+    """Factory for creating Chroma clients using the Builder pattern.
+
+    This provides a cleaner, more maintainable approach to client creation
+    compared to having multiple factory functions.
+
+    Example:
+        # Create ephemeral client
+        client = ClientFactory().ephemeral().build()
+
+        # Create persistent client
+        client = ClientFactory().persistent(path="./data").build()
+
+        # Create HTTP client
+        client = ClientFactory().http(host="localhost", port=8000).build()
+
+        # Create with custom settings
+        client = ClientFactory().with_settings(
+            Settings(allow_reset=True)
+        ).persistent().build()
+    """
+
+    def __init__(self):
+        """Initialize the client factory."""
+        self._settings: Optional[Settings] = None
+        self._mode: Optional[str] = None
+        self._params: Dict[str, Any] = {}
+
+    def with_settings(self, settings: Settings) -> "ClientFactory":
+        """Set custom settings for the client.
+
+        Args:
+            settings: Settings instance to use
+
+        Returns:
+            Self for method chaining
+        """
+        self._settings = settings
+        return self
+
+    def ephemeral(self) -> "ClientFactory":
+        """Configure for ephemeral (in-memory) client.
+
+        Returns:
+            Self for method chaining
+        """
+        self._mode = "ephemeral"
+        return self
+
+    def persistent(self, path: str = "./chroma") -> "ClientFactory":
+        """Configure for persistent client.
+
+        Args:
+            path: Path to store persistent data
+
+        Returns:
+            Self for method chaining
+        """
+        self._mode = "persistent"
+        self._params["path"] = path
+        return self
+
+    def http(
+        self,
+        host: str = "localhost",
+        port: int = 8000,
+        ssl: bool = False,
+        headers: Optional[Dict[str, str]] = None,
+    ) -> "ClientFactory":
+        """Configure for HTTP client.
+
+        Args:
+            host: Server host
+            port: Server port
+            ssl: Whether to use SSL
+            headers: Optional HTTP headers
+
+        Returns:
+            Self for method chaining
+        """
+        self._mode = "http"
+        self._params["host"] = host
+        self._params["port"] = port
+        self._params["ssl"] = ssl
+        if headers:
+            self._params["headers"] = headers
+        return self
+
+    def cloud(
+        self,
+        tenant: str,
+        database: str,
+        api_key: Optional[str] = None,
+    ) -> "ClientFactory":
+        """Configure for cloud client.
+
+        Args:
+            tenant: Cloud tenant name
+            database: Database name
+            api_key: Optional API key
+
+        Returns:
+            Self for method chaining
+        """
+        self._mode = "cloud"
+        self._params["tenant"] = tenant
+        self._params["database"] = database
+        if api_key:
+            self._params["api_key"] = api_key
+        return self
+
+    def build(self) -> Any:
+        """Build and return the configured client.
+
+        Returns:
+            Configured Chroma client instance
+
+        Raises:
+            ValueError: If no mode was configured
+        """
+        if self._mode is None:
+            raise ValueError("Must configure client mode before building")
+
+        # Import here to avoid circular dependencies
+        from chromadb import (
+            EphemeralClient,
+            PersistentClient,
+            HttpClient,
+            CloudClient,
+        )
+
+        if self._mode == "ephemeral":
+            if self._settings:
+                return EphemeralClient(self._settings)
+            return EphemeralClient()
+
+        elif self._mode == "persistent":
+            path = self._params.get("path", "./chroma")
+            if self._settings:
+                return PersistentClient(path=path, settings=self._settings)
+            return PersistentClient(path=path)
+
+        elif self._mode == "http":
+            host = self._params.get("host", "localhost")
+            port = self._params.get("port", 8000)
+            ssl = self._params.get("ssl", False)
+            headers = self._params.get("headers")
+            return HttpClient(
+                host=host,
+                port=port,
+                ssl=ssl,
+                headers=headers,
+                settings=self._settings,
+            )
+
+        elif self._mode == "cloud":
+            tenant = self._params["tenant"]
+            database = self._params["database"]
+            api_key = self._params.get("api_key")
+            return CloudClient(
+                tenant=tenant,
+                database=database,
+                api_key=api_key,
+                settings=self._settings,
+            )
+
+        else:
+            raise ValueError(f"Unknown client mode: {self._mode}")
