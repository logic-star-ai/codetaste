-                        allowed_ids is None or id in allowed_ids
-                    ):
-                        curr_results.append(
-                            VectorQueryResult(
-                                id=id,
-                                distance=distances[i][j].item(),
-                                embedding=self.vectors[j].tolist(),
-                            )
-                        )
-            filtered_results.append(curr_results)
-        return filtered_results
