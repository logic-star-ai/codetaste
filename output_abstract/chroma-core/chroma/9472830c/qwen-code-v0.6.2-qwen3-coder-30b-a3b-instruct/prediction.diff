-        key: K,
-    ) -> Option<V> {
-        // Copied from std lib https://doc.rust-lang.org/src/core/slice/mod.rs.html#2786
-        // and modified for two nested level comparisons.
-        let mut size = self.len();
-        let mut left = 0;
-        let mut right = size;
