-                    self.update_count -= 1
-                    self._deleted_ids.add(id)
-                elif (
-                    self._ids_to_records[id]["record"]["operation"] == Operation.UPSERT
-                ):
-                    if id in self._upsert_add_ids:
-                        self.add_count -= 1
-                        self._upsert_add_ids.remove(id)
-                    else:
-                        self.update_count -= 1
-                        self._deleted_ids.add(id)
-            elif id not in self._deleted_ids:
-                self._deleted_ids.add(id)
