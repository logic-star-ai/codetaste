-    }
-
-    let mut iterated = false;
-    let mut max_score = u64::MIN;
-    let mut max_member = None;
-
-    for member in members {
-        if !iterated {
-            iterated = true;
-        }
-        let score = hasher.hash(member.as_ref(), key);
