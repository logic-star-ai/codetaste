-fn f32_to_vec(vector: &[f32]) -> Vec<u8> {
-    unsafe {
-        std::slice::from_raw_parts(
-            vector.as_ptr() as *const u8,
-            vector.len() * std::mem::size_of::<f32>(),
-        )
-    }
-    .to_vec()
-}
