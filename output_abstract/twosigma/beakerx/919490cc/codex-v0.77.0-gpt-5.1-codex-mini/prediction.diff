diff --git a/js/notebook/src/plot/core/pointsLimiter.ts b/js/notebook/src/plot/core/pointsLimiter.ts
new file mode 100644
index 0000000..c4e3d52
--- /dev/null
+++ b/js/notebook/src/plot/core/pointsLimiter.ts
@@ -0,0 +1,112 @@
+export interface PlotGraphic {
+  x?: any[];
+  y?: any[];
+}
+
+export interface StandardPlotModel {
+  graphics_list?: PlotGraphic[];
+  numberOfPoints?: number;
+  outputPointsLimit?: number;
+  outputPointsPreviewNumber?: number;
+}
+
+export interface CombinedPlotModel {
+  plots?: StandardPlotModel[];
+  graphics_list?: PlotGraphic[];
+}
+
+export interface PointsLimitOptions {
+  outputPointsLimit: number;
+  outputPointsPreviewNumber: number;
+}
+
+export const DEFAULT_POINTS_LIMIT_OPTIONS: PointsLimitOptions = {
+  outputPointsLimit: 1000000,
+  outputPointsPreviewNumber: 10000
+};
+
+export function getNumberOfPointsForStandardPlot(plotModel: StandardPlotModel): number {
+  const graphicsList = plotModel && plotModel.graphics_list;
+  if (!Array.isArray(graphicsList) || graphicsList.length === 0) {
+    return 0;
+  }
+
+  let maxPoints = 0;
+  for (let index = 0; index < graphicsList.length; index++) {
+    const graphic = graphicsList[index];
+    const points = graphic && (graphic.x ? graphic.x : graphic.y);
+    const length = points ? points.length : 0;
+    maxPoints = Math.max(maxPoints, length);
+  }
+  return maxPoints;
+}
+
+export function truncatePointsForStandardPlot(
+  plotModel: StandardPlotModel,
+  outputPointsPreviewNumber: number
+): void {
+  const graphicsList = plotModel && plotModel.graphics_list;
+  if (!Array.isArray(graphicsList)) {
+    return;
+  }
+
+  for (let index = 0; index < graphicsList.length; index++) {
+    const graphic = graphicsList[index];
+    if (graphic && graphic.x && graphic.y) {
+      graphic.x = graphic.x.slice(0, outputPointsPreviewNumber);
+      graphic.y = graphic.y.slice(0, outputPointsPreviewNumber);
+    }
+  }
+}
+
+export function limitPointsForStandardPlot(
+  plotModel: StandardPlotModel,
+  numberOfPoints: number,
+  options: PointsLimitOptions
+): void {
+  truncatePointsForStandardPlot(plotModel, options.outputPointsPreviewNumber);
+
+  plotModel.numberOfPoints = numberOfPoints;
+  plotModel.outputPointsLimit = options.outputPointsLimit;
+  plotModel.outputPointsPreviewNumber = options.outputPointsPreviewNumber;
+}
+
+export function limitPoints(plotModel: CombinedPlotModel, options?: Partial<PointsLimitOptions>): void {
+  if (!plotModel) {
+    return;
+  }
+
+  const resolvedOptions: PointsLimitOptions = {
+    outputPointsLimit:
+      options && typeof options.outputPointsLimit === 'number'
+        ? options.outputPointsLimit
+        : DEFAULT_POINTS_LIMIT_OPTIONS.outputPointsLimit,
+    outputPointsPreviewNumber:
+      options && typeof options.outputPointsPreviewNumber === 'number'
+        ? options.outputPointsPreviewNumber
+        : DEFAULT_POINTS_LIMIT_OPTIONS.outputPointsPreviewNumber
+  };
+
+  if (!Array.isArray(plotModel.graphics_list) && !Array.isArray(plotModel.plots)) {
+    return;
+  }
+
+  if (!Array.isArray(plotModel.plots)) {
+    const numberOfPoints = getNumberOfPointsForStandardPlot(plotModel);
+    limitPointsForStandardPlot(plotModel, numberOfPoints, resolvedOptions);
+    return;
+  }
+
+  let maxPointsAcrossPlots = 0;
+  for (let index = 0; index < plotModel.plots.length; index++) {
+    maxPointsAcrossPlots = Math.max(
+      maxPointsAcrossPlots,
+      getNumberOfPointsForStandardPlot(plotModel.plots[index])
+    );
+  }
+
+  for (let index = 0; index < plotModel.plots.length; index++) {
+    limitPointsForStandardPlot(plotModel.plots[index], maxPointsAcrossPlots, resolvedOptions);
+  }
+}
+
diff --git a/js/notebook/src/plot/core/scopeLifecycle.ts b/js/notebook/src/plot/core/scopeLifecycle.ts
new file mode 100644
index 0000000..0de606e
--- /dev/null
+++ b/js/notebook/src/plot/core/scopeLifecycle.ts
@@ -0,0 +1,57 @@
+import * as $ from 'jquery';
+
+export interface ScopeLifecycleArgs {
+  wrapperId: string;
+  widgetModel: any;
+  widgetView: any;
+  hostElement: JQuery;
+  plotModel: any;
+}
+
+export function initStandardPlotScope(PlotScope: any, args: ScopeLifecycleArgs): any {
+  const scope = new PlotScope(args.wrapperId);
+  const tmpl = scope.buildTemplate();
+  const tmplElement = $(tmpl);
+
+  tmplElement.appendTo(args.hostElement);
+
+  scope.setWidgetModel(args.widgetModel);
+  scope.setElement(tmplElement.children('.dtcontainer'));
+  scope.setModelData(args.plotModel);
+  scope.setWidgetView(args.widgetView);
+  scope.init(args.widgetModel);
+
+  return scope;
+}
+
+export function initCombinedPlotScope(CombinedPlotScope: any, args: ScopeLifecycleArgs): any {
+  const scope = new CombinedPlotScope(args.wrapperId);
+  const tmpl = scope.buildTemplate();
+  const tmplElement = $(tmpl);
+
+  tmplElement.appendTo(args.hostElement);
+
+  scope.setModelData(args.plotModel);
+  scope.setElement(tmplElement);
+  scope.setWidgetView(args.widgetView);
+  scope.init(args.widgetModel);
+
+  return scope;
+}
+
+export function destroyPlotScope(scope: any): void {
+  if (!scope) {
+    return;
+  }
+
+  const childScopes = scope.scopes;
+  if (Array.isArray(childScopes)) {
+    childScopes.forEach(function(childScope: any) {
+      childScope && childScope.destroy && childScope.destroy();
+    });
+    return;
+  }
+
+  scope.destroy && scope.destroy();
+}
+
diff --git a/js/notebook/src/plot/core/styleApplier.ts b/js/notebook/src/plot/core/styleApplier.ts
new file mode 100644
index 0000000..6643304
--- /dev/null
+++ b/js/notebook/src/plot/core/styleApplier.ts
@@ -0,0 +1,65 @@
+import * as $ from 'jquery';
+import sanitize from '../plotSanitize';
+
+export interface ApplyCustomStylesArgs {
+  wrapperId: string;
+  scopeId: string;
+  rootElement: JQuery;
+  customStyles: string[];
+}
+
+export interface ApplyElementStylesArgs {
+  wrapperId: string;
+  scopeId: string;
+  rootElement: JQuery;
+  elementStyles: { [selector: string]: string };
+}
+
+function prependSanitizedStyle(rootElement: JQuery, rawCss: string): void {
+  $('<style>\n' + sanitize(rawCss) + '\n</style>').prependTo(rootElement);
+}
+
+export function applyCustomStyles(args: ApplyCustomStylesArgs): void {
+  if (!args.customStyles || args.customStyles.length === 0) {
+    return;
+  }
+
+  const customStyleString = args.customStyles
+    .map(function(style) {
+      return '#' + args.wrapperId + ' #' + args.scopeId + ' ' + style;
+    })
+    .join('\n');
+
+  prependSanitizedStyle(args.rootElement, customStyleString);
+}
+
+export function applyElementStyles(args: ApplyElementStylesArgs): void {
+  if (!args.elementStyles) {
+    return;
+  }
+
+  const styleLines: string[] = [];
+  for (const selector in args.elementStyles) {
+    if (Object.prototype.hasOwnProperty.call(args.elementStyles, selector)) {
+      styleLines.push(
+        '#' + args.wrapperId + ' #' + args.scopeId + ' ' + selector + ' { ' + args.elementStyles[selector] + ' }'
+      );
+    }
+  }
+
+  if (styleLines.length > 0) {
+    prependSanitizedStyle(args.rootElement, styleLines.join('\n'));
+  }
+
+  const titleStyle = args.elementStyles['.plot-title'];
+  if (titleStyle) {
+    const titleSelector = '.plot-title-' + args.scopeId;
+    prependSanitizedStyle($(titleSelector), titleSelector + ' { ' + titleStyle + ' }');
+  }
+}
+
+export default {
+  applyCustomStyles: applyCustomStyles,
+  applyElementStyles: applyElementStyles
+};
+
