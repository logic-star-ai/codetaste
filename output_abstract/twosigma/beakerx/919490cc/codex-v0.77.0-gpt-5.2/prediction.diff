diff --git a/js/notebook/src/plotting/scopes/scopeFactory.ts b/js/notebook/src/plotting/scopes/scopeFactory.ts
new file mode 100644
index 0000000..f5e8d39
--- /dev/null
+++ b/js/notebook/src/plotting/scopes/scopeFactory.ts
@@ -0,0 +1,53 @@
+import { PlotScopeHandle } from './scopeTypes';
+
+const PlotScope = require('../../plot/plotScope');
+const CombinedPlotScope = require('../../plot/combinedPlotScope');
+
+type AnyPlotModel = any;
+type AnyWidgetModel = any;
+type AnyWidgetView = any;
+
+function destroyCombinedPlotScope(scope: any): void {
+  if (!scope) {
+    return;
+  }
+
+  if (scope.scopes && Array.isArray(scope.scopes)) {
+    scope.scopes.forEach((childScope: any) => {
+      childScope && childScope.destroy && childScope.destroy();
+    });
+  }
+
+  scope.doDestroy && scope.doDestroy();
+}
+
+function destroyStandardPlotScope(scope: any): void {
+  if (!scope) {
+    return;
+  }
+
+  scope.destroy && scope.destroy();
+}
+
+export function createScopeHandle(opts: {
+  model: AnyPlotModel;
+  widgetModel: AnyWidgetModel;
+  widgetView: AnyWidgetView;
+}): PlotScopeHandle {
+  const type = (opts.model && opts.model.type) || 'Text';
+
+  if (type === 'CombinedPlot') {
+    const scope = new CombinedPlotScope(`wrap_${opts.widgetView.id}`);
+    return {
+      scope,
+      destroy: () => destroyCombinedPlotScope(scope)
+    };
+  }
+
+  const scope = new PlotScope(`wrap_${opts.widgetModel.model_id}`);
+  return {
+    scope,
+    destroy: () => destroyStandardPlotScope(scope)
+  };
+}
+
