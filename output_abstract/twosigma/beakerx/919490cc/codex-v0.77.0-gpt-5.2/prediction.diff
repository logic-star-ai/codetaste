diff --git a/js/notebook/src/plotting/controller/plotWidgetController.ts b/js/notebook/src/plotting/controller/plotWidgetController.ts
new file mode 100644
index 0000000..ea23bf5
--- /dev/null
+++ b/js/notebook/src/plotting/controller/plotWidgetController.ts
@@ -0,0 +1,92 @@
+import { limitPlotPoints } from '../points/pointLimiter';
+import { createScopeHandle } from '../scopes/scopeFactory';
+import { PlotScopeHandle } from '../scopes/scopeTypes';
+import * as _ from 'underscore';
+
+type AnyWidgetModel = any;
+type AnyWidgetView = any;
+
+export class PlotWidgetController {
+  private currentScopeHandle: PlotScopeHandle | null = null;
+
+  constructor(private readonly widgetView: AnyWidgetView, private readonly widgetModel: AnyWidgetModel) {}
+
+  render(): void {
+    this.currentScopeHandle = null;
+
+    this.widgetView.displayed.then(() => {
+      const plotModel = this.widgetModel.get('model');
+      limitPlotPoints(plotModel);
+
+      this.initPlot(plotModel);
+
+      this.widgetView.listenTo(this.widgetModel, 'change:updateData', this.widgetView.handleUpdateData);
+      this.widgetView.listenTo(this.widgetModel, 'change:model', this.widgetView.handleModellUpdate);
+      this.widgetView.listenTo(this.widgetModel, 'beakerx-tabSelected', () => {
+        const scope = this.currentScopeHandle && this.currentScopeHandle.scope;
+        scope && scope.adjustModelWidth && scope.adjustModelWidth();
+      });
+
+      this.widgetView.on('remove', () => this.destroy());
+    });
+  }
+
+  destroy(): void {
+    if (this.currentScopeHandle) {
+      this.currentScopeHandle.destroy();
+    }
+
+    setTimeout(() => {
+      this.currentScopeHandle = null;
+    });
+  }
+
+  handleModelUpdate(): void {
+    const newModel = this.widgetModel.get('model');
+    const scope = this.currentScopeHandle && this.currentScopeHandle.scope;
+
+    if (!scope) {
+      return;
+    }
+
+    scope.updateModelData && scope.updateModelData(newModel);
+    scope.updatePlot && scope.updatePlot();
+  }
+
+  handleUpdateData(): void {
+    const change = this.widgetModel.get('updateData');
+    const currentModel = this.widgetModel.get('model');
+    const updatedModel = _.extend(currentModel, change);
+    this.widgetModel.set('model', updatedModel, { updated_view: this.widgetView });
+
+    this.handleModelUpdate();
+  }
+
+  private initPlot(model: any): void {
+    this.currentScopeHandle = createScopeHandle({
+      model,
+      widgetModel: this.widgetModel,
+      widgetView: this.widgetView
+    });
+
+    const scope = this.currentScopeHandle.scope;
+    const tmpl = scope.buildTemplate();
+    const tmplElement = $(tmpl);
+
+    tmplElement.appendTo(this.widgetView.$el);
+
+    if ((model && model.type) === 'CombinedPlot') {
+      scope.setModelData(model);
+      scope.setElement(tmplElement);
+      scope.setWidgetView(this.widgetView);
+      scope.init(this.widgetModel);
+      return;
+    }
+
+    scope.setWidgetModel(this.widgetModel);
+    scope.setElement(tmplElement.children('.dtcontainer'));
+    scope.setModelData(model);
+    scope.setWidgetView(this.widgetView);
+    scope.init(this.widgetModel);
+  }
+}
diff --git a/js/notebook/src/plotting/points/pointLimiter.ts b/js/notebook/src/plotting/points/pointLimiter.ts
new file mode 100644
index 0000000..4aaf0f1
--- /dev/null
+++ b/js/notebook/src/plotting/points/pointLimiter.ts
@@ -0,0 +1,67 @@
+import * as _ from 'underscore';
+import { OUTPUT_POINTS_LIMIT, OUTPUT_POINTS_PREVIEW_NUMBER } from './pointLimits';
+
+type AnyPlotModel = any;
+
+function getNumberOfPointsForStandardPlot(plotModel: AnyPlotModel): number {
+  if (!plotModel || !_.isArray(plotModel.graphics_list)) {
+    return 0;
+  }
+
+  return Math.max.apply(
+    null,
+    plotModel.graphics_list.map((graphic: any) => {
+      const points = graphic && (graphic.x ? graphic.x : graphic.y);
+      return points ? points.length : 0;
+    })
+  );
+}
+
+function truncatePointsForStandardPlot(plotModel: AnyPlotModel): void {
+  if (!plotModel || !_.isArray(plotModel.graphics_list)) {
+    return;
+  }
+
+  plotModel.graphics_list.forEach((graphic: any) => {
+    if (graphic && graphic.x && graphic.y) {
+      graphic.x = graphic.x.slice(0, OUTPUT_POINTS_PREVIEW_NUMBER);
+      graphic.y = graphic.y.slice(0, OUTPUT_POINTS_PREVIEW_NUMBER);
+    }
+  });
+}
+
+function limitPointsForStandardPlot(plotModel: AnyPlotModel, numberOfPoints: number): void {
+  truncatePointsForStandardPlot(plotModel);
+
+  plotModel.numberOfPoints = numberOfPoints;
+  plotModel.outputPointsLimit = OUTPUT_POINTS_LIMIT;
+  plotModel.outputPointsPreviewNumber = OUTPUT_POINTS_PREVIEW_NUMBER;
+}
+
+export function limitPlotPoints(plotModel: AnyPlotModel): void {
+  if (!plotModel) {
+    return;
+  }
+
+  if (!_.isArray(plotModel.graphics_list) && !_.isArray(plotModel.plots)) {
+    return;
+  }
+
+  if (!plotModel.plots) {
+    const numberOfPoints = getNumberOfPointsForStandardPlot(plotModel);
+    limitPointsForStandardPlot(plotModel, numberOfPoints);
+    return;
+  }
+
+  const maxPoints = Math.max.apply(
+    null,
+    plotModel.plots.map((standardPlotModel: AnyPlotModel) =>
+      getNumberOfPointsForStandardPlot(standardPlotModel)
+    )
+  );
+
+  plotModel.plots.forEach((standardPlotModel: AnyPlotModel) => {
+    limitPointsForStandardPlot(standardPlotModel, maxPoints);
+  });
+}
+
