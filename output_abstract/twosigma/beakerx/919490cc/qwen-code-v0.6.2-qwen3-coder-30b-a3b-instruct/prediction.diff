+
+import widgets from '../widgets';
+import * as _ from 'underscore';
+
+// Import base classes and components
+import { BaseModel } from '../models/PlotModel';
+
+// Define types for better type safety
+export interface PlotModelData {
+  [key: string]: any;
+}
+
+export interface PlotViewOptions {
+  model: any;
+  options?: any;
+}
+
+export class PlotModel extends widgets.DOMWidgetModel {
+  defaults() {
+    return {
+      ...super.defaults(),
+      _model_name : 'PlotModel',
+      _view_name : 'PlotView',
+      _model_module : 'beakerx',
+      _view_module : 'beakerx',
+      _model_module_version: BEAKERX_MODULE_VERSION,
+      _view_module_version: BEAKERX_MODULE_VERSION
+    }
+  }
+}
+
+export class PlotView extends widgets.DOMWidgetView {
+  protected _currentScope: any = null;
+  protected static readonly OUTPUT_POINTS_LIMIT = 1000000;
+  protected static readonly OUTPUT_POINTS_PREVIEW_NUMBER = 10000;
+
+  initialize(options: PlotViewOptions) {
+    super.initialize(options);
+  }
+
+  render() {
+    this._currentScope = null;
+
+    this.displayed.then(() => {
+      const plotModel = this.model.get('model');
+      const type = plotModel.type || 'Text';
+
+      this.limitPoints(plotModel);
+
+      switch (type) {
+        case 'CombinedPlot':
+          this.initCombinedPlot(plotModel);
+          break;
+        default:
+          this.initStandardPlot(plotModel);
+          break;
+      }
+
+      this.listenTo(this.model, 'change:updateData', this.handleUpdateData);
+      this.listenTo(this.model, 'change:model', this.handleModellUpdate);
+      this.listenTo(this.model, 'beakerx-tabSelected', () => {
+        this._currentScope.adjustModelWidth();
+      });
+
+      this.on('remove', () => {
+        if (this._currentScope) {
+          this._currentScope.destroy();
+        }
+        setTimeout(() => { this._currentScope = null; });
+      });
+    });
+  }
+
+  getNumberOfPointsForStandardPlot(plotModel: PlotModelData): number {
+    return Math.max.apply(null, plotModel.graphics_list.map((graphic: any) => {
+      const points = graphic.x ? graphic.x : graphic.y;
+      return points ? points.length : 0;
+    }));
+  }
+
+  truncatePointsForStandardPlot(plotModel: PlotModelData): void {
+    plotModel.graphics_list.forEach((graphic: any) => {
+      if (graphic.x && graphic.y) {
+        graphic.x = graphic.x.slice(0, PlotView.OUTPUT_POINTS_PREVIEW_NUMBER);
+        graphic.y = graphic.y.slice(0, PlotView.OUTPUT_POINTS_PREVIEW_NUMBER);
+      }
+    });
+  }
+
+  limitPoints(plotModel: PlotModelData): void {
+    let numberOfPoints: number;
+
+    if (!_.isArray(plotModel.graphics_list)) {
+      return;
+    }
+
+    if (!plotModel.plots) {
+      numberOfPoints = this.getNumberOfPointsForStandardPlot(plotModel);
+      this.limitPointsForStandardPlot(plotModel, numberOfPoints);
+      return;
+    }
+
+    numberOfPoints = Math.max.apply(plotModel.plots.map(this.getNumberOfPointsForStandardPlot));
+    plotModel.plots.forEach((standardPlotModel: PlotModelData) => {
+      this.limitPointsForStandardPlot(standardPlotModel, numberOfPoints);
+    });
+  }
+
+  limitPointsForStandardPlot(plotModel: PlotModelData, numberOfPoints: number): void {
+    this.truncatePointsForStandardPlot(plotModel);
+
+    plotModel.numberOfPoints = numberOfPoints;
+    plotModel.outputPointsLimit = PlotView.OUTPUT_POINTS_LIMIT;
+    plotModel.outputPointsPreviewNumber = PlotView.OUTPUT_POINTS_PREVIEW_NUMBER;
+  }
+
+  handleModellUpdate(): void {
+    const newModel = this.model.get('model');
+    this._currentScope.updateModelData && this._currentScope.updateModelData(newModel);
+    this._currentScope.updatePlot();
+  }
+
+  handleUpdateData(): void {
+    const change = this.model.get('updateData');
+    const currentModel = this.model.get('model');
+    const updatedModel = _.extend(currentModel, change);
+    this.model.set('model', updatedModel, {updated_view: this});
+    this.handleModellUpdate();
+  }
+
+  initStandardPlot(model: PlotModelData): void {
+    // Implementation to be moved to scope layer
+  }
+
+  initCombinedPlot(model: PlotModelData): void {
+    // Implementation to be moved to scope layer
+  }
+}
