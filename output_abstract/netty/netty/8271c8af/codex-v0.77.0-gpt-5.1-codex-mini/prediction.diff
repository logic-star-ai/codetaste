+package io.netty.handler.codec.dns;
+
+import io.netty.buffer.ByteBuf;
+import io.netty.handler.codec.CorruptedFrameException;
+import io.netty.util.CharsetUtil;
+
+/**
+ * Utility methods used for encoding and decoding of DNS messages.
+ */
+public final class DnsCodecUtil {
+
+    private static final int MAX_LABEL_LEN = 63;
+    private static final int MAX_NAME_LEN = 255;
+
+    private DnsCodecUtil() {
+    }
+
+    /**
+     * Decodes a domain name given a buffer containing a DNS packet. If the name contains a pointer, the position of
+     * the buffer will be set to directly after the pointer's index after the name has been read.
+     *
+     * @param buf the buffer containing the DNS packet
+     * @return the decoded domain name. The root domain is represented as an empty string.
+     */
+    public static String decodeDomainName(ByteBuf buf) {
+        int position = -1;
+        int checked = 0;
+        int length = buf.writerIndex();
+        StringBuilder name = new StringBuilder(64);
+
+        while (buf.isReadable()) {
+            int len = buf.readUnsignedByte();
+            if (len == 0) {
+                break;
+            }
+
+            boolean pointer = (len & 0xc0) == 0xc0;
+            if (pointer) {
+                if (!buf.isReadable()) {
+                    throw new CorruptedFrameException("truncated pointer in a name.");
+                }
+
+                if (position == -1) {
+                    position = buf.readerIndex() + 1;
+                }
+
+                int next = (len & 0x3f) << 8 | buf.readUnsignedByte();
+                if (next >= length) {
+                    throw new CorruptedFrameException("name has an out-of-range pointer.");
+                }
+
+                buf.readerIndex(next);
+                checked += 2;
+            } else {
+                if (len > MAX_LABEL_LEN) {
+                    throw new CorruptedFrameException("name contains a label with length greater than 63.");
+                }
+                if (buf.readableBytes() < len) {
+                    throw new CorruptedFrameException("truncated label in a name.");
+                }
+
+                name.append(buf.toString(buf.readerIndex(), len, CharsetUtil.US_ASCII)).append('.');
+                buf.skipBytes(len);
+                checked += 1 + len;
+            }
+
+            // Guard against pointer loops and other malformed names.
+            if (checked >= length) {
+                throw new CorruptedFrameException("name contains a loop.");
+            }
+            if (name.length() > MAX_NAME_LEN) {
+                throw new CorruptedFrameException("name is too long.");
+            }
+        }
+
+        if (position != -1) {
+            buf.readerIndex(position);
+        }
+
+        if (name.length() == 0) {
+            return "";
+        }
+
+        return name.substring(0, name.length() - 1);
+    }
+
+    /**
+     * Encodes a domain name according to RFC 1035.
+     *
+     * @param buf  the output buffer
+     * @param name the domain name. The root domain can be represented as either an empty string or {@code "."}.
+     */
+    public static void encodeDomainName(ByteBuf buf, String name) {
+        if (name == null) {
+            throw new NullPointerException("name");
+        }
+
+        if (name.length() == 0 || ".".equals(name)) {
+            buf.writeByte(0);
+            return;
+        }
+
+        final int nameLen = name.length();
+        int totalLen = 1; // includes the terminating zero byte
+
+        int labelStart = 0;
+        for (int i = 0; i <= nameLen; i++) {
+            char c = i == nameLen ? '.' : name.charAt(i);
+            if (c == '.') {
+                int labelLen = i - labelStart;
+                if (labelLen == 0) {
+                    // Allow a trailing dot, but reject empty labels elsewhere.
+                    if (i == nameLen) {
+                        break;
+                    }
+                    throw new IllegalArgumentException("name contains an empty label: " + name);
+                }
+                if (labelLen > MAX_LABEL_LEN) {
+                    throw new IllegalArgumentException("name contains a label longer than 63 characters: " + name);
+                }
+
+                totalLen += 1 + labelLen;
+                if (totalLen > MAX_NAME_LEN) {
+                    throw new IllegalArgumentException("name is too long: " + name);
+                }
+
+                buf.writeByte(labelLen);
+                for (int j = labelStart; j < i; j++) {
+                    char labelChar = name.charAt(j);
+                    if (labelChar > 0x7f) {
+                        throw new IllegalArgumentException(
+                                "name contains non-ASCII character: " + name);
+                    }
+                    buf.writeByte((byte) labelChar);
+                }
+
+                labelStart = i + 1;
+            } else if (c > 0x7f) {
+                throw new IllegalArgumentException("name contains non-ASCII character: " + name);
+            }
+        }
+
+        buf.writeByte(0); // marks end of name field
+    }
+}
