+package io.netty.handler.codec.dns;
+
+import io.netty.buffer.ByteBuf;
+import io.netty.channel.ChannelHandlerContext;
+import io.netty.handler.codec.ByteToMessageDecoder;
+import io.netty.handler.codec.CorruptedFrameException;
+
+import java.util.List;
+
+/**
+ * Decodes DNS messages over TCP using the 2-byte length prefix defined in RFC 1035 section 4.2.2.
+ */
+public final class TcpDnsMessageDecoder extends ByteToMessageDecoder {
+
+    private final DnsMessageCodec codec;
+
+    public TcpDnsMessageDecoder() {
+        this(DefaultDnsMessageCodec.INSTANCE);
+    }
+
+    public TcpDnsMessageDecoder(DnsMessageCodec codec) {
+        if (codec == null) {
+            throw new NullPointerException("codec");
+        }
+        this.codec = codec;
+    }
+
+    @Override
+    protected void decode(ChannelHandlerContext ctx, ByteBuf in, List<Object> out) throws Exception {
+        if (in.readableBytes() < 2) {
+            return;
+        }
+
+        in.markReaderIndex();
+        int length = in.readUnsignedShort();
+        if (in.readableBytes() < length) {
+            in.resetReaderIndex();
+            return;
+        }
+
+        if (length < DnsCodecUtil.DNS_HEADER_SIZE) {
+            throw new CorruptedFrameException("DNS message is too short: " + length);
+        }
+
+        ByteBuf frame = in.readSlice(length).retain();
+        try {
+            out.add(codec.decode(frame));
+        } finally {
+            frame.release();
+        }
+    }
+}
