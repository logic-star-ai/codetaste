+
+import java.net.InetSocketAddress;
+
+public class DnsCodecComplianceTest {
+
+    @Rule
+    public ExpectedException exception = ExpectedException.none();
+
+    @Test
+    public void queryOpcodeEncodedInCorrectBits() {
+        InetSocketAddress addr = new InetSocketAddress(0);
+        EmbeddedChannel channel = new EmbeddedChannel(new DnsQueryEncoder());
+        DnsQuery query = new DnsQuery(1, addr)
+                .addQuestion(new DnsQuestion("www.example.com", DnsType.A));
+        query.header().setOpcode(DnsHeader.OPCODE_IQUERY);
+
+        channel.writeOutbound(query);
+        DatagramPacket packet = channel.readOutbound();
+        try {
+            ByteBuf content = packet.content();
+            int flags = content.getUnsignedShort(2);
+            Assert.assertEquals(0x0900, flags);
+            Assert.assertEquals(0, flags & 0x4000);
+        } finally {
+            packet.release();
+        }
+    }
+
+    @Test
+    public void queryNameLabelTooLongFailsFast() {
+        InetSocketAddress addr = new InetSocketAddress(0);
+        EmbeddedChannel channel = new EmbeddedChannel(new DnsQueryEncoder());
+
+        StringBuilder label = new StringBuilder(64);
+        for (int i = 0; i < 64; i++) {
+            label.append('a');
+        }
+
+        DnsQuery query = new DnsQuery(1, addr)
+                .addQuestion(new DnsQuestion(label + ".com", DnsType.A));
+
+        exception.expect(EncoderException.class);
+        channel.writeOutbound(query);
+    }
+
+    @Test
+    public void queryNameTooLongFailsFast() {
+        InetSocketAddress addr = new InetSocketAddress(0);
+        EmbeddedChannel channel = new EmbeddedChannel(new DnsQueryEncoder());
+
+        StringBuilder label = new StringBuilder(63);
+        for (int i = 0; i < 63; i++) {
+            label.append('a');
+        }
+
+        String name = label + "." + label + "." + label + "." + label;
+        DnsQuery query = new DnsQuery(1, addr)
