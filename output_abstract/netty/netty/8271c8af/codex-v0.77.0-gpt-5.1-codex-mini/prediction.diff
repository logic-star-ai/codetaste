+package io.netty.handler.codec.dns;
+
+import io.netty.buffer.ByteBuf;
+
+/**
+ * Encodes and decodes DNS messages in their wire format as defined in RFC 1035.
+ * <p>
+ * This interface intentionally does not model any transport. Transports such as UDP (datagrams) and TCP (stream with a
+ * 2-byte length prefix) should be implemented separately.
+ */
+public interface DnsMessageCodec {
+
+    /**
+     * Encodes {@code message} in wire format into {@code out}.
+     */
+    void encode(DnsMessage message, ByteBuf out) throws Exception;
+
+    /**
+     * Decodes a complete DNS message in wire format from {@code in}.
+     */
+    DnsMessage decode(ByteBuf in) throws Exception;
+}
+
