+package io.netty.handler.codec.dns;
+
+import io.netty.buffer.ByteBuf;
+import io.netty.handler.codec.CorruptedFrameException;
+import io.netty.util.CharsetUtil;
+import io.netty.util.internal.StringUtil;
+
+import java.nio.charset.Charset;
+
+final class DnsCodecUtil {
+
+    static final int DNS_HEADER_SIZE = 12;
+    static final Charset DNS_CHARSET = CharsetUtil.US_ASCII;
+
+    private DnsCodecUtil() {
+    }
+
+    static void encodeDomainName(String name, ByteBuf out) {
+        if (name == null) {
+            throw new NullPointerException("name");
+        }
+        if (name.length() == 0) {
+            out.writeByte(0);
+            return;
+        }
+
+        String[] labels = StringUtil.split(name, '.');
+        for (int i = 0; i < labels.length; i++) {
+            String label = labels[i];
+            int labelLen = label.length();
+            if (labelLen == 0) {
+                continue;
+            }
+            if (labelLen > 63) {
+                throw new IllegalArgumentException("label is too long: " + label);
+            }
+            out.writeByte(labelLen);
+            out.writeBytes(label.getBytes(DNS_CHARSET));
+        }
+        out.writeByte(0); // root label
+    }
+
+    /**
+     * Decodes a domain name (QNAME/NAME) and advances {@code in.readerIndex()} accordingly.
+     * <p>
+     * If the name uses compression pointers, the reader index is restored to directly after the pointer once the name
+     * is decoded (RFC 1035 section 4.1.4).
+     */
+    static String decodeDomainName(ByteBuf in) {
+        int position = -1;
+        int checked = 0;
+        int length = in.writerIndex();
+        StringBuilder name = new StringBuilder(64);
+
+        for (int len = in.readUnsignedByte(); in.isReadable() && len != 0; len = in.readUnsignedByte()) {
+            boolean pointer = (len & 0xc0) == 0xc0;
+            if (pointer) {
+                if (position == -1) {
+                    position = in.readerIndex() + 1;
+                }
+                in.readerIndex((len & 0x3f) << 8 | in.readUnsignedByte());
+
+                // Check for loops.
+                checked += 2;
+                if (checked >= length) {
+                    throw new CorruptedFrameException("domain name contains a loop.");
+                }
+            } else {
+                name.append(in.toString(in.readerIndex(), len, DNS_CHARSET)).append('.');
+                in.skipBytes(len);
+            }
+        }
+
+        if (position != -1) {
+            in.readerIndex(position);
+        }
+
+        if (name.length() == 0) {
+            return "";
+        }
+
+        return name.substring(0, name.length() - 1);
+    }
+}
+
