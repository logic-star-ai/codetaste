+package io.netty.handler.codec.dns;
+
+import io.netty.buffer.ByteBuf;
+import io.netty.channel.ChannelHandler;
+import io.netty.channel.ChannelHandlerContext;
+import io.netty.handler.codec.CorruptedFrameException;
+import io.netty.handler.codec.MessageToByteEncoder;
+
+/**
+ * Encodes {@link DnsMessage} for TCP transport using the 2-byte length prefix defined in RFC 1035 section 4.2.2.
+ */
+@ChannelHandler.Sharable
+public final class TcpDnsMessageEncoder extends MessageToByteEncoder<DnsMessage> {
+
+    private final DnsMessageCodec codec;
+
+    public TcpDnsMessageEncoder() {
+        this(DefaultDnsMessageCodec.INSTANCE);
+    }
+
+    public TcpDnsMessageEncoder(DnsMessageCodec codec) {
+        if (codec == null) {
+            throw new NullPointerException("codec");
+        }
+        this.codec = codec;
+    }
+
+    @Override
+    protected void encode(ChannelHandlerContext ctx, DnsMessage msg, ByteBuf out) throws Exception {
+        int lengthIndex = out.writerIndex();
+        out.writeShort(0); // placeholder
+        int messageIndex = out.writerIndex();
+
+        codec.encode(msg, out);
+
+        int messageLength = out.writerIndex() - messageIndex;
+        if (messageLength > 65535) {
+            throw new CorruptedFrameException("DNS message is too long for TCP transport: " + messageLength);
+        }
+        out.setShort(lengthIndex, messageLength);
+    }
+}
