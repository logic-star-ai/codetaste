+ * WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied. See the
+ * License for the specific language governing permissions and limitations
+ * under the License.
+ */
+package io.netty.handler.codec.dns;
+
+import io.netty.buffer.ByteBuf;
+import io.netty.handler.codec.CorruptedFrameException;
+
+import java.util.List;
+
+/**
+ * The default {@link DnsMessageCodec} implementation.
+ * <p>
+ * This codec does not implement name compression when encoding.
+ */
+public final class DefaultDnsMessageCodec implements DnsMessageCodec {
+
+    public static final DefaultDnsMessageCodec INSTANCE = new DefaultDnsMessageCodec();
+
+    private DefaultDnsMessageCodec() {
+    }
+
+    public void encode(DnsMessage message, ByteBuf out) throws Exception {
+        if (message == null) {
+            throw new NullPointerException("message");
+        }
+        if (out == null) {
+            throw new NullPointerException("out");
+        }
+
+        DnsHeader header = message.header();
+        out.writeShort(header.id());
+        out.writeShort(encodeFlags(header));
+
+        out.writeShort(message.questions().size());
+        out.writeShort(message.answers().size());
+        out.writeShort(message.authorityResources().size());
+        out.writeShort(message.additionalResources().size());
+
+        List<DnsQuestion> questions = message.questions();
+        for (int i = 0; i < questions.size(); i++) {
+            encodeQuestion(questions.get(i), out);
+        }
+
+        encodeResources(message.answers(), out);
+        encodeResources(message.authorityResources(), out);
+        encodeResources(message.additionalResources(), out);
+    }
+
+    private static void encodeResources(List<DnsResource> resources, ByteBuf out) {
+        for (int i = 0; i < resources.size(); i++) {
+            encodeResourceRecord(resources.get(i), out);
+        }
+    }
+
+    private static int encodeFlags(DnsHeader header) {
+        int flags = 0;
+
+        // QR
+        flags |= (header.type() & 0x1) << 15;
+
+        // OPCODE (4 bits)
+        flags |= (header.opcode() & 0xF) << 11;
+
+        // RD
+        flags |= header.isRecursionDesired() ? 1 << 8 : 0;
+
+        // Z (3 bits) - reserved in RFC 1035.
+        flags |= (header.z() & 0x7) << 4;
+
+        if (header instanceof DnsResponseHeader) {
+            DnsResponseHeader responseHeader = (DnsResponseHeader) header;
+
+            // AA
+            flags |= responseHeader.isAuthoritativeAnswer() ? 1 << 10 : 0;
+            // TC
+            flags |= responseHeader.isTruncated() ? 1 << 9 : 0;
+            // RA
+            flags |= responseHeader.isRecursionAvailable() ? 1 << 7 : 0;
+
+            DnsResponseCode rcode = responseHeader.responseCode();
+            if (rcode != null) {
+                flags |= rcode.code() & 0xF;
+            }
+        }
+
+        return flags;
+    }
+
+    private static void encodeQuestion(DnsQuestion question, ByteBuf out) {
+        DnsCodecUtil.encodeDomainName(question.name(), out);
+        out.writeShort(question.type().intValue());
+        out.writeShort(question.dnsClass().intValue());
+    }
+
+    private static void encodeResourceRecord(DnsResource resource, ByteBuf out) {
+        DnsCodecUtil.encodeDomainName(resource.name(), out);
+
+        out.writeShort(resource.type().intValue());
+        out.writeShort(resource.dnsClass().intValue());
+        out.writeInt((int) resource.timeToLive());
+
+        ByteBuf content = resource.content();
+        int contentLen = content.readableBytes();
+        out.writeShort(contentLen);
+        out.writeBytes(content, content.readerIndex(), contentLen);
+    }
+
+    public DnsMessage decode(ByteBuf in) throws Exception {
+        if (in == null) {
+            throw new NullPointerException("in");
+        }
+        if (in.readableBytes() < DnsCodecUtil.DNS_HEADER_SIZE) {
+            throw new CorruptedFrameException("DNS message is too short: " + in.readableBytes());
+        }
+
+        int id = in.readUnsignedShort();
+        int flags = in.readUnsignedShort();
+
+        boolean isResponse = (flags >> 15 & 0x1) == 1;
+        DnsMessage message = isResponse ? new DnsResponse(id) : new DnsQuery(id);
+
+        boolean release = true;
+        try {
+            DnsHeader header = message.header();
+            header.setOpcode(flags >> 11 & 0xF);
+            header.setRecursionDesired((flags >> 8 & 0x1) == 1);
+            header.setZ(flags >> 4 & 0x7);
+
+            if (header instanceof DnsResponseHeader) {
+                DnsResponseHeader responseHeader = (DnsResponseHeader) header;
+                responseHeader.setAuthoritativeAnswer((flags >> 10 & 0x1) == 1);
+                responseHeader.setTruncated((flags >> 9 & 0x1) == 1);
+                responseHeader.setRecursionAvailable((flags >> 7 & 0x1) == 1);
+                responseHeader.setResponseCode(DnsResponseCode.valueOf(flags & 0xF));
+            }
+
+            int questionCount = in.readUnsignedShort();
+            int answerCount = in.readUnsignedShort();
+            int authorityCount = in.readUnsignedShort();
+            int additionalCount = in.readUnsignedShort();
+
+            for (int i = 0; i < questionCount; i++) {
+                message.addQuestion(decodeQuestion(in));
+            }
+            for (int i = 0; i < answerCount; i++) {
+                message.addAnswer(decodeResourceRecord(in));
+            }
+            for (int i = 0; i < authorityCount; i++) {
+                message.addAuthorityResource(decodeResourceRecord(in));
+            }
+            for (int i = 0; i < additionalCount; i++) {
+                message.addAdditionalResource(decodeResourceRecord(in));
+            }
+
+            release = false;
+            return message;
+        } finally {
+            if (release) {
+                message.release();
+            }
+        }
+    }
+
+    private static DnsQuestion decodeQuestion(ByteBuf in) {
+        String name = DnsCodecUtil.decodeDomainName(in);
+        DnsType type = DnsType.valueOf(in.readUnsignedShort());
+        DnsClass qClass = DnsClass.valueOf(in.readUnsignedShort());
+        return new DnsQuestion(name, type, qClass);
+    }
+
+    private static DnsResource decodeResourceRecord(ByteBuf in) {
+        String name = DnsCodecUtil.decodeDomainName(in);
+        DnsType type = DnsType.valueOf(in.readUnsignedShort());
+        DnsClass aClass = DnsClass.valueOf(in.readUnsignedShort());
+        long ttl = in.readUnsignedInt();
+        int len = in.readUnsignedShort();
+
+        int readerIndex = in.readerIndex();
+        ByteBuf rdata = in.duplicate().setIndex(readerIndex, readerIndex + len).retain();
+        in.readerIndex(readerIndex + len);
+
+        return new DnsResource(name, type, aClass, ttl, rdata);
+    }
+}
