+package io.netty.handler.codec.dns;
+
+import io.netty.buffer.ByteBuf;
+import io.netty.buffer.ByteBufUtil;
+import io.netty.handler.codec.CorruptedFrameException;
+import io.netty.handler.codec.EncoderException;
+import io.netty.util.CharsetUtil;
+
+/**
+ * Shared DNS codec utilities (name encoding/decoding, header flags).
+ */
+final class DnsCodecUtil {
+
+    static final int MAX_LABEL_LENGTH = 63;
+    static final int MAX_NAME_LENGTH = 255;
+
+    private DnsCodecUtil() {
+    }
+
+    static void encodeQueryHeader(DnsHeader header, ByteBuf out) {
+        out.writeShort(header.id());
+
+        int flags = 0;
+        flags |= (header.type() & 0x1) << 15;
+        flags |= (header.opcode() & 0xf) << 11;
+        flags |= header.isRecursionDesired() ? 1 << 8 : 0;
+        flags |= (header.z() & 0x7) << 4;
+        out.writeShort(flags);
+
+        writeUnsignedShort(out, header.questionCount(), "QDCOUNT");
+        out.writeShort(0); // ANCOUNT
+        out.writeShort(0); // NSCOUNT
+        writeUnsignedShort(out, header.additionalResourceCount(), "ARCOUNT");
+    }
+
+    static void encodeQuestion(DnsQuestion question, DnsNameEncoder nameEncoder, ByteBuf out) {
+        nameEncoder.encodeName(question.name(), out);
+        out.writeShort(question.type().intValue());
+        out.writeShort(question.dnsClass().intValue());
+    }
+
+    static void encodeResource(DnsResource resource, DnsNameEncoder nameEncoder, ByteBuf out) {
+        nameEncoder.encodeName(resource.name(), out);
+        out.writeShort(resource.type().intValue());
+        out.writeShort(resource.dnsClass().intValue());
+
+        long ttl = resource.timeToLive();
+        if (ttl < 0 || ttl > 0xFFFFFFFFL) {
+            throw new EncoderException("TTL must be between 0 and 0xFFFFFFFF: " + ttl);
+        }
+        out.writeInt((int) ttl);
+
+        ByteBuf content = resource.content();
+        int contentLen = content.readableBytes();
+        writeUnsignedShort(out, contentLen, "RDLENGTH");
+        out.writeBytes(content, content.readerIndex(), contentLen);
+    }
+
+    static String decodeName(ByteBuf in, int dnsStart, int dnsEnd) {
+        int position = -1;
+        int checked = 0;
+        StringBuilder name = new StringBuilder(64);
+
+        while (true) {
+            if (!in.isReadable()) {
+                throw new CorruptedFrameException("truncated name.");
+            }
+
+            short len = in.readUnsignedByte();
+            if (len == 0) {
+                break;
+            }
+
+            boolean pointer = (len & 0xc0) == 0xc0;
+            if (pointer) {
+                if (!in.isReadable()) {
+                    throw new CorruptedFrameException("truncated pointer in name.");
+                }
+
+                if (position == -1) {
+                    position = in.readerIndex() + 1;
+                }
+
+                int offset = (len & 0x3f) << 8 | in.readUnsignedByte();
+                int pointerIndex = dnsStart + offset;
+                if (pointerIndex < dnsStart || pointerIndex >= dnsEnd) {
+                    throw new CorruptedFrameException("name pointer out of range: " + offset);
+                }
+
+                in.readerIndex(pointerIndex);
+
+                checked += 2;
+                if (checked >= dnsEnd - dnsStart) {
+                    throw new CorruptedFrameException("name contains a loop.");
+                }
+                continue;
+            }
+
+            if (len > MAX_LABEL_LENGTH) {
+                throw new CorruptedFrameException("name label is longer than 63 bytes.");
+            }
+            if (len > in.readableBytes()) {
+                throw new CorruptedFrameException("truncated label in name.");
+            }
+
+            name.append(in.toString(in.readerIndex(), len, CharsetUtil.UTF_8)).append('.');
+            in.skipBytes(len);
+        }
+
+        if (position != -1) {
+            in.readerIndex(position);
+        }
+
+        if (name.length() == 0) {
+            return "";
+        }
+        return name.substring(0, name.length() - 1);
+    }
+
+    static void validateName(String name) {
+        if (name == null) {
+            throw new NullPointerException("name");
+        }
+        if (name.isEmpty()) {
+            return; // root
+        }
+
+        int end = name.length();
+        if (name.charAt(end - 1) == '.') {
+            end--;
+        }
+        if (end == 0) {
+            return; // "."
+        }
+
+        int expandedLen = 1; // terminator
+        int labelLen = 0;
+        boolean lastWasDot = true;
+
+        for (int i = 0; i < end; i++) {
+            char c = name.charAt(i);
+            if (c == '.') {
+                if (lastWasDot) {
+                    throw new EncoderException("name contains empty label: " + name);
+                }
+                if (labelLen > MAX_LABEL_LENGTH) {
+                    throw new EncoderException("name label is longer than 63 bytes: " + name);
+                }
+                expandedLen += 1 + labelLen;
+                labelLen = 0;
+                lastWasDot = true;
+                continue;
+            }
+            if (c > 0x7f) {
+                throw new EncoderException("name contains non-ASCII character: " + name);
+            }
+            labelLen++;
+            lastWasDot = false;
+        }
+
+        if (lastWasDot) {
+            throw new EncoderException("name must not end with empty label: " + name);
+        }
+        if (labelLen > MAX_LABEL_LENGTH) {
+            throw new EncoderException("name label is longer than 63 bytes: " + name);
+        }
+        expandedLen += 1 + labelLen;
+
+        if (expandedLen > MAX_NAME_LENGTH) {
+            throw new EncoderException("name exceeds 255 bytes: " + name);
+        }
+    }
+
+    static void writeAscii(ByteBuf out, CharSequence value) {
+        ByteBufUtil.writeAscii(out, value);
+    }
+
+    private static void writeUnsignedShort(ByteBuf out, int value, String fieldName) {
+        if ((value & 0xFFFF0000) != 0) {
+            throw new EncoderException(fieldName + " does not fit into 16 bits: " + value);
+        }
+        out.writeShort(value);
+    }
+}
