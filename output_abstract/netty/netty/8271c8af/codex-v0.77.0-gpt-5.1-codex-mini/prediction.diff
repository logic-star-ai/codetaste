+package io.netty.handler.codec.dns;
+
+import io.netty.buffer.ByteBuf;
+
+import java.util.HashMap;
+import java.util.Map;
+
+/**
+ * Stateful DNS name encoder which supports RFC1035 name compression.
+ */
+final class DnsNameEncoder {
+
+    private final int dnsStart;
+    private final Map<String, Integer> suffixes = new HashMap<String, Integer>(32);
+
+    DnsNameEncoder(int dnsStart) {
+        this.dnsStart = dnsStart;
+    }
+
+    void encodeName(String name, ByteBuf out) {
+        DnsCodecUtil.validateName(name);
+
+        if (name.isEmpty() || ".".equals(name)) {
+            out.writeByte(0);
+            return;
+        }
+
+        String normalized = name.charAt(name.length() - 1) == '.' ? name.substring(0, name.length() - 1) : name;
+        String[] labels = normalized.split("\\.");
+
+        for (int i = 0; i < labels.length; i++) {
+            String suffix = join(labels, i);
+
+            Integer existingOffset = suffixes.get(suffix);
+            if (existingOffset != null) {
+                out.writeShort(0xC000 | existingOffset);
+                return;
+            }
+
+            int offset = out.writerIndex() - dnsStart;
+            if (offset <= 0x3FFF) {
+                suffixes.put(suffix, offset);
+            }
+
+            String label = labels[i];
+            int len = label.length();
+            out.writeByte(len);
+            DnsCodecUtil.writeAscii(out, label);
+        }
+
+        out.writeByte(0);
+    }
+
+    private static String join(String[] labels, int start) {
+        if (start == labels.length - 1) {
+            return labels[start];
+        }
+        StringBuilder b = new StringBuilder(64);
+        for (int i = start; i < labels.length; i++) {
+            if (i != start) {
+                b.append('.');
+            }
+            b.append(labels[i]);
+        }
+        return b.toString();
+    }
+}
