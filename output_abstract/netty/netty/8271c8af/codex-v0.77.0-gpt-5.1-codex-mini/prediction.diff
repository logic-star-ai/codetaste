+    @Test
+    public void writeQueryWithOpcodeTest() throws Exception {
+        InetSocketAddress addr = new InetSocketAddress(0);
+        DnsQuery query = new DnsQuery(1, addr).addQuestion(new DnsQuestion("www.example.com", DnsType.A));
+        query.header().setOpcode(DnsHeader.OPCODE_IQUERY);
+
+        EmbeddedChannel embedder = new EmbeddedChannel(new DnsQueryEncoder());
+        embedder.writeOutbound(query);
+
+        DatagramPacket packet = embedder.readOutbound();
+        ByteBuf content = packet.content();
+        int flags = content.getUnsignedShort(2);
+        Assert.assertEquals((DnsHeader.OPCODE_IQUERY & 0xf) << 11, flags & 0x7800);
+        packet.release();
+        Assert.assertNull(embedder.readOutbound());
+    }
 }
