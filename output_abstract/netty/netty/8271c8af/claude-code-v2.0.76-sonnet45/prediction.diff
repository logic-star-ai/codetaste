+ * Unless required by applicable law or agreed to in writing, software
+ * distributed under the License is distributed on an "AS IS" BASIS, WITHOUT
+ * WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied. See the
+ * License for the specific language governing permissions and limitations
+ * under the License.
+ */
+package io.netty.handler.codec.dns;
+
+import io.netty.buffer.ByteBuf;
+
+/**
+ * Decoder for EDNS0 OPT pseudo-records (RFC 2671, RFC 6891).
+ */
+public final class DnsOptRecordDecoder implements DnsRecordDecoder {
+
+    /**
+     * DNSSEC OK flag bit position
+     */
+    private static final int DNSSEC_OK_FLAG = 0x8000;
+
+    @Override
+    public Object decodeRecordData(DnsType type, ByteBuf buf, int length) throws Exception {
+        if (type != DnsType.OPT) {
+            return null;
+        }
+
+        // For OPT records, the data is in the RDATA section
+        // The class field contains the UDP payload size
+        // The TTL field contains: extended RCODE (8 bits), version (8 bits), flags (16 bits)
+
+        // Note: This method receives the RDATA portion
+        // The actual parsing happens in a specialized decodeOptResource method
+        // For now, just return the raw buffer
+        return buf.duplicate().retain();
+    }
+
+    @Override
+    public boolean supportsType(DnsType type) {
+        return type == DnsType.OPT;
+    }
+
+    /**
+     * Decodes an OPT resource record from the buffer.
+     * This is a specialized decoder that should be called instead of the generic
+     * decodeResource method for OPT records.
+     *
+     * @param buf the buffer containing the DNS packet
+     * @return a DnsOptRecord
+     */
+    public static DnsOptRecord decodeOptResource(ByteBuf buf) {
+        // Read name (should be empty/root for OPT)
+        String name = readName(buf);
+
+        // Read type (should be OPT)
+        int typeValue = buf.readUnsignedShort();
+
+        // UDP payload size is stored in the CLASS field
+        int udpPayloadSize = buf.readUnsignedShort();
+
+        // TTL field contains extended RCODE, version, and flags
+        int ttl = buf.readInt();
+        int extendedRcode = (ttl >> 24) & 0xFF;
+        int version = (ttl >> 16) & 0xFF;
+        int flags = ttl & 0xFFFF;
+        boolean dnssecOk = (flags & DNSSEC_OK_FLAG) != 0;
+
+        // Read RDATA length and data
+        int rdataLength = buf.readUnsignedShort();
+        int readerIndex = buf.readerIndex();
+        ByteBuf options = buf.duplicate().setIndex(readerIndex, readerIndex + rdataLength).retain();
+        buf.readerIndex(readerIndex + rdataLength);
+
+        return new DnsOptRecord(udpPayloadSize, extendedRcode, version, dnssecOk, options);
+    }
+
+    /**
+     * Reads a domain name from the buffer (with pointer support).
+     */
+    private static String readName(ByteBuf buf) {
+        int position = -1;
+        int checked = 0;
+        int length = buf.writerIndex();
+        StringBuilder name = new StringBuilder();
+
+        for (int len = buf.readUnsignedByte(); buf.isReadable() && len != 0; len = buf.readUnsignedByte()) {
+            boolean pointer = (len & 0xc0) == 0xc0;
+            if (pointer) {
+                if (position == -1) {
+                    position = buf.readerIndex() + 1;
+                }
+                buf.readerIndex((len & 0x3f) << 8 | buf.readUnsignedByte());
+                checked += 2;
+                if (checked >= length) {
+                    throw new IllegalStateException("name contains a loop");
+                }
+            } else {
+                if (name.length() > 0) {
+                    name.append('.');
+                }
+                name.append(buf.toString(buf.readerIndex(), len, io.netty.util.CharsetUtil.UTF_8));
+                buf.skipBytes(len);
+            }
+        }
+
+        if (position != -1) {
+            buf.readerIndex(position);
+        }
+
+        return name.toString();
+    }
+}
