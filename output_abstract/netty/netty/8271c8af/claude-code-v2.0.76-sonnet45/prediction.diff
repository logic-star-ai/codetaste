+package io.netty.handler.codec.dns;
+
+import io.netty.buffer.ByteBuf;
+import io.netty.buffer.Unpooled;
+import org.junit.Test;
+
+import static org.junit.Assert.*;
+
+public class DnsMessageValidatorTest {
+
+    @Test
+    public void testValidateMessageSizeUdp() {
+        // Valid UDP message
+        DnsMessageValidator.validateMessageSize(512, false);
+
+        // Valid smaller message
+        DnsMessageValidator.validateMessageSize(256, false);
+    }
+
+    @Test(expected = IllegalArgumentException.class)
+    public void testValidateMessageSizeUdpTooLarge() {
+        DnsMessageValidator.validateMessageSize(513, false);
+    }
+
+    @Test
+    public void testValidateMessageSizeEdns() {
+        // Valid EDNS message
+        DnsMessageValidator.validateMessageSize(4096, true);
+
+        // Maximum EDNS message
+        DnsMessageValidator.validateMessageSize(65535, true);
+    }
+
+    @Test(expected = IllegalArgumentException.class)
+    public void testValidateMessageSizeEdnsTooLarge() {
+        DnsMessageValidator.validateMessageSize(65536, true);
+    }
+
+    @Test
+    public void testValidateDomainName() {
+        // Valid names
+        DnsMessageValidator.validateDomainName("example.com");
+        DnsMessageValidator.validateDomainName("www.example.com");
+        DnsMessageValidator.validateDomainName("a.b.c.d.e.f.g.example.com");
+        DnsMessageValidator.validateDomainName(""); // root
+    }
+
+    @Test(expected = IllegalArgumentException.class)
+    public void testValidateDomainNameTooLong() {
+        // Create a name longer than 255 characters
+        StringBuilder longName = new StringBuilder();
+        for (int i = 0; i < 30; i++) {
+            longName.append("verylonglabel.");
+        }
+        DnsMessageValidator.validateDomainName(longName.toString());
+    }
+
+    @Test(expected = IllegalArgumentException.class)
+    public void testValidateDomainNameLabelTooLong() {
+        // Create a label longer than 63 characters
+        StringBuilder longLabel = new StringBuilder();
+        for (int i = 0; i < 64; i++) {
+            longLabel.append('a');
+        }
+        longLabel.append(".com");
+        DnsMessageValidator.validateDomainName(longLabel.toString());
+    }
+
+    @Test
+    public void testValidateMessageStructure() {
+        // Valid DNS header (12 bytes)
+        ByteBuf buf = Unpooled.buffer(12);
+        for (int i = 0; i < 12; i++) {
+            buf.writeByte(0);
+        }
+        DnsMessageValidator.validateMessageStructure(buf);
+        buf.release();
+    }
+
+    @Test(expected = IllegalArgumentException.class)
+    public void testValidateMessageStructureTooSmall() {
+        // Too small (less than 12 bytes)
+        ByteBuf buf = Unpooled.buffer(11);
+        for (int i = 0; i < 11; i++) {
+            buf.writeByte(0);
+        }
+        try {
+            DnsMessageValidator.validateMessageStructure(buf);
+        } finally {
+            buf.release();
+        }
+    }
+
+    @Test
+    public void testValidateResourceRecordCount() {
+        DnsMessageValidator.validateResourceRecordCount(0, "answers");
+        DnsMessageValidator.validateResourceRecordCount(100, "answers");
+        DnsMessageValidator.validateResourceRecordCount(65535, "answers");
+    }
+
+    @Test(expected = IllegalArgumentException.class)
+    public void testValidateResourceRecordCountNegative() {
+        DnsMessageValidator.validateResourceRecordCount(-1, "answers");
+    }
+
+    @Test(expected = IllegalArgumentException.class)
+    public void testValidateResourceRecordCountTooLarge() {
+        DnsMessageValidator.validateResourceRecordCount(65536, "answers");
+    }
+
+    @Test
+    public void testValidateTTL() {
+        DnsMessageValidator.validateTTL(0);
+        DnsMessageValidator.validateTTL(3600);
+        DnsMessageValidator.validateTTL(0xFFFFFFFFL);
+    }
+
+    @Test(expected = IllegalArgumentException.class)
+    public void testValidateTTLNegative() {
+        DnsMessageValidator.validateTTL(-1);
+    }
+
+    @Test(expected = IllegalArgumentException.class)
+    public void testValidateTTLTooLarge() {
+        DnsMessageValidator.validateTTL(0x100000000L);
+    }
+}
