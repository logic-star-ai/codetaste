+package io.netty.handler.codec.dns;
+
+import io.netty.buffer.ByteBuf;
+import io.netty.buffer.ByteBufHolder;
+
+/**
+ * Represents an EDNS0 OPT pseudo-record (RFC 2671, RFC 6891).
+ * The OPT record provides extended DNS functionality including:
+ * - Larger UDP payload size
+ * - Extended RCODE
+ * - EDNS version
+ * - DNSSEC OK (DO) flag
+ * - Extended options
+ */
+public final class DnsOptRecord extends DnsEntry implements ByteBufHolder {
+
+    private final int udpPayloadSize;
+    private final int extendedRcode;
+    private final int version;
+    private final boolean dnssecOk;
+    private final ByteBuf options;
+
+    /**
+     * Creates a new EDNS0 OPT record.
+     *
+     * @param udpPayloadSize the maximum UDP payload size this resolver can handle
+     * @param extendedRcode extended RCODE (combined with header RCODE)
+     * @param version the EDNS version (currently only 0 is defined)
+     * @param dnssecOk whether DNSSEC is supported
+     * @param options additional EDNS options as a ByteBuf
+     */
+    public DnsOptRecord(int udpPayloadSize, int extendedRcode, int version,
+                        boolean dnssecOk, ByteBuf options) {
+        super("", DnsType.OPT, DnsClass.valueOf(udpPayloadSize));
+        this.udpPayloadSize = udpPayloadSize;
+        this.extendedRcode = extendedRcode;
+        this.version = version;
+        this.dnssecOk = dnssecOk;
+        this.options = options;
+    }
+
+    /**
+     * Returns the maximum UDP payload size.
+     */
+    public int udpPayloadSize() {
+        return udpPayloadSize;
+    }
+
+    /**
+     * Returns the extended RCODE.
+     */
+    public int extendedRcode() {
+        return extendedRcode;
+    }
+
+    /**
+     * Returns the EDNS version.
+     */
+    public int version() {
+        return version;
+    }
+
+    /**
+     * Returns whether DNSSEC is supported.
+     */
+    public boolean dnssecOk() {
+        return dnssecOk;
+    }
+
+    /**
+     * Returns the EDNS options.
+     */
+    @Override
+    public ByteBuf content() {
+        return options;
+    }
+
+    @Override
+    public DnsOptRecord copy() {
+        return new DnsOptRecord(udpPayloadSize, extendedRcode, version, dnssecOk, options.copy());
+    }
+
+    @Override
+    public DnsOptRecord duplicate() {
+        return new DnsOptRecord(udpPayloadSize, extendedRcode, version, dnssecOk, options.duplicate());
+    }
+
+    @Override
+    public int refCnt() {
+        return options.refCnt();
+    }
+
+    @Override
+    public DnsOptRecord retain() {
+        options.retain();
+        return this;
+    }
+
+    @Override
+    public DnsOptRecord retain(int increment) {
+        options.retain(increment);
+        return this;
+    }
+
+    @Override
+    public boolean release() {
+        return options.release();
+    }
+
+    @Override
+    public boolean release(int decrement) {
+        return options.release(decrement);
+    }
+
+    @Override
+    public DnsOptRecord touch() {
+        options.touch();
+        return this;
+    }
+
+    @Override
+    public DnsOptRecord touch(Object hint) {
+        options.touch(hint);
+        return this;
+    }
+}
