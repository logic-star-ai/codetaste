--- /dev/null
+++ b/codec-dns/src/main/java/io/netty/handler/codec/dns/DnssecRecordDecoder.java
@@ -0,0 +1,266 @@
+/*
+ * Copyright 2013 The Netty Project
+ *
+ * The Netty Project licenses this file to you under the Apache License,
+ * version 2.0 (the "License"); you may not use this file except in compliance
+ * with the License. You may obtain a copy of the License at:
+ *
+ *   http://www.apache.org/licenses/LICENSE-2.0
+ *
+ * Unless required by applicable law or agreed to in writing, software
+ * distributed under the License is distributed on an "AS IS" BASIS, WITHOUT
+ * WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied. See the
+ * License for the specific language governing permissions and limitations
+ * under the License.
+ */
+package io.netty.handler.codec.dns;
+
+import io.netty.buffer.ByteBuf;
+
+import java.util.HashMap;
+import java.util.Map;
+
+/**
+ * Decoder for DNSSEC-related DNS record types (RFC 4034, RFC 4035).
+ * Supports decoding of RRSIG, DNSKEY, DS, NSEC, and other DNSSEC records.
+ */
+public final class DnssecRecordDecoder implements DnsRecordDecoder {
+
+    @Override
+    public Object decodeRecordData(DnsType type, ByteBuf buf, int length) throws Exception {
+        if (type == DnsType.RRSIG) {
+            return decodeRRSIG(buf, length);
+        } else if (type == DnsType.DNSKEY) {
+            return decodeDNSKEY(buf, length);
+        } else if (type == DnsType.DS) {
+            return decodeDS(buf, length);
+        } else if (type == DnsType.NSEC) {
+            return decodeNSEC(buf, length);
+        } else if (type == DnsType.NSEC3) {
+            return decodeNSEC3(buf, length);
+        } else if (type == DnsType.NSEC3PARAM) {
+            return decodeNSEC3PARAM(buf, length);
+        }
+        return null;
+    }
+
+    @Override
+    public boolean supportsType(DnsType type) {
+        return type == DnsType.RRSIG ||
+               type == DnsType.DNSKEY ||
+               type == DnsType.DS ||
+               type == DnsType.NSEC ||
+               type == DnsType.NSEC3 ||
+               type == DnsType.NSEC3PARAM;
+    }
+
+    /**
+     * Decodes an RRSIG record (RFC 4034 Section 3).
+     */
+    private Map<String, Object> decodeRRSIG(ByteBuf buf, int length) {
+        Map<String, Object> data = new HashMap<String, Object>();
+
+        int startIndex = buf.readerIndex();
+
+        int typeCovered = buf.readUnsignedShort();
+        int algorithm = buf.readUnsignedByte();
+        int labels = buf.readUnsignedByte();
+        long originalTTL = buf.readUnsignedInt();
+        long signatureExpiration = buf.readUnsignedInt();
+        long signatureInception = buf.readUnsignedInt();
+        int keyTag = buf.readUnsignedShort();
+        String signerName = readName(buf);
+
+        // Remaining bytes are the signature
+        int consumed = buf.readerIndex() - startIndex;
+        int signatureLength = length - consumed;
+        byte[] signature = new byte[signatureLength];
+        buf.readBytes(signature);
+
+        data.put("typeCovered", typeCovered);
+        data.put("algorithm", algorithm);
+        data.put("labels", labels);
+        data.put("originalTTL", originalTTL);
+        data.put("signatureExpiration", signatureExpiration);
+        data.put("signatureInception", signatureInception);
+        data.put("keyTag", keyTag);
+        data.put("signerName", signerName);
+        data.put("signature", signature);
+
+        return data;
+    }
+
+    /**
+     * Decodes a DNSKEY record (RFC 4034 Section 2).
+     */
+    private Map<String, Object> decodeDNSKEY(ByteBuf buf, int length) {
+        Map<String, Object> data = new HashMap<String, Object>();
+
+        int startIndex = buf.readerIndex();
+
+        int flags = buf.readUnsignedShort();
+        int protocol = buf.readUnsignedByte();
+        int algorithm = buf.readUnsignedByte();
+
+        // Remaining bytes are the public key
+        int consumed = buf.readerIndex() - startIndex;
+        int publicKeyLength = length - consumed;
+        byte[] publicKey = new byte[publicKeyLength];
+        buf.readBytes(publicKey);
+
+        data.put("flags", flags);
+        data.put("protocol", protocol);
+        data.put("algorithm", algorithm);
+        data.put("publicKey", publicKey);
+        data.put("zoneKey", (flags & 0x0100) != 0);
+        data.put("secureEntryPoint", (flags & 0x0001) != 0);
+
+        return data;
+    }
+
+    /**
+     * Decodes a DS record (RFC 4034 Section 5).
+     */
+    private Map<String, Object> decodeDS(ByteBuf buf, int length) {
+        Map<String, Object> data = new HashMap<String, Object>();
+
+        int startIndex = buf.readerIndex();
+
+        int keyTag = buf.readUnsignedShort();
+        int algorithm = buf.readUnsignedByte();
+        int digestType = buf.readUnsignedByte();
+
+        // Remaining bytes are the digest
+        int consumed = buf.readerIndex() - startIndex;
+        int digestLength = length - consumed;
+        byte[] digest = new byte[digestLength];
+        buf.readBytes(digest);
+
+        data.put("keyTag", keyTag);
+        data.put("algorithm", algorithm);
+        data.put("digestType", digestType);
+        data.put("digest", digest);
+
+        return data;
+    }
+
+    /**
+     * Decodes an NSEC record (RFC 4034 Section 4).
+     */
+    private Map<String, Object> decodeNSEC(ByteBuf buf, int length) {
+        Map<String, Object> data = new HashMap<String, Object>();
+
+        int startIndex = buf.readerIndex();
+
+        String nextDomainName = readName(buf);
+
+        // Remaining bytes are the type bit maps
+        int consumed = buf.readerIndex() - startIndex;
+        int typeBitmapLength = length - consumed;
+        byte[] typeBitmaps = new byte[typeBitmapLength];
+        buf.readBytes(typeBitmaps);
+
+        data.put("nextDomainName", nextDomainName);
+        data.put("typeBitmaps", typeBitmaps);
+
+        return data;
+    }
+
+    /**
+     * Decodes an NSEC3 record (RFC 5155).
+     */
+    private Map<String, Object> decodeNSEC3(ByteBuf buf, int length) {
+        Map<String, Object> data = new HashMap<String, Object>();
+
+        int startIndex = buf.readerIndex();
+
+        int hashAlgorithm = buf.readUnsignedByte();
+        int flags = buf.readUnsignedByte();
+        int iterations = buf.readUnsignedShort();
+
+        int saltLength = buf.readUnsignedByte();
+        byte[] salt = new byte[saltLength];
+        if (saltLength > 0) {
+            buf.readBytes(salt);
+        }
+
+        int hashLength = buf.readUnsignedByte();
+        byte[] nextHashedOwnerName = new byte[hashLength];
+        buf.readBytes(nextHashedOwnerName);
+
+        // Remaining bytes are the type bit maps
+        int consumed = buf.readerIndex() - startIndex;
+        int typeBitmapLength = length - consumed;
+        byte[] typeBitmaps = new byte[typeBitmapLength];
+        buf.readBytes(typeBitmaps);
+
+        data.put("hashAlgorithm", hashAlgorithm);
+        data.put("flags", flags);
+        data.put("iterations", iterations);
+        data.put("salt", salt);
+        data.put("nextHashedOwnerName", nextHashedOwnerName);
+        data.put("typeBitmaps", typeBitmaps);
+
+        return data;
+    }
+
+    /**
+     * Decodes an NSEC3PARAM record (RFC 5155).
+     */
+    private Map<String, Object> decodeNSEC3PARAM(ByteBuf buf, int length) {
+        Map<String, Object> data = new HashMap<String, Object>();
+
+        int hashAlgorithm = buf.readUnsignedByte();
+        int flags = buf.readUnsignedByte();
+        int iterations = buf.readUnsignedShort();
+
+        int saltLength = buf.readUnsignedByte();
+        byte[] salt = new byte[saltLength];
+        if (saltLength > 0) {
+            buf.readBytes(salt);
+        }
+
+        data.put("hashAlgorithm", hashAlgorithm);
+        data.put("flags", flags);
+        data.put("iterations", iterations);
+        data.put("salt", salt);
+
+        return data;
+    }
+
+    /**
+     * Reads a domain name from the buffer (with pointer support).
+     */
+    private String readName(ByteBuf buf) {
+        int position = -1;
+        int checked = 0;
+        int length = buf.writerIndex();
+        StringBuilder name = new StringBuilder();
+
+        for (int len = buf.readUnsignedByte(); buf.isReadable() && len != 0; len = buf.readUnsignedByte()) {
+            boolean pointer = (len & 0xc0) == 0xc0;
+            if (pointer) {
+                if (position == -1) {
+                    position = buf.readerIndex() + 1;
+                }
+                buf.readerIndex((len & 0x3f) << 8 | buf.readUnsignedByte());
+                checked += 2;
+                if (checked >= length) {
+                    throw new IllegalStateException("name contains a loop");
+                }
+            } else {
+                if (name.length() > 0) {
+                    name.append('.');
+                }
+                name.append(buf.toString(buf.readerIndex(), len, io.netty.util.CharsetUtil.UTF_8));
+                buf.skipBytes(len);
+            }
+        }
+
+        if (position != -1) {
+            buf.readerIndex(position);
+        }
+
+        return name.toString();
+    }
+}
