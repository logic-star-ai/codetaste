+ * License for the specific language governing permissions and limitations
+ * under the License.
+ */
+package io.netty.handler.codec.dns;
+
+import java.util.ArrayList;
+import java.util.List;
+import java.util.concurrent.CopyOnWriteArrayList;
+
+/**
+ * A registry for DNS record codecs that allows pluggable encoders and decoders
+ * for different DNS record types. This enables extensibility for custom DNS
+ * record types and compliance with various DNS RFCs.
+ */
+public final class DnsRecordCodecRegistry {
+
+    private static final DnsRecordCodecRegistry DEFAULT = new DnsRecordCodecRegistry();
+
+    private final List<DnsRecordDecoder> decoders = new CopyOnWriteArrayList<DnsRecordDecoder>();
+    private final List<DnsRecordEncoder> encoders = new CopyOnWriteArrayList<DnsRecordEncoder>();
+
+    /**
+     * Returns the default global registry instance.
+     */
+    public static DnsRecordCodecRegistry getDefault() {
+        return DEFAULT;
+    }
+
+    /**
+     * Registers a decoder for DNS records.
+     *
+     * @param decoder the decoder to register
+     */
+    public void registerDecoder(DnsRecordDecoder decoder) {
+        if (decoder == null) {
+            throw new NullPointerException("decoder");
+        }
+        decoders.add(decoder);
+    }
+
+    /**
+     * Registers an encoder for DNS records.
+     *
+     * @param encoder the encoder to register
+     */
+    public void registerEncoder(DnsRecordEncoder encoder) {
+        if (encoder == null) {
+            throw new NullPointerException("encoder");
+        }
+        encoders.add(encoder);
+    }
+
+    /**
+     * Unregisters a decoder from the registry.
+     *
+     * @param decoder the decoder to unregister
+     * @return true if the decoder was removed, false otherwise
+     */
+    public boolean unregisterDecoder(DnsRecordDecoder decoder) {
+        return decoders.remove(decoder);
+    }
+
+    /**
+     * Unregisters an encoder from the registry.
+     *
+     * @param encoder the encoder to unregister
+     * @return true if the encoder was removed, false otherwise
+     */
+    public boolean unregisterEncoder(DnsRecordEncoder encoder) {
+        return encoders.remove(encoder);
+    }
+
+    /**
+     * Finds a decoder that supports the given DNS record type.
+     *
+     * @param type the DNS record type
+     * @return a decoder that supports the type, or null if none found
+     */
+    public DnsRecordDecoder findDecoder(DnsType type) {
+        for (DnsRecordDecoder decoder : decoders) {
+            if (decoder.supportsType(type)) {
+                return decoder;
+            }
+        }
+        return null;
+    }
+
+    /**
+     * Finds an encoder that supports the given DNS record type.
+     *
+     * @param type the DNS record type
+     * @return an encoder that supports the type, or null if none found
+     */
+    public DnsRecordEncoder findEncoder(DnsType type) {
+        for (DnsRecordEncoder encoder : encoders) {
+            if (encoder.supportsType(type)) {
+                return encoder;
+            }
+        }
+        return null;
+    }
+
+    /**
+     * Returns a list of all registered decoders.
+     */
+    public List<DnsRecordDecoder> getDecoders() {
+        return new ArrayList<DnsRecordDecoder>(decoders);
+    }
+
+    /**
+     * Returns a list of all registered encoders.
+     */
+    public List<DnsRecordEncoder> getEncoders() {
+        return new ArrayList<DnsRecordEncoder>(encoders);
+    }
+}
