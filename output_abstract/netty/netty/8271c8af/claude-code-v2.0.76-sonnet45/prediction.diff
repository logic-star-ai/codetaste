+package io.netty.handler.codec.dns;
+
+import io.netty.buffer.ByteBuf;
+
+/**
+ * Validates DNS messages for compliance with DNS protocol specifications.
+ * Provides checks for message size limits, structure validation, and other
+ * compliance requirements.
+ */
+public final class DnsMessageValidator {
+
+    /**
+     * Maximum DNS message size for UDP (RFC 1035)
+     */
+    public static final int MAX_UDP_MESSAGE_SIZE = 512;
+
+    /**
+     * Maximum DNS message size with EDNS0 extension
+     */
+    public static final int MAX_EDNS_MESSAGE_SIZE = 65535;
+
+    /**
+     * Maximum label length in a domain name (RFC 1035)
+     */
+    public static final int MAX_LABEL_LENGTH = 63;
+
+    /**
+     * Maximum domain name length (RFC 1035)
+     */
+    public static final int MAX_NAME_LENGTH = 255;
+
+    /**
+     * Maximum number of resource records per section (practical limit)
+     */
+    public static final int MAX_RESOURCE_RECORDS = 65535;
+
+    private DnsMessageValidator() {
+        // Utility class
+    }
+
+    /**
+     * Validates that a DNS message size is within acceptable limits.
+     *
+     * @param messageSize the size of the message in bytes
+     * @param useEdns whether EDNS0 is being used
+     * @throws IllegalArgumentException if the message size exceeds limits
+     */
+    public static void validateMessageSize(int messageSize, boolean useEdns) {
+        int maxSize = useEdns ? MAX_EDNS_MESSAGE_SIZE : MAX_UDP_MESSAGE_SIZE;
+        if (messageSize > maxSize) {
+            throw new IllegalArgumentException(
+                "DNS message size " + messageSize + " exceeds maximum of " + maxSize);
+        }
+    }
+
+    /**
+     * Validates that a domain name is well-formed and within size limits.
+     *
+     * @param name the domain name to validate
+     * @throws IllegalArgumentException if the name is invalid
+     */
+    public static void validateDomainName(String name) {
+        if (name == null) {
+            throw new NullPointerException("name");
+        }
+
+        if (name.length() > MAX_NAME_LENGTH) {
+            throw new IllegalArgumentException(
+                "Domain name length " + name.length() + " exceeds maximum of " + MAX_NAME_LENGTH);
+        }
+
+        if (name.isEmpty()) {
+            return; // Empty name is valid (root)
+        }
+
+        String[] labels = name.split("\\.");
+        for (String label : labels) {
+            if (label.length() > MAX_LABEL_LENGTH) {
+                throw new IllegalArgumentException(
+                    "Label length " + label.length() + " exceeds maximum of " + MAX_LABEL_LENGTH);
+            }
+
+            if (!label.isEmpty()) {
+                // Validate label characters (RFC 1035: letters, digits, hyphens)
+                // Allow more permissive validation for international domain names
+                for (int i = 0; i < label.length(); i++) {
+                    char c = label.charAt(i);
+                    if (!(Character.isLetterOrDigit(c) || c == '-' || c == '_')) {
+                        // Allow underscore for SRV records and other special cases
+                        if (i == 0 && c != '_') {
+                            throw new IllegalArgumentException(
+                                "Invalid character '" + c + "' in label: " + label);
+                        }
+                    }
+                }
+            }
+        }
+    }
+
+    /**
+     * Validates the structure of a DNS message buffer.
+     *
+     * @param buf the buffer containing the DNS message
+     * @throws IllegalArgumentException if the message structure is invalid
+     */
+    public static void validateMessageStructure(ByteBuf buf) {
+        if (buf == null) {
+            throw new NullPointerException("buf");
+        }
+
+        // DNS header is always 12 bytes
+        if (buf.readableBytes() < 12) {
+            throw new IllegalArgumentException(
+                "DNS message too short: " + buf.readableBytes() + " bytes (minimum 12)");
+        }
+    }
+
+    /**
+     * Validates that a resource record count is within acceptable limits.
+     *
+     * @param count the number of resource records
+     * @param section the section name (for error messages)
+     * @throws IllegalArgumentException if the count exceeds limits
+     */
+    public static void validateResourceRecordCount(int count, String section) {
+        if (count < 0) {
+            throw new IllegalArgumentException(
+                section + " count cannot be negative: " + count);
+        }
+        if (count > MAX_RESOURCE_RECORDS) {
+            throw new IllegalArgumentException(
+                section + " count " + count + " exceeds maximum of " + MAX_RESOURCE_RECORDS);
+        }
+    }
+
+    /**
+     * Validates that a TTL value is within acceptable range.
+     *
+     * @param ttl the time-to-live value
+     * @throws IllegalArgumentException if the TTL is invalid
+     */
+    public static void validateTTL(long ttl) {
+        if (ttl < 0) {
+            throw new IllegalArgumentException("TTL cannot be negative: " + ttl);
+        }
+        if (ttl > 0xFFFFFFFFL) {
+            throw new IllegalArgumentException("TTL exceeds maximum 32-bit unsigned value: " + ttl);
+        }
+    }
+}
