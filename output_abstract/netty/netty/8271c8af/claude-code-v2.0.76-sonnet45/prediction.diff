+package io.netty.handler.codec.dns;
+
+import io.netty.buffer.ByteBuf;
+import org.junit.Before;
+import org.junit.Test;
+
+import static org.junit.Assert.*;
+
+public class DnsRecordCodecRegistryTest {
+
+    private DnsRecordCodecRegistry registry;
+
+    @Before
+    public void setUp() {
+        registry = new DnsRecordCodecRegistry();
+    }
+
+    @Test
+    public void testRegisterAndFindDecoder() {
+        DnsRecordDecoder decoder = new DnsRecordDecoder() {
+            @Override
+            public Object decodeRecordData(DnsType type, ByteBuf buf, int length) {
+                return "decoded";
+            }
+
+            @Override
+            public boolean supportsType(DnsType type) {
+                return type == DnsType.A;
+            }
+        };
+
+        registry.registerDecoder(decoder);
+        DnsRecordDecoder found = registry.findDecoder(DnsType.A);
+
+        assertNotNull(found);
+        assertEquals(decoder, found);
+    }
+
+    @Test
+    public void testRegisterAndFindEncoder() {
+        DnsRecordEncoder encoder = new DnsRecordEncoder() {
+            @Override
+            public void encodeRecordData(DnsType type, Object recordData, ByteBuf buf) {
+                // no-op
+            }
+
+            @Override
+            public boolean supportsType(DnsType type) {
+                return type == DnsType.AAAA;
+            }
+        };
+
+        registry.registerEncoder(encoder);
+        DnsRecordEncoder found = registry.findEncoder(DnsType.AAAA);
+
+        assertNotNull(found);
+        assertEquals(encoder, found);
+    }
+
+    @Test
+    public void testFindNonExistentDecoder() {
+        DnsRecordDecoder found = registry.findDecoder(DnsType.MX);
+        assertNull(found);
+    }
+
+    @Test
+    public void testFindNonExistentEncoder() {
+        DnsRecordEncoder found = registry.findEncoder(DnsType.NS);
+        assertNull(found);
+    }
+
+    @Test
+    public void testUnregisterDecoder() {
+        DnsRecordDecoder decoder = new DnsRecordDecoder() {
+            @Override
+            public Object decodeRecordData(DnsType type, ByteBuf buf, int length) {
+                return null;
+            }
+
+            @Override
+            public boolean supportsType(DnsType type) {
+                return type == DnsType.TXT;
+            }
+        };
+
+        registry.registerDecoder(decoder);
+        assertTrue(registry.unregisterDecoder(decoder));
+        assertNull(registry.findDecoder(DnsType.TXT));
+    }
+
+    @Test
+    public void testUnregisterEncoder() {
+        DnsRecordEncoder encoder = new DnsRecordEncoder() {
+            @Override
+            public void encodeRecordData(DnsType type, Object recordData, ByteBuf buf) {
+            }
+
+            @Override
+            public boolean supportsType(DnsType type) {
+                return type == DnsType.CNAME;
+            }
+        };
+
+        registry.registerEncoder(encoder);
+        assertTrue(registry.unregisterEncoder(encoder));
+        assertNull(registry.findEncoder(DnsType.CNAME));
+    }
+
+    @Test
+    public void testGetDecodersAndEncoders() {
+        DnsRecordDecoder decoder = new DnsRecordDecoder() {
+            @Override
+            public Object decodeRecordData(DnsType type, ByteBuf buf, int length) {
+                return null;
+            }
+
+            @Override
+            public boolean supportsType(DnsType type) {
+                return true;
+            }
+        };
+
+        DnsRecordEncoder encoder = new DnsRecordEncoder() {
+            @Override
+            public void encodeRecordData(DnsType type, Object recordData, ByteBuf buf) {
+            }
+
+            @Override
+            public boolean supportsType(DnsType type) {
+                return true;
+            }
+        };
+
+        registry.registerDecoder(decoder);
+        registry.registerEncoder(encoder);
+
+        assertEquals(1, registry.getDecoders().size());
+        assertEquals(1, registry.getEncoders().size());
+    }
+
+    @Test
+    public void testDefaultRegistry() {
+        DnsRecordCodecRegistry defaultRegistry = DnsRecordCodecRegistry.getDefault();
+        assertNotNull(defaultRegistry);
+        assertSame(defaultRegistry, DnsRecordCodecRegistry.getDefault());
+    }
+
+    @Test(expected = NullPointerException.class)
+    public void testRegisterNullDecoder() {
+        registry.registerDecoder(null);
+    }
+
+    @Test(expected = NullPointerException.class)
+    public void testRegisterNullEncoder() {
+        registry.registerEncoder(null);
+    }
+}
