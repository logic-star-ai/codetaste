+package io.netty.handler.codec.dns;
+
+import io.netty.buffer.ByteBuf;
+import io.netty.buffer.Unpooled;
+import io.netty.util.CharsetUtil;
+import org.junit.Test;
+
+import static org.junit.Assert.*;
+
+public class DnsNameCompressorTest {
+
+    @Test
+    public void testSimpleNameEncoding() {
+        DnsNameCompressor compressor = new DnsNameCompressor();
+        ByteBuf buf = Unpooled.buffer();
+
+        compressor.encodeName("example.com", buf);
+
+        assertEquals(7, buf.readUnsignedByte()); // "example"
+        assertEquals("example", buf.toString(buf.readerIndex(), 7, CharsetUtil.US_ASCII));
+        buf.skipBytes(7);
+        assertEquals(3, buf.readUnsignedByte()); // "com"
+        assertEquals("com", buf.toString(buf.readerIndex(), 3, CharsetUtil.US_ASCII));
+        buf.skipBytes(3);
+        assertEquals(0, buf.readUnsignedByte()); // terminator
+
+        buf.release();
+    }
+
+    @Test
+    public void testNameCompression() {
+        DnsNameCompressor compressor = new DnsNameCompressor();
+        ByteBuf buf = Unpooled.buffer();
+
+        // Encode first name
+        compressor.encodeName("www.example.com", buf);
+
+        int afterFirstName = buf.writerIndex();
+
+        // Encode second name with shared suffix
+        compressor.encodeName("mail.example.com", buf);
+
+        // The second name should use compression for "example.com"
+        buf.readerIndex(afterFirstName);
+        assertEquals(4, buf.readUnsignedByte()); // "mail"
+        assertEquals("mail", buf.toString(buf.readerIndex(), 4, CharsetUtil.US_ASCII));
+        buf.skipBytes(4);
+
+        // Next should be a pointer (0xC0 mask) or continue with uncompressed name
+        // Check if there's data remaining
+        if (buf.isReadable()) {
+            int nextByte = buf.getUnsignedByte(buf.readerIndex());
+            // Check if it's a pointer (top 2 bits are 11)
+            if ((nextByte & 0xC0) == 0xC0) {
+                int pointer = buf.readUnsignedShort();
+                assertTrue((pointer & 0xC000) == 0xC000);
+            }
+        }
+
+        buf.release();
+    }
+
+    @Test
+    public void testEmptyName() {
+        DnsNameCompressor compressor = new DnsNameCompressor();
+        ByteBuf buf = Unpooled.buffer();
+
+        compressor.encodeName("", buf);
+
+        assertEquals(0, buf.readUnsignedByte()); // just terminator
+
+        buf.release();
+    }
+
+    @Test
+    public void testClearCompressionTable() {
+        DnsNameCompressor compressor = new DnsNameCompressor();
+        ByteBuf buf = Unpooled.buffer();
+
+        compressor.encodeName("example.com", buf);
+        compressor.clear();
+
+        int afterClear = buf.writerIndex();
+        compressor.encodeName("example.com", buf);
+
+        // After clear, the name should be encoded again without compression
+        buf.readerIndex(afterClear);
+        assertEquals(7, buf.readUnsignedByte()); // "example"
+        buf.skipBytes(7);
+        assertEquals(3, buf.readUnsignedByte()); // "com"
+
+        buf.release();
+    }
+
+    @Test
+    public void testWithoutCompression() {
+        ByteBuf buf = Unpooled.buffer();
+
+        DnsNameCompressor.encodeNameWithoutCompression("example.com", CharsetUtil.US_ASCII, buf);
+
+        assertEquals(7, buf.readUnsignedByte());
+        assertEquals("example", buf.toString(buf.readerIndex(), 7, CharsetUtil.US_ASCII));
+        buf.skipBytes(7);
+        assertEquals(3, buf.readUnsignedByte());
+        assertEquals("com", buf.toString(buf.readerIndex(), 3, CharsetUtil.US_ASCII));
+        buf.skipBytes(3);
+        assertEquals(0, buf.readUnsignedByte());
+
+        buf.release();
+    }
+}
