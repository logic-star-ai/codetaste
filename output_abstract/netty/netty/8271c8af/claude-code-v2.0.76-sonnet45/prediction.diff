+package io.netty.handler.codec.dns;
+
+import io.netty.buffer.ByteBuf;
+import io.netty.util.CharsetUtil;
+
+import java.nio.charset.Charset;
+import java.util.HashMap;
+import java.util.Map;
+
+/**
+ * Provides DNS name compression support according to RFC 1035 Section 4.1.4.
+ * This class maintains a compression table that maps domain names to their
+ * positions in the DNS message for efficient encoding.
+ */
+public final class DnsNameCompressor {
+
+    private static final int MAX_COMPRESSION_POINTER = 0x3FFF;
+    private static final int POINTER_MASK = 0xC000;
+
+    private final Map<String, Integer> compressionTable;
+    private final Charset charset;
+
+    /**
+     * Creates a new DNS name compressor with US-ASCII charset.
+     */
+    public DnsNameCompressor() {
+        this(CharsetUtil.US_ASCII);
+    }
+
+    /**
+     * Creates a new DNS name compressor with the specified charset.
+     *
+     * @param charset the charset to use for encoding domain names
+     */
+    public DnsNameCompressor(Charset charset) {
+        this.compressionTable = new HashMap<String, Integer>();
+        this.charset = charset;
+    }
+
+    /**
+     * Encodes a domain name with compression support. If the name or any of its
+     * suffixes has been previously encoded, a pointer will be used instead of
+     * repeating the name.
+     *
+     * @param name the domain name to encode
+     * @param buf the buffer to write the encoded name to
+     */
+    public void encodeName(String name, ByteBuf buf) {
+        if (name == null || name.isEmpty()) {
+            buf.writeByte(0);
+            return;
+        }
+
+        // Check if we can use compression for this exact name
+        Integer position = compressionTable.get(name);
+        if (position != null && position <= MAX_COMPRESSION_POINTER) {
+            // Write pointer
+            buf.writeShort(POINTER_MASK | position);
+            return;
+        }
+
+        // Record position of this name for future compression
+        int startPosition = buf.writerIndex();
+
+        // Split name into labels
+        String[] labels = splitName(name);
+        StringBuilder suffix = new StringBuilder();
+
+        for (int i = 0; i < labels.length; i++) {
+            String label = labels[i];
+
+            // Build suffix for compression lookup
+            if (i > 0) {
+                suffix.insert(0, '.');
+            }
+            suffix.insert(0, label);
+            String currentSuffix = suffix.toString();
+
+            // Check if this suffix exists in compression table
+            Integer suffixPosition = compressionTable.get(currentSuffix);
+            if (suffixPosition != null && suffixPosition <= MAX_COMPRESSION_POINTER) {
+                // Write pointer to suffix
+                buf.writeShort(POINTER_MASK | suffixPosition);
+                return;
+            }
+
+            // Write the label
+            int labelLen = label.length();
+            if (labelLen > 0) {
+                // Record position for compression
+                int labelPosition = buf.writerIndex();
+                if (labelPosition <= MAX_COMPRESSION_POINTER) {
+                    compressionTable.put(currentSuffix, labelPosition);
+                }
+
+                buf.writeByte(labelLen);
+                buf.writeBytes(label.getBytes(charset));
+            }
+        }
+
+        // Write terminating zero
+        buf.writeByte(0);
+    }
+
+    /**
+     * Encodes a domain name without compression support.
+     *
+     * @param name the domain name to encode
+     * @param charset the charset to use
+     * @param buf the buffer to write the encoded name to
+     */
+    public static void encodeNameWithoutCompression(String name, Charset charset, ByteBuf buf) {
+        if (name == null || name.isEmpty()) {
+            buf.writeByte(0);
+            return;
+        }
+
+        String[] labels = splitName(name);
+        for (String label : labels) {
+            int labelLen = label.length();
+            if (labelLen > 0) {
+                buf.writeByte(labelLen);
+                buf.writeBytes(label.getBytes(charset));
+            }
+        }
+        buf.writeByte(0);
+    }
+
+    /**
+     * Splits a domain name into labels.
+     *
+     * @param name the domain name to split
+     * @return array of labels
+     */
+    private static String[] splitName(String name) {
+        String[] parts = name.split("\\.");
+        int count = 0;
+        for (String part : parts) {
+            if (!part.isEmpty()) {
+                count++;
+            }
+        }
+
+        String[] result = new String[count];
+        int index = 0;
+        for (String part : parts) {
+            if (!part.isEmpty()) {
+                result[index++] = part;
+            }
+        }
+        return result;
+    }
+
+    /**
+     * Clears the compression table. This should be called when starting to
+     * encode a new DNS message.
+     */
+    public void clear() {
+        compressionTable.clear();
+    }
+}
