+package io.netty.handler.codec.dns;
+
+import io.netty.buffer.ByteBuf;
+import io.netty.handler.codec.CorruptedFrameException;
+import io.netty.util.CharsetUtil;
+
+/**
+ * DNS codec utility methods and default implementations.
+ */
+final class DnsCodecUtil {
+
+    static final int MAX_LABEL_LENGTH = 63;
+    static final int MAX_NAME_LENGTH = 255;
+
+    static final DnsNameDecoder DEFAULT_NAME_DECODER = new DefaultDnsNameDecoder();
+    static final DnsNameEncoder DEFAULT_NAME_ENCODER = new DefaultDnsNameEncoder();
+
+    private DnsCodecUtil() {
+        // Utility
+    }
+
+    static String decodeName(ByteBuf buf, int dnsMessageStart) {
+        return DEFAULT_NAME_DECODER.decodeName(buf, dnsMessageStart);
+    }
+
+    static void encodeName(String name, ByteBuf buf) {
+        DEFAULT_NAME_ENCODER.encodeName(name, buf);
+    }
+
+    private static final class DefaultDnsNameDecoder implements DnsNameDecoder {
+        @Override
+        public String decodeName(ByteBuf buf, int dnsMessageStart) {
+            final int messageEnd = buf.writerIndex();
+            int readerIndex = buf.readerIndex();
+
+            int totalLength = 0;
+            int pointerJumps = 0;
+            boolean jumped = false;
+
+            final StringBuilder name = new StringBuilder(64);
+
+            for (;;) {
+                if (readerIndex >= messageEnd) {
+                    throw new CorruptedFrameException("name exceeds the bounds of the DNS message.");
+                }
+
+                final int len = buf.getUnsignedByte(readerIndex++);
+
+                if (len == 0) {
+                    if (!jumped) {
+                        buf.readerIndex(readerIndex);
+                    }
+                    break;
+                }
+
+                final int labelType = len & 0xC0;
+                if (labelType == 0xC0) {
+                    if (readerIndex >= messageEnd) {
+                        throw new CorruptedFrameException("truncated name pointer in DNS message.");
+                    }
+                    final int pointer = (len & 0x3F) << 8 | buf.getUnsignedByte(readerIndex++);
+                    final int nextIndex = dnsMessageStart + pointer;
+                    if (nextIndex < dnsMessageStart || nextIndex >= messageEnd) {
+                        throw new CorruptedFrameException("name pointer exceeds the bounds of the DNS message.");
+                    }
+                    if (!jumped) {
+                        buf.readerIndex(readerIndex);
+                        jumped = true;
+                    }
+                    readerIndex = nextIndex;
+                    if (++pointerJumps > MAX_NAME_LENGTH) {
+                        throw new CorruptedFrameException("name contains a loop.");
+                    }
+                    continue;
+                }
+
+                if (labelType != 0) {
+                    throw new CorruptedFrameException("unsupported label type in DNS name.");
+                }
+
+                if (len > MAX_LABEL_LENGTH) {
+                    throw new CorruptedFrameException("label exceeds the maximum length: " + len);
+                }
+
+                if (readerIndex + len > messageEnd) {
+                    throw new CorruptedFrameException("truncated label in DNS name.");
+                }
+
+                totalLength += len + 1; // label + dot / root
+                if (totalLength > MAX_NAME_LENGTH) {
+                    throw new CorruptedFrameException("name exceeds the maximum length: " + totalLength);
+                }
+
+                name.append(buf.toString(readerIndex, len, CharsetUtil.US_ASCII)).append('.');
+                readerIndex += len;
+            }
+
+            if (name.length() == 0) {
+                return "";
+            }
+
+            return name.substring(0, name.length() - 1);
+        }
+    }
+
+    private static final class DefaultDnsNameEncoder implements DnsNameEncoder {
+        @Override
+        public void encodeName(String name, ByteBuf buf) {
+            if (name == null) {
+                throw new NullPointerException("name");
+            }
+
+            final int length = name.length();
+            if (length == 0 || ".".equals(name)) {
+                buf.writeByte(0);
+                return;
+            }
+
+            final boolean hasTrailingDot = name.charAt(length - 1) == '.';
+            final int end = hasTrailingDot ? length - 1 : length;
+            if (end == 0) {
+                buf.writeByte(0);
+                return;
+            }
+
+            int totalLength = 0;
+            int labelStart = 0;
+            for (int i = 0; i <= end; i++) {
+                final boolean isDot = i == end || name.charAt(i) == '.';
+                if (!isDot) {
+                    continue;
+                }
+
+                final int labelLen = i - labelStart;
+                if (labelLen == 0) {
+                    throw new IllegalArgumentException("name contains an empty label: " + name);
+                }
+                if (labelLen > MAX_LABEL_LENGTH) {
+                    throw new IllegalArgumentException("label exceeds the maximum length: " + labelLen);
+                }
+
+                totalLength += labelLen + 1;
+                if (totalLength > MAX_NAME_LENGTH) {
+                    throw new IllegalArgumentException("name exceeds the maximum length: " + totalLength);
+                }
+
+                buf.writeByte(labelLen);
+                for (int j = labelStart; j < i; j++) {
+                    final char c = name.charAt(j);
+                    if (c > 0x7f) {
+                        throw new IllegalArgumentException("name must be US-ASCII: " + name);
+                    }
+                    buf.writeByte((byte) c);
+                }
+
+                labelStart = i + 1;
+            }
+
+            buf.writeByte(0);
+        }
+    }
+}
