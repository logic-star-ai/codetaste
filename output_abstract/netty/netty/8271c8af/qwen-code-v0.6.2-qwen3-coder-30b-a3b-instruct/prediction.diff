+package io.netty.handler.codec.dns;
+
+import io.netty.channel.embedded.EmbeddedChannel;
+import io.netty.channel.socket.DatagramPacket;
+import io.netty.util.NetUtil;
+import org.junit.Test;
+
+import java.net.InetSocketAddress;
+
+import static org.junit.Assert.*;
+
+public class DnsCodecExtensibilityTest {
+
+    @Test
+    public void testDnsMessageTypes() {
+        // Create a sample query
+        DnsQuery query = new DnsQuery(1234, new InetSocketAddress(NetUtil.LOCALHOST, 53));
+        assertEquals(DnsMessageType.QUERY, query.type());
+        
+        // Create a sample response
+        DnsResponse response = new DnsResponse(1234, new InetSocketAddress(NetUtil.LOCALHOST, 53));
+        assertEquals(DnsMessageType.RESPONSE, response.type());
+    }
+
+    @Test
+    public void testDnsMessageFactory() {
+        DnsMessageFactory factory = new DefaultDnsMessageFactory();
+        
+        // Test creating queries
+        DnsQuery query = factory.newQuery(1234, new InetSocketAddress(NetUtil.LOCALHOST, 53));
+        assertEquals(DnsMessageType.QUERY, query.type());
+        
+        // Test creating responses
+        DnsResponse response = factory.newResponse(1234, new InetSocketAddress(NetUtil.LOCALHOST, 53));
+        assertEquals(DnsMessageType.RESPONSE, response.type());
+        
+        // Test creating messages by type
+        DnsMessage message = factory.newMessage(DnsMessageType.QUERY, 1234, new InetSocketAddress(NetUtil.LOCALHOST, 53));
+        assertEquals(DnsMessageType.QUERY, message.type());
+        
+        message = factory.newMessage(DnsMessageType.RESPONSE, 1234, new InetSocketAddress(NetUtil.LOCALHOST, 53));
+        assertEquals(DnsMessageType.RESPONSE, message.type());
+    }
+
+    @Test
+    public void testDnsEncodersDecoders() {
+        // Test that we can create encoders and decoders
+        DnsQueryEncoder encoder = new DnsQueryEncoder();
+        DnsResponseDecoder decoder = new DnsResponseDecoder();
+        
+        assertNotNull(encoder);
+        assertNotNull(decoder);
+    }
+    
+    @Test
+    public void testDnsMessageInterfaces() {
+        // Test that we can work with the interfaces
+        DnsMessageFactory factory = new DefaultDnsMessageFactory();
+        
+        // Create a query using the factory
+        DnsQuery query = factory.newQuery(1234, new InetSocketAddress(NetUtil.LOCALHOST, 53));
+        DnsMessage message = query; // Polymorphism
+        
+        assertEquals(DnsMessageType.QUERY, message.type());
+        
+        // Create a response using the factory
+        DnsResponse response = factory.newResponse(1234, new InetSocketAddress(NetUtil.LOCALHOST, 53));
+        message = response; // Polymorphism
+        
+        assertEquals(DnsMessageType.RESPONSE, message.type());
+    }
+}
