+package io.netty.handler.codec.dns;
+
+/**
+ * The header interface which includes information shared by DNS query and
+ * response packet headers such as the ID, opcode, and type. The only flag
+ * shared by both classes is the flag for desiring recursion.
+ */
+public interface DnsHeaderOperations {
+    
+    /**
+     * Message type is query.
+     */
+    int TYPE_QUERY = 0;
+
+    /**
+     * Message type is response.
+     */
+    int TYPE_RESPONSE = 1;
+
+    /**
+     * Message is for a standard query.
+     */
+    int OPCODE_QUERY = 0;
+
+    /**
+     * Message is for an inverse query. <strong>Note: inverse queries have been
+     * obsoleted since RFC 3425, and are not necessarily supported.</strong>
+     */
+    @Deprecated
+    int OPCODE_IQUERY = 1;
+
+    /**
+     * Returns the identifier assigned by the program that generates any
+     * kind of query.
+     */
+    int id();
+    
+    /**
+     * Returns the message type (query or response).
+     */
+    int type();
+    
+    /**
+     * Returns the operation code.
+     */
+    int opcode();
+    
+    /**
+     * Returns {@code true} if a query is to be pursued recursively.
+     */
+    boolean isRecursionDesired();
+    
+    /**
+     * Returns {@code true} if the server supports recursive queries.
+     */
+    boolean isRecursionAvailable();
+    
+    /**
+     * Returns {@code true} if the response is truncated.
+     */
+    boolean isTruncated();
+    
+    /**
+     * Returns {@code true} if the response is authoritative.
+     */
+    boolean isAuthoritativeAnswer();
+    
+    /**
+     * Returns the response code.
+     */
+    DnsResponseCode responseCode();
+    
+    /**
+     * Returns the number of questions in the {@link DnsMessage}.
+     */
+    int questionCount();
+    
+    /**
+     * Returns the number of answer resource records in the {@link DnsMessage}.
+     */
+    int answerCount();
+    
+    /**
+     * Returns the number of authority resource records in the
+     * {@link DnsMessage}.
+     */
+    int authorityResourceCount();
+    
+    /**
+     * Returns the number of additional resource records in the
+     * {@link DnsMessage}.
+     */
+    int additionalResourceCount();
+    
+    /**
+     * Sets the identifier assigned by the program that generates any
+     * kind of query.
+     *
+     * @param id
+     *            the identifier
+     * @return the header to allow method chaining
+     */
+    DnsHeaderOperations setId(int id);
+    
+    /**
+     * Sets the message type (query or response).
+     *
+     * @param type
+     *            the message type
+     * @return the header to allow method chaining
+     */
+    DnsHeaderOperations setType(int type);
+    
+    /**
+     * Sets the operation code.
+     *
+     * @param opcode
+     *            the operation code
+     * @return the header to allow method chaining
+     */
+    DnsHeaderOperations setOpcode(int opcode);
+    
+    /**
+     * Sets the recursion desired flag.
+     *
+     * @param recursionDesired
+     *            {@code true} if recursion is desired
+     * @return the header to allow method chaining
+     */
+    DnsHeaderOperations setRecursionDesired(boolean recursionDesired);
+    
+    /**
+     * Sets the recursion available flag.
+     *
+     * @param recursionAvailable
+     *            {@code true} if recursion is available
+     * @return the header to allow method chaining
+     */
+    DnsHeaderOperations setRecursionAvailable(boolean recursionAvailable);
+    
+    /**
+     * Sets the truncated flag.
+     *
+     * @param truncated
+     *            {@code true} if the response is truncated
+     * @return the header to allow method chaining
+     */
+    DnsHeaderOperations setTruncated(boolean truncated);
+    
+    /**
+     * Sets the authoritative answer flag.
+     *
+     * @param authoritativeAnswer
+     *            {@code true} if the response is authoritative
+     * @return the header to allow method chaining
+     */
+    DnsHeaderOperations setAuthoritativeAnswer(boolean authoritativeAnswer);
+    
+    /**
+     * Sets the response code.
+     *
+     * @param responseCode
+     *            the response code
+     * @return the header to allow method chaining
+     */
+    DnsHeaderOperations setResponseCode(DnsResponseCode responseCode);
+}
