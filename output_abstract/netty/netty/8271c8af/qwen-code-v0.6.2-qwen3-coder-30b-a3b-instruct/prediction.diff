+ * under the License.
+ */
+package io.netty.handler.codec.dns;
+
+import java.net.InetSocketAddress;
+
+/**
+ * Default implementation of the DNS message factory.
+ */
+public class DefaultDnsMessageFactory implements DnsMessageFactory {
+    
+    @Override
+    public DnsQuery newQuery(int id, InetSocketAddress recipient) {
+        return new DnsQuery(id, recipient);
+    }
+    
+    @Override
+    public DnsResponse newResponse(int id, InetSocketAddress sender) {
+        return new DnsResponse(id, sender);
+    }
+    
+    @Override
+    public DnsMessage newMessage(DnsMessageType type, int id, InetSocketAddress address) {
+        switch (type) {
+            case QUERY:
+                return newQuery(id, address);
+            case RESPONSE:
+                return newResponse(id, address);
+            default:
+                throw new IllegalArgumentException("Unknown DNS message type: " + type);
+        }
+    }
+}
