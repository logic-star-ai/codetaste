+package io.netty.channel.embedded;
+
+import io.netty.channel.EventExecutor;
+
+import java.util.Iterator;
+
+import org.junit.Assert;
+import org.junit.Test;
+
+public class EmbeddedEventLoopGroupTest {
+
+    @Test
+    public void testSingleMemberGroup() {
+        EmbeddedEventLoop loop = new EmbeddedEventLoop();
+
+        Assert.assertSame(loop, loop.next());
+
+        Iterator<EventExecutor> it = loop.iterator();
+        Assert.assertTrue(it.hasNext());
+        Assert.assertSame(loop, it.next());
+        Assert.assertFalse(it.hasNext());
+    }
+}
