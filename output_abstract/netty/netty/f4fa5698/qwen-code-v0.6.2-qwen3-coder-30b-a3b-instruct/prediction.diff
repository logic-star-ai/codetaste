+package io.netty.util.group;
+
+import io.netty.util.concurrent.EventExecutor;
+import io.netty.util.concurrent.EventExecutorGroup;
+
+import java.util.concurrent.TimeUnit;
+
+/**
+ * A group abstraction for event loops and executors where individual instances are treated as single-member groups.
+ */
+public interface EventExecutorGroup extends io.netty.util.concurrent.EventExecutorGroup {
+    
+    /**
+     * Returns the next {@link EventExecutor} in this group.
+     * 
+     * @return the next {@link EventExecutor}
+     */
+    EventExecutor next();
+    
+    /**
+     * Returns the number of executors in this group.
+     * 
+     * @return the number of executors in this group
+     */
+    int executorCount();
+    
+    /**
+     * Returns the executor at the specified index.
+     * 
+     * @param index the index of the executor to return
+     * @return the executor at the specified index
+     */
+    EventExecutor executor(int index);
+    
+    /**
+     * Returns the index of the specified executor in this group.
+     * 
+     * @param executor the executor to find the index of
+     * @return the index of the specified executor, or -1 if not found
+     */
+    int indexOf(EventExecutor executor);
+    
+    /**
+     * Returns a new group containing the same executors as this group.
+     * 
+     * @return a new group with the same executors
+     */
+    EventExecutorGroup duplicate();
+    
+    // Override methods from EventExecutorGroup to ensure they work with single-member groups
+    @Override
+    EventExecutor next();
+    
+    @Override
+    boolean isShuttingDown();
+    
+    @Override
+    boolean isShutdown();
+    
+    @Override
+    boolean isTerminated();
+    
+    @Override
+    boolean awaitTermination(long timeout, TimeUnit unit) throws InterruptedException;
+    
+    @Override
+    void shutdown();
+    
+    @Override
+    void shutdownNow();
+    
+    @Override
+    Iterable<EventExecutor> iterator();
+}
