+package io.netty.util.group;
+
+import io.netty.util.concurrent.AbstractEventExecutorGroup;
+import io.netty.util.concurrent.EventExecutor;
+import io.netty.util.concurrent.EventExecutorGroup;
+
+import java.util.concurrent.TimeUnit;
+
+/**
+ * Base implementation of {@link EventExecutorGroup} that treats individual instances as single-member groups.
+ */
+public abstract class AbstractEventExecutorGroup extends AbstractEventExecutorGroup implements EventExecutorGroup {
+    
+    @Override
+    public EventExecutor next() {
+        return nextEventExecutor();
+    }
+    
+    /**
+     * Returns the next {@link EventExecutor} in this group.
+     * 
+     * @return the next {@link EventExecutor}
+     */
+    protected abstract EventExecutor nextEventExecutor();
+    
+    @Override
+    public int executorCount() {
+        return 1;
+    }
+    
+    @Override
+    public EventExecutor executor(int index) {
+        if (index != 0) {
+            throw new IndexOutOfBoundsException(
+                    "index: " + index + " (expected: 0)");
+        }
+        return nextEventExecutor();
+    }
+    
+    @Override
+    public int indexOf(EventExecutor executor) {
+        return nextEventExecutor() == executor ? 0 : -1;
+    }
+    
+    @Override
+    public EventExecutorGroup duplicate() {
+        return new EventExecutorGroup() {
+            @Override
+            public EventExecutor next() {
+                return AbstractEventExecutorGroup.this.nextEventExecutor();
+            }
+            
+            @Override
+            protected EventExecutor nextEventExecutor() {
+                return AbstractEventExecutorGroup.this.nextEventExecutor();
+            }
+            
+            @Override
+            public int executorCount() {
+                return 1;
+            }
+            
+            @Override
+            public EventExecutor executor(int index) {
+                return AbstractEventExecutorGroup.this.executor(index);
+            }
+            
+            @Override
+            public int indexOf(EventExecutor executor) {
+                return AbstractEventExecutorGroup.this.indexOf(executor);
+            }
+            
+            @Override
+            public EventExecutorGroup duplicate() {
+                return this;
+            }
+            
+            @Override
+            public boolean isShuttingDown() {
+                return AbstractEventExecutorGroup.this.isShuttingDown();
+            }
+            
+            @Override
+            public boolean isShutdown() {
+                return AbstractEventExecutorGroup.this.isShutdown();
+            }
+            
+            @Override
+            public boolean isTerminated() {
+                return AbstractEventExecutorGroup.this.isTerminated();
+            }
+            
+            @Override
+            public boolean awaitTermination(long timeout, TimeUnit unit) throws InterruptedException {
+                return AbstractEventExecutorGroup.this.awaitTermination(timeout, unit);
+            }
+            
+            @Override
+            public void shutdown() {
+                AbstractEventExecutorGroup.this.shutdown();
+            }
+            
+            @Override
+            public void shutdownNow() {
+                AbstractEventExecutorGroup.this.shutdownNow();
+            }
+            
+            @Override
+            public Iterable<EventExecutor> iterator() {
+                return AbstractEventExecutorGroup.this.iterator();
+            }
+        };
+    }
+    
+    @Override
+    public boolean isShuttingDown() {
+        return false;
+    }
+    
+    @Override
+    public boolean isShutdown() {
+        return false;
+    }
+    
+    @Override
+    public boolean isTerminated() {
+        return false;
+    }
+    
+    @Override
+    public boolean awaitTermination(long timeout, TimeUnit unit) throws InterruptedException {
+        return false;
+    }
+    
+    @Override
+    public void shutdown() {
+        // No-op for single-member groups
+    }
+    
+    @Override
+    public void shutdownNow() {
+        // No-op for single-member groups
+    }
+    
+    @Override
+    public Iterable<EventExecutor> iterator() {
+        return new Iterable<EventExecutor>() {
+            @Override
+            public java.util.Iterator<EventExecutor> iterator() {
+                return new java.util.Iterator<EventExecutor>() {
+                    private boolean hasNext = true;
+                    
+                    @Override
+                    public boolean hasNext() {
+                        return hasNext;
+                    }
+                    
+                    @Override
+                    public EventExecutor next() {
+                        if (!hasNext) {
+                            throw new java.util.NoSuchElementException();
+                        }
+                        hasNext = false;
+                        return nextEventExecutor();
+                    }
+                };
+            }
+        };
+    }
+}
