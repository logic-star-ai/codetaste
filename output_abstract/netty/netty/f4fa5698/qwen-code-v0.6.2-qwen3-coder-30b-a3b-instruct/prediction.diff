+package io.netty.util.group;
+
+import io.netty.channel.EventLoop;
+import io.netty.channel.EventLoopGroup;
+import io.netty.util.concurrent.EventExecutor;
+import io.netty.util.concurrent.EventExecutorGroup;
+
+import java.util.concurrent.ThreadFactory;
+
+/**
+ * Utility class for creating group abstractions for event loops and executors.
+ */
+public final class EventExecutorGroupFactory {
+    
+    /**
+     * Creates a single-member group from an EventExecutor.
+     * 
+     * @param executor the EventExecutor to wrap
+     * @return a single-member EventExecutorGroup
+     */
+    public static EventExecutorGroup createSingleMemberGroup(EventExecutor executor) {
+        return new SingleMemberEventExecutorGroup(executor);
+    }
+    
+    /**
+     * Creates a single-member group from an EventLoop.
+     * 
+     * @param eventLoop the EventLoop to wrap
+     * @return a single-member EventExecutorGroup
+     */
+    public static EventExecutorGroup createSingleMemberGroup(EventLoop eventLoop) {
+        return new SingleMemberEventExecutorGroup(eventLoop);
+    }
+    
+    /**
+     * Creates a single-member group from an EventLoopGroup.
+     * 
+     * @param eventLoopGroup the EventLoopGroup to wrap (assumes it contains only one member)
+     * @return a single-member EventExecutorGroup
+     */
+    public static EventExecutorGroup createSingleMemberGroup(EventLoopGroup eventLoopGroup) {
+        if (eventLoopGroup == null) {
+            throw new NullPointerException("eventLoopGroup");
+        }
+        if (eventLoopGroup.executorCount() != 1) {
+            throw new IllegalArgumentException("EventLoopGroup must contain exactly one executor");
+        }
+        return new SingleMemberEventExecutorGroup(eventLoopGroup.executor(0));
+    }
+    
+    private EventExecutorGroupFactory() {
+        // Prevent instantiation
+    }
+}
