+package io.netty.util.group;
+
+import io.netty.channel.EventLoop;
+import io.netty.channel.EventLoopGroup;
+import io.netty.util.concurrent.DefaultEventExecutor;
+import io.netty.util.concurrent.EventExecutor;
+import org.junit.Test;
+
+import static org.junit.Assert.*;
+
+public class EventExecutorGroupTest {
+    
+    @Test
+    public void testSingleMemberGroupCreation() {
+        EventExecutor executor = new DefaultEventExecutor();
+        EventExecutorGroup group = new SingleMemberEventExecutorGroup(executor);
+        
+        assertSame(executor, group.executor(0));
+        assertEquals(1, group.executorCount());
+        assertEquals(0, group.indexOf(executor));
+        assertSame(executor, group.next());
+    }
+    
+    @Test
+    public void testDuplicate() {
+        EventExecutor executor = new DefaultEventExecutor();
+        EventExecutorGroup group = new SingleMemberEventExecutorGroup(executor);
+        EventExecutorGroup duplicate = group.duplicate();
+        
+        assertSame(executor, duplicate.executor(0));
+        assertEquals(1, duplicate.executorCount());
+        assertEquals(0, duplicate.indexOf(executor));
+        assertSame(executor, duplicate.next());
+    }
+    
+    @Test
+    public void testIterator() {
+        EventExecutor executor = new DefaultEventExecutor();
+        EventExecutorGroup group = new SingleMemberEventExecutorGroup(executor);
+        
+        int count = 0;
+        for (EventExecutor e : group) {
+            assertSame(executor, e);
+            count++;
+        }
+        assertEquals(1, count);
+    }
+    
+    @Test(expected = IndexOutOfBoundsException.class)
+    public void testInvalidIndex() {
+        EventExecutor executor = new DefaultEventExecutor();
+        EventExecutorGroup group = new SingleMemberEventExecutorGroup(executor);
+        group.executor(1); // Should throw exception
+    }
+    
+    @Test
+    public void testFactoryMethod() {
+        EventExecutor executor = new DefaultEventExecutor();
+        EventExecutorGroup group1 = EventExecutorGroupFactory.createSingleMemberGroup(executor);
+        assertTrue(group1 instanceof SingleMemberEventExecutorGroup);
+        
+        EventLoop eventLoop = new DefaultEventExecutor() {
+            @Override
+            public boolean inEventLoop() {
+                return false;
+            }
+            
+            @Override
+            public boolean inEventLoop(Thread thread) {
+                return false;
+            }
+            
+            @Override
+            public Unsafe unsafe() {
+                return null;
+            }
+        };
+        EventExecutorGroup group2 = EventExecutorGroupFactory.createSingleMemberGroup(eventLoop);
+        assertTrue(group2 instanceof SingleMemberEventExecutorGroup);
+    }
+}
