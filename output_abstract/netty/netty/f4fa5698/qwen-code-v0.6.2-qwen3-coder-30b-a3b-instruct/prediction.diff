@@ -17,12 +17,35 @@ package io.netty.channel;
 
 import java.util.concurrent.ScheduledExecutorService;
 
+/**
+ * A service that executes tasks in an event-driven fashion.
+ *
+ * EventExecutor represents a core execution unit that can execute tasks,
+ * and also provides information about the current execution context.
+ */
 public interface EventExecutor extends ScheduledExecutorService {
+    /**
+     * Returns {@code true} if the current Thread is executing a task.
+     */
     boolean inEventLoop();
+
+    /**
+     * Returns {@code true} if the given Thread is executing a task.
+     */
     boolean inEventLoop(Thread thread);
+
+    /**
+     * Returns the unsafe operations that allow low-level access to the executor.
+     */
     Unsafe unsafe();
 
+    /**
+     * Unsafe operations that provide low-level access to the executor.
+     */
     interface Unsafe {
+        /**
+         * Returns the next child executor to use for load balancing.
+         */
         EventExecutor nextChild();
     }
 }
