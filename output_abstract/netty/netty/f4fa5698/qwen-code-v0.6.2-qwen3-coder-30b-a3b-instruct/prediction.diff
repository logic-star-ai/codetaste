+package io.netty.util.group;
+
+import io.netty.util.concurrent.EventExecutor;
+
+/**
+ * A single-member group implementation that wraps a single {@link EventExecutor}.
+ */
+public class SingleMemberEventExecutorGroup extends AbstractEventExecutorGroup {
+    
+    private final EventExecutor executor;
+    
+    /**
+     * Creates a new single-member group wrapping the given executor.
+     * 
+     * @param executor the executor to wrap
+     */
+    public SingleMemberEventExecutorGroup(EventExecutor executor) {
+        if (executor == null) {
+            throw new NullPointerException("executor");
+        }
+        this.executor = executor;
+    }
+    
+    @Override
+    protected EventExecutor nextEventExecutor() {
+        return executor;
+    }
+    
+    /**
+     * Returns the wrapped executor.
+     * 
+     * @return the wrapped executor
+     */
+    public EventExecutor getExecutor() {
+        return executor;
+    }
+}
