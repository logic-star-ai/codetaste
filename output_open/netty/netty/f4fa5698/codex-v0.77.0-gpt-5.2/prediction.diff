 public abstract class ZlibEncoder extends ByteToByteEncoder {
 
+    private static final long FINISH_AND_CLOSE_TIMEOUT_SECONDS = 10;
+
+    private volatile ChannelHandlerContext ctx;
+
     /**
      * Returns {@code true} if and only if the end of the compressed stream
      * has been reached.
@@ -36,4 +44,38 @@ public abstract class ZlibEncoder extends ByteToByteEncoder {
 
     public abstract ChannelFuture close(ChannelFuture future);
 
+    @Override
+    public final void beforeAdd(ChannelHandlerContext ctx) throws Exception {
+        this.ctx = ctx;
+    }
+
+    @Override
+    public final void close(final ChannelHandlerContext ctx, final ChannelFuture future) throws Exception {
+        ChannelFuture finishFuture = finishEncode(ctx, ctx.newFuture());
+        finishFuture.addListener(new ChannelFutureListener() {
+            @Override
+            public void operationComplete(ChannelFuture f) throws Exception {
+                ctx.close(future);
+            }
+        });
+
+        if (!finishFuture.isDone()) {
+            ctx.executor().schedule(new Runnable() {
+                @Override
+                public void run() {
+                    ctx.close(future);
+                }
+            }, FINISH_AND_CLOSE_TIMEOUT_SECONDS, TimeUnit.SECONDS);
+        }
+    }
+
+    protected final ChannelHandlerContext ctx() {
+        ChannelHandlerContext ctx = this.ctx;
+        if (ctx == null) {
+            throw new IllegalStateException("not added to a pipeline");
+        }
+        return ctx;
+    }
+
+    protected abstract ChannelFuture finishEncode(ChannelHandlerContext ctx, ChannelFuture future);
 }
