  */
 final class ZlibUtil {
 
+    private static final double DEFLATE_OVERHEAD = 0.001;
+    private static final int DEFLATE_MINIMUM_SPACE = 12;
+
+    static int deflateBound(int inputLength) {
+        return (int) Math.ceil(inputLength * (1.0 + DEFLATE_OVERHEAD)) + DEFLATE_MINIMUM_SPACE;
+    }
+
     static void fail(ZStream z, String message, int resultCode) {
         throw exception(z, message, resultCode);
     }
