+/**
+ * Shared request utilities for n8n nodes
+ * Centralizes common HTTP request patterns
+ */
+
+import type { IDataObject, IRequestOptions } from 'n8n-workflow';
+import { removeEmptyProperties } from './validation.utils';
+
+/**
+ * Cleans request options by removing empty body and qs properties
+ * @param options - Request options to clean
+ */
+export function cleanRequestOptions(options: IRequestOptions): void {
+	removeEmptyProperties(options, ['body', 'qs']);
+}
+
+/**
+ * Merges headers into request options
+ * @param options - Request options
+ * @param headers - Headers to merge
+ */
+export function mergeHeaders(options: IRequestOptions, headers: IDataObject): void {
+	if (Object.keys(headers).length > 0) {
+		options.headers = Object.assign({}, options.headers || {}, headers);
+	}
+}
+
+/**
+ * Creates base request options with common defaults
+ * @param method - HTTP method
+ * @param url - Request URL
+ * @param body - Request body
+ * @param qs - Query string parameters
+ * @returns Request options object
+ */
+export function createBaseRequestOptions(
+	method: string,
+	url: string,
+	body: IDataObject = {},
+	qs: IDataObject = {},
+): IRequestOptions {
+	const options: IRequestOptions = {
+		method: method as any,
+		body,
+		qs,
+		uri: url,
+		json: true,
+	};
+
+	cleanRequestOptions(options);
+	return options;
+}
+
+/**
+ * Extracts pagination info from response headers
+ * @param headers - Response headers
+ * @returns Pagination info
+ */
+export function extractPaginationFromHeaders(headers: Record<string, any>): {
+	nextPage?: string;
+	hasMore: boolean;
+	totalCount?: number;
+} {
+	const linkHeader = headers.link || headers.Link;
+	const totalCountHeader = headers['x-total-count'] || headers['X-Total-Count'];
+
+	let nextPage: string | undefined;
+	if (linkHeader) {
+		const nextMatch = linkHeader.match(/<([^>]+)>;\s*rel="next"/);
+		nextPage = nextMatch ? nextMatch[1] : undefined;
+	}
+
+	return {
+		nextPage,
+		hasMore: !!nextPage,
+		totalCount: totalCountHeader ? parseInt(totalCountHeader, 10) : undefined,
+	};
+}
+
+/**
+ * Builds standard pagination query parameters
+ * @param page - Page number (1-indexed)
+ * @param pageSize - Number of items per page
+ * @param offset - Optional offset (overrides page)
+ * @returns Query parameters for pagination
+ */
+export function buildPaginationParams(
+	page?: number,
+	pageSize?: number,
+	offset?: number,
+): IDataObject {
+	const params: IDataObject = {};
+
+	if (offset !== undefined) {
+		params.offset = offset;
+	} else if (page !== undefined) {
+		params.page = page;
+	}
+
+	if (pageSize !== undefined) {
+		params.limit = pageSize;
+		params.per_page = pageSize; // Some APIs use this
+		params.pageSize = pageSize; // Some APIs use this
+	}
+
+	return params;
+}
