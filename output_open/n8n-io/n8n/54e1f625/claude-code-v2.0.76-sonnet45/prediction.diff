+/**
+ * Date utility functions for n8n nodes
+ * Provides consistent date handling across nodes
+ */
+
+import { ApplicationError } from 'n8n-workflow';
+
+/**
+ * Formats a date to ISO 8601 string
+ * @param date - Date to format
+ * @returns ISO 8601 formatted string
+ */
+export function toISOString(date: Date | string | number): string {
+	if (date instanceof Date) {
+		return date.toISOString();
+	}
+	return new Date(date).toISOString();
+}
+
+/**
+ * Formats a date to UNIX timestamp (seconds)
+ * @param date - Date to format
+ * @returns UNIX timestamp in seconds
+ */
+export function toUnixTimestamp(date: Date | string | number): number {
+	if (date instanceof Date) {
+		return Math.floor(date.getTime() / 1000);
+	}
+	return Math.floor(new Date(date).getTime() / 1000);
+}
+
+/**
+ * Formats a date to UNIX timestamp in milliseconds
+ * @param date - Date to format
+ * @returns UNIX timestamp in milliseconds
+ */
+export function toUnixTimestampMs(date: Date | string | number): number {
+	if (date instanceof Date) {
+		return date.getTime();
+	}
+	return new Date(date).getTime();
+}
+
+/**
+ * Parses various date formats to Date object
+ * @param date - Date string, number, or Date object
+ * @returns Date object or null if invalid
+ */
+export function parseDate(date: string | number | Date | null | undefined): Date | null {
+	if (!date) return null;
+
+	if (date instanceof Date) {
+		return isNaN(date.getTime()) ? null : date;
+	}
+
+	const parsed = new Date(date);
+	return isNaN(parsed.getTime()) ? null : parsed;
+}
+
+/**
+ * Checks if a date string/value is valid
+ * @param date - Date to validate
+ * @returns true if valid date
+ */
+export function isValidDate(date: unknown): boolean {
+	if (!date) return false;
+
+	const parsed = parseDate(date as any);
+	return parsed !== null;
+}
+
+/**
+ * Formats date to common API formats
+ * @param date - Date to format
+ * @param format - Format type: 'iso', 'unix', 'unix-ms', 'date-only', 'time-only'
+ * @returns Formatted date string or number
+ */
+export function formatDate(
+	date: Date | string | number,
+	format: 'iso' | 'unix' | 'unix-ms' | 'date-only' | 'time-only' = 'iso',
+): string | number {
+	const parsedDate = parseDate(date);
+	if (!parsedDate) {
+		throw new ApplicationError('Invalid date provided to formatDate');
+	}
+
+	switch (format) {
+		case 'iso':
+			return parsedDate.toISOString();
+		case 'unix':
+			return toUnixTimestamp(parsedDate);
+		case 'unix-ms':
+			return toUnixTimestampMs(parsedDate);
+		case 'date-only':
+			return parsedDate.toISOString().split('T')[0];
+		case 'time-only':
+			return parsedDate.toISOString().split('T')[1];
+		default:
+			return parsedDate.toISOString();
+	}
+}
+
+/**
+ * Adds time to a date
+ * @param date - Base date
+ * @param amount - Amount to add
+ * @param unit - Unit of time: 'seconds', 'minutes', 'hours', 'days'
+ * @returns New date with added time
+ */
+export function addTime(
+	date: Date | string | number,
+	amount: number,
+	unit: 'seconds' | 'minutes' | 'hours' | 'days',
+): Date {
+	const parsedDate = parseDate(date);
+	if (!parsedDate) {
+		throw new ApplicationError('Invalid date provided to addTime');
+	}
+
+	const result = new Date(parsedDate);
+
+	switch (unit) {
+		case 'seconds':
+			result.setSeconds(result.getSeconds() + amount);
+			break;
+		case 'minutes':
+			result.setMinutes(result.getMinutes() + amount);
+			break;
+		case 'hours':
+			result.setHours(result.getHours() + amount);
+			break;
+		case 'days':
+			result.setDate(result.getDate() + amount);
+			break;
+	}
+
+	return result;
+}
+
+/**
+ * Gets the difference between two dates
+ * @param date1 - First date
+ * @param date2 - Second date
+ * @param unit - Unit to return: 'seconds', 'minutes', 'hours', 'days'
+ * @returns Difference in specified unit
+ */
+export function dateDiff(
+	date1: Date | string | number,
+	date2: Date | string | number,
+	unit: 'seconds' | 'minutes' | 'hours' | 'days' = 'seconds',
+): number {
+	const parsed1 = parseDate(date1);
+	const parsed2 = parseDate(date2);
+
+	if (!parsed1 || !parsed2) {
+		throw new ApplicationError('Invalid dates provided to dateDiff');
+	}
+
+	const diffMs = parsed1.getTime() - parsed2.getTime();
+
+	switch (unit) {
+		case 'seconds':
+			return Math.floor(diffMs / 1000);
+		case 'minutes':
+			return Math.floor(diffMs / (1000 * 60));
+		case 'hours':
+			return Math.floor(diffMs / (1000 * 60 * 60));
+		case 'days':
+			return Math.floor(diffMs / (1000 * 60 * 60 * 24));
+		default:
+			return Math.floor(diffMs / 1000);
+	}
+}
