+/**
+ * Shared URL utilities for n8n nodes
+ * Centralizes common URL manipulation patterns
+ */
+
+/**
+ * Removes trailing slash from a URL
+ * @param url - URL to clean
+ * @returns URL without trailing slash
+ */
+export function removeTrailingSlash(url: string): string {
+	return url.replace(/\/$/, '');
+}
+
+/**
+ * Ensures a URL has a protocol (defaults to https)
+ * @param url - URL to check
+ * @param defaultProtocol - Default protocol to add (defaults to 'https')
+ * @returns URL with protocol
+ */
+export function ensureProtocol(url: string, defaultProtocol: string = 'https'): string {
+	if (!/^https?:\/\//i.test(url)) {
+		return `${defaultProtocol}://${url}`;
+	}
+	return url;
+}
+
+/**
+ * Joins URL parts ensuring proper slashes
+ * @param parts - URL parts to join
+ * @returns Joined URL
+ */
+export function joinUrl(...parts: string[]): string {
+	return parts
+		.map((part, index) => {
+			if (index === 0) {
+				return part.replace(/\/$/, '');
+			}
+			return part.replace(/^\//, '').replace(/\/$/, '');
+		})
+		.filter(Boolean)
+		.join('/');
+}
+
+/**
+ * Builds query string from object
+ * @param params - Object with query parameters
+ * @returns Query string (without leading ?)
+ */
+export function buildQueryString(params: Record<string, any>): string {
+	const searchParams = new URLSearchParams();
+
+	for (const [key, value] of Object.entries(params)) {
+		if (value !== undefined && value !== null && value !== '') {
+			if (Array.isArray(value)) {
+				value.forEach(v => searchParams.append(key, String(v)));
+			} else {
+				searchParams.append(key, String(value));
+			}
+		}
+	}
+
+	return searchParams.toString();
+}
+
+/**
+ * Normalizes URL by removing trailing slash and ensuring protocol
+ * @param url - URL to normalize
+ * @returns Normalized URL
+ */
+export function normalizeUrl(url: string): string {
+	return removeTrailingSlash(ensureProtocol(url));
+}
