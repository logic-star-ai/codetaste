+/**
+ * Shared error handling utilities for n8n nodes
+ * Centralizes common error handling patterns
+ */
+
+import type { INode, JsonObject } from 'n8n-workflow';
+import { NodeApiError, NodeOperationError } from 'n8n-workflow';
+
+/**
+ * Wraps an error in NodeApiError
+ * @param node - Node that generated the error
+ * @param error - Original error
+ * @param message - Optional custom message
+ * @returns NodeApiError
+ */
+export function wrapApiError(node: INode, error: any, message?: string): NodeApiError {
+	const apiError = new NodeApiError(node, error as JsonObject);
+	if (message) {
+		apiError.message = message;
+	}
+	return apiError;
+}
+
+/**
+ * Creates a NodeOperationError with standardized message
+ * @param node - Node that generated the error
+ * @param message - Error message
+ * @param options - Additional error options
+ * @returns NodeOperationError
+ */
+export function createOperationError(
+	node: INode,
+	message: string,
+	options?: { description?: string; itemIndex?: number },
+): NodeOperationError {
+	return new NodeOperationError(node, message, options);
+}
+
+/**
+ * Checks if an error is a specific HTTP status code
+ * @param error - Error to check
+ * @param statusCode - HTTP status code to match
+ * @returns true if error matches status code
+ */
+export function isHttpStatusCode(error: any, statusCode: number): boolean {
+	return error?.statusCode === statusCode || error?.response?.status === statusCode;
+}
+
+/**
+ * Checks if an error is a 404 Not Found
+ * @param error - Error to check
+ * @returns true if error is 404
+ */
+export function isNotFoundError(error: any): boolean {
+	return isHttpStatusCode(error, 404);
+}
+
+/**
+ * Checks if an error is a 401 Unauthorized
+ * @param error - Error to check
+ * @returns true if error is 401
+ */
+export function isUnauthorizedError(error: any): boolean {
+	return isHttpStatusCode(error, 401);
+}
+
+/**
+ * Checks if an error is a 429 Too Many Requests (rate limit)
+ * @param error - Error to check
+ * @returns true if error is 429
+ */
+export function isRateLimitError(error: any): boolean {
+	return isHttpStatusCode(error, 429);
+}
+
+/**
+ * Extracts error message from various error formats
+ * @param error - Error object
+ * @param defaultMessage - Default message if extraction fails
+ * @returns Error message
+ */
+export function extractErrorMessage(error: any, defaultMessage: string = 'Unknown error'): string {
+	if (typeof error === 'string') {
+		return error;
+	}
+
+	return (
+		error?.message ||
+		error?.description ||
+		error?.error?.message ||
+		error?.response?.data?.message ||
+		error?.response?.data?.error?.message ||
+		defaultMessage
+	);
+}
+
+/**
+ * Safely handles errors with optional retry logic hint
+ * @param error - Error to handle
+ * @returns Object with error info and retry suggestion
+ */
+export function analyzeError(error: any): {
+	message: string;
+	shouldRetry: boolean;
+	retryAfter?: number;
+} {
+	const message = extractErrorMessage(error);
+	const shouldRetry = isRateLimitError(error) || isHttpStatusCode(error, 503);
+
+	let retryAfter: number | undefined;
+	if (isRateLimitError(error)) {
+		const retryAfterHeader =
+			error?.response?.headers?.['retry-after'] || error?.headers?.['retry-after'];
+		if (retryAfterHeader) {
+			retryAfter = parseInt(retryAfterHeader, 10);
+		}
+	}
+
+	return { message, shouldRetry, retryAfter };
+}
