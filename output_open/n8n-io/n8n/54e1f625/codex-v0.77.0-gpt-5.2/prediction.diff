new file mode 100644
index 0000000..815d4d5
--- /dev/null
+++ b/scripts/bin-utils.mjs
@@ -0,0 +1,23 @@
+import fs from 'node:fs';
+import path from 'node:path';
+import { spawnSync } from 'node:child_process';
+
+export function resolveBin(binName) {
+	const windowsExt = process.platform === 'win32' ? '.cmd' : '';
+	const candidate = path.resolve('node_modules', '.bin', `${binName}${windowsExt}`);
+	if (fs.existsSync(candidate)) return candidate;
+
+	const fallback = path.resolve('node_modules', '.bin', binName);
+	if (fs.existsSync(fallback)) return fallback;
+
+	return candidate;
+}
+
+export function run(bin, args, options = {}) {
+	const result = spawnSync(bin, args, { stdio: 'inherit', shell: false, ...options });
+
+	if (result.error) throw result.error;
+	if (result.status !== 0) {
+		throw new Error(`${path.basename(bin)} exited with code ${result.status}`);
+	}
+}
