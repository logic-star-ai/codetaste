+// EndpointHealthGetTimeout fetches the health status of the endpoint identified by id
+// with specified timeout
+func (c *Client) EndpointHealthGetTimeout(id string, timeoutSeconds int) (*models.EndpointHealth, error) {
+	ctx, cancel := context.WithTimeout(context.Background(), time.Duration(timeoutSeconds)*time.Second)
+	defer cancel()
+
+	params := endpoint.NewGetEndpointIDHealthzParams().WithID(id)
+	params.SetContext(ctx)
+
+	resp, err := c.Endpoint.GetEndpointIDHealthz(params)
+	if err != nil {
+		return nil, Hint(err)
+	}
+
+	return resp.Payload, nil
+}
