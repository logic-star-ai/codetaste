+func findGiteaRoot() (string, error) {

+	if giteaRoot != "" {

+		return giteaRoot, nil

+	}

+

+	if setting.AppWorkPath != "" {

+		if _, err := os.Stat(filepath.Join(setting.AppWorkPath, "go.mod")); err == nil {

+			return setting.AppWorkPath, nil

+		}

+	}

+

+	if setting.AppPath != "" {

+		root := filepath.Dir(setting.AppPath)

+		if _, err := os.Stat(filepath.Join(root, "go.mod")); err == nil {

+			return root, nil

+		}

+	}

+

+	searchDir, _ := os.Getwd()

+	for searchDir != "" {

+		if _, err := os.Stat(filepath.Join(searchDir, "go.mod")); err == nil {

+			return searchDir, nil // The "go.mod" should be the one for Gitea repository

+		}

+		if dir := filepath.Dir(searchDir); dir == searchDir {

+			searchDir = "" // reaches the root of filesystem

+		} else {

+			searchDir = dir

+		}

+	}

+	return "", fmt.Errorf("the tests should run in a Gitea repository, there should be a 'go.mod' in the root")

+}

+

