// SyncAllTables sync the schemas of all tables, is required by unit test code

func SyncAllTables() error {

	_, err := x.StoreEngine("InnoDB").SyncWithOptions(xorm.SyncOptions{

		WarnIfDatabaseColumnMissed: true,

