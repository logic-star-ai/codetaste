diff --git a/models/unittest/sqlite_ini.go b/models/unittest/sqlite_ini.go

new file mode 100644

index 0000000000000000000000000000000000000000..fec48603d7cc6cc1c931de0dedcca1ce4c90bd07

--- /dev/null

+++ b/models/unittest/sqlite_ini.go

@@ -0,0 +1,85 @@

+package unittest

+

+import (

+	"errors"

+	"os"

+	"path/filepath"

+	"strings"

+)

+

+// EnsureDefaultSQLiteTestIni creates "tests/sqlite.ini" from "tests/sqlite.ini.tmpl" (using the same defaults as Makefile)

+// if it doesn't exist yet. This helps `go test ./...` work without running `make generate-ini-sqlite`.

+func EnsureDefaultSQLiteTestIni(giteaRoot string) (string, error) {

+	destPath := filepath.Join(giteaRoot, "tests", "sqlite.ini")

+	if existingBytes, err := os.ReadFile(destPath); err == nil {

+		existing := string(existingBytes)

+		// The old template used absolute-ish paths which were later treated as relative to APP_DATA_PATH, leading to duplication.

+		looksStale := strings.Contains(existing, "\n[attachment]\nPATH = tests/") ||

+			strings.Contains(existing, "\n[lfs]\nPATH = tests/") ||

+			strings.Contains(existing, "AVATAR_UPLOAD_PATH            = tests/") ||

+			strings.Contains(existing, "REPOSITORY_AVATAR_UPLOAD_PATH = tests/")

+		if !looksStale {

+			return destPath, nil

+		}

+	} else if !errors.Is(err, os.ErrNotExist) {

+		return "", err

+	}

+

+	tmplPath := filepath.Join(giteaRoot, "tests", "sqlite.ini.tmpl")

+	tmplBytes, err := os.ReadFile(tmplPath)

+	if err != nil {

+		return "", err

+	}

+

+	repoTestDir := os.Getenv("REPO_TEST_DIR")

+	if repoTestDir == "" {

+		repoTestDir = filepath.ToSlash(giteaRoot)

+		if !strings.HasSuffix(repoTestDir, "/") {

+			repoTestDir += "/"

+		}

+	}

+	testLogger := os.Getenv("TEST_LOGGER")

+	if testLogger == "" {

+		testLogger = "test,file"

+	}

+	testType := os.Getenv("TEST_TYPE")

+	if testType == "" {

+		testType = "integration"

+	}

+

+	iniContent := string(tmplBytes)

+	iniContent = strings.ReplaceAll(iniContent, "{{REPO_TEST_DIR}}", repoTestDir)

+	iniContent = strings.ReplaceAll(iniContent, "{{TEST_LOGGER}}", testLogger)

+	iniContent = strings.ReplaceAll(iniContent, "{{TEST_TYPE}}", testType)

+

+	if err := os.MkdirAll(filepath.Dir(destPath), 0o755); err != nil {

+		return "", err

+	}

+

+	tmpFile, err := os.CreateTemp(filepath.Dir(destPath), "sqlite.ini.*.tmp")

+	if err != nil {

+		return "", err

+	}

+	tmpName := tmpFile.Name()

+	_, writeErr := tmpFile.WriteString(iniContent)

+	closeErr := tmpFile.Close()

+	if writeErr != nil {

+		_ = os.Remove(tmpName)

+		return "", writeErr

+	}

+	if closeErr != nil {

+		_ = os.Remove(tmpName)

+		return "", closeErr

+	}

+

+	if err := os.Rename(tmpName, destPath); err != nil {

+		// If another test process wrote it concurrently, use the existing file.

+		if _, statErr := os.Stat(destPath); statErr == nil {

+			_ = os.Remove(tmpName)

+			return destPath, nil

+		}

+		_ = os.Remove(tmpName)

+		return "", err

+	}

+	return destPath, nil

+}

