+func findArtifactByName(t *testing.T, listResp listArtifactsResponse, name string) listArtifactsResponseItem {

+	t.Helper()

+	for _, v := range listResp.Value {

+		if v.Name == name {

+			return v

+		}

+	}

+	assert.FailNow(t, "artifact not found", "artifact name: %s", name)

+	return listArtifactsResponseItem{}

