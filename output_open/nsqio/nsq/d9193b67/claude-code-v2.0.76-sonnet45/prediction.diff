@@ -1,9 +1,21 @@
 package util
 
+import "errors"
+
 type ChildErr interface {
 	Parent() error
 }
 
+// Unwrap provides support for errors.Is and errors.As
+func (e *ClientErr) Unwrap() error {
+	return e.ParentErr
+}
+
+// Unwrap provides support for errors.Is and errors.As
+func (e *FatalClientErr) Unwrap() error {
+	return e.ParentErr
+}
+
 // ClientErr provides a way for NSQ daemons to log a human reabable
 // error string and return a machine readable string to the client.
 //
@@ -49,3 +61,15 @@ func (e *FatalClientErr) Parent() error {
 func NewFatalClientErr(parent error, code string, description string) *FatalClientErr {
 	return &FatalClientErr{parent, code, description}
 }
+
+// IsFatalClientErr checks if an error is or wraps a FatalClientErr
+func IsFatalClientErr(err error) bool {
+	var fatalErr *FatalClientErr
+	return errors.As(err, &fatalErr)
+}
+
+// IsClientErr checks if an error is or wraps a ClientErr
+func IsClientErr(err error) bool {
+	var clientErr *ClientErr
+	return errors.As(err, &clientErr)
+}
diff --git a/internal/util/logger.go b/internal/util/logger.go
index 8532193..a6774e9 100644
--- a/internal/util/logger.go
+++ b/internal/util/logger.go
@@ -1,5 +1,17 @@
 package util
 
+import "fmt"
+
 type logger interface {
 	Output(maxdepth int, s string) error
 }
+
+// Logf formats and logs a message using the provided logger.
+// If logger is nil, the function returns without logging.
+// The calldepth parameter is added to account for the call stack.
+func Logf(logger logger, calldepth int, format string, args ...interface{}) {
+	if logger == nil {
+		return
+	}
+	logger.Output(calldepth, fmt.Sprintf(format, args...))
+}
