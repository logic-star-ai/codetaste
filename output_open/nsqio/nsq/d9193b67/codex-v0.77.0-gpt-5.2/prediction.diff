diff --git a/nsqd/certs_test.go b/nsqd/certs_test.go
new file mode 100644
index 0000000..ec8aa85
--- /dev/null
+++ b/nsqd/certs_test.go
@@ -0,0 +1,149 @@
+package nsqd
+
+import (
+	"crypto/rand"
+	"crypto/rsa"
+	"crypto/x509"
+	"crypto/x509/pkix"
+	"encoding/pem"
+	"math/big"
+	"net"
+	"os"
+	"path/filepath"
+	"testing"
+	"time"
+)
+
+type tlsTestCerts struct {
+	CAFile string
+
+	ServerCertFile string
+	ServerKeyFile  string
+
+	ClientCertFile string
+	ClientKeyFile  string
+
+	UnsignedClientCertFile string
+	UnsignedClientKeyFile  string
+}
+
+func mustMakeTLSTestCerts(t *testing.T) tlsTestCerts {
+	t.Helper()
+
+	dir := t.TempDir()
+	now := time.Now()
+
+	caKey := mustGenerateRSAKey(t)
+	caTemplate := &x509.Certificate{
+		SerialNumber:          mustRandSerial(t),
+		Subject:               pkix.Name{CommonName: "NSQ Test CA"},
+		NotBefore:             now.Add(-1 * time.Hour),
+		NotAfter:              now.Add(10 * 365 * 24 * time.Hour),
+		KeyUsage:              x509.KeyUsageCertSign | x509.KeyUsageCRLSign,
+		BasicConstraintsValid: true,
+		IsCA:                  true,
+	}
+	caDER := mustCreateCertificate(t, caTemplate, caTemplate, &caKey.PublicKey, caKey)
+	caFile := filepath.Join(dir, "ca.pem")
+	mustWritePEM(t, caFile, "CERTIFICATE", caDER)
+
+	serverKey := mustGenerateRSAKey(t)
+	serverTemplate := &x509.Certificate{
+		SerialNumber: mustRandSerial(t),
+		Subject:      pkix.Name{CommonName: "localhost"},
+		NotBefore:    now.Add(-1 * time.Hour),
+		NotAfter:     now.Add(10 * 365 * 24 * time.Hour),
+		KeyUsage:     x509.KeyUsageDigitalSignature | x509.KeyUsageKeyEncipherment,
+		ExtKeyUsage:  []x509.ExtKeyUsage{x509.ExtKeyUsageServerAuth},
+		DNSNames:     []string{"localhost"},
+		IPAddresses:  []net.IP{net.ParseIP("127.0.0.1")},
+	}
+	serverDER := mustCreateCertificate(t, serverTemplate, caTemplate, &serverKey.PublicKey, caKey)
+	serverCertFile := filepath.Join(dir, "server.pem")
+	serverKeyFile := filepath.Join(dir, "server.key")
+	mustWritePEM(t, serverCertFile, "CERTIFICATE", serverDER)
+	mustWritePEM(t, serverKeyFile, "RSA PRIVATE KEY", x509.MarshalPKCS1PrivateKey(serverKey))
+
+	clientKey := mustGenerateRSAKey(t)
+	clientTemplate := &x509.Certificate{
+		SerialNumber: mustRandSerial(t),
+		Subject:      pkix.Name{CommonName: "NSQ Test Client"},
+		NotBefore:    now.Add(-1 * time.Hour),
+		NotAfter:     now.Add(10 * 365 * 24 * time.Hour),
+		KeyUsage:     x509.KeyUsageDigitalSignature | x509.KeyUsageKeyEncipherment,
+		ExtKeyUsage:  []x509.ExtKeyUsage{x509.ExtKeyUsageClientAuth},
+	}
+	clientDER := mustCreateCertificate(t, clientTemplate, caTemplate, &clientKey.PublicKey, caKey)
+	clientCertFile := filepath.Join(dir, "client.pem")
+	clientKeyFile := filepath.Join(dir, "client.key")
+	mustWritePEM(t, clientCertFile, "CERTIFICATE", clientDER)
+	mustWritePEM(t, clientKeyFile, "RSA PRIVATE KEY", x509.MarshalPKCS1PrivateKey(clientKey))
+
+	unsignedKey := mustGenerateRSAKey(t)
+	unsignedTemplate := &x509.Certificate{
+		SerialNumber: mustRandSerial(t),
+		Subject:      pkix.Name{CommonName: "NSQ Unsigned Test Client"},
+		NotBefore:    now.Add(-1 * time.Hour),
+		NotAfter:     now.Add(10 * 365 * 24 * time.Hour),
+		KeyUsage:     x509.KeyUsageDigitalSignature | x509.KeyUsageKeyEncipherment,
+		ExtKeyUsage:  []x509.ExtKeyUsage{x509.ExtKeyUsageClientAuth},
+	}
+	unsignedDER := mustCreateCertificate(t, unsignedTemplate, unsignedTemplate, &unsignedKey.PublicKey, unsignedKey)
+	unsignedCertFile := filepath.Join(dir, "cert.pem")
+	unsignedKeyFile := filepath.Join(dir, "key.pem")
+	mustWritePEM(t, unsignedCertFile, "CERTIFICATE", unsignedDER)
+	mustWritePEM(t, unsignedKeyFile, "RSA PRIVATE KEY", x509.MarshalPKCS1PrivateKey(unsignedKey))
+
+	return tlsTestCerts{
+		CAFile: caFile,
+
+		ServerCertFile: serverCertFile,
+		ServerKeyFile:  serverKeyFile,
+
+		ClientCertFile: clientCertFile,
+		ClientKeyFile:  clientKeyFile,
+
+		UnsignedClientCertFile: unsignedCertFile,
+		UnsignedClientKeyFile:  unsignedKeyFile,
+	}
+}
+
+func mustGenerateRSAKey(t *testing.T) *rsa.PrivateKey {
+	t.Helper()
+	key, err := rsa.GenerateKey(rand.Reader, 2048)
+	if err != nil {
+		t.Fatalf("generate RSA key: %v", err)
+	}
+	return key
+}
+
+func mustRandSerial(t *testing.T) *big.Int {
+	t.Helper()
+	limit := new(big.Int).Lsh(big.NewInt(1), 128)
+	serial, err := rand.Int(rand.Reader, limit)
+	if err != nil {
+		t.Fatalf("generate serial: %v", err)
+	}
+	return serial
+}
+
+func mustCreateCertificate(t *testing.T, template, parent *x509.Certificate, publicKey interface{}, parentPrivateKey interface{}) []byte {
+	t.Helper()
+	der, err := x509.CreateCertificate(rand.Reader, template, parent, publicKey, parentPrivateKey)
+	if err != nil {
+		t.Fatalf("create certificate: %v", err)
+	}
+	return der
+}
+
+func mustWritePEM(t *testing.T, path string, typ string, derBytes []byte) {
+	t.Helper()
+	f, err := os.OpenFile(path, os.O_WRONLY|os.O_CREATE|os.O_TRUNC, 0600)
+	if err != nil {
+		t.Fatalf("open %s: %v", path, err)
+	}
+	defer f.Close()
+	if err := pem.Encode(f, &pem.Block{Type: typ, Bytes: derBytes}); err != nil {
+		t.Fatalf("write PEM %s: %v", path, err)
+	}
+}
