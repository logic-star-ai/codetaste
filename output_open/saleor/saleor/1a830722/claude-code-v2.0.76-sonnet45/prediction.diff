@@ -1,3 +1,4 @@
+from collections.abc import Generator
 from contextlib import contextmanager
 
 from django.db import DatabaseError
@@ -6,15 +7,28 @@ from ..core.tracing import traced_atomic_transaction
 
 
 @contextmanager
-def transaction_with_commit_on_errors():
-    """Perform transaction and raise an error in any occurred."""
+def transaction_with_commit_on_errors() -> Generator[None, None, None]:
+    """Perform transaction and raise an error if any occurred.
+
+    This context manager commits the transaction even if a non-database error
+    occurs, then re-raises that error. Database errors cause an immediate
+    rollback as expected.
+
+    Yields:
+        None
+
+    Raises:
+        Exception: Re-raises any non-DatabaseError exception after committing
+    """
     error = None
     with traced_atomic_transaction():
         try:
             yield
         except DatabaseError:
+            # Let database errors rollback immediately
             raise
         except Exception as e:
+            # Capture non-database errors to raise after commit
             error = e
     if error:
         raise error
