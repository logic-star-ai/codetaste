+package com.linecorp.armeria.common;
+
+import java.util.concurrent.CompletableFuture;
+import java.util.concurrent.ExecutorService;
+import java.util.function.Consumer;
+
+import com.google.common.util.concurrent.MoreExecutors;
+
+/**
+ * Utility class for common operations in Armeria.
+ */
+public final class Util {
+    private Util() {}
+
+    /**
+     * Runs the given action in a blocking executor.
+     *
+     * @param executor The executor to use
+     * @param action   The action to run
+     */
+    public static void runBlocking(ExecutorService executor, Runnable action) {
+        executor.execute(action);
+    }
+
+    /**
+     * Runs the given action in a blocking executor with a future.
+     *
+     * @param executor The executor to use
+     * @param action   The action to run
+     * @param <T>      The return type of the action
+     * @return The future result of the action
+     */
+    public static <T> CompletableFuture<T> runBlockingFuture(
+            ExecutorService executor, java.util.function.Supplier<T> action) {
+        return CompletableFuture.supplyAsync(action, executor);
+    }
+
+    /**
+     * Runs the given action in a blocking executor with a future.
+     *
+     * @param executor The executor to use
+     * @param action   The action to run
+     * @param <T>      The return type of the action
+     * @return The future result of the action
+     */
+    public static <T> CompletableFuture<T> runBlockingFuture(
+            ExecutorService executor, java.util.function.Supplier<T> action, Consumer<T> callback) {
+        CompletableFuture<T> future = CompletableFuture.supplyAsync(action, executor);
+        future.thenAccept(callback);
+        return future;
+    }
+}
