+// TCPUDPSocketType returns the socket type for TCP/UDP sockets, or (0, false)
+// if (stype, protocol) isn't supported.
+//
+// stype may include flags (e.g. SOCK_NONBLOCK); only the base type is used.
+// The returned socket type excludes flags.
+func TCPUDPSocketType(stype transport.SockType, protocol int) (int, bool) {
+	socketType := int(stype) & linux.SOCK_TYPE_MASK
+	switch socketType {
+	case linux.SOCK_STREAM:
+		return socketType, protocol == 0 || protocol == syscall.IPPROTO_TCP
+	case linux.SOCK_DGRAM:
+		return socketType, protocol == 0 || protocol == syscall.IPPROTO_UDP
+	default:
+		return 0, false
+	}
+}
