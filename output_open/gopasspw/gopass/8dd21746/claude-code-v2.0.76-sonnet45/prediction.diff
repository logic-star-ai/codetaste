diff --git a/pkg/ctxutil/helpers.go b/pkg/ctxutil/helpers.go
new file mode 100644
index 0000000..fc4df38
--- /dev/null
+++ b/pkg/ctxutil/helpers.go
@@ -0,0 +1,105 @@
+package ctxutil
+
+import "context"
+
+// boolContextHelper provides helper functions for boolean context values
+type boolContextHelper struct {
+	key          contextKey
+	defaultValue bool
+}
+
+// newBoolHelper creates a new boolean context helper
+func newBoolHelper(key contextKey, defaultValue bool) boolContextHelper {
+	return boolContextHelper{
+		key:          key,
+		defaultValue: defaultValue,
+	}
+}
+
+// With returns a context with the specified boolean value
+func (h boolContextHelper) With(ctx context.Context, value bool) context.Context {
+	return context.WithValue(ctx, h.key, value)
+}
+
+// Has returns true if a value has been set in this context
+func (h boolContextHelper) Has(ctx context.Context) bool {
+	_, ok := ctx.Value(h.key).(bool)
+	return ok
+}
+
+// Is returns the value or the default if not set
+func (h boolContextHelper) Is(ctx context.Context) bool {
+	bv, ok := ctx.Value(h.key).(bool)
+	if !ok {
+		return h.defaultValue
+	}
+	return bv
+}
+
+// stringContextHelper provides helper functions for string context values
+type stringContextHelper struct {
+	key          contextKey
+	defaultValue string
+}
+
+// newStringHelper creates a new string context helper
+func newStringHelper(key contextKey, defaultValue string) stringContextHelper {
+	return stringContextHelper{
+		key:          key,
+		defaultValue: defaultValue,
+	}
+}
+
+// With returns a context with the specified string value
+func (h stringContextHelper) With(ctx context.Context, value string) context.Context {
+	return context.WithValue(ctx, h.key, value)
+}
+
+// Has returns true if a value has been set in this context
+func (h stringContextHelper) Has(ctx context.Context) bool {
+	_, ok := ctx.Value(h.key).(string)
+	return ok
+}
+
+// Get returns the value or the default if not set
+func (h stringContextHelper) Get(ctx context.Context) string {
+	sv, ok := ctx.Value(h.key).(string)
+	if !ok {
+		return h.defaultValue
+	}
+	return sv
+}
+
+// intContextHelper provides helper functions for integer context values
+type intContextHelper struct {
+	key          contextKey
+	defaultValue int
+}
+
+// newIntHelper creates a new integer context helper
+func newIntHelper(key contextKey, defaultValue int) intContextHelper {
+	return intContextHelper{
+		key:          key,
+		defaultValue: defaultValue,
+	}
+}
+
+// With returns a context with the specified integer value
+func (h intContextHelper) With(ctx context.Context, value int) context.Context {
+	return context.WithValue(ctx, h.key, value)
+}
+
+// Has returns true if a value has been set in this context
+func (h intContextHelper) Has(ctx context.Context) bool {
+	_, ok := ctx.Value(h.key).(int)
+	return ok
+}
+
+// Get returns the value or the default if not set
+func (h intContextHelper) Get(ctx context.Context) int {
+	iv, ok := ctx.Value(h.key).(int)
+	if !ok {
+		return h.defaultValue
+	}
+	return iv
+}
