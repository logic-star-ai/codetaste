new file mode 100644
index 0000000..51ae6b5
--- /dev/null
+++ b/command_helpers.go
@@ -0,0 +1,43 @@
+package main
+
+import (
+	"context"
+
+	ap "github.com/gopasspw/gopass/pkg/action"
+	"github.com/urfave/cli/v2"
+)
+
+// initBeforeFunc creates a Before function that initializes the store
+func initBeforeFunc(ctx context.Context, action *ap.Action) func(*cli.Context) error {
+	return func(c *cli.Context) error {
+		return action.Initialized(withGlobalFlags(ctx, c), c)
+	}
+}
+
+// completeFunc creates a BashComplete function
+func completeFunc(ctx context.Context, action *ap.Action) func(*cli.Context) {
+	return func(c *cli.Context) {
+		action.Complete(ctx, c)
+	}
+}
+
+// gitCredentialBeforeFunc creates a Before function for git credential commands
+func gitCredentialBeforeFunc(ctx context.Context, action *ap.Action) func(*cli.Context) error {
+	return func(c *cli.Context) error {
+		return action.GitCredentialBefore(withGlobalFlags(ctx, c), c)
+	}
+}
+
+// makeActionFunc creates an action function with global flags
+func makeActionFunc(ctx context.Context, fn func(context.Context, *cli.Context) error) func(*cli.Context) error {
+	return func(c *cli.Context) error {
+		return fn(withGlobalFlags(ctx, c), c)
+	}
+}
+
+// makeActionWithStoreFunc creates an action function that passes the store
+func makeActionWithStoreFunc(ctx context.Context, action *ap.Action, fn func(context.Context, *cli.Context, interface{}) error) func(*cli.Context) error {
+	return func(c *cli.Context) error {
+		return fn(withGlobalFlags(ctx, c), c, action.Store)
+	}
+}
