new file mode 100644
index 0000000..3be8c34
--- /dev/null
+++ b/flags.go
@@ -0,0 +1,72 @@
+package main
+
+import "github.com/urfave/cli/v2"
+
+// Common flags used across multiple commands
+var (
+	forceFlag = &cli.BoolFlag{
+		Name:    "force",
+		Aliases: []string{"f"},
+		Usage:   "Force the operation and overwrite existing items",
+	}
+
+	storeFlag = &cli.StringFlag{
+		Name:  "store",
+		Usage: "Store to operate on",
+	}
+
+	clipFlag = &cli.BoolFlag{
+		Name:    "clip",
+		Aliases: []string{"c"},
+		Usage:   "Copy to clipboard",
+	}
+
+	echoFlag = &cli.BoolFlag{
+		Name:    "echo",
+		Aliases: []string{"e"},
+		Usage:   "Display secret while typing",
+	}
+
+	recursiveFlag = &cli.BoolFlag{
+		Name:    "recursive",
+		Aliases: []string{"r"},
+		Usage:   "Recursive operation",
+	}
+
+	editorFlag = &cli.StringFlag{
+		Name:    "editor",
+		Aliases: []string{"e"},
+		Usage:   "Use this editor binary",
+	}
+
+	printFlag = &cli.BoolFlag{
+		Name:  "print",
+		Usage: "Print to terminal",
+	}
+)
+
+// cloneForceFlag creates a new force flag for a specific use case
+func cloneForceFlag(usage string) *cli.BoolFlag {
+	return &cli.BoolFlag{
+		Name:    "force",
+		Aliases: []string{"f"},
+		Usage:   usage,
+	}
+}
+
+// cloneStoreFlag creates a new store flag
+func cloneStoreFlag() *cli.StringFlag {
+	return &cli.StringFlag{
+		Name:  "store",
+		Usage: "Store to operate on",
+	}
+}
+
+// cloneClipFlag creates a new clip flag for a specific use case
+func cloneClipFlag(usage string) *cli.BoolFlag {
+	return &cli.BoolFlag{
+		Name:    "clip",
+		Aliases: []string{"c"},
+		Usage:   usage,
+	}
+}
