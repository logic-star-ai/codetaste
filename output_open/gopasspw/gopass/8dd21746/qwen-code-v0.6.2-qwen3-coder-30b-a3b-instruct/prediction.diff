+package main
+
+import (
+	"context"
+	"fmt"
+	"os"
+	"path/filepath"
+	"strings"
+
+	"github.com/gopasspw/gopass/pkg/out"
+	"github.com/urfave/cli/v2"
+)
+
+// Error message for command not found
+func printCommandNotFound(ctx context.Context, c *cli.Context, app *cli.App) {
+	out.Error(ctx, "Command not found: %s", c.Command.Name)
+	
+	// Print available commands
+	fmt.Printf("Available commands:\n")
+	for _, cmd := range app.Commands {
+		if cmd.Name != "update" {
+			fmt.Printf("\t%s - %s\n", cmd.Name, cmd.Usage)
+		}
+	}
+}
+
+// Improved command execution with better error handling
+func executeCommand(ctx context.Context, c *cli.Context, action *ap.Action) error {
+	if c.Command.Name == "" {
+		// If no command was provided, execute default behavior
+		return action.List(withGlobalFlags(ctx, c), c)
+	}
+	
+	// Use the action's built-in error handling
+	err := c.Command.Action(c)
+	if err != nil {
+		out.Error(ctx, "Error executing command: %s", err.Error())
+		os.Exit(1)
+	}
+	
+	return err
+}
+
+// Enhanced error handling for command errors
+func handleCommandError(ctx context.Context, cmd string, err error) {
+	if err != nil {
+		out.Error(ctx, "Error with command '%s': %s", cmd, err.Error())
+		os.Exit(1)
+	}
+}
+
+// NormalizePath converts the command path to a standard format if needed
+func normalizePath(path string) string {
+	if strings.HasPrefix(path, "~/") {
+		home, err := os.UserHomeDir()
+		if err == nil {
+			path = filepath.Join(home, path[2:])
+		}
+	}
+	
+	// Resolve . and ..
+	path, _ = filepath.Abs(path)
+	
+	return path
+}
+
+// ValidateContext verifies that the context is properly configured
+func validateContext(ctx context.Context) error {
+	if ctx == nil {
+		return fmt.Errorf("context is nil")
+	}
+	
+	// Add more validation checks here as needed
+	return nil
+}
