+func (ts *tester) binaryPath() string {
+	ts.t.Helper()
+
+	if b := os.Getenv("GOPASS_BINARY"); b != "" {
+		fi, err := os.Stat(b)
+		if err != nil {
+			ts.t.Fatalf("Failed to stat GOPASS_BINARY %s: %s", b, err)
+		}
+		if !strings.HasSuffix(b, ".exe") && fi.Mode()&0111 == 0 {
+			ts.t.Fatalf("GOPASS_BINARY is not executeable")
+		}
+		return b
+	}
+
+	out := filepath.Join(ts.tempDir, "gopass")
+	if runtime.GOOS == "windows" {
+		out += ".exe"
+	}
+
+	buildDir := filepath.Clean(filepath.Join(ts.sourceDir, ".."))
+	cmd := exec.Command("go", "build", "-o", out, ".")
+	cmd.Dir = buildDir
+	cmd.Env = os.Environ()
+	ts.t.Logf("%+v", cmd.Args)
+
+	buf, err := cmd.CombinedOutput()
+	if err != nil {
+		ts.t.Fatalf("Failed to build gopass binary: %s\n%s", err, string(buf))
+	}
+
+	return out
+}
+
 func (ts tester) gpgDir() string {
 	return filepath.Join(ts.tempDir, ".gnupg")
 }
