+func isExecutableFile(path string) bool {
+	fi, err := os.Stat(path)
+	if err != nil {
+		return false
+	}
+	if fi.Mode().IsDir() {
+		return false
+	}
+	if strings.HasSuffix(path, ".exe") {
+		return true
+	}
+	return fi.Mode()&0111 != 0
+}
+
+func buildGopassBinary(t *testing.T, sourceDir string) string {
+	t.Helper()
+
+	cmd := exec.Command("go", "env", "GOMOD")
+	cmd.Dir = sourceDir
+	out, err := cmd.CombinedOutput()
+	require.NoError(t, err, "failed to resolve module root:\n%s", string(out))
+
+	goMod := strings.TrimSpace(string(out))
+	if goMod == "" || goMod == os.DevNull {
+		t.Fatalf("failed to resolve module root: go env GOMOD returned %q", goMod)
+	}
+
+	moduleRoot := filepath.Dir(goMod)
+	binName := "gopass"
+	if runtime.GOOS == "windows" {
+		binName = "gopass.exe"
+	}
+	binPath := filepath.Join(t.TempDir(), binName)
+
+	cmd = exec.Command("go", "build", "-o", binPath, "./")
+	cmd.Dir = moduleRoot
+	out, err = cmd.CombinedOutput()
+	require.NoError(t, err, "failed to build gopass test binary:\n%s", string(out))
+
+	return binPath
+}
