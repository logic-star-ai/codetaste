+package org.apache.shenyu.web.local;
+
+import org.apache.commons.collections4.CollectionUtils;
+import org.apache.commons.lang3.StringUtils;
+import org.apache.shenyu.common.dto.ConditionData;
+import org.apache.shenyu.common.enums.ParamTypeEnum;
+
+import java.util.Collections;
+import java.util.List;
+import java.util.stream.Collectors;
+
+/**
+ * Extracts URI paths from condition lists.
+ */
+final class ConditionPathExtractor {
+
+    private ConditionPathExtractor() {
+    }
+
+    static List<String> extractUriPaths(final List<ConditionData> conditions) {
+        if (CollectionUtils.isEmpty(conditions)) {
+            return Collections.emptyList();
+        }
+        return conditions.stream()
+                .filter(condition -> ParamTypeEnum.URI.getName().equals(condition.getParamType()))
+                .map(ConditionData::getParamValue)
+                .filter(StringUtils::isNotBlank)
+                .collect(Collectors.toList());
+    }
+}
