+package org.apache.shenyu.web.configuration;
+
+import org.apache.shenyu.plugin.base.cache.BaseDataCache;
+import org.apache.shenyu.plugin.base.cache.MatchDataCache;
+import org.springframework.context.annotation.Bean;
+import org.springframework.context.annotation.Configuration;
+
+/**
+ * Exposes singleton caches as injectable beans to avoid static access in web layer.
+ */
+@Configuration
+public class LocalDataCacheConfiguration {
+
+    @Bean
+    public BaseDataCache baseDataCache() {
+        return BaseDataCache.getInstance();
+    }
+
+    @Bean
+    public MatchDataCache matchDataCache() {
+        return MatchDataCache.getInstance();
+    }
+}
