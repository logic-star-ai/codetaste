+package org.apache.shenyu.web.local;
+
+import org.apache.commons.lang3.RandomUtils;
+import org.apache.commons.lang3.StringUtils;
+import org.apache.shenyu.common.dto.RuleData;
+import org.apache.shenyu.common.dto.SelectorData;
+import org.apache.shenyu.common.enums.MatchModeEnum;
+import org.apache.shenyu.common.enums.SelectorTypeEnum;
+import org.apache.shenyu.common.utils.UUIDUtils;
+import org.springframework.stereotype.Component;
+
+import java.util.Optional;
+
+/**
+ * Produces selector/rule data with required defaults applied.
+ */
+@Component
+public class LocalPluginDataFactory {
+
+    private static final int DEFAULT_SORT = 10;
+
+    private static final int RANDOM_NAME_MIN_INCLUSIVE = 1;
+
+    private static final int RANDOM_NAME_MAX_EXCLUSIVE = 1000;
+
+    public SelectorData withDefaults(final SelectorData selectorData) {
+        return SelectorData.builder()
+                .id(defaultSelectorId(selectorData))
+                .pluginId(selectorData.getPluginId())
+                .pluginName(selectorData.getPluginName())
+                .name(defaultSelectorName(selectorData))
+                .matchMode(Optional.ofNullable(selectorData.getMatchMode()).orElse(MatchModeEnum.AND.getCode()))
+                .type(Optional.ofNullable(selectorData.getType()).orElse(SelectorTypeEnum.FULL_FLOW.getCode()))
+                .sort(Optional.ofNullable(selectorData.getSort()).orElse(DEFAULT_SORT))
+                .enabled(Optional.ofNullable(selectorData.getEnabled()).orElse(Boolean.TRUE))
+                .logged(Optional.ofNullable(selectorData.getLogged()).orElse(Boolean.FALSE))
+                .continued(selectorData.getContinued())
+                .handle(selectorData.getHandle())
+                .conditionList(selectorData.getConditionList())
+                .beforeConditionList(selectorData.getBeforeConditionList())
+                .matchRestful(Optional.ofNullable(selectorData.getMatchRestful()).orElse(Boolean.FALSE))
+                .namespaceId(selectorData.getNamespaceId())
+                .build();
+    }
+
+    public RuleData withDefaults(final RuleData ruleData) {
+        return RuleData.builder()
+                .id(defaultRuleId(ruleData))
+                .name(defaultRuleName(ruleData))
+                .selectorId(ruleData.getSelectorId())
+                .pluginName(ruleData.getPluginName())
+                .matchMode(Optional.ofNullable(ruleData.getMatchMode()).orElse(MatchModeEnum.AND.getCode()))
+                .sort(Optional.ofNullable(ruleData.getSort()).orElse(DEFAULT_SORT))
+                .enabled(Optional.ofNullable(ruleData.getEnabled()).orElse(Boolean.TRUE))
+                .loged(Optional.ofNullable(ruleData.getLoged()).orElse(Boolean.FALSE))
+                .handle(ruleData.getHandle())
+                .conditionDataList(ruleData.getConditionDataList())
+                .matchRestful(Optional.ofNullable(ruleData.getMatchRestful()).orElse(Boolean.FALSE))
+                .build();
+    }
+
+    private String defaultSelectorId(final SelectorData selectorData) {
+        return StringUtils.isBlank(selectorData.getId()) ? UUIDUtils.getInstance().generateShortUuid() : selectorData.getId();
+    }
+
+    private String defaultRuleId(final RuleData ruleData) {
+        return StringUtils.isBlank(ruleData.getId()) ? UUIDUtils.getInstance().generateShortUuid() : ruleData.getId();
+    }
+
+    private String defaultSelectorName(final SelectorData selectorData) {
+        if (StringUtils.isNotBlank(selectorData.getName())) {
+            return selectorData.getName();
+        }
+        return selectorData.getPluginName() + ":selector" + RandomUtils.nextInt(RANDOM_NAME_MIN_INCLUSIVE, RANDOM_NAME_MAX_EXCLUSIVE);
+    }
+
+    private String defaultRuleName(final RuleData ruleData) {
+        if (StringUtils.isNotBlank(ruleData.getName())) {
+            return ruleData.getName();
+        }
+        return ruleData.getPluginName() + ":rule" + RandomUtils.nextInt(RANDOM_NAME_MIN_INCLUSIVE, RANDOM_NAME_MAX_EXCLUSIVE);
+    }
+}
+
