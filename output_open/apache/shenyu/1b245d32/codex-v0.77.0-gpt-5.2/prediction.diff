+import org.apache.shenyu.common.dto.DiscoveryUpstreamData;
+import org.apache.shenyu.common.dto.PluginData;
+import org.apache.shenyu.common.dto.RuleData;
+import org.apache.shenyu.common.dto.SelectorData;
+import org.apache.shenyu.common.dto.convert.selector.DivideUpstream;
+import org.apache.shenyu.common.enums.SelectorTypeEnum;
+import org.apache.shenyu.common.utils.GsonUtils;
+import org.apache.shenyu.common.utils.JsonUtils;
+import org.apache.shenyu.plugin.base.cache.BaseDataCache;
+import org.apache.shenyu.sync.data.api.DiscoveryUpstreamDataSubscriber;
+import org.apache.shenyu.sync.data.api.PluginDataSubscriber;
+import org.apache.shenyu.web.controller.dto.RuleLocalData;
+import org.apache.shenyu.web.controller.dto.SelectorRuleData;
+import org.apache.shenyu.web.controller.dto.SelectorRulesData;
+import org.springframework.stereotype.Component;
+import reactor.core.publisher.Mono;
+
+import java.sql.Timestamp;
+import java.util.Collections;
+import java.util.List;
+import java.util.Objects;
+import java.util.Optional;
+import java.util.Properties;
+import java.util.stream.Collectors;
+
+/**
+ * Business logic for local management endpoints.
+ */
+@Component
+public class LocalPluginService {
+
+    private final PluginDataSubscriber pluginDataSubscriber;
+
+    private final DiscoveryUpstreamDataSubscriber discoveryUpstreamDataSubscriber;
+
+    private final BaseDataCache baseDataCache;
+
+    private final LocalPluginCacheCleaner cacheCleaner;
+
+    private final LocalPluginDataFactory dataFactory;
+
+    public LocalPluginService(final PluginDataSubscriber pluginDataSubscriber,
+                              final DiscoveryUpstreamDataSubscriber discoveryUpstreamDataSubscriber,
+                              final BaseDataCache baseDataCache,
+                              final LocalPluginCacheCleaner cacheCleaner,
+                              final LocalPluginDataFactory dataFactory) {
+        this.pluginDataSubscriber = pluginDataSubscriber;
+        this.discoveryUpstreamDataSubscriber = discoveryUpstreamDataSubscriber;
+        this.baseDataCache = baseDataCache;
+        this.cacheCleaner = cacheCleaner;
+        this.dataFactory = dataFactory;
+    }
+
+    public Mono<String> cleanAll() {
+        pluginDataSubscriber.refreshPluginDataAll();
+        pluginDataSubscriber.refreshSelectorDataAll();
+        pluginDataSubscriber.refreshRuleDataAll();
+        return Mono.just(Constants.SUCCESS);
+    }
+
+    public Mono<String> cleanPlugin(final String pluginName) {
+        cacheCleaner.cleanPlugin(pluginName);
+        return Mono.just(Constants.SUCCESS);
+    }
+
+    public Mono<String> saveOrUpdatePlugin(final PluginData pluginData) {
+        pluginDataSubscriber.onSubscribe(pluginData);
+        return Mono.just(Constants.SUCCESS);
+    }
+
+    public Mono<String> deletePlugin(final String pluginName) {
+        pluginDataSubscriber.unSubscribe(PluginData.builder().name(pluginName).build());
+        return Mono.just(Constants.SUCCESS);
+    }
+
+    public Mono<String> deleteAllPlugins() {
+        pluginDataSubscriber.refreshPluginDataAll();
+        return Mono.just(Constants.SUCCESS);
+    }
+
+    public Mono<String> findPluginByName(final String pluginName) {
+        PluginData pluginData = baseDataCache.obtainPluginData(pluginName);
+        if (Objects.isNull(pluginData)) {
+            return Mono.just("can not find this plugin : " + pluginName);
+        }
+        return Mono.just(JsonUtils.toJson(pluginData));
+    }
+
+    public Mono<String> saveOrUpdateSelector(final SelectorData selectorData) {
+        if (StringUtils.isBlank(selectorData.getPluginName())) {
+            return Mono.just("Error: please add pluginName!");
+        }
+        SelectorData selectorWithDefaults = dataFactory.withDefaults(selectorData);
+        pluginDataSubscriber.onSelectorSubscribe(selectorWithDefaults);
+        publishDiscoveryUpstreamData(selectorWithDefaults);
+        return Mono.just(selectorWithDefaults.getId());
+    }
+
+    public Mono<String> selectorAndRule(final SelectorRuleData selectorRuleData) {
+        SelectorData selectorData = SelectorData.builder()
+                .pluginName(selectorRuleData.getPluginName())
+                .name(selectorRuleData.getSelectorName())
+                .handle(selectorRuleData.getSelectorHandler())
+                .conditionList(selectorRuleData.getConditionDataList())
+                .type(SelectorTypeEnum.CUSTOM_FLOW.getCode())
+                .build();
+        SelectorData selectorWithDefaults = dataFactory.withDefaults(selectorData);
+        pluginDataSubscriber.onSelectorSubscribe(selectorWithDefaults);
+        publishDiscoveryUpstreamData(selectorWithDefaults);
+
+        RuleData ruleData = RuleData.builder()
+                .selectorId(selectorWithDefaults.getId())
+                .matchRestful(Boolean.FALSE)
+                .pluginName(selectorRuleData.getPluginName())
+                .handle(selectorRuleData.getRuleHandler())
+                .conditionDataList(selectorRuleData.getConditionDataList())
+                .build();
+        pluginDataSubscriber.onRuleSubscribe(dataFactory.withDefaults(ruleData));
+        return Mono.just(Constants.SUCCESS);
+    }
+
+    public Mono<String> selectorAndRules(final SelectorRulesData selectorRulesData) {
+        SelectorData selectorData = SelectorData.builder()
+                .pluginName(selectorRulesData.getPluginName())
+                .name(selectorRulesData.getSelectorName())
+                .handle(selectorRulesData.getSelectorHandler())
+                .matchMode(selectorRulesData.getMatchMode())
+                .conditionList(selectorRulesData.getConditionDataList())
+                .type(SelectorTypeEnum.CUSTOM_FLOW.getCode())
+                .sort(selectorRulesData.getSort())
+                .build();
+        SelectorData selectorWithDefaults = dataFactory.withDefaults(selectorData);
+        pluginDataSubscriber.onSelectorSubscribe(selectorWithDefaults);
+        publishDiscoveryUpstreamData(selectorWithDefaults);
+
+        List<RuleLocalData> rules = Optional.ofNullable(selectorRulesData.getRuleDataList()).orElse(Collections.emptyList());
+        rules.forEach(ruleLocalData -> pluginDataSubscriber.onRuleSubscribe(
+                dataFactory.withDefaults(toRuleData(selectorWithDefaults, ruleLocalData))
+        ));
+        return Mono.just(Constants.SUCCESS);
+    }
+
+    public Mono<String> deleteSelector(final String pluginName, final String selectorId) {
+        pluginDataSubscriber.unSelectorSubscribe(SelectorData.builder().pluginName(pluginName).id(selectorId).build());
+        return Mono.just(Constants.SUCCESS);
+    }
+
+    public Mono<String> findSelectors(final String pluginName, final String selectorId) {
+        List<SelectorData> selectorDataList = baseDataCache.obtainSelectorData(pluginName);
+        if (CollectionUtils.isEmpty(selectorDataList)) {
+            return Mono.just("Error: can not find selector data by pluginName :" + pluginName);
+        }
+        if (StringUtils.isNotBlank(selectorId)) {
+            List<SelectorData> filtered = selectorDataList.stream().filter(selectorData -> selectorData.getId().equals(selectorId)).collect(Collectors.toList());
+            return Mono.just(JsonUtils.toJson(filtered));
+        }
+        return Mono.just(JsonUtils.toJson(selectorDataList));
+    }
+
+    public Mono<String> saveOrUpdateRule(final RuleData ruleData) {
+        if (StringUtils.isBlank(ruleData.getSelectorId())) {
+            return Mono.just("Error: please add selectorId!");
+        }
+        RuleData ruleWithDefaults = dataFactory.withDefaults(ruleData);
+        pluginDataSubscriber.onRuleSubscribe(ruleWithDefaults);
+        return Mono.just(ruleWithDefaults.getId());
+    }
+
+    public Mono<String> deleteRule(final String selectorId, final String id, final String pluginName) {
+        pluginDataSubscriber.unRuleSubscribe(RuleData.builder().selectorId(selectorId).id(id).pluginName(pluginName).build());
+        return Mono.just(Constants.SUCCESS);
+    }
+
+    public Mono<String> findRules(final String selectorId, final String id) {
+        List<RuleData> ruleDataList = baseDataCache.obtainRuleData(selectorId);
+        if (CollectionUtils.isEmpty(ruleDataList)) {
+            return Mono.just("Error: can not find rule data by selector id :" + selectorId);
+        }
+        if (StringUtils.isNotBlank(id)) {
+            List<RuleData> filtered = ruleDataList.stream().filter(ruleData -> ruleData.getId().equals(id)).collect(Collectors.toList());
+            return Mono.just(JsonUtils.toJson(filtered));
+        }
+        return Mono.just(JsonUtils.toJson(ruleDataList));
+    }
+
+    private RuleData toRuleData(final SelectorData selectorWithDefaults, final RuleLocalData data) {
+        return RuleData.builder()
+                .selectorId(selectorWithDefaults.getId())
+                .pluginName(selectorWithDefaults.getPluginName())
+                .name(data.getRuleName())
+                .matchMode(data.getMatchMode())
+                .handle(data.getRuleHandler())
+                .conditionDataList(data.getConditionDataList())
+                .build();
+    }
+
+    private void publishDiscoveryUpstreamData(final SelectorData selectorData) {
+        List<DivideUpstream> upstreamList = GsonUtils.getInstance().fromList(selectorData.getHandle(), DivideUpstream.class);
+        if (CollectionUtils.isEmpty(upstreamList)) {
+            return;
+        }
+        DiscoverySyncData discoverySyncData = new DiscoverySyncData();
+        discoverySyncData.setSelectorId(selectorData.getId());
+        discoverySyncData.setSelectorName(selectorData.getName());
+        discoverySyncData.setPluginName(selectorData.getPluginName());
+        discoverySyncData.setUpstreamDataList(toDiscoveryUpstreamDataList(upstreamList));
+        discoveryUpstreamDataSubscriber.onSubscribe(discoverySyncData);
+    }
+
+    private List<DiscoveryUpstreamData> toDiscoveryUpstreamDataList(final List<DivideUpstream> upstreamList) {
+        return upstreamList.stream().map(up -> {
+            DiscoveryUpstreamData upstreamData = new DiscoveryUpstreamData();
+            upstreamData.setUrl(up.getUpstreamUrl());
+            upstreamData.setProtocol(up.getProtocol());
+            upstreamData.setWeight(up.getWeight());
+            upstreamData.setStatus(up.isStatus() ? 0 : 1);
+            Properties properties = new Properties();
+            properties.setProperty("warmup", String.valueOf(up.getWarmup()));
+            properties.setProperty("upstreamHost", String.valueOf(up.getUpstreamHost()));
+            Timestamp timestamp = Optional.ofNullable(up.getTimestamp())
+                    .map(Timestamp::new)
+                    .orElse(new Timestamp(System.currentTimeMillis()));
+            upstreamData.setDateUpdated(timestamp);
+            upstreamData.setDateCreated(timestamp);
+            upstreamData.setProps(GsonUtils.getInstance().toJson(properties));
+            return upstreamData;
+        }).collect(Collectors.toList());
+    }
+}
