+package org.apache.shenyu.web.local;
+
+import org.apache.commons.collections4.CollectionUtils;
+import org.apache.shenyu.common.config.ShenyuConfig;
+import org.apache.shenyu.common.dto.ConditionData;
+import org.apache.shenyu.common.dto.RuleData;
+import org.apache.shenyu.common.dto.SelectorData;
+import org.apache.shenyu.common.enums.TrieCacheTypeEnum;
+import org.apache.shenyu.plugin.base.cache.BaseDataCache;
+import org.apache.shenyu.plugin.base.cache.MatchDataCache;
+import org.apache.shenyu.plugin.base.trie.ShenyuTrie;
+import org.springframework.beans.factory.annotation.Qualifier;
+import org.springframework.stereotype.Component;
+
+import java.util.ArrayList;
+import java.util.Collections;
+import java.util.List;
+import java.util.Optional;
+import java.util.stream.Collectors;
+
+/**
+ * Removes local plugin data from in-memory caches and trie caches.
+ */
+@Component
+public class LocalPluginCacheCleaner {
+
+    private final BaseDataCache baseDataCache;
+
+    private final MatchDataCache matchDataCache;
+
+    private final ShenyuTrie selectorTrie;
+
+    private final ShenyuTrie ruleTrie;
+
+    private final ShenyuConfig shenyuConfig;
+
+    public LocalPluginCacheCleaner(final BaseDataCache baseDataCache,
+                                   final MatchDataCache matchDataCache,
+                                   @Qualifier("shenyuSelectorTrie") final ShenyuTrie selectorTrie,
+                                   @Qualifier("shenyuRuleTrie") final ShenyuTrie ruleTrie,
+                                   final ShenyuConfig shenyuConfig) {
+        this.baseDataCache = baseDataCache;
+        this.matchDataCache = matchDataCache;
+        this.selectorTrie = selectorTrie;
+        this.ruleTrie = ruleTrie;
+        this.shenyuConfig = shenyuConfig;
+    }
+
+    /**
+     * Clears all local caches for a single plugin.
+     *
+     * @param pluginName plugin name
+     */
+    public void cleanPlugin(final String pluginName) {
+        baseDataCache.removePluginDataByPluginName(pluginName);
+
+        List<SelectorData> selectorsSnapshot = snapshotSelectors(pluginName);
+
+        baseDataCache.removeSelectDataByPluginName(pluginName);
+        matchDataCache.removeSelectorData(pluginName);
+        matchDataCache.removeRuleData(pluginName);
+
+        if (isSelectorTrieEnabled()) {
+            selectorsSnapshot.forEach(this::removeSelectorFromTrie);
+        }
+
+        List<String> selectorIds = selectorsSnapshot.stream().map(SelectorData::getId).collect(Collectors.toList());
+        selectorIds.forEach(this::cleanSelectorRules);
+    }
+
+    private void cleanSelectorRules(final String selectorId) {
+        List<RuleData> rulesSnapshot = snapshotRules(selectorId);
+        baseDataCache.removeRuleDataBySelectorId(selectorId);
+
+        if (isRuleTrieEnabled()) {
+            rulesSnapshot.forEach(this::removeRuleFromTrie);
+        }
+    }
+
+    private List<SelectorData> snapshotSelectors(final String pluginName) {
+        List<SelectorData> selectors = Optional.ofNullable(baseDataCache.obtainSelectorData(pluginName)).orElse(Collections.emptyList());
+        return CollectionUtils.isEmpty(selectors) ? Collections.emptyList() : new ArrayList<>(selectors);
+    }
+
+    private List<RuleData> snapshotRules(final String selectorId) {
+        List<RuleData> rules = Optional.ofNullable(baseDataCache.obtainRuleData(selectorId)).orElse(Collections.emptyList());
+        return CollectionUtils.isEmpty(rules) ? Collections.emptyList() : new ArrayList<>(rules);
+    }
+
+    private void removeSelectorFromTrie(final SelectorData selector) {
+        List<String> uriPaths = ConditionPathExtractor.extractUriPaths(selector.getConditionList());
+        if (CollectionUtils.isNotEmpty(uriPaths)) {
+            selectorTrie.remove(uriPaths, selector, TrieCacheTypeEnum.SELECTOR);
+        }
+    }
+
+    private void removeRuleFromTrie(final RuleData rule) {
+        List<ConditionData> conditions = rule.getConditionDataList();
+        List<String> uriPaths = ConditionPathExtractor.extractUriPaths(conditions);
+        if (CollectionUtils.isNotEmpty(uriPaths)) {
+            ruleTrie.remove(uriPaths, rule, TrieCacheTypeEnum.RULE);
+        }
+    }
+
+    private boolean isSelectorTrieEnabled() {
+        return Boolean.TRUE.equals(shenyuConfig.getSelectorMatchCache().getTrie().getEnabled());
+    }
+
+    private boolean isRuleTrieEnabled() {
+        return Boolean.TRUE.equals(shenyuConfig.getRuleMatchCache().getTrie().getEnabled());
+    }
+}
