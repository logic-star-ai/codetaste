+func requireLedgerDevice(t *testing.T) {
+	t.Helper()
+
+	// These tests require both:
+	// - a build with ledger support enabled, and
+	// - a physical device connected and ready.
+	//
+	// Default to skipping to keep CI and developer environments stable.
+	if os.Getenv("COSMOS_SDK_ENABLE_LEDGER_TESTS") == "" {
+		t.Skip("ledger device tests disabled (set COSMOS_SDK_ENABLE_LEDGER_TESTS=1 to run)")
+	}
+
+	path := *hd.NewFundraiserParams(0, sdk.CoinType, 0)
+	_, err := NewPrivKeySecp256k1Unsafe(path)
+	if err != nil {
+		// This can happen either when the build doesn't include ledger support
+		// (e.g. missing build tags / cgo), or when a device isn't connected.
+		t.Skipf("ledger device not available: %v", err)
+	}
