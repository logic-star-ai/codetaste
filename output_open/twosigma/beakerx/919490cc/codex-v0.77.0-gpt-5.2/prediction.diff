diff --git a/js/notebook/src/plot/plotPointsLimiter.ts b/js/notebook/src/plot/plotPointsLimiter.ts
new file mode 100644
index 0000000..643ee03
--- /dev/null
+++ b/js/notebook/src/plot/plotPointsLimiter.ts
@@ -0,0 +1,90 @@
+export interface PlotPointsLimitConfig {
+  outputPointsLimit: number;
+  outputPointsPreviewNumber: number;
+}
+
+const DEFAULT_OUTPUT_POINTS_LIMIT = 1_000_000;
+const DEFAULT_OUTPUT_POINTS_PREVIEW_NUMBER = 10_000;
+
+export const DEFAULT_PLOT_POINTS_LIMIT_CONFIG: PlotPointsLimitConfig = {
+  outputPointsLimit: DEFAULT_OUTPUT_POINTS_LIMIT,
+  outputPointsPreviewNumber: DEFAULT_OUTPUT_POINTS_PREVIEW_NUMBER
+};
+
+function isArray(value: any): value is any[] {
+  return Array.isArray(value);
+}
+
+function maxPointsInGraphicsList(graphicsList: any): number {
+  if (!isArray(graphicsList) || graphicsList.length === 0) {
+    return 0;
+  }
+
+  return graphicsList.reduce((maxPoints, graphic) => {
+    const points = graphic && (graphic.x || graphic.y);
+    const length = isArray(points) ? points.length : 0;
+
+    return Math.max(maxPoints, length);
+  }, 0);
+}
+
+function truncateGraphicsListInPlace(graphicsList: any, previewNumber: number): void {
+  if (!isArray(graphicsList) || graphicsList.length === 0) {
+    return;
+  }
+
+  graphicsList.forEach((graphic) => {
+    if (!graphic || !isArray(graphic.x) || !isArray(graphic.y)) {
+      return;
+    }
+
+    graphic.x = graphic.x.slice(0, previewNumber);
+    graphic.y = graphic.y.slice(0, previewNumber);
+  });
+}
+
+function applyLimitsToStandardPlotModel(plotModel: any, config: PlotPointsLimitConfig, numberOfPoints: number): void {
+  truncateGraphicsListInPlace(plotModel.graphics_list, config.outputPointsPreviewNumber);
+
+  plotModel.numberOfPoints = numberOfPoints;
+  plotModel.outputPointsLimit = config.outputPointsLimit;
+  plotModel.outputPointsPreviewNumber = config.outputPointsPreviewNumber;
+}
+
+function resolveStandardPlotPointCount(plotModel: any): number {
+  return maxPointsInGraphicsList(plotModel && plotModel.graphics_list);
+}
+
+function resolveCombinedPlotPointCount(plotModel: any): number {
+  const plots = plotModel && plotModel.plots;
+  if (!isArray(plots) || plots.length === 0) {
+    return 0;
+  }
+
+  return plots.reduce((maxPoints, standardPlotModel) => {
+    return Math.max(maxPoints, resolveStandardPlotPointCount(standardPlotModel));
+  }, 0);
+}
+
+export function applyPlotPointsLimitsInPlace(plotModel: any, config: PlotPointsLimitConfig = DEFAULT_PLOT_POINTS_LIMIT_CONFIG): void {
+  if (!plotModel) {
+    return;
+  }
+
+  const plots = plotModel.plots;
+  if (isArray(plots) && plots.length > 0) {
+    const numberOfPoints = resolveCombinedPlotPointCount(plotModel);
+    plots.forEach((standardPlotModel) => {
+      applyLimitsToStandardPlotModel(standardPlotModel, config, numberOfPoints);
+    });
+    return;
+  }
+
+  if (!isArray(plotModel.graphics_list)) {
+    return;
+  }
+
+  const numberOfPoints = resolveStandardPlotPointCount(plotModel);
+  applyLimitsToStandardPlotModel(plotModel, config, numberOfPoints);
+}
+
diff --git a/js/notebook/src/shared/widgetModelUpdate.ts b/js/notebook/src/shared/widgetModelUpdate.ts
new file mode 100644
index 0000000..711141d
--- /dev/null
+++ b/js/notebook/src/shared/widgetModelUpdate.ts
@@ -0,0 +1,7 @@
+export function applyWidgetModelUpdateInPlace(widgetModel: any, updatedView: any): void {
+  const change = widgetModel.get('updateData');
+  const currentModel = widgetModel.get('model');
+
+  widgetModel.set('model', { ...currentModel, ...change }, { updated_view: updatedView });
+}
+
