+        return [block.strip() for block in blocks if block.strip()]
+
+    def _split_into_blocks(self, lines: List[str], inputs: _ChunkingInput) -> List[str]:
+        language = inputs.language.lower()
+        preprocessed_lines = list(self._preprocess_lines(lines, language))
+        block_starts = self._find_block_starts(preprocessed_lines, language)
+        if len(block_starts) <= 1:
+            return self._split_by_line_windows(preprocessed_lines, inputs)
+
+        blocks: List[str] = []
+        for idx, start in enumerate(block_starts):
+            end = block_starts[idx + 1] if idx + 1 < len(block_starts) else None
+            block_lines = preprocessed_lines[start:end]
+            block_text = "".join(block_lines)
+            if len(block_text) > inputs.max_chars:
+                blocks.extend(self._split_by_line_windows(block_lines, inputs))
+            else:
+                blocks.append(block_text)
+        return blocks
+
+    def _preprocess_lines(self, lines: List[str], language: str) -> Iterable[str]:
+        if language not in {"c", "cpp", "c++", "java", "javascript", "typescript"}:
+            yield from lines
+            return
+
+        for line in lines:
+            stripped = line.rstrip("\n")
+            newline = "\n" if line.endswith("\n") else ""
+            if "{" in stripped and stripped.rstrip().endswith("{"):
+                before = stripped[: stripped.rfind("{")].rstrip()
+                if before:
+                    yield before + newline
+                yield "{" + newline
+            else:
+                yield line
+
+    def _find_block_starts(self, lines: List[str], language: str) -> List[int]:
+        starts = [0]
+
+        def add_start(idx: int) -> None:
+            if idx not in starts:
+                starts.append(idx)
+
+        for idx, line in enumerate(lines):
+            stripped = line.lstrip()
+            trimmed = stripped.strip()
+            if idx == 0 or not stripped:
+                continue
+
+            if language == "python":
+                if trimmed.startswith("def ") or trimmed.startswith("class "):
+                    add_start(idx)
+            elif language in {"typescript", "javascript"}:
+                if (
+                    trimmed.startswith("function ")
+                    or trimmed.startswith("class ")
+                    or trimmed.startswith("interface ")
+                    or trimmed.startswith("type ")
+                    or trimmed.startswith("export ")
+                    or trimmed.startswith("import ")
+                    or trimmed.startswith("const ")
+                    or trimmed.startswith("let ")
+                ):
+                    add_start(idx)
+            elif language == "html":
+                if trimmed.startswith("<"):
+                    add_start(idx)
+            elif language in {"c", "cpp", "c++"}:
+                if not trimmed:
+                    continue
+
+                first_token = trimmed.split(maxsplit=1)[0]
+                is_control_stmt = first_token in {
+                    "if",
+                    "for",
+                    "while",
+                    "switch",
+                    "catch",
+                }
+                looks_like_signature = (
+                    not is_control_stmt
+                    and "(" in trimmed
+                    and ")" in trimmed
+                    and trimmed.endswith(")")
+                )
+                if (
+                    trimmed.startswith("#include")
+                    or trimmed == "{"
+                    or looks_like_signature
+                ):
+                    add_start(idx)
+        starts.sort()
+        return starts
+
+    def _split_by_line_windows(self, lines: List[str], inputs: _ChunkingInput) -> List[str]:
+        if not lines:
+            return []
+
+        step = max(1, inputs.chunk_lines - inputs.chunk_lines_overlap)
+        chunks: List[str] = []
+        start = 0
+        while start < len(lines):
+            end = min(len(lines), start + inputs.chunk_lines)
+            chunk_lines = lines[start:end]
+            chunk_text = "".join(chunk_lines)
+            while len(chunk_text) > inputs.max_chars and end > start + 1:
+                end -= 1
+                chunk_lines = lines[start:end]
+                chunk_text = "".join(chunk_lines)
+
+            if len(chunk_text) > inputs.max_chars and end == start + 1:
+                chunk_text = chunk_text[: inputs.max_chars]
+
+            chunks.append(chunk_text)
+            if end == len(lines):
+                break
+            start += step
+        return chunks
