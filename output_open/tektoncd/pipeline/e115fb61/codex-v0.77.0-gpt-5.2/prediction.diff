new file mode 100644
index 0000000..b4b1f46
--- /dev/null
+++ b/pkg/credentials/parse_test.go
@@ -0,0 +1,60 @@
+package credentials
+
+import "testing"
+
+func TestParseSecretURLPair(t *testing.T) {
+	t.Parallel()
+
+	tests := []struct {
+		name       string
+		value      string
+		wantOK     bool
+		wantSecret string
+		wantURL    string
+	}{{
+		name:       "basic",
+		value:      "s=https://example.com",
+		wantOK:     true,
+		wantSecret: "s",
+		wantURL:    "https://example.com",
+	}, {
+		name:       "urlContainsEquals",
+		value:      "s=https://example.com?x=y=z",
+		wantOK:     true,
+		wantSecret: "s",
+		wantURL:    "https://example.com?x=y=z",
+	}, {
+		name:   "missingEquals",
+		value:  "nope",
+		wantOK: false,
+	}, {
+		name:   "emptySecret",
+		value:  "=https://example.com",
+		wantOK: false,
+	}, {
+		name:   "emptyURL",
+		value:  "s=",
+		wantOK: false,
+	}}
+
+	for _, tc := range tests {
+		tc := tc
+		t.Run(tc.name, func(t *testing.T) {
+			t.Parallel()
+
+			gotSecret, gotURL, err := ParseSecretURLPair(tc.value)
+			if tc.wantOK {
+				if err != nil {
+					t.Fatalf("ParseSecretURLPair(%q) err = %v", tc.value, err)
+				}
+				if gotSecret != tc.wantSecret || gotURL != tc.wantURL {
+					t.Fatalf("ParseSecretURLPair(%q) = (%q, %q), want (%q, %q)", tc.value, gotSecret, gotURL, tc.wantSecret, tc.wantURL)
+				}
+				return
+			}
+			if err == nil {
+				t.Fatalf("ParseSecretURLPair(%q) err = nil, want error", tc.value)
+			}
+		})
+	}
+}
