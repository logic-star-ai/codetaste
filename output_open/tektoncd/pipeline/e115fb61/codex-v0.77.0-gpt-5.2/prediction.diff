+// ParseSecretURLPair parses a flag value of the form "secret=url".
+// It uses the first '=' as the delimiter, which allows '=' in the URL.
+func ParseSecretURLPair(value string) (secretName, url string, err error) {
+	secretName, url, ok := strings.Cut(value, "=")
+	if !ok || secretName == "" || url == "" {
+		return "", "", fmt.Errorf("expect entries of the form secret=url, got: %q", value)
+	}
+	return secretName, url, nil
+}
