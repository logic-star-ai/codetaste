+func formatEvents(events []*corev1.Event) string {
+	if len(events) == 0 {
+		return ""
+	}
+	var b strings.Builder
+	for i, event := range events {
+		if i > 0 {
+			b.WriteString(", ")
+		}
+		fmt.Fprintf(&b, "%#v", event)
+	}
+	return b.String()
+}
