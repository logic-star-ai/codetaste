+package substitution
+
+import "regexp"
+
+// PatternRegistry centralizes all regex patterns used for variable substitution
+// and validation throughout the package.
+type PatternRegistry struct {
+	// ArrayIndexing matches array indexing expressions like [0], [1], [*]
+	ArrayIndexing *regexp.Regexp
+
+	// ParamIndexing matches parameter indexing expressions like $(params.foo[0])
+	ParamIndexing *regexp.Regexp
+
+	// IntIndex matches integer indexing expressions like [0], [1], [2]
+	IntIndex *regexp.Regexp
+}
+
+// patterns is the global pattern registry, initialized on package load
+var patterns = &PatternRegistry{
+	ArrayIndexing: regexp.MustCompile(`\[([0-9])*\*?\]`),
+	ParamIndexing: regexp.MustCompile(`\$\(params(\.[_a-zA-Z0-9.-]+|\[\'[_a-zA-Z0-9.-\/]+\'\]|\[\"[_a-zA-Z0-9.-\/]+\"\])\[[0-9]+\]\)`),
+	IntIndex:      regexp.MustCompile(`\[[0-9]+\]`),
+}
+
+// GetPatterns returns the global pattern registry
+func GetPatterns() *PatternRegistry {
+	return patterns
+}
