+package common
+
+import (
+	"time"
+
+	metav1 "k8s.io/apimachinery/pkg/apis/meta/v1"
+)
+
+// TimeSinceStart calculates the duration since a start time
+func TimeSinceStart(startTime *metav1.Time) time.Duration {
+	if startTime == nil || startTime.IsZero() {
+		return 0
+	}
+	return time.Since(startTime.Time)
+}
+
+// IsTimedOut checks if a resource has exceeded its timeout
+func IsTimedOut(startTime *metav1.Time, timeout time.Duration) bool {
+	if timeout == 0 {
+		return false
+	}
+	return TimeSinceStart(startTime) > timeout
+}
