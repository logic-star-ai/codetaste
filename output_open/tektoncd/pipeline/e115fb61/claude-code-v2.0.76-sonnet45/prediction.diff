+limitations under the License.
+*/
+
+package common
+
+import (
+	"fmt"
+
+	k8serrors "k8s.io/apimachinery/pkg/api/errors"
+)
+
+// ErrorType categorizes different types of errors for better handling
+type ErrorType string
+
+const (
+	// ErrorTypeTransient represents temporary errors that may resolve on retry
+	ErrorTypeTransient ErrorType = "transient"
+	// ErrorTypePermanent represents errors that won't resolve on retry
+	ErrorTypePermanent ErrorType = "permanent"
+	// ErrorTypeValidation represents validation errors
+	ErrorTypeValidation ErrorType = "validation"
+	// ErrorTypeNotFound represents resource not found errors
+	ErrorTypeNotFound ErrorType = "notfound"
+)
+
+// ReconcilerError wraps an error with additional context for reconciliation
+type ReconcilerError struct {
+	Type    ErrorType
+	Message string
+	Cause   error
+}
+
+// Error implements the error interface
+func (e *ReconcilerError) Error() string {
+	if e.Cause != nil {
+		return fmt.Sprintf("%s: %s: %v", e.Type, e.Message, e.Cause)
+	}
+	return fmt.Sprintf("%s: %s", e.Type, e.Message)
+}
+
+// Unwrap implements the unwrap interface for error chains
+func (e *ReconcilerError) Unwrap() error {
+	return e.Cause
+}
+
+// IsTransient returns true if the error is transient
+func (e *ReconcilerError) IsTransient() bool {
+	return e.Type == ErrorTypeTransient
+}
+
+// IsPermanent returns true if the error is permanent
+func (e *ReconcilerError) IsPermanent() bool {
+	return e.Type == ErrorTypePermanent
+}
+
+// NewTransientError creates a new transient error
+func NewTransientError(message string, cause error) *ReconcilerError {
+	return &ReconcilerError{
+		Type:    ErrorTypeTransient,
+		Message: message,
+		Cause:   cause,
+	}
+}
+
+// NewPermanentError creates a new permanent error
+func NewPermanentError(message string, cause error) *ReconcilerError {
+	return &ReconcilerError{
+		Type:    ErrorTypePermanent,
+		Message: message,
+		Cause:   cause,
+	}
+}
+
+// NewValidationError creates a new validation error
+func NewValidationError(message string, cause error) *ReconcilerError {
+	return &ReconcilerError{
+		Type:    ErrorTypeValidation,
+		Message: message,
+		Cause:   cause,
+	}
+}
+
+// NewNotFoundError creates a new not found error
+func NewNotFoundError(resource, name string) *ReconcilerError {
+	return &ReconcilerError{
+		Type:    ErrorTypeNotFound,
+		Message: fmt.Sprintf("%s %q not found", resource, name),
+		Cause:   nil,
+	}
+}
+
+// WrapK8sError wraps a Kubernetes API error with appropriate categorization
+func WrapK8sError(err error, message string) error {
+	if err == nil {
+		return nil
+	}
+
+	if k8serrors.IsNotFound(err) {
+		return &ReconcilerError{
+			Type:    ErrorTypeNotFound,
+			Message: message,
+			Cause:   err,
+		}
+	}
+
+	if k8serrors.IsConflict(err) || k8serrors.IsServerTimeout(err) || k8serrors.IsTimeout(err) {
+		return &ReconcilerError{
+			Type:    ErrorTypeTransient,
+			Message: message,
+			Cause:   err,
+		}
+	}
+
+	if k8serrors.IsInvalid(err) || k8serrors.IsBadRequest(err) {
+		return &ReconcilerError{
+			Type:    ErrorTypeValidation,
+			Message: message,
+			Cause:   err,
+		}
+	}
+
+	// Unknown error types are treated as transient
+	return &ReconcilerError{
+		Type:    ErrorTypeTransient,
+		Message: message,
+		Cause:   err,
+	}
+}
