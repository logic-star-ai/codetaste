+	}
+
+	obj := &corev1.Container{
+		Name: "test-container",
+	}
+
+	out := &corev1.Container{}
+
+	err = MergeObjWithTemplateBytes(md, obj, out)
+	if err != nil {
+		t.Fatalf("MergeObjWithTemplateBytes() failed: %v", err)
+	}
+
+	if out.Name != "test-container" {
+		t.Errorf("Expected Name='test-container', got '%s'", out.Name)
+	}
+
+	if out.Image != "ubuntu" {
+		t.Errorf("Expected Image='ubuntu', got '%s'", out.Image)
+	}
+}
