+func TestMergeObjWithTemplate(t *testing.T) {
+	template := &corev1.Container{
+		Image: "ubuntu",
+		Env: []corev1.EnvVar{
+			{Name: "TEMPLATE_VAR", Value: "template"},
+		},
+	}
+
+	obj := &corev1.Container{
+		Name: "my-container",
+		Env: []corev1.EnvVar{
+			{Name: "OBJ_VAR", Value: "object"},
+		},
+	}
+
+	out := &corev1.Container{}
+
+	err := MergeObjWithTemplate(template, obj, out)
+	if err != nil {
+		t.Fatalf("MergeObjWithTemplate() failed: %v", err)
+	}
+
+	// Check that the output has both template and object properties
+	if out.Name != "my-container" {
+		t.Errorf("Expected Name='my-container', got '%s'", out.Name)
+	}
+
+	if out.Image != "ubuntu" {
+		t.Errorf("Expected Image='ubuntu', got '%s'", out.Image)
+	}
+
+	// Check that env vars from both template and object are present
+	if len(out.Env) < 2 {
+		t.Errorf("Expected at least 2 env vars, got %d", len(out.Env))
+	}
+}
+
+func TestAmendConflictingEnvVars(t *testing.T) {
+	tests := []struct {
+		name        string
+		container   *corev1.Container
+		stepEnv     []corev1.EnvVar
+		wantEnvName string
+		wantValue   string
+	}{
+		{
+			name:      "nil container",
+			container: nil,
+			stepEnv: []corev1.EnvVar{
+				{Name: "TEST", Value: "value"},
+			},
+			wantEnvName: "",
+			wantValue:   "",
+		},
+		{
+			name: "empty stepEnv",
+			container: &corev1.Container{
+				Env: []corev1.EnvVar{
+					{Name: "TEST", Value: "original"},
+				},
+			},
+			stepEnv:     []corev1.EnvVar{},
+			wantEnvName: "TEST",
+			wantValue:   "original",
+		},
+		{
+			name: "conflicting env with ValueFrom and Value",
+			container: &corev1.Container{
+				Env: []corev1.EnvVar{
+					{
+						Name:  "TEST",
+						Value: "should-be-overridden",
+						ValueFrom: &corev1.EnvVarSource{
+							FieldRef: &corev1.ObjectFieldSelector{
+								FieldPath: "metadata.name",
+							},
+						},
+					},
+				},
+			},
+			stepEnv: []corev1.EnvVar{
+				{Name: "TEST", Value: "override"},
+			},
+			wantEnvName: "TEST",
+			wantValue:   "override",
+		},
+		{
+			name: "no conflict - only Value set",
+			container: &corev1.Container{
+				Env: []corev1.EnvVar{
+					{Name: "TEST", Value: "original"},
+				},
+			},
+			stepEnv: []corev1.EnvVar{
+				{Name: "TEST", Value: "override"},
+			},
+			wantEnvName: "TEST",
+			wantValue:   "original",
+		},
+	}
+
+	for _, tt := range tests {
+		t.Run(tt.name, func(t *testing.T) {
+			AmendConflictingEnvVars(tt.container, tt.stepEnv)
+
+			if tt.container == nil {
+				return
+			}
+
+			if tt.wantEnvName == "" {
+				return
+			}
+
+			found := false
+			for _, env := range tt.container.Env {
+				if env.Name == tt.wantEnvName {
+					found = true
+					if env.Value != tt.wantValue {
+						t.Errorf("Expected env %s=%s, got %s=%s",
+							tt.wantEnvName, tt.wantValue, env.Name, env.Value)
+					}
+					break
+				}
+			}
+
+			if !found {
+				t.Errorf("Expected to find env var %s", tt.wantEnvName)
+			}
+		})
+	}
+}
+
+func TestMergeObjWithTemplateBytes(t *testing.T) {
+	template := &corev1.Container{
