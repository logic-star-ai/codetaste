+
+package pod
+
+import (
+	"path/filepath"
+
+	corev1 "k8s.io/api/core/v1"
+	"k8s.io/utils/strings/slices"
+)
+
+// applyEnvVarPrecedence applies environment variables with proper precedence order:
+// 1. implicit env vars (lowest priority)
+// 2. step env vars
+// 3. podTemplate envs (highest priority, after filtering forbidden ones)
+// Returns modified containers with envs applied according to precedence.
+func applyEnvVarPrecedence(containers []corev1.Container, implicitEnvVars, podTemplateEnvs []corev1.EnvVar, defaultForbiddenEnv []string) []corev1.Container {
+	result := make([]corev1.Container, len(containers))
+	copy(result, containers)
+
+	// Apply implicit env vars first (if any)
+	if len(implicitEnvVars) > 0 {
+		for i := range result {
+			result[i].Env = append(implicitEnvVars, result[i].Env...)
+		}
+	}
+
+	// Filter and apply podTemplate envs (highest priority)
+	if len(podTemplateEnvs) > 0 {
+		filteredEnvs := filterForbiddenEnvVars(podTemplateEnvs, defaultForbiddenEnv)
+		for i := range result {
+			result[i].Env = append(result[i].Env, filteredEnvs...)
+		}
+	}
+
+	return result
+}
+
+// filterForbiddenEnvVars filters out environment variables that are in the forbidden list
+func filterForbiddenEnvVars(envVars []corev1.EnvVar, forbiddenEnv []string) []corev1.EnvVar {
+	if len(forbiddenEnv) == 0 {
+		return envVars
+	}
+
+	filtered := make([]corev1.EnvVar, 0, len(envVars))
+	for _, e := range envVars {
+		if !slices.Contains(forbiddenEnv, e.Name) {
+			filtered = append(filtered, e)
+		}
+	}
+	return filtered
+}
+
+// addHermeticEnvVar adds the hermetic execution environment variable to all containers
+func addHermeticEnvVar(containers []corev1.Container, hermeticValue string) []corev1.Container {
+	result := make([]corev1.Container, len(containers))
+	copy(result, containers)
+
+	for i := range result {
+		result[i].Env = append(result[i].Env, corev1.EnvVar{
+			Name:  TektonHermeticEnvVar,
+			Value: hermeticValue,
+		})
+	}
+	return result
+}
+
+// mergeVolumeMounts adds implicit volume mounts to container, avoiding duplicates.
+// It checks for conflicts by cleaning and comparing mount paths.
+func mergeVolumeMounts(containerMounts, implicitMounts []corev1.VolumeMount) []corev1.VolumeMount {
+	if len(implicitMounts) == 0 {
+		return containerMounts
+	}
+
+	// Build map of requested mount paths
+	requestedPaths := make(map[string]bool, len(containerMounts))
+	for _, vm := range containerMounts {
+		requestedPaths[filepath.Clean(vm.MountPath)] = true
+	}
+
+	// Add only non-conflicting implicit mounts
+	result := make([]corev1.VolumeMount, len(containerMounts))
+	copy(result, containerMounts)
+
+	for _, imp := range implicitMounts {
+		if !requestedPaths[filepath.Clean(imp.MountPath)] {
+			result = append(result, imp)
+		}
+	}
+
+	return result
+}
+
+// applyVolumeMountsToContainers applies volume mounts to all containers, avoiding path conflicts
+func applyVolumeMountsToContainers(containers []corev1.Container, implicitMounts []corev1.VolumeMount) []corev1.Container {
+	result := make([]corev1.Container, len(containers))
+	copy(result, containers)
+
+	for i := range result {
+		result[i].VolumeMounts = mergeVolumeMounts(result[i].VolumeMounts, implicitMounts)
+	}
+
+	return result
+}
