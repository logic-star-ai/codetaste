+func TestGetMergeData(t *testing.T) {
+	template := &corev1.Container{
+		Image: "ubuntu",
+		Env: []corev1.EnvVar{
+			{Name: "TEMPLATE_VAR", Value: "template"},
+		},
+	}
+	empty := &corev1.Container{}
+
+	md, err := GetMergeData(template, empty)
+	if err != nil {
+		t.Fatalf("GetMergeData() failed: %v", err)
+	}
+
+	if md == nil {
+		t.Fatal("GetMergeData() returned nil MergeData")
+	}
+
+	if len(md.templateJSON) == 0 {
+		t.Error("MergeData.templateJSON is empty")
+	}
+
+	if len(md.emptyJSON) == 0 {
+		t.Error("MergeData.emptyJSON is empty")
+	}
+
+	// patchSchema is a struct, not a pointer, so we can't check for nil
+}
