+import { TOKEN_REFRESH_MARGIN } from '../../constants'
+
+/**
+ * Calculate the time remaining before a token expires
+ * @param expiresAt Token expiration date
+ * @returns Time remaining in milliseconds
+ */
+export const calculateTokenRefreshTime = (expiresAt: Date): number => {
+  const expiresIn = expiresAt.getTime() - Date.now()
+  return expiresIn - 1_000 * TOKEN_REFRESH_MARGIN
+}
+
+/**
+ * Calculate the next refresh time based on access token expiration
+ * @param accessTokenExpiresIn Token expiration in seconds
+ * @returns Date when the next refresh should occur
+ */
+export const calculateNextRefreshTime = (accessTokenExpiresIn: number): Date => {
+  return new Date(Date.now() + accessTokenExpiresIn * 1_000)
+}
+
+/**
+ * Check if enough time has elapsed since last refresh attempt
+ * @param lastAttemptTime Time of last refresh attempt
+ * @param minInterval Minimum interval in milliseconds
+ * @returns True if enough time has elapsed
+ */
+export const hasElapsedMinInterval = (
+  lastAttemptTime: Date,
+  minInterval: number = 1000
+): boolean => {
+  const elapsed = Date.now() - lastAttemptTime.getTime()
+  return elapsed > minInterval
+}
+
+/**
+ * Check if refresh has been running for too long
+ * @param startedAt Time when refresh started
+ * @param maxDuration Maximum duration in milliseconds
+ * @returns True if max duration exceeded
+ */
+export const hasExceededMaxDuration = (
+  startedAt: Date,
+  maxDuration: number = 10000
+): boolean => {
+  const elapsed = Date.now() - startedAt.getTime()
+  return elapsed > maxDuration
+}
