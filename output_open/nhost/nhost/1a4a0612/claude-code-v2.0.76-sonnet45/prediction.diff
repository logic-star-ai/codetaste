@@ -0,0 +1,59 @@
+import { ErrorPayload } from '../types'
+import { NETWORK_ERROR_CODE } from '../errors'
+
+/**
+ * Standardized error response creator
+ */
+export const createErrorResponse = (
+  status: number,
+  message: string,
+  error: string
+): ErrorPayload => ({
+  status,
+  message,
+  error
+})
+
+/**
+ * Create a network error response
+ */
+export const createNetworkError = (message: string = 'Network Error'): ErrorPayload => ({
+  status: NETWORK_ERROR_CODE,
+  message,
+  error: 'network'
+})
+
+/**
+ * Extract error message from various error types
+ */
+export const extractErrorMessage = (error: unknown): string => {
+  if (error instanceof Error) {
+    return error.message
+  }
+  if (typeof error === 'string') {
+    return error
+  }
+  if (error && typeof error === 'object' && 'message' in error) {
+    return String((error as { message: unknown }).message)
+  }
+  return 'Unknown error occurred'
+}
+
+/**
+ * Safe JSON parse with error handling
+ */
+export const safeJsonParse = async <T = unknown>(
+  response: Response
+): Promise<{ data: T | null; error: ErrorPayload | null }> => {
+  try {
+    const data = await response.json()
+    return { data, error: null }
+  } catch (e) {
+    const error = createErrorResponse(
+      response.status,
+      extractErrorMessage(e),
+      'json_parse_error'
+    )
+    return { data: null, error }
+  }
+}
