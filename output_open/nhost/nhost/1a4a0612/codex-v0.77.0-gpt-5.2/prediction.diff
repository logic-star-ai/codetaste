+  private async signInAnonymously(
+    interpreter: AuthInterpreter
+  ): Promise<SignInResponse & { providerUrl?: string; provider?: string }> {
+    const anonymousResult = await signInAnonymousPromise(interpreter)
+    return { ...getAuthenticationResult(anonymousResult), mfa: null }
+  }
+
+  private async signInWithProvider({
+    provider,
+    options
+  }: SignInWithProviderParams): Promise<
+    SignInResponse & { providerUrl?: string; provider?: string }
+  > {
+    const providerUrl = encodeQueryParameters(
+      `${this._client.backendUrl}/signin/provider/${provider}`,
+      rewriteRedirectTo(this._client.clientUrl, options as any)
+    )
+    if (isBrowser()) {
+      window.location.href = providerUrl
+    }
+    return { providerUrl, provider, session: null, mfa: null, error: null }
+  }
+
+  private async signInWithEmailPassword(
+    interpreter: AuthInterpreter,
+    { email, password }: SignInEmailPasswordParams
+  ): Promise<SignInResponse & { providerUrl?: string; provider?: string }> {
+    const response = await signInEmailPasswordPromise(interpreter, email, password)
+    if (response.needsEmailVerification) {
+      return { session: null, mfa: null, error: EMAIL_NEEDS_VERIFICATION }
+    }
+    if (response.needsMfaOtp) {
+      return { session: null, mfa: response.mfa, error: null }
+    }
+    return { ...getAuthenticationResult(response), mfa: null }
+  }
+
+  private async signInWithSecurityKey(
+    interpreter: AuthInterpreter,
+    { email, securityKey }: SignInPasswordlessSecurityKeyParams
+  ): Promise<SignInResponse & { providerUrl?: string; provider?: string }> {
+    if (securityKey !== true) {
+      throw new Error('securityKey must be true')
+    }
+    const response = await signInEmailSecurityKeyPromise(interpreter, email)
+    return { ...getAuthenticationResult(response), mfa: null }
+  }
+
+  private async signInPasswordlessEmail(
+    interpreter: AuthInterpreter,
+    { email, options }: SignInPasswordlessEmailParams
+  ): Promise<SignInResponse & { providerUrl?: string; provider?: string }> {
+    const { error } = await signInEmailPasswordlessPromise(interpreter, email, options)
+    return { session: null, mfa: null, error }
+  }
+
+  private async signInPasswordlessSmsOtp(
+    interpreter: AuthInterpreter,
+    { phoneNumber, otp }: SignInPasswordlessSmsOtpParams
+  ): Promise<SignInResponse & { providerUrl?: string; provider?: string }> {
+    const response = await signInSmsPasswordlessOtpPromise(interpreter, phoneNumber, otp)
+    return { ...getAuthenticationResult(response), mfa: null }
+  }
+
+  private async signInPasswordlessSms(
+    interpreter: AuthInterpreter,
+    { phoneNumber, options }: SignInPasswordlessSmsParams
+  ): Promise<SignInResponse & { providerUrl?: string; provider?: string }> {
+    const { error } = await signInSmsPasswordlessPromise(interpreter, phoneNumber, options)
+    return { error, mfa: null, session: null }
+  }
+
+  private async signInMfaTotp(
+    interpreter: AuthInterpreter,
+    { otp, ticket }: SignInEmailPasswordOtpParams
+  ): Promise<SignInResponse & { providerUrl?: string; provider?: string }> {
+    const response = await signInMfaTotpPromise(interpreter, otp, ticket)
+    return { ...getAuthenticationResult(response), mfa: null }
+  }
+
+  private async deanonymizeWithPasswordless(
+    interpreter: AuthInterpreter,
+    params: Extract<DeanonymizeParams, { signInMethod: 'passwordless' }>
+  ): Promise<DeanonymizeResponse> {
+    if (params.connection === 'email') {
+      const { error } = await signInEmailPasswordlessPromise(
+        interpreter,
+        params.email,
+        params.options
+      )
+      return { error }
+    }
+    if (params.connection === 'sms') {
+      const { error } = await signInSmsPasswordlessPromise(
+        interpreter,
+        params.phoneNumber,
+        params.options
+      )
+      return { error }
+    }
+    throw new Error('Unknown passwordless connection')
+  }
+
+  private async deanonymizeWithEmailPassword(
+    interpreter: AuthInterpreter,
+    params: Extract<DeanonymizeParams, { signInMethod: 'email-password' }>
+  ): Promise<DeanonymizeResponse> {
+    const { error } = await signUpEmailPasswordPromise(
+      interpreter,
+      params.email,
+      params.password,
+      params.options
+    )
+    return { error }
+  }
+
   get client() {
     return this._client
   }
