index 0000000..3a58fa6
--- /dev/null
+++ b/packages/hasura-auth-js/src/utils/auth-results.ts
@@ -0,0 +1,26 @@
+/**
+ * Helper to extract error details from authentication responses
+ */
+export function getAuthenticationResult<T>(
+  result: {
+    error: Error | null
+    isError: boolean
+    isSuccess: boolean
+    accessToken: string | null
+    user: any
+  }
+): {
+  error: Error | null
+  isError: boolean
+  isSuccess: boolean
+  accessToken: string | null
+  user: any
+} {
+  return {
+    error: result.error,
+    isError: result.isError,
+    isSuccess: result.isSuccess,
+    accessToken: result.accessToken,
+    user: result.user
+  }
+}
