-const shell = require('shelljs');
+const {spawnSync} = require('child_process');
 
-function exec(command, opt, ignoreCode) {
-  const res = shell.exec(command, opt);
-  if (!ignoreCode && res.code !== 0) {
-    shell.echo('command', command, 'returned code', res.code);
-    process.exit(1);
+function exec(command, opt = {}, ignoreCode = false) {
+  const {silent = false, cwd, env} = opt;
+  const res = spawnSync(command, {
+    shell: true,
+    cwd,
+    env,
+    encoding: 'utf8',
+    windowsHide: true,
+  });
+
+  if (res.error) {
+    throw res.error;
+  }
+
+  const stdout = res.stdout || '';
+  const stderr = res.stderr || '';
+
+  if (!silent) {
+    if (stdout) process.stdout.write(stdout);
+    if (stderr) process.stderr.write(stderr);
   }
-  return res;
+
+  const code = res.status == null ? 0 : res.status;
+  if (!ignoreCode && code !== 0) {
+    throw new Error(`command "${command}" returned code ${code}`);
+  }
+
+  return {code, stdout, stderr};
 }
 
 exports.exec = exec;
