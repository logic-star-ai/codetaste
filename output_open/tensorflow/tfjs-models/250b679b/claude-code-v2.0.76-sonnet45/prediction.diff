+ * distributed under the License is distributed on an "AS IS" BASIS,
+ * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.
+ * See the License for the specific language governing permissions and
+ * limitations under the License.
+ * =============================================================================
+ */
+
+/**
+ * Shared utility functions for pose manipulation across multiple packages.
+ * This module provides common functions for scaling and flipping poses.
+ */
+
+export interface Keypoint {
+  score: number;
+  part: string;
+  position: {x: number, y: number};
+}
+
+export interface Pose {
+  score: number;
+  keypoints: Keypoint[];
+}
+
+/**
+ * Scales a single pose by the given scale factors and offsets.
+ * @param pose The pose to scale
+ * @param scaleY Vertical scale factor
+ * @param scaleX Horizontal scale factor
+ * @param offsetY Vertical offset (default: 0)
+ * @param offsetX Horizontal offset (default: 0)
+ * @returns Scaled pose
+ */
+export function scalePose(
+    pose: Pose, scaleY: number, scaleX: number, offsetY = 0,
+    offsetX = 0): Pose {
+  return {
+    score: pose.score,
+    keypoints: pose.keypoints.map(({score, part, position}) => ({
+      score,
+      part,
+      position: {
+        x: position.x * scaleX + offsetX,
+        y: position.y * scaleY + offsetY
+      }
+    }))
+  };
+}
+
+/**
+ * Scales multiple poses by the given scale factors and offsets.
+ * Returns early if no scaling is needed (identity transformation).
+ * @param poses Array of poses to scale
+ * @param scaleY Vertical scale factor
+ * @param scaleX Horizontal scale factor
+ * @param offsetY Vertical offset (default: 0)
+ * @param offsetX Horizontal offset (default: 0)
+ * @returns Array of scaled poses
+ */
+export function scalePoses(
+    poses: Pose[], scaleY: number, scaleX: number, offsetY = 0,
+    offsetX = 0): Pose[] {
+  if (scaleX === 1 && scaleY === 1 && offsetY === 0 && offsetX === 0) {
+    return poses;
+  }
+  return poses.map(pose => scalePose(pose, scaleY, scaleX, offsetY, offsetX));
+}
+
+/**
+ * Flips a single pose horizontally.
+ * @param pose The pose to flip
+ * @param imageWidth Width of the image for calculating flipped x coordinates
+ * @returns Horizontally flipped pose
+ */
+export function flipPoseHorizontal(pose: Pose, imageWidth: number): Pose {
+  return {
+    score: pose.score,
+    keypoints: pose.keypoints.map(
+        ({score, part, position}) => ({
+          score,
+          part,
+          position: {x: imageWidth - 1 - position.x, y: position.y}
+        }))
+  };
+}
+
+/**
+ * Flips multiple poses horizontally.
+ * Returns early if image width is invalid.
+ * @param poses Array of poses to flip
+ * @param imageWidth Width of the image for calculating flipped x coordinates
+ * @returns Array of horizontally flipped poses
+ */
+export function flipPosesHorizontal(poses: Pose[], imageWidth: number): Pose[] {
+  if (imageWidth <= 0) {
+    return poses;
+  }
+  return poses.map(pose => flipPoseHorizontal(pose, imageWidth));
+}
