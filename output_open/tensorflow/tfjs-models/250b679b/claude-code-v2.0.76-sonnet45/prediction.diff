+ * See the License for the specific language governing permissions and
+ * limitations under the License.
+ * =============================================================================
+ */
+
+import * as tf from '@tensorflow/tfjs-core';
+
+/**
+ * Shared utility functions for tensor operations across multiple packages.
+ */
+
+/**
+ * Converts an array of 3D tensors to tensor buffers.
+ * @param tensors Array of 3D tensors to convert
+ * @returns Promise resolving to array of tensor buffers
+ */
+export async function toTensorBuffers3D(
+    tensors: tf.Tensor3D[]): Promise<tf.TensorBuffer<tf.Rank.R3>[]> {
+  return Promise.all(tensors.map(tensor => tensor.buffer()));
+}
+
+/**
+ * Type guard to check if input is a tensor.
+ * @param input Input to check
+ * @returns True if input is a tensor
+ */
+export function isTensor(input: unknown): input is tf.Tensor {
+  return input instanceof tf.Tensor;
+}
+
+/**
+ * Gets dimensions from various input types.
+ * @param input Image-like input (Tensor, ImageData, or HTML element)
+ * @returns [height, width] tuple
+ */
+export function getInputTensorDimensions(
+    input: tf.Tensor3D|ImageData|HTMLVideoElement|HTMLImageElement|
+    HTMLCanvasElement): [number, number] {
+  return input instanceof tf.Tensor ? [input.shape[0], input.shape[1]] :
+                                      [input.height, input.width];
+}
+
+/**
+ * Converts various input types to a 4D input tensor for model inference.
+ * @param input Image-like input
+ * @returns 4D tensor ready for model input
+ */
+export function toInputTensor(
+    input: tf.Tensor3D|ImageData|HTMLVideoElement|HTMLImageElement|
+    HTMLCanvasElement): tf.Tensor4D {
+  return tf.tidy(() => {
+    let imageTensor: tf.Tensor3D;
+    if (input instanceof tf.Tensor) {
+      imageTensor = input;
+    } else {
+      imageTensor = tf.browser.fromPixels(input);
+    }
+    return tf.expandDims(tf.cast(imageTensor, 'float32'), 0) as tf.Tensor4D;
+  });
+}
