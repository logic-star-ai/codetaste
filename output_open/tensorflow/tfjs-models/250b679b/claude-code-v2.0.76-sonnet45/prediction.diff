+ * Common image sizes used across models
+ */
+export const COMMON_IMAGE_SIZES = {
+  MOBILENET_V1_224: 224,
+  MOBILENET_V2_224: 224,
+  INCEPTION_V3_299: 299,
+  RESNET_224: 224
+} as const;
+
+/**
+ * TensorFlow Hub base URL
+ */
+export const TFHUB_BASE_URL = 'https://tfhub.dev/tensorflow/tfjs-model';
