+
+/**
+ * Shared constants used across multiple packages
+ */
+
+/**
+ * Default image normalization factor (scales RGB values to 0-1 range)
+ */
+export const DEFAULT_IMAGE_NORMALIZATION_FACTOR = 255;
+
+/**
+ * Common confidence threshold values
+ */
+export const CONFIDENCE_THRESHOLDS = {
+  LOW: 0.3,
+  MEDIUM: 0.5,
+  HIGH: 0.75,
+  VERY_HIGH: 0.9
+} as const;
+
