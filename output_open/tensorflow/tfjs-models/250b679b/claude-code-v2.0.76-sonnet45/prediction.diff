+ * distributed under the License is distributed on an "AS IS" BASIS,
+ * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.
+ * See the License for the specific language governing permissions and
+ * limitations under the License.
+ * =============================================================================
+ */
+
+import * as tf from '@tensorflow/tfjs-core';
+
+/**
+ * Shared utility functions for image manipulation across multiple packages.
+ */
+
+export type ImageType = HTMLImageElement | HTMLCanvasElement | HTMLVideoElement |
+                        ImageData | tf.Tensor3D;
+
+/**
+ * Gets the size (height and width) from an image-like element.
+ * Handles different types of image inputs consistently.
+ * @param input Image-like input
+ * @returns [height, width] tuple
+ */
+export function getInputSize(input: ImageType): [number, number] {
+  if (input instanceof tf.Tensor) {
+    return [input.shape[0], input.shape[1]];
+  } else if (input instanceof ImageData) {
+    return [input.height, input.width];
+  } else if ('videoHeight' in input && 'videoWidth' in input) {
+    // HTMLVideoElement
+    return [input.videoHeight, input.videoWidth];
+  } else if ('offsetHeight' in input && input.offsetHeight !== 0 &&
+             'offsetWidth' in input && input.offsetWidth !== 0) {
+    // HTMLImageElement or HTMLCanvasElement with offset dimensions
+    return [input.offsetHeight, input.offsetWidth];
+  } else if ('height' in input && 'width' in input &&
+             input.height !== null && input.height !== undefined &&
+             input.width !== null && input.width !== undefined) {
+    // Fallback to height/width properties
+    return [input.height, input.width];
+  }
+  throw new Error('Unable to determine dimensions of input element');
+}
+
+/**
+ * Resizes and normalizes an image tensor for model input.
+ * Common preprocessing step for many vision models.
+ * @param input Input tensor
+ * @param targetHeight Target height
+ * @param targetWidth Target width
+ * @param normalizationFactor Optional normalization factor (default: 255)
+ * @returns Resized and normalized tensor
+ */
+export function resizeAndNormalize(
+    input: tf.Tensor3D | tf.Tensor4D,
+    targetHeight: number,
+    targetWidth: number,
+    normalizationFactor = 255): tf.Tensor {
+  return tf.tidy(() => {
+    const resized = tf.image.resizeBilinear(
+        input as tf.Tensor3D | tf.Tensor4D,
+        [targetHeight, targetWidth]);
+    return tf.div(resized, normalizationFactor);
+  });
+}
+
+/**
+ * Pads an image tensor to match target dimensions.
+ * @param tensor Input tensor
+ * @param targetHeight Target height after padding
+ * @param targetWidth Target width after padding
+ * @returns Padded tensor
+ */
+export function padToTargetSize(
+    tensor: tf.Tensor3D,
+    targetHeight: number,
+    targetWidth: number): tf.Tensor3D {
+  return tf.tidy(() => {
+    const [height, width] = [tensor.shape[0], tensor.shape[1]];
+    const padHeight = targetHeight - height;
+    const padWidth = targetWidth - width;
+
+    if (padHeight < 0 || padWidth < 0) {
+      throw new Error(
+          `Target dimensions must be >= input dimensions. ` +
+          `Got input: [${height}, ${width}], target: [${targetHeight}, ${targetWidth}]`);
+    }
+
+    return tf.pad(tensor, [[0, padHeight], [0, padWidth], [0, 0]]) as tf.Tensor3D;
+  });
+}
