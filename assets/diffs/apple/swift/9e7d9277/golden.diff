+#define BRIDGING_WRAPPER_IMPL(Node, Name, Nullability)                         \
+  class Bridged##Name {                                                        \
+    swift::Node * Nullability Ptr;                                             \
+                                                                               \
+  public:                                                                      \
+    SWIFT_UNAVAILABLE("Use init(raw:) instead")                                \
