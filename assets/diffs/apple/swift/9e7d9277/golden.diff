+BridgedTypeAttrKind BridgedTypeAttrKind_fromString(BridgedStringRef cStr) {
+  TypeAttrKind kind = TypeAttributes::getAttrKindFromString(unbridged(cStr));
+  switch (kind) {
+#define TYPE_ATTR(X)                                                           \
+  case TAK_##X:                                                                \
