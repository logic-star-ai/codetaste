-    BridgedSourceLoc cColonLoc, BridgedIdentifier cPrecedenceGroupName,
-    BridgedSourceLoc cPrecedenceGroupLoc) {
-  assert(bool(cColonLoc.raw) == (bool)cPrecedenceGroupName.raw);
