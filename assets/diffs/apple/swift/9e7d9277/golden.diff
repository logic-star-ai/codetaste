+BridgedClosureExpr
+BridgedClosureExpr_createParsed(BridgedASTContext cContext,
+                                BridgedDeclContext cDeclContext,
+                                BridgedBraceStmt body) {
+  DeclAttributes attributes;
+  SourceRange bracketRange;
