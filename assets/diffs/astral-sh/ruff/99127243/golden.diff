+        let stmt = program.first().unwrap();
+        let locator = Locator::new(contents);
+        assert!(!has_trailing_content(stmt.end(), &locator));
+
+        let contents = r#"
+x = 1
+y = 2
+"#
+        .trim();
+        let program = Suite::parse(contents, "<filename>")?;
+        let stmt = program.first().unwrap();
+        let locator = Locator::new(contents);
+        assert!(!has_trailing_content(stmt.end(), &locator));
+
+        Ok(())
+    }
