+export const sanitizeHighlightedValues = (labels: Label[]): Label[] =>
+  labels.map(v => {
+    return {
+      ...v,
+      value: v.value.includes('\\') ? v.value.replaceAll('\\', '\\\\') : v.value,
+    };
+  });
