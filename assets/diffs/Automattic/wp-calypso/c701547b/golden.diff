+		[ 'D', 36, 50 ],
+		[ 'E', 26, 35 ],
+		[ 'F', 0, 25 ],
+	] )(
+		'should return a rating of "%s" for scores from %d to %d inclusive',
+		( expectedRating, minScore, maxScore ) => {
+			const minRating = getBoostRating( minScore );
+			const maxRating = getBoostRating( maxScore );
+
