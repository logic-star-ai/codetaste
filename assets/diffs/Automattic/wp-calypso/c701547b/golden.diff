-export const BOOST_THRESHOLDS: BoostThreshold[] = [
-	{ threshold: 90, rating: 'A' },
-	{ threshold: 75, rating: 'B' },
-	{ threshold: 50, rating: 'C' },
-	{ threshold: 35, rating: 'D' },
-	{ threshold: 25, rating: 'E' },
-	{ threshold: 0, rating: 'F' },
-];
