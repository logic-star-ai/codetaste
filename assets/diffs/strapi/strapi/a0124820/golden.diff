+  on?: Record<string, unknown>;
+  pivotColumns: string[];
+  morphColumn: MorphColumn;
+}
+
+export interface BaseRelationalAttribute {
+  type: 'relation';
+  target: string;
+  useJoinTable?: boolean;
+  joinTable?: JoinTable | MorphJoinTable;
+  morphBy?: string;
+  inversedBy?: string;
+  owner?: boolean;
+  morphColumn?: MorphColumn;
+  joinColumn?: JoinColumn;
+  // TODO: remove this
