diff --git a/packages/error/README.md b/packages/error/README.md
new file mode 100644
index 00000000000..e0c50580bfe
--- /dev/null
+++ b/packages/error/README.md
@@ -0,0 +1,32 @@
+# @pnpm/error
+
+> An error class for pnpm errors
+
+<!--@shields('npm')-->
+[![npm version](https://img.shields.io/npm/v/@pnpm/error.svg)](https://www.npmjs.com/package/@pnpm/error)
+<!--/@-->
+
+## Installation
+
+```sh
+pnpm add @pnpm/error
+```
+
+### Usage
+
+```ts
+import PnpmError from '@pnpm/error'
+
+try {
+    throw new PnpmError('THE_ERROR_CODE', 'The error message')
+} catch (err) {
+    console.log(err.code)
+    //> ERR_PNPM_THE_ERROR_CODE
+    console.log(err.message)
+    //> The error message
+}
+```
+
+## License
+
+MIT © [Zoltan Kochan](https://www.kochan.io/)
