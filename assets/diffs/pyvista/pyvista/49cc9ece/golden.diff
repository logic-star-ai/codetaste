+    elif output_type == np.uint8:
+        samp.SetOutputScalarTypeToUnsignedChar()
+    else:
+        raise ValueError(f'Invalid output_type {output_type}')
+
+    _update_alg(samp, progress_bar=progress_bar, message='Sampling')
+    return wrap(samp.GetOutput())
