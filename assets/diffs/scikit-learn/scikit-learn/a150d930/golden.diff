-    array([[0, 8, 0, 3],
-           [0, 0, 2, 0],
-           [0, 0, 0, 0],
-           [0, 0, 0, 0]])
-
-    Note that the resulting graph is a Directed Acyclic Graph which spans
-    the graph.  A breadth-first tree from a given node is unique.
-    """
-    node_list, predecessors = breadth_first_order(csgraph, i_start,
-                                                  directed, True)
