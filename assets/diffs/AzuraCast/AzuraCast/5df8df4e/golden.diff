+                        fields.display_name,
+                        fields.comments,
+                        fields.is_active,
+                        fields.enforce_schedule,
+                    ],
+                })
+            }
+        );
+
+        const $reset = () => {
+            reset();
+            r$.$reset();
+        }
+
+        return {
+            isEditMode,
+            setEditMode,
+            form,
+            r$,
+            $reset
+        }
+    }
+);
