+                hls_segments_overhead: 2,
+                record_streams: false,
+                record_streams_format: StreamFormats.Mp3,
+                record_streams_bitrate: 128,
+                dj_buffer: 5,
+                live_broadcast_text: 'Live Broadcast',
+                dj_port: null,
+                dj_mount_point: '/',
+            },
+            enable_hls: false,
+            enable_requests: false,
