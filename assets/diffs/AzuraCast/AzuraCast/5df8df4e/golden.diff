+    recordings_storage_location: string | number,
+    podcasts_storage_location: string | number,
+}
+
+export const useAdminStationsForm = defineStore(
+    'form-admin-stations',
+    () => {
+        const {record: form, reset} = useResettableRef<StationRecord>({
+            name: '',
