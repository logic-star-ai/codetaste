+		.send_request(
+			"signup",
+			json!([{
+				"ns": NS,
+				"db": DB,
+				"ac": "user",
+				"email": "email@email.com",
+				"pass": "pass",
+			}]),
+		)
+		.await;
+	assert!(res.is_ok(), "result: {res:?}");
