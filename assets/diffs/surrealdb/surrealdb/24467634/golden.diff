+		"2024-08-19T12:00:00Z",
+	];
+
+	for (i, version) in versions.iter().enumerate() {
+		let _ = db
+			.query(format!(
+				"
+                CREATE user:user1
+                SET name = 'Updated User {i}' VERSION d'{version}'
+                "
+			))
+			.await
+			.unwrap()
+			.check()
+			.unwrap();
+	}
+
+	// Export the database to a file
