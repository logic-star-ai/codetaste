-    };
-  },
-  render: function() {
-    return (
-      <Animated.div
-        style={{
-          transform: [
-            {rotate: this.state.anim.interpolate({
-              inputRange: [0, 1],
-              outputRange: ['260deg', '0deg']
-            })},
-            {scale: this.state.anim},
-          ]
-        }}
-        className="circle"
-        onClick={this.handleClick}>
-        Click
-      </Animated.div>
-    );
-  },
-  handleClick: function() {
-    Animated.spring(this.state.anim, {toValue: 0}).start();
-  }
-}));
-</script><script>example();</script>
