+    'bubbles',
+    'cancelable',
+    'changedTouches',
+    'ctrlKey',
+    'detail',
+    'eventPhase',
+    'metaKey',
+    'pageX',
+    'pageY',
+    'shiftKey',
+    'view',
+    'char',
+    'code',
+    'charCode',
+    'key',
+    'keyCode',
+    'button',
+    'buttons',
+    'clientX',
+    'clientY',
+    'offsetX',
+    'offsetY',
+    'pointerId',
+    'pointerType',
+    'screenX',
+    'screenY',
