+			if tfawserr.ErrCodeEquals(r.Error, securityhub_sdkv1.ErrCodeResourceConflictException) {
+				r.Retryable = aws_sdkv1.Bool(true)
+			}
+		}
+	})
+
+	return conn, nil
+}
