 }
 
 // Write writes the string to the file.
 func (f File) Write(s string) error {
+	if f == "" {
+		return xerrors.Errorf("empty file path")
+	}
 	return write(string(f), 0o600, []byte(s))
 }
 
 // Read reads the file to a string.
