diff --git a/mod/tigron/test/interfaces.go b/mod/tigron/test/interfaces.go
new file mode 100644
index 00000000000..d83b3117887
--- /dev/null
+++ b/mod/tigron/test/interfaces.go
@@ -0,0 +1,109 @@
+/*
