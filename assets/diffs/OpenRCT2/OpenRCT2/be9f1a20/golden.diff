+
+#pragma once
+
+#include "../../common.h"
+#include "../Scene.h"
+
+struct DrawPixelInfo;
+
+namespace OpenRCT2
+{
+    enum class IntroState : uint8_t
+    {
+        None,
+        PublisherBegin,
+        PublisherScroll,
+        DeveloperBegin,
+        DeveloperScroll,
+        LogoFadeIn,
+        LogoWait,
+        LogoFadeOut,
+        Disclaimer1,
+        Disclaimer2,
+        Clear = 254,
+        Finish = 255,
+    };
+
+    class IntroScene final : public Scene
+    {
+    public:
+        using Scene::Scene;
+
+        void Load() override;
+        void Tick() override;
+        void Stop() override;
+    };
+
+    bool IntroIsPlaying();
+    void IntroUpdate();
+    void IntroDraw(DrawPixelInfo& dpi);
+} // namespace OpenRCT2
