-func removeNilTenants(tenants []*cmd.Tenant) []*cmd.Tenant {
-	n := 0
-	for i := range tenants {
-		if tenants[i] != nil && tenants[i].Name != "" {
-			tenants[n] = tenants[i]
-			n++
-		}
-	}
-	return tenants[:n]
-}
