+			'tag:list',
+			'tag:read',
+			'tag:update',
+			'user:changeRole',
+			'user:create',
+			'user:delete',
+			'user:list',
+			'user:read',
+			'variable:create',
+			'variable:delete',
+			'variable:list',
+			'workflow:create',
+			'workflow:delete',
+			'workflow:list',
+			'workflow:move',
+			'workflow:read',
+			'workflow:update',
+		];
