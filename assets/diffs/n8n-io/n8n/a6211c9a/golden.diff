+				if (overwrite === MODAL_CONFIRM) {
+					return await saveCurrentWorkflow({ id, name, tags }, redirect, true);
+				}
+
+				return false;
+			}
+
+			toast.showMessage({
+				title: i18n.baseText('workflowHelpers.showMessage.title'),
+				message: error.message,
+				type: 'error',
+			});
+
+			return false;
+		}
+	}
