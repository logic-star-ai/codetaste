+			const workflowData = await workflowsStore.updateWorkflow(
+				currentWorkflow,
+				workflowDataRequest,
+				forceSave,
+			);
+			workflowsStore.setWorkflowVersionId(workflowData.versionId);
+
+			if (name) {
+				workflowsStore.setWorkflowName({ newName: workflowData.name, setStateDirty: false });
+			}
