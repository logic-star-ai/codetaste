+
+        .. include:: defaults.rst
+            :start-after: :orphan:
+
+        .. testcode::
+
+            metric = MeanNormalizedBias()
+            metric.attach(default_evaluator, 'mnb')
+            y_true = torch.tensor([1., 2., 3., 4., 5.])
+            y_pred = y_true * 0.75
+            state = default_evaluator.run([[y_pred, y_true]])
+            print(state.metrics['mnb'])
+
+        .. testoutput::
+
+            0.25...
+
+    .. versionchanged:: 0.4.5
