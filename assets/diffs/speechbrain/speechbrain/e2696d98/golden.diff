-def read_rttm(rttm_file_path):
-    """Reads and returns RTTM in list format.
-
-    Arguments
-    ---------
-    rttm_file_path : str
-        Path to the RTTM file to be read.
-
-    Returns
-    -------
-    rttm : list
-        List containing rows of RTTM file.
-    """
-    rttm = []
-    with open(rttm_file_path, "r", encoding="utf-8") as f:
-        for line in f:
-            entry = line[:-1]
-            rttm.append(entry)
-    return rttm
