+
+      if (!apiKey) {
+        throw new TRPCError({
+          code: 'BAD_REQUEST',
+          message: 'No app found',
+        });
+      }
+
+      const appUrl = new URL(app.url);
+
+      if (input.type === 'movie') {
+        const movie = await axios
+          .get(`${appUrl.origin}/api/v1/movie/${input.id}`, {
+            headers: {
+              // Set X-Api-Key to the value of the API key
