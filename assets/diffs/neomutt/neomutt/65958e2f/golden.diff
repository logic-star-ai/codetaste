+struct PgpUidArray;
+
+/**
+ * enum KeySortType - Methods for sorting Crypto Keys
+ */
+enum KeySortType
+{
+  KEY_SORT_ADDRESS,    ///< Sort by address
+  KEY_SORT_DATE,       ///< Sort by date
+  KEY_SORT_KEYID,      ///< Sort by key id
+  KEY_SORT_TRUST,      ///< Sort by trust level
