+            self.path = get_safe_path(cm_constants.CONFIG_DEFAULT_FOLDER, base_name)
+
+    def persist(self):
+        if self.path is None:
+            self.build_path()
+
+        if not os.path.exists(self.path):
+            os.mkdir(self.path)
+
+        with open(self.path + "/.folder.json", 'w') as outFile:
