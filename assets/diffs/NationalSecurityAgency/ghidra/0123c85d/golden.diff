+	/**
+	 * Find the id associated with a specific attribute name
+	 * @param nm the attribute name
+	 * @return the associated id
+	 */
+	public static int find(String nm) {
+		Integer res = lookupAttributeId.get(nm);
+		if (res != null) {
+			return res.intValue();
+		}
+		return ATTRIB_UNKNOWN.id;
+	}
