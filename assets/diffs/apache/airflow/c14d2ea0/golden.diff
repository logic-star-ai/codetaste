index 0000000000000..beccbe69b2d5c
--- /dev/null
+++ b/airflow/utils/helpers.py
@@ -0,0 +1,147 @@
+# -*- coding: utf-8 -*-
+#
+# Licensed under the Apache License, Version 2.0 (the "License");
