-IEnumerable<IGrouping<int, int>> query = from number in numbers  
-                                         group number by number % 2;  
-  
-foreach (var group in query)  
-{  
-    Console.WriteLine(group.Key == 0 ? "\nEven numbers:" : "\nOdd numbers:");  
-    foreach (int i in group)  
-        Console.WriteLine(i);  
-}  
