-            Fail("2) ERROR: random generated an invalid value: %d", TempRandNumber);
-        }
-    }
-
-
-
-    /* renitialize the srand with 1 */
-    srand(SRAND_REINIT);
-
-
-
-    /* choose 10 numbers with seed 1,
