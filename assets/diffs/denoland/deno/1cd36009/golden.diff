+  ) -> std::io::Result<()> {
+    match self {
+      Self::Real(sys) => sys.base_fs_create_dir(p, options),
+      Self::DenoCompile(sys) => sys.base_fs_create_dir(p, options),
+    }
+  }
+}
+
+impl sys_traits::BaseFsOpen for CliSys {
+  type File = BoxedFsFile;
+
+  fn base_fs_open(
+    &self,
+    path: &std::path::Path,
