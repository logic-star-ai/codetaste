+      Self::DenoCompile(sys) => sys.base_fs_remove_file(p),
+    }
+  }
+}
+
+impl sys_traits::BaseFsRename for CliSys {
+  fn base_fs_rename(
+    &self,
+    old: &std::path::Path,
+    new: &std::path::Path,
