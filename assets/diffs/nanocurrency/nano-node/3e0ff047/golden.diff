+	blocks,
+	confirmation_height,
+	default_unused, // RocksDB only
+	final_votes,
+	frontiers,
+	meta,
+	online_weight,
+	peers,
+	pending,
+	pruned,
+	vote
+};
+} // namespace nano
+
+namespace std
+{
+template <>
+struct hash<::nano::tables>
+{
+	size_t operator() (::nano::tables const & table_a) const
+	{
+		return static_cast<size_t> (table_a);
+	}
+}; // struct hash
