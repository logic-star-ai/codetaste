--- /dev/null
+++ b/docs/src/components/function-return-type.tsx
@@ -0,0 +1,40 @@
+import type { Signature } from "@/lib/typedoc/schema";
+import type { ReactNode } from "react";
+
+export function FunctionReturnType({
+  type,
+  className,
+}: {
+  readonly type: Signature["type"];
+  readonly className?: string | undefined;
+}): ReactNode {
+  return <div className={className}>{extractReturnType(type)}</div>;
+}
+
+function extractReturnType(type: Signature["type"]): string {
+  switch (type.type) {
+    case "intrinsic":
+      return type.name;
+
+    case "array":
+      return "Array";
+
+    case "predicate":
+      return "boolean";
+
+    case "indexedAccess":
+    case "intersection":
+    case "query":
+    case "reference":
+    case "reflection":
+    case "tuple":
+    case "union":
+      // TODO: Can we improve our docs by making these more specific?
+      return "Object";
+
+    case "mapped":
+    case "conditional":
+      // These only show up in V1!
+      return "Object";
+  }
+}
