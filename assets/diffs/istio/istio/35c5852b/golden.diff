+func TestSchemasBuilder_Remove(t *testing.T) {
+	g := NewGomegaWithT(t)
+	b := NewSchemasBuilder()
+
+	s := Builder{
+		Name: "foo",
+		Schema: resource.Builder{
+			ProtoPackage: "github.com/gogo/protobuf/types",
