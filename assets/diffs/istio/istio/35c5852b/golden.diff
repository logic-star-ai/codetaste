+}
+
+func TestSchemasBuilder_RemoveSpecs(t *testing.T) {
+	g := NewGomegaWithT(t)
+
+	s := Builder{
+		Name: "foo",
+		Schema: resource.Builder{
+			ProtoPackage: "github.com/gogo/protobuf/types",
+			Proto:        "google.protobuf.Empty",
+		}.Build(),
+	}.MustBuild()
+
+	b1 := NewSchemasBuilder()
+	b1.MustAdd(s)
+
+	b2 := NewSchemasBuilder()
+	b2.MustAdd(s)
