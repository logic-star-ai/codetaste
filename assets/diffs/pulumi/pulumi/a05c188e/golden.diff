-		return nil, backend.ErrTeamsNotSupported
-	}
-
-	localStackRef, err := b.getReference(stackRef)
-	if err != nil {
-		return nil, err
-	}
-
-	err = b.Lock(ctx, stackRef)
-	if err != nil {
-		return nil, err
