+func TestRandomMatcher(t *testing.T) {
+	rand.Seed(0)
+
+	rm := NewRequestMatcher(&RequestMatcherBaseSpec{
+		Policy: "random",
+		Permil: 100,
+	})
+
+	match := 0
+	for i := 0; i < 10000; i++ {
+		if rm.Match(nil) {
+			match++
+		}
+	}
+
+	if match < 900 || match > 1100 {
+		t.Error("random matcher is not working as configured")
+	}
