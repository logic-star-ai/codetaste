+// NanoSecondToHuman converts nanoseconds to a human readable string
+func NanoSecondToHuman(ns float64) string {
+	switch {
+	case ns >= 1000000000:
+		return fmt.Sprintf("%.2fs", ns/1000000000)
+	case ns >= 1000000:
+		return fmt.Sprintf("%.2fms", ns/1000000)
+	case ns >= 1000:
+		return fmt.Sprintf("%.2fus", ns/1000)
+	default:
+		return fmt.Sprintf("%dns", int64(ns))
+	}
