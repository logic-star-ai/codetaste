+package org.apache.shenyu.infra.common.config;
+
+/**
+ * Base class for infrastructure configuration properties.
+ * Provides common configuration fields for sync data infrastructure.
+ */
+public abstract class InfraParentProperties {
+
+    private String url;
+
+    /**
+     * Get url.
+     *
+     * @return url
+     */
+    public String getUrl() {
+        return url;
+    }
+
+    /**
+     * Set url.
