+package org.apache.shenyu.infra.redis;
+
+import org.apache.shenyu.infra.redis.serializer.ShenyuRedisSerializationContext;
+import org.springframework.boot.autoconfigure.AutoConfiguration;
+import org.springframework.boot.autoconfigure.condition.ConditionalOnClass;
+import org.springframework.boot.autoconfigure.condition.ConditionalOnMissingBean;
+import org.springframework.context.annotation.Bean;
+import org.springframework.data.redis.serializer.RedisSerializationContext;
+
+/**
+ * Redis infrastructure auto-configuration.
+ */
+@AutoConfiguration
+@ConditionalOnClass(RedisSerializationContext.class)
+public class RedisInfraAutoConfiguration {
+
+    @Bean
+    @ConditionalOnMissingBean(name = "shenyuStringRedisSerializationContext")
+    public RedisSerializationContext<String, String> shenyuStringRedisSerializationContext() {
+        return ShenyuRedisSerializationContext.stringSerializationContext();
+    }
+
+    @Bean
+    @ConditionalOnMissingBean(name = "shenyuBytesRedisSerializationContext")
+    public RedisSerializationContext<String, byte[]> shenyuBytesRedisSerializationContext() {
+        return ShenyuRedisSerializationContext.bytesSerializationContext();
+    }
+}
