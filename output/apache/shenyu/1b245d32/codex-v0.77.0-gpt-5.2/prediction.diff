+package org.apache.shenyu.infra.etcd;
+
+import io.etcd.jetcd.Client;
+import org.apache.shenyu.infra.common.condition.ConditionOnSyncEtcd;
+import org.apache.shenyu.infra.etcd.config.EtcdConfig;
+import org.springframework.boot.autoconfigure.AutoConfiguration;
+import org.springframework.boot.autoconfigure.condition.ConditionalOnClass;
+import org.springframework.boot.autoconfigure.condition.ConditionalOnMissingBean;
+import org.springframework.boot.context.properties.EnableConfigurationProperties;
+import org.springframework.context.annotation.Bean;
+
+/**
+ * Etcd infrastructure auto-configuration.
+ */
+@AutoConfiguration
+@ConditionalOnClass(Client.class)
+@ConditionOnSyncEtcd
+@EnableConfigurationProperties(EtcdConfig.class)
+public class EtcdInfraAutoConfiguration {
+
+    @Bean
+    @ConditionalOnMissingBean
+    public Client etcdJetcdClient(final EtcdConfig etcdConfig) {
+        return Client.builder()
+                .endpoints(etcdConfig.getUrl().split(","))
+                .build();
+    }
+
+    @Bean
+    @ConditionalOnMissingBean
+    public EtcdClient etcdClient(final Client etcdJetcdClient) {
+        return new EtcdClient(etcdJetcdClient);
+    }
+}
