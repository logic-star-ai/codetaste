-    // expressions that take literals
-    prefixGet |
-    // expression with special identifier
-    prefixIf |
-    // expression with prefix distinct
-    prefixDistinct |
-    // function call must always be at the end
-    prefixFunctionCall | prefixFunctionCallOneArg
