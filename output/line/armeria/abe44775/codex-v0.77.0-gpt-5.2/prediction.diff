+
+package com.linecorp.armeria.client;
+
+import static java.util.Objects.requireNonNull;
+
+import java.net.URI;
+import java.util.ArrayList;
+import java.util.List;
+import java.util.Optional;
+import java.util.ServiceLoader;
+import java.util.Set;
+import java.util.function.Supplier;
+import java.util.stream.Collectors;
+
+import org.slf4j.Logger;
+import org.slf4j.LoggerFactory;
+
+import com.google.common.collect.ImmutableMap;
+import com.google.common.collect.ImmutableSet;
+import com.google.common.collect.Streams;
+
+import com.linecorp.armeria.common.Scheme;
+import com.linecorp.armeria.common.SerializationFormat;
+
+import io.netty.channel.EventLoop;
+import io.netty.channel.EventLoopGroup;
+
+/**
+ * The default {@link ClientFactory} implementation.
+ */
+final class DefaultClientFactory extends AbstractClientFactory {
+
+    private static final Logger logger = LoggerFactory.getLogger(DefaultClientFactory.class);
+
+    static {
+        if (DefaultClientFactory.class.getClassLoader() == ClassLoader.getSystemClassLoader()) {
+            Runtime.getRuntime().addShutdownHook(new Thread(ClientFactory::closeDefault));
+        }
+    }
+
+    private final HttpClientFactory httpClientFactory;
+    private final ImmutableMap<Scheme, ClientFactory> nonHttpFactories;
+    private final Set<Scheme> supportedSchemes;
+
+    DefaultClientFactory(boolean useDaemonThreads) {
+        this(new ClientFactoryBuilder().useDaemonThreads(useDaemonThreads));
+    }
+
+    DefaultClientFactory(ClientFactoryBuilder builder) {
+        requireNonNull(builder, "builder");
+
+        httpClientFactory = new HttpClientFactory(builder);
+
+        final List<ClientFactoryProvider> providers =
+                Streams.stream(ServiceLoader.load(ClientFactoryProvider.class,
+                                                  DefaultClientFactory.class.getClassLoader()))
+                       .collect(Collectors.toCollection(ArrayList::new));
+
+        final List<ClientFactory> factories = new ArrayList<>();
+        for (ClientFactoryProvider p : providers) {
+            factories.add(requireNonNull(p.newFactory(httpClientFactory),
+                                         "ClientFactoryProvider returned null: " + p.getClass().getName()));
+        }
+
+        final ImmutableMap.Builder<Scheme, ClientFactory> mapBuilder = ImmutableMap.builder();
+        final ImmutableSet.Builder<Scheme> schemeBuilder = ImmutableSet.builder();
+        schemeBuilder.addAll(httpClientFactory.supportedSchemes());
+
+        for (ClientFactory f : factories) {
+            for (Scheme scheme : f.supportedSchemes()) {
+                // HTTP serialization uses HttpClientFactory directly.
+                if (scheme.serializationFormat() == SerializationFormat.NONE) {
+                    continue;
+                }
+                mapBuilder.put(scheme, f);
+                schemeBuilder.add(scheme);
+            }
+        }
+
+        nonHttpFactories = mapBuilder.build();
+        supportedSchemes = schemeBuilder.build();
+    }
+
+    @Override
+    public Set<Scheme> supportedSchemes() {
+        return supportedSchemes;
+    }
+
+    @Override
+    public EventLoopGroup eventLoopGroup() {
+        return httpClientFactory.eventLoopGroup();
+    }
+
+    @Override
+    public Supplier<EventLoop> eventLoopSupplier() {
+        return httpClientFactory.eventLoopSupplier();
+    }
+
+    @Override
+    public <T> T newClient(URI uri, Class<T> clientType, ClientOptions options) {
+        final Scheme scheme = validateScheme(uri);
+        if (scheme.serializationFormat() == SerializationFormat.NONE) {
+            return httpClientFactory.newClient(uri, clientType, options);
+        }
+
+        final ClientFactory factory = nonHttpFactories.get(scheme);
+        if (factory == null) {
+            throw new IllegalArgumentException("URI with unsupported scheme: " + uri + " (expected: " +
+                                               supportedSchemes + ')');
+        }
+        return factory.newClient(uri, clientType, options);
+    }
+
+    @Override
+    public <T> Optional<ClientBuilderParams> clientBuilderParams(T client) {
+        Optional<ClientBuilderParams> params = httpClientFactory.clientBuilderParams(client);
+        if (params.isPresent()) {
+            return params;
+        }
+        for (ClientFactory factory : nonHttpFactories.values()) {
+            params = factory.clientBuilderParams(client);
+            if (params.isPresent()) {
+                return params;
+            }
