+package com.linecorp.armeria.client;
+
+import static java.util.Objects.requireNonNull;
+
+import java.net.InetSocketAddress;
+import java.time.Duration;
+import java.util.HashMap;
+import java.util.Map;
+import java.util.function.Consumer;
+import java.util.function.Function;
+
+import javax.annotation.Nullable;
+
+import com.linecorp.armeria.client.pool.KeyedChannelPoolHandler;
+import com.linecorp.armeria.client.pool.PoolKey;
+import com.linecorp.armeria.common.Flags;
+import com.linecorp.armeria.internal.TransportType;
+
+import io.netty.channel.ChannelOption;
+import io.netty.channel.EventLoopGroup;
+import io.netty.handler.ssl.SslContextBuilder;
+import io.netty.resolver.AddressResolverGroup;
+import io.netty.resolver.dns.DnsAddressResolverGroup;
+import io.netty.resolver.dns.DnsServerAddressStreamProviders;
+
+/**
+ * Builds a new {@link ClientFactory}.
+ */
+public final class ClientFactoryBuilder {
+
+    @Nullable
+    private EventLoopGroup eventLoopGroup;
+    private boolean useDaemonThreads;
+    private int numWorkers = Flags.defaultNumClientWorkers();
+
+    private long connectTimeoutMillis = Flags.defaultConnectTimeoutMillis();
+    private final Map<ChannelOption<?>, Object> socketOptions = new HashMap<>();
+
+    @Nullable
+    private Consumer<? super SslContextBuilder> sslContextCustomizer;
+
+    private boolean useHttp2Preface = Flags.defaultUseHttp2Preface();
+    private boolean useHttp1Pipelining = Flags.defaultUseHttp1Pipelining();
+
+    private long idleTimeoutMillis = Flags.defaultClientIdleTimeoutMillis();
+    @Nullable
+    private KeyedChannelPoolHandler<? super PoolKey> connectionPoolListener;
+
+    private Function<? super EventLoopGroup,
+            ? extends AddressResolverGroup<? extends InetSocketAddress>> addressResolverGroupFactory =
+            eventLoopGroup -> new DnsAddressResolverGroup(
+                    TransportType.datagramChannelType(eventLoopGroup),
+                    DnsServerAddressStreamProviders.platformDefault());
+
+    /**
+     * Sets the {@link EventLoopGroup} to use.
+     */
+    public ClientFactoryBuilder eventLoopGroup(EventLoopGroup eventLoopGroup) {
+        this.eventLoopGroup = requireNonNull(eventLoopGroup, "eventLoopGroup");
+        return this;
+    }
+
+    @Nullable
+    EventLoopGroup eventLoopGroup() {
+        return eventLoopGroup;
+    }
+
+    /**
+     * Sets whether to use daemon threads for the internally created {@link EventLoopGroup}.
+     */
+    public ClientFactoryBuilder useDaemonThreads(boolean useDaemonThreads) {
+        this.useDaemonThreads = useDaemonThreads;
+        return this;
+    }
+
+    boolean useDaemonThreads() {
+        return useDaemonThreads;
+    }
+
+    /**
+     * Sets the number of worker threads for the internally created {@link EventLoopGroup}.
+     */
+    public ClientFactoryBuilder numWorkers(int numWorkers) {
+        if (numWorkers <= 0) {
+            throw new IllegalArgumentException("numWorkers: " + numWorkers + " (expected: > 0)");
+        }
+        this.numWorkers = numWorkers;
+        return this;
+    }
+
+    int numWorkers() {
+        return numWorkers;
+    }
+
+    /**
+     * Sets the timeout of a socket connection attempt.
+     */
+    public ClientFactoryBuilder connectTimeout(Duration connectTimeout) {
+        requireNonNull(connectTimeout, "connectTimeout");
+        connectTimeoutMillis(connectTimeout.toMillis());
+        return this;
+    }
+
+    /**
+     * Sets the timeout of a socket connection attempt.
+     */
+    public ClientFactoryBuilder connectTimeoutMillis(long connectTimeoutMillis) {
+        if (connectTimeoutMillis <= 0) {
+            throw new IllegalArgumentException(
+                    "connectTimeoutMillis: " + connectTimeoutMillis + " (expected: > 0)");
+        }
+        this.connectTimeoutMillis = connectTimeoutMillis;
+        return this;
+    }
+
+    long connectTimeoutMillis() {
+        return connectTimeoutMillis;
+    }
+
+    /**
+     * Sets the specified Netty socket option.
+     */
+    public <T> ClientFactoryBuilder socketOption(ChannelOption<T> option, T value) {
+        requireNonNull(option, "option");
+        requireNonNull(value, "value");
+        socketOptions.put(option, value);
+        return this;
+    }
+
+    Map<ChannelOption<?>, Object> socketOptions() {
+        return socketOptions;
+    }
+
+    /**
+     * Sets the {@link SslContextBuilder} customizer that is applied when building a TLS configuration.
+     */
+    public ClientFactoryBuilder sslContextCustomizer(Consumer<? super SslContextBuilder> sslContextCustomizer) {
+        this.sslContextCustomizer = requireNonNull(sslContextCustomizer, "sslContextCustomizer");
+        return this;
+    }
+
+    @Nullable
+    Consumer<? super SslContextBuilder> sslContextCustomizer() {
+        return sslContextCustomizer;
+    }
+
+    /**
+     * Sets whether to send an HTTP/2 preface string instead of an HTTP/1 upgrade request when negotiating the
+     * protocol version of a cleartext connection.
+     */
+    public ClientFactoryBuilder useHttp2Preface(boolean useHttp2Preface) {
+        this.useHttp2Preface = useHttp2Preface;
+        return this;
+    }
+
+    boolean useHttp2Preface() {
+        return useHttp2Preface;
+    }
+
+    /**
+     * Sets whether to use HTTP/1 pipelining for HTTP/1 connections.
+     */
+    public ClientFactoryBuilder useHttp1Pipelining(boolean useHttp1Pipelining) {
+        this.useHttp1Pipelining = useHttp1Pipelining;
+        return this;
+    }
+
+    boolean useHttp1Pipelining() {
+        return useHttp1Pipelining;
+    }
+
+    /**
+     * Sets the idle timeout of a connection. The connection is closed if there is no invocation in progress
+     * for this amount of time.
+     */
+    public ClientFactoryBuilder idleTimeout(Duration idleTimeout) {
+        requireNonNull(idleTimeout, "idleTimeout");
+        idleTimeoutMillis(idleTimeout.toMillis());
+        return this;
+    }
+
+    /**
+     * Sets the idle timeout of a connection. The connection is closed if there is no invocation in progress
+     * for this amount of time.
+     */
+    public ClientFactoryBuilder idleTimeoutMillis(long idleTimeoutMillis) {
+        if (idleTimeoutMillis < 0) {
+            throw new IllegalArgumentException(
+                    "idleTimeoutMillis: " + idleTimeoutMillis + " (expected: >= 0)");
+        }
+        this.idleTimeoutMillis = idleTimeoutMillis;
+        return this;
+    }
+
+    long idleTimeoutMillis() {
+        return idleTimeoutMillis;
+    }
+
+    /**
+     * Sets the listener that is notified when connection pool events are triggered.
+     */
+    public ClientFactoryBuilder connectionPoolListener(KeyedChannelPoolHandler<? super PoolKey> listener) {
+        connectionPoolListener = requireNonNull(listener, "listener");
+        return this;
+    }
+
+    @Nullable
+    KeyedChannelPoolHandler<? super PoolKey> connectionPoolListener() {
+        return connectionPoolListener;
+    }
+
+    /**
+     * Sets the factory that creates an {@link AddressResolverGroup} for the created {@link ClientFactory}.
+     */
+    public ClientFactoryBuilder addressResolverGroupFactory(
+            Function<? super EventLoopGroup,
+                    ? extends AddressResolverGroup<? extends InetSocketAddress>> addressResolverGroupFactory) {
+        this.addressResolverGroupFactory =
+                requireNonNull(addressResolverGroupFactory, "addressResolverGroupFactory");
+        return this;
+    }
+
+    Function<? super EventLoopGroup,
+            ? extends AddressResolverGroup<? extends InetSocketAddress>> addressResolverGroupFactory() {
+        return addressResolverGroupFactory;
+    }
+
+    /**
+     * Returns a newly-created {@link ClientFactory}.
+     */
+    public ClientFactory build() {
+        return new DefaultClientFactory(this);
+    }
+}
