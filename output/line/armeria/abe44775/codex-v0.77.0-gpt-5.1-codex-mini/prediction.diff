-            logger.debug("Refusing to close the default {}; must be closed via closeDefault()",
-                         ClientFactory.class.getSimpleName());
-            return;
-        }
-
-        doClose();
-    }
-
-    void doClose() {
-        try {
-            clientFactories.values().forEach(ClientFactory::close);
-        } finally {
-            super.close();
-        }
-    }
-}
