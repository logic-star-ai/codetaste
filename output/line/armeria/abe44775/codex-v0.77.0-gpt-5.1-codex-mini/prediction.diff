+final class DefaultClientFactory extends AbstractClientFactory {
+
+    private static final Logger logger = LoggerFactory.getLogger(DefaultClientFactory.class);
+
+    static {
+        if (DefaultClientFactory.class.getClassLoader() == ClassLoader.getSystemClassLoader()) {
+            Runtime.getRuntime().addShutdownHook(new Thread(ClientFactory::closeDefault));
+        }
+    }
+
+    private final HttpClientFactory httpClientFactory;
+    private final Map<Scheme, ClientFactory> clientFactories;
+    private final Set<ClientFactory> closingFactories;
+
+    DefaultClientFactory(ClientFactoryBuilder builder) {
+        httpClientFactory = builder.buildHttpClientFactory();
+
+        final List<ClientFactory> factories = new ArrayList<>();
+        factories.add(httpClientFactory);
+
+        final ServiceLoader<ClientFactoryProvider> loader =
+                ServiceLoader.load(ClientFactoryProvider.class, DefaultClientFactory.class.getClassLoader());
+        for (ClientFactoryProvider provider : loader) {
+            factories.add(provider.newFactory(httpClientFactory));
+        }
+
+        final ImmutableMap.Builder<Scheme, ClientFactory> mapBuilder = ImmutableMap.builder();
+        for (ClientFactory factory : factories) {
+            for (Scheme scheme : factory.supportedSchemes()) {
+                mapBuilder.put(scheme, factory);
+            }
+        }
+
+        clientFactories = mapBuilder.build();
+        closingFactories = Collections.unmodifiableSet(new LinkedHashSet<>(factories));
+    }
+
+    @Override
+    public ClientFactoryOptions options() {
+        return httpClientFactory.options();
+    }
+
+    @Override
+    public Set<Scheme> supportedSchemes() {
+        return clientFactories.keySet();
+    }
+
+    @Override
+    public EventLoopGroup eventLoopGroup() {
+        return httpClientFactory.eventLoopGroup();
+    }
+
+    @Override
+    public Supplier<EventLoop> eventLoopSupplier() {
+        return httpClientFactory.eventLoopSupplier();
+    }
+
+    @Override
+    public <T> T newClient(URI uri, Class<T> clientType, ClientOptions options) {
+        final Scheme scheme = validateScheme(uri);
+        final ClientFactory factory = clientFactories.get(scheme);
+        if (factory == null) {
+            throw new IllegalStateException("scheme not supported: " + uri);
+        }
+        return factory.newClient(uri, clientType, options);
+    }
+
+    @Override
+    public <T> Optional<ClientBuilderParams> clientBuilderParams(T client) {
+        for (ClientFactory factory : clientFactories.values()) {
+            Optional<ClientBuilderParams> params = factory.clientBuilderParams(client);
+            if (params.isPresent()) {
+                return params;
+            }
+        }
+        return Optional.empty();
+    }
+
+    @Override
+    public void close() {
+        if (this == ClientFactory.DEFAULT) {
+            logger.debug("Refusing to close the default {}; must be closed via closeDefault()",
+                         ClientFactory.class.getSimpleName());
+            return;
+        }
+        doClose();
+    }
+
+    void doClose() {
+        for (ClientFactory factory : closingFactories) {
+            if (factory == httpClientFactory) {
+                continue;
+            }
+            closeQuietly(factory);
+        }
+        closeQuietly(httpClientFactory);
+    }
+
+    private static void closeQuietly(ClientFactory factory) {
+        try {
+            factory.close();
+        } catch (Throwable t) {
+            logger.warn("Failed to close {}", factory, t);
+        }
+    }
+}
