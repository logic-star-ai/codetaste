+import java.util.Objects;
+
+/**
+ * A callback that decorates a {@link KeyedChannelPoolHandler}.
+ */
+@FunctionalInterface
+public interface ConnectionPoolListener {
+
+    ConnectionPoolListener NONE = delegate -> delegate;
+
+    /**
+     * Decorates the specified {@code delegate} handler.
+     */
+    KeyedChannelPoolHandler<PoolKey> wrap(KeyedChannelPoolHandler<PoolKey> delegate);
+
+    /**
+     * Returns a composed {@link ConnectionPoolListener} which returns {@code this} listener applied before
+     * {@code after}.
+     */
+    default ConnectionPoolListener andThen(ConnectionPoolListener after) {
+        Objects.requireNonNull(after, "after");
+        return delegate -> after.wrap(wrap(delegate));
+    }
+}
