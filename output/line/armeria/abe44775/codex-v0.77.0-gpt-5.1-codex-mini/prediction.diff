+package com.linecorp.armeria.client;
+
+import java.util.Objects;
+import java.util.function.Consumer;
+
+import io.netty.handler.ssl.SslContextBuilder;
+
+/**
+ * Internal configuration values that are shared by the client factories.
+ */
+final class ClientFactoryOptions {
+
+    private final long connectTimeoutMillis;
+    private final long idleTimeoutMillis;
+    private final boolean useHttp2Preface;
+    private final boolean useHttp1Pipelining;
+    private final Consumer<SslContextBuilder> sslContextCustomizer;
+    private final ConnectionPoolListener connectionPoolListener;
+
+    ClientFactoryOptions(long connectTimeoutMillis,
+                         long idleTimeoutMillis,
+                         boolean useHttp2Preface,
+                         boolean useHttp1Pipelining,
+                         Consumer<SslContextBuilder> sslContextCustomizer,
+                         ConnectionPoolListener connectionPoolListener) {
+        this.connectTimeoutMillis = connectTimeoutMillis;
+        this.idleTimeoutMillis = idleTimeoutMillis;
+        this.useHttp2Preface = useHttp2Preface;
+        this.useHttp1Pipelining = useHttp1Pipelining;
+        this.sslContextCustomizer = Objects.requireNonNull(sslContextCustomizer, "sslContextCustomizer");
+        this.connectionPoolListener = Objects.requireNonNull(connectionPoolListener, "connectionPoolListener");
+    }
+
+    long connectTimeoutMillis() {
+        return connectTimeoutMillis;
+    }
+
+    long idleTimeoutMillis() {
+        return idleTimeoutMillis;
+    }
+
+    boolean useHttp2Preface() {
+        return useHttp2Preface;
+    }
+
+    boolean useHttp1Pipelining() {
+        return useHttp1Pipelining;
+    }
+
+    Consumer<SslContextBuilder> sslContextCustomizer() {
+        return sslContextCustomizer;
+    }
+
+    ConnectionPoolListener connectionPoolListener() {
+        return connectionPoolListener;
+    }
+}
