+import static org.assertj.core.api.Assertions.assertThat;
+
+import java.time.Duration;
+
+import org.junit.Test;
+
+import com.linecorp.armeria.common.Flags;
+
+public class ClientFactoryBuilderTest {
+
+    @Test
+    public void defaultTimeouts() {
+        ClientFactoryOptions options = new ClientFactoryBuilder().options();
+        assertThat(options.connectTimeoutMillis()).isEqualTo(Flags.defaultConnectTimeoutMillis());
+        assertThat(options.idleTimeoutMillis()).isEqualTo(Flags.defaultClientIdleTimeoutMillis());
+    }
+
+    @Test
+    public void overrideTimeouts() {
+        long connectTimeoutMillis = Duration.ofSeconds(1).toMillis();
+        long idleTimeoutMillis = Duration.ofSeconds(5).toMillis();
+        ClientFactoryOptions options = new ClientFactoryBuilder()
+                .connectTimeout(Duration.ofMillis(connectTimeoutMillis))
+                .idleTimeout(Duration.ofMillis(idleTimeoutMillis))
+                .options();
+        assertThat(options.connectTimeoutMillis()).isEqualTo(connectTimeoutMillis);
+        assertThat(options.idleTimeoutMillis()).isEqualTo(idleTimeoutMillis);
+    }
+
+    @Test(expected = IllegalArgumentException.class)
+    public void invalidConnectTimeout() {
+        new ClientFactoryBuilder().connectTimeout(Duration.ZERO);
+    }
+
+    @Test(expected = IllegalArgumentException.class)
+    public void invalidIdleTimeout() {
+        new ClientFactoryBuilder().idleTimeout(Duration.ofMillis(-1));
+    }
+}
