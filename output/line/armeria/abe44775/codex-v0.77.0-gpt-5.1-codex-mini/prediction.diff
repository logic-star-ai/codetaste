+package com.linecorp.armeria.client;
+
+import static java.util.Objects.requireNonNull;
+
+import java.net.InetSocketAddress;
+import java.time.Duration;
+import java.util.LinkedHashMap;
+import java.util.Map;
+import java.util.function.Consumer;
+
+import io.netty.channel.ChannelOption;
+import io.netty.channel.EventLoopGroup;
+import io.netty.handler.ssl.SslContextBuilder;
+import io.netty.resolver.dns.DnsAddressResolverGroup;
+import io.netty.resolver.dns.DnsServerAddressStreamProviders;
+
+import com.linecorp.armeria.client.pool.ConnectionPoolListener;
+import com.linecorp.armeria.common.Flags;
+import com.linecorp.armeria.internal.TransportType;
+
+/**
+ * Builds {@link ClientFactory} instances with convenient configuration methods.
+ */
+public final class ClientFactoryBuilder {
+
+    private static final long DEFAULT_CONNECT_TIMEOUT_MILLIS = Flags.defaultConnectTimeoutMillis();
+    private static final long DEFAULT_IDLE_TIMEOUT_MILLIS = Flags.defaultClientIdleTimeoutMillis();
+    private static final int DEFAULT_NUM_WORKERS = Flags.defaultNumClientWorkers();
+
+    private EventLoopGroup eventLoopGroup;
+    private boolean useDaemonThreads;
+    private int numWorkers = DEFAULT_NUM_WORKERS;
+    private long connectTimeoutMillis = DEFAULT_CONNECT_TIMEOUT_MILLIS;
+    private long idleTimeoutMillis = DEFAULT_IDLE_TIMEOUT_MILLIS;
+    private Consumer<SslContextBuilder> sslContextCustomizer = builder -> {};
+    private boolean useHttp2Preface = Flags.defaultUseHttp2Preface();
+    private boolean useHttp1Pipelining = Flags.defaultUseHttp1Pipelining();
+    private ConnectionPoolListener connectionPoolListener = ConnectionPoolListener.NONE;
+    private AddressResolverGroupFactory addressResolverGroupFactory = ClientFactoryBuilder::defaultAddressResolverGroup;
+    private final Map<ChannelOption<?>, Object> socketOptions = new LinkedHashMap<>();
+
+    /**
+     * Sets the {@link EventLoopGroup} to use for connections. If not specified, Armeria creates one.
+     */
+    public ClientFactoryBuilder eventLoopGroup(EventLoopGroup eventLoopGroup) {
+        this.eventLoopGroup = requireNonNull(eventLoopGroup, "eventLoopGroup");
+        return this;
+    }
+
+    /**
+     * Sets whether to use daemon threads when Armeria creates the event loops.
+     */
+    public ClientFactoryBuilder useDaemonThreads(boolean useDaemonThreads) {
+        this.useDaemonThreads = useDaemonThreads;
+        return this;
+    }
+
+    /**
+     * Sets the number of network worker threads to use when Armeria creates the event loops.
+     */
+    public ClientFactoryBuilder numWorkers(int numWorkers) {
+        this.numWorkers = validateNumWorkers(numWorkers);
+        return this;
+    }
+
+    /**
+     * Sets the connect timeout.
+     */
+    public ClientFactoryBuilder connectTimeout(Duration connectTimeout) {
+        requireNonNull(connectTimeout, "connectTimeout");
+        this.connectTimeoutMillis = validateConnectTimeout(connectTimeout);
+        return this;
+    }
+
+    /**
+     * Sets a socket option to be applied to every {@link io.netty.channel.Channel}.
+     */
+    public <T> ClientFactoryBuilder socketOption(ChannelOption<T> option, T value) {
+        socketOptions.put(requireNonNull(option, "option"), requireNonNull(value, "value"));
+        return this;
+    }
+
+    /**
+     * Sets a customizer to configure the {@link SslContextBuilder}.
+     */
+    public ClientFactoryBuilder sslContextCustomizer(Consumer<SslContextBuilder> sslContextCustomizer) {
+        this.sslContextCustomizer = requireNonNull(sslContextCustomizer, "sslContextCustomizer");
+        return this;
+    }
+
+    /**
+     * Sets whether to send the HTTP/2 client preface.
+     */
+    public ClientFactoryBuilder useHttp2Preface(boolean useHttp2Preface) {
+        this.useHttp2Preface = useHttp2Preface;
+        return this;
+    }
+
+    /**
+     * Sets whether to use HTTP/1 pipelining.
+     */
+    public ClientFactoryBuilder useHttp1Pipelining(boolean useHttp1Pipelining) {
+        this.useHttp1Pipelining = useHttp1Pipelining;
+        return this;
+    }
+
+    /**
+     * Sets the idle timeout for pooled connections.
+     */
+    public ClientFactoryBuilder idleTimeout(Duration idleTimeout) {
+        requireNonNull(idleTimeout, "idleTimeout");
+        this.idleTimeoutMillis = validateIdleTimeout(idleTimeout);
+        return this;
+    }
+
+    /**
+     * Sets a {@link ConnectionPoolListener} that decorates the pool handler.
+     */
+    public ClientFactoryBuilder connectionPoolListener(ConnectionPoolListener connectionPoolListener) {
+        this.connectionPoolListener = requireNonNull(connectionPoolListener, "connectionPoolListener");
+        return this;
+    }
+
+    /**
+     * Sets the {@link AddressResolverGroupFactory} to use when creating {@link io.netty.channel.Channel}s.
+     */
+    public ClientFactoryBuilder addressResolverGroupFactory(
+            AddressResolverGroupFactory addressResolverGroupFactory) {
+        this.addressResolverGroupFactory = requireNonNull(addressResolverGroupFactory, "addressResolverGroupFactory");
+        return this;
+    }
+
+    /**
+     * Builds the default {@link ClientFactory} which aggregates HTTP, GRPC, and Thrift client factories.
+     */
+    public ClientFactory build() {
+        return new DefaultClientFactory(this);
+    }
+
+    HttpClientFactory buildHttpClientFactory() {
+        return new HttpClientFactory(this);
+    }
+
+    EventLoopGroup eventLoopGroup() {
+        return eventLoopGroup;
+    }
+
+    boolean useDaemonThreads() {
+        return useDaemonThreads;
+    }
+
+    int numWorkers() {
+        return numWorkers;
+    }
+
+    Map<ChannelOption<?>, Object> socketOptions() {
+        return socketOptions;
+    }
+
+    AddressResolverGroupFactory addressResolverGroupFactory() {
+        return addressResolverGroupFactory;
+    }
+
+    ClientFactoryOptions options() {
+        return new ClientFactoryOptions(connectTimeoutMillis, idleTimeoutMillis,
+                                        useHttp2Preface, useHttp1Pipelining,
+                                        sslContextCustomizer, connectionPoolListener);
+    }
+
+    private static long validateConnectTimeout(Duration connectTimeout) {
+        if (connectTimeout.isZero() || connectTimeout.isNegative()) {
+            throw new IllegalArgumentException("connectTimeout: " + connectTimeout + " (expected: > 0)");
+        }
+        return connectTimeout.toMillis();
+    }
+
+    private static long validateIdleTimeout(Duration idleTimeout) {
+        if (idleTimeout.isNegative()) {
+            throw new IllegalArgumentException("idleTimeout: " + idleTimeout + " (expected: >= 0)");
+        }
+        return idleTimeout.toMillis();
+    }
+
+    private static int validateNumWorkers(int numWorkers) {
+        if (numWorkers <= 0) {
+            throw new IllegalArgumentException("numWorkers: " + numWorkers + " (expected: > 0)");
+        }
+        return numWorkers;
+    }
+
+    private static AddressResolverGroup<? extends InetSocketAddress> defaultAddressResolverGroup(
+            EventLoopGroup eventLoopGroup) {
+        return new DnsAddressResolverGroup(
+                TransportType.datagramChannelType(eventLoopGroup),
+                DnsServerAddressStreamProviders.platformDefault());
+    }
+}
