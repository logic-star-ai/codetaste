+package com.linecorp.armeria.client;
+
+import static java.util.Objects.requireNonNull;
+
+import java.net.InetSocketAddress;
+import java.net.URI;
+import java.time.Duration;
+import java.util.ArrayList;
+import java.util.Iterator;
+import java.util.List;
+import java.util.Map;
+import java.util.Optional;
+import java.util.ServiceLoader;
+import java.util.Set;
+import java.util.function.Consumer;
+import java.util.function.Function;
+import java.util.function.Supplier;
+import java.util.stream.Collectors;
+
+import javax.annotation.Nullable;
+
+import org.slf4j.Logger;
+import org.slf4j.LoggerFactory;
+
+import com.google.common.collect.ImmutableMap;
+import com.google.common.collect.Streams;
+import com.linecorp.armeria.client.pool.KeyedChannelPoolHandler;
+import com.linecorp.armeria.client.pool.PoolKey;
+import com.linecorp.armeria.common.RequestContext;
+import com.linecorp.armeria.common.Scheme;
+
+import io.netty.channel.EventLoop;
+import io.netty.channel.EventLoopGroup;
+import io.netty.handler.ssl.SslContextBuilder;
+import io.netty.resolver.AddressResolverGroup;
+
+/**
+ * Default {@link ClientFactory} implementation which combines all discovered {@link ClientFactory}
+ * implementations.
+ *
+ * <h3>How are the {@link ClientFactory}s discovered?</h3>
+ *
+ * <p>{@link DefaultClientFactory} looks up the {@link ClientFactoryProvider}s available in the current JVM
+ * using Java SPI (Service Provider Interface). The {@link ClientFactoryProvider} implementations will create
+ * the {@link ClientFactory} implementations.
+ */
+final class DefaultClientFactory extends AbstractClientFactory {
+
+    private static final Logger logger = LoggerFactory.getLogger(DefaultClientFactory.class);
+
+    static {
+        if (DefaultClientFactory.class.getClassLoader() == ClassLoader.getSystemClassLoader()) {
+            Runtime.getRuntime().addShutdownHook(new Thread(ClientFactory::closeDefault));
+        }
+    }
+
+    private final EventLoopGroup eventLoopGroup;
+    private final boolean closeEventLoopGroup;
+    private final Duration connectTimeout;
+    private final Duration idleTimeout;
+    @Nullable
+    private final Consumer<SslContextBuilder> sslContextCustomizer;
+    @Nullable
+    private final AddressResolverGroup<InetSocketAddress> addressResolverGroup;
+    @Nullable
+    private final Function<KeyedChannelPoolHandler<PoolKey>, KeyedChannelPoolHandler<PoolKey>>
+            connectionPoolListener;
+    private final boolean useHttp2Preface;
+    private final boolean useHttp1Pipelining;
+
+    private final Map<Scheme, ClientFactory> clientFactories;
+
+    private final Supplier<EventLoop> eventLoopSupplier =
+            () -> RequestContext.mapCurrent(RequestContext::eventLoop, () -> eventLoopGroup().next());
+
+    /**
+     * Creates a new instance.
+     */
+    DefaultClientFactory(
+            @Nullable EventLoopGroup eventLoopGroup,
+            boolean useDaemonThreads,
+            int numWorkers,
+            Duration connectTimeout,
+            Duration idleTimeout,
+            @Nullable Consumer<SslContextBuilder> sslContextCustomizer,
+            @Nullable AddressResolverGroup<InetSocketAddress> addressResolverGroup,
+            @Nullable Function<KeyedChannelPoolHandler<PoolKey>, KeyedChannelPoolHandler<PoolKey>>
+                    connectionPoolListener,
+            boolean useHttp2Preface,
+            boolean useHttp1Pipelining) {
+
+        requireNonNull(connectTimeout, "connectTimeout");
+        requireNonNull(idleTimeout, "idleTimeout");
+
+        if (eventLoopGroup != null) {
+            this.eventLoopGroup = eventLoopGroup;
+            closeEventLoopGroup = false;
+        } else {
+            this.eventLoopGroup = HttpClientFactory.createEventLoopGroup(numWorkers, useDaemonThreads);
+            closeEventLoopGroup = true;
+        }
+
+        this.connectTimeout = connectTimeout;
+        this.idleTimeout = idleTimeout;
+        this.sslContextCustomizer = sslContextCustomizer;
+        this.addressResolverGroup = addressResolverGroup;
+        this.connectionPoolListener = connectionPoolListener;
+        this.useHttp2Preface = useHttp2Preface;
+        this.useHttp1Pipelining = useHttp1Pipelining;
+
+        // Create the HTTP client factory with our configuration
+        final HttpClientFactory httpClientFactory = new HttpClientFactory(
+                this.eventLoopGroup,
+                false, // Don't close the event loop group in the HTTP factory
+                connectTimeout,
+                idleTimeout,
+                sslContextCustomizer,
+                addressResolverGroup,
+                connectionPoolListener,
+                useHttp2Preface,
+                useHttp1Pipelining);
+
+        // Load all client factory providers
+        final List<ClientFactoryProvider> providers =
+                Streams.stream(ServiceLoader.load(ClientFactoryProvider.class,
+                                                  DefaultClientFactory.class.getClassLoader()))
+                       .collect(Collectors.toCollection(ArrayList::new));
+
+        if (providers.isEmpty()) {
+            throw new IllegalStateException("could not find any providers");
+        }
+
+        final List<ClientFactory> availableClientFactories = new ArrayList<>();
+        availableClientFactories.add(httpClientFactory);
+
+        // Instantiate providers based on dependencies
+        do {
+            boolean added = false;
+            for (Iterator<ClientFactoryProvider> i = providers.iterator(); i.hasNext();) {
+                final ClientFactoryProvider p = i.next();
