+                // Find the ClientFactory instances that meet the type requirements
+                final Map<Class<?>, ClientFactory> requiredClientFactories =
+                        findRequiredClientFactories(p, availableClientFactories);
+
+                if (requiredClientFactories == null) {
+                    // Dependencies are not met yet. Try instantiating others first.
+                    continue;
+                }
+
+                // Dependencies are met. Remove the provider and instantiate
+                i.remove();
+                availableClientFactories.add(p.newFactory(httpClientFactory));
+                added = true;
+            }
