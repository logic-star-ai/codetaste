+package com.linecorp.armeria.client;
+
+import static com.google.common.base.Preconditions.checkArgument;
+import static java.util.Objects.requireNonNull;
+
+import java.net.InetSocketAddress;
+import java.time.Duration;
+import java.util.Map;
+import java.util.function.Consumer;
+import java.util.function.Function;
+
+import javax.annotation.Nullable;
+
+import com.linecorp.armeria.client.pool.KeyedChannelPoolHandler;
+import com.linecorp.armeria.client.pool.PoolKey;
+import com.linecorp.armeria.common.Flags;
+
+import io.netty.channel.ChannelOption;
+import io.netty.channel.EventLoopGroup;
+import io.netty.handler.ssl.SslContextBuilder;
+import io.netty.resolver.AddressResolverGroup;
+
+/**
+ * Builds a new {@link ClientFactory}.
+ *
+ * <h2>Example</h2>
+ * <pre>{@code
+ * ClientFactory factory =
+ *     new ClientFactoryBuilder()
+ *         .connectTimeout(Duration.ofSeconds(5))
+ *         .idleTimeout(Duration.ofSeconds(30))
+ *         .useHttp2Preface(true)
+ *         .build();
+ * }</pre>
+ */
+public final class ClientFactoryBuilder {
+
+    @Nullable
+    private EventLoopGroup eventLoopGroup;
+    private boolean useDaemonThreads = true;
+    private int numWorkers = Flags.defaultNumClientWorkers();
+    private Duration connectTimeout = Duration.ofMillis(Flags.defaultConnectTimeoutMillis());
+    private Duration idleTimeout = Duration.ofMillis(Flags.defaultClientIdleTimeoutMillis());
+    @Nullable
+    private Consumer<SslContextBuilder> sslContextCustomizer;
+    @Nullable
+    private AddressResolverGroup<InetSocketAddress> addressResolverGroup;
+    @Nullable
+    private Function<KeyedChannelPoolHandler<PoolKey>, KeyedChannelPoolHandler<PoolKey>>
+            connectionPoolListener;
+    private boolean useHttp2Preface = Flags.defaultUseHttp2Preface();
+    private boolean useHttp1Pipelining = Flags.defaultUseHttp1Pipelining();
+
+    /**
+     * Sets the {@link EventLoopGroup} to use for client connections. If not set, a new
+     * {@link EventLoopGroup} will be created.
+     *
+     * @param eventLoopGroup the {@link EventLoopGroup} to use
+     */
+    public ClientFactoryBuilder eventLoopGroup(EventLoopGroup eventLoopGroup) {
+        this.eventLoopGroup = requireNonNull(eventLoopGroup, "eventLoopGroup");
+        return this;
+    }
+
+    /**
+     * Sets whether to create I/O event loop threads as daemon threads. If an {@link EventLoopGroup} is
+     * specified via {@link #eventLoopGroup(EventLoopGroup)}, this setting is ignored.
+     *
+     * @param useDaemonThreads {@code true} to use daemon threads, {@code false} otherwise
+     */
+    public ClientFactoryBuilder useDaemonThreads(boolean useDaemonThreads) {
+        this.useDaemonThreads = useDaemonThreads;
+        return this;
+    }
+
+    /**
+     * Sets the number of worker threads to use for client-side event loops. If an {@link EventLoopGroup} is
+     * specified via {@link #eventLoopGroup(EventLoopGroup)}, this setting is ignored.
+     *
+     * @param numWorkers the number of worker threads
+     */
+    public ClientFactoryBuilder numWorkers(int numWorkers) {
+        checkArgument(numWorkers > 0, "numWorkers: %s (expected: > 0)", numWorkers);
+        this.numWorkers = numWorkers;
+        return this;
+    }
+
+    /**
+     * Sets the timeout for connecting to a server. If a connection attempt does not finish within this
+     * timeout, the connection attempt is failed.
+     *
+     * @param connectTimeout the connect timeout
+     */
+    public ClientFactoryBuilder connectTimeout(Duration connectTimeout) {
+        requireNonNull(connectTimeout, "connectTimeout");
+        checkArgument(!connectTimeout.isNegative() && !connectTimeout.isZero(),
+                      "connectTimeout: %s (expected: > 0)", connectTimeout);
+        this.connectTimeout = connectTimeout;
+        return this;
+    }
+
+    /**
+     * Sets the timeout for connecting to a server. If a connection attempt does not finish within this
+     * timeout, the connection attempt is failed.
+     *
+     * @param connectTimeoutMillis the connect timeout in milliseconds
+     */
+    public ClientFactoryBuilder connectTimeoutMillis(long connectTimeoutMillis) {
+        checkArgument(connectTimeoutMillis > 0,
+                      "connectTimeoutMillis: %s (expected: > 0)", connectTimeoutMillis);
+        connectTimeout = Duration.ofMillis(connectTimeoutMillis);
+        return this;
+    }
+
+    /**
+     * Sets the idle timeout of a connection. The connection will be closed if it stays idle for this
+     * amount of time. A value of {@link Duration#ZERO} disables the timeout.
+     *
+     * @param idleTimeout the idle timeout
+     */
+    public ClientFactoryBuilder idleTimeout(Duration idleTimeout) {
+        requireNonNull(idleTimeout, "idleTimeout");
+        checkArgument(!idleTimeout.isNegative(), "idleTimeout: %s (expected: >= 0)", idleTimeout);
+        this.idleTimeout = idleTimeout;
+        return this;
+    }
+
+    /**
+     * Sets the idle timeout of a connection in milliseconds. The connection will be closed if it stays idle
+     * for this amount of time. A value of {@code 0} disables the timeout.
+     *
+     * @param idleTimeoutMillis the idle timeout in milliseconds
+     */
+    public ClientFactoryBuilder idleTimeoutMillis(long idleTimeoutMillis) {
+        checkArgument(idleTimeoutMillis >= 0,
+                      "idleTimeoutMillis: %s (expected: >= 0)", idleTimeoutMillis);
+        idleTimeout = Duration.ofMillis(idleTimeoutMillis);
+        return this;
+    }
+
+    /**
+     * Sets a {@link Consumer} that customizes the Netty {@link SslContextBuilder} used for configuring
+     * TLS connections.
+     *
+     * @param sslContextCustomizer the customizer function
+     */
+    public ClientFactoryBuilder sslContextCustomizer(Consumer<SslContextBuilder> sslContextCustomizer) {
+        this.sslContextCustomizer = requireNonNull(sslContextCustomizer, "sslContextCustomizer");
+        return this;
+    }
+
+    /**
+     * Sets the {@link AddressResolverGroup} to use for resolving remote addresses.
+     *
+     * @param addressResolverGroup the address resolver group
+     */
+    public ClientFactoryBuilder addressResolverGroupFactory(
+            AddressResolverGroup<InetSocketAddress> addressResolverGroup) {
+        this.addressResolverGroup = requireNonNull(addressResolverGroup, "addressResolverGroup");
+        return this;
+    }
+
+    /**
+     * Sets a {@link Function} that decorates the {@link KeyedChannelPoolHandler} to monitor connection
+     * pool events.
+     *
+     * @param connectionPoolListener the decorator function
+     */
+    public ClientFactoryBuilder connectionPoolListener(
+            Function<KeyedChannelPoolHandler<PoolKey>, KeyedChannelPoolHandler<PoolKey>>
+                    connectionPoolListener) {
+        this.connectionPoolListener = requireNonNull(connectionPoolListener, "connectionPoolListener");
+        return this;
+    }
+
+    /**
+     * Sets whether to use HTTP/2 preface instead of HTTP/1 upgrade. If enabled, the client will send the
+     * HTTP/2 connection preface immediately upon establishing a connection, rather than attempting to
+     * upgrade from HTTP/1.
+     *
+     * @param useHttp2Preface {@code true} to use HTTP/2 preface, {@code false} to use HTTP/1 upgrade
+     */
+    public ClientFactoryBuilder useHttp2Preface(boolean useHttp2Preface) {
+        this.useHttp2Preface = useHttp2Preface;
+        return this;
+    }
+
+    /**
+     * Sets whether to use HTTP/1 pipelining. When enabled, multiple requests can be sent on a connection
+     * without waiting for corresponding responses to arrive.
+     *
+     * @param useHttp1Pipelining {@code true} to enable HTTP/1 pipelining, {@code false} to disable
+     */
+    public ClientFactoryBuilder useHttp1Pipelining(boolean useHttp1Pipelining) {
+        this.useHttp1Pipelining = useHttp1Pipelining;
+        return this;
+    }
+
+    /**
+     * Sets the value of a Netty {@link ChannelOption}.
+     *
+     * @param option the channel option to set
+     * @param value the value of the option
+     * @param <T> the type of the option value
+     */
+    public <T> ClientFactoryBuilder socketOption(ChannelOption<T> option, T value) {
+        requireNonNull(option, "option");
+        requireNonNull(value, "value");
+        // For now, we don't support custom socket options as it would require changes
+        // to how we build the Bootstrap. This is a placeholder for future enhancement.
+        throw new UnsupportedOperationException(
+                "Custom socket options are not yet supported. " +
+                "Use the standard configuration methods instead.");
+    }
+
+    /**
+     * Returns a newly-created {@link ClientFactory} based on the properties set so far.
+     */
+    public ClientFactory build() {
+        return new DefaultClientFactory(
+                eventLoopGroup, useDaemonThreads, numWorkers,
+                connectTimeout, idleTimeout,
+                sslContextCustomizer, addressResolverGroup,
+                connectionPoolListener,
+                useHttp2Preface, useHttp1Pipelining);
+    }
+}
