@@ -0,0 +1,71 @@
+// Demonstration of how the refactored API works in usage sites
+
+// Before:
+// openDrawer('CREATE_TABLE', {
+//   title: 'Create Table',
+//   props: {
+//     titleProps: { className: '!pb-0' },
+//     PaperProps: { className: 'max-w-lg' },
+//   },
+//   payload: { onSubmit, onCancel, schema }
+// })
+
+// After:
+import CreateTableForm, { CreateTableFormProps } from '@/components/dataBrowser/CreateTableForm';
+import { ReactElement } from 'react';
+
+// In component code:
+function handleOpenCreator() {
+  const component = (
+    <CreateTableForm 
+      schema={someSchema}
+      onSubmit={onSubmitCallback}
+      onCancel={onCancelCallback}
+    />
+  );
+  
+  openDrawer({
+    title: 'Create Table',
+    component,
+    props: {
+      titleProps: { className: '!pb-0' },
+      PaperProps: { className: 'max-w-lg' },
+    },
+  });
+}
+
+// In another component:
+function handleOpenEditor(originalRole: Role) {
+  const component = (
+    <EditRoleForm 
+      originalRole={originalRole}
+      onSubmit={onSubmitCallback}
+      onCancel={onCancelCallback}
+    />
+  );
+  
+  openDialog({
+    title: 'Edit Allowed Role',
+    component,
+    props: {
+      titleProps: { className: '!pb-0' },
+      PaperProps: { className: 'max-w-sm' },
+    },
+  });
+}
+
+// In a component with a form that needs both drawer and dialog capability:
+function MyForm({ location }: { location: 'drawer' | 'dialog' }) {
+  // The form receives the location prop automatically
+  return <div>Form for {location}</div>;
+}
+
+// And usage would be:
+function handleOpenForm() {
+  const component = <MyForm location="drawer" />;
+  
+  openDrawer({
+    title: 'My Form',
+    component,
+  });
+}
