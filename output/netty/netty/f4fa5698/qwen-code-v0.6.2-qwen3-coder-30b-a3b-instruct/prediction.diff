+            boolean success = false;
+            try {
+                children[i] = newChild(threadFactory, args);
+                success = true;
+            } catch (Exception e) {
+                throw new EventLoopException("failed to create a child event loop", e);
+            } finally {
+                if (!success) {
+                    for (int j = 0; j < i; j ++) {
+                        children[j].shutdown();
