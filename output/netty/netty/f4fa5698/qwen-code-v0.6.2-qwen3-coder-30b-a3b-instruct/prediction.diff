+ * under the License.
+ */
+package io.netty.channel;
+
+import java.util.concurrent.ScheduledExecutorService;
+import java.util.concurrent.TimeUnit;
+
+public interface EventExecutorGroup extends ScheduledExecutorService {
+    /**
+     * Return the next {@link EventExecutor} to use for load balancing.
+     * For a single executor, this will return the executor itself.
+     */
+    EventExecutor next();
+
+    /**
+     * Shut down this executor group. After shutdown, no tasks can be submitted.
+     */
+    void shutdown();
+
+    /**
+     * Returns {@code true} if this group has been shut down.
+     */
+    boolean isShutdown();
+
+    /**
+     * Returns {@code true} if all executors in this group have terminated.
+     */
+    boolean isTerminated();
+
+    /**
+     * Blocks until all executors in this group have terminated or the specified timeout has elapsed.
+     *
+     * @param timeout the maximum time to wait
+     * @param unit the time unit of the timeout argument
+     * @return {@code true} if all executors terminated and {@code false} if the timeout elapsed before all executors terminated
+     * @throws InterruptedException if the current thread was interrupted while waiting
+     */
+    boolean awaitTermination(long timeout, TimeUnit unit) throws InterruptedException;
+}
