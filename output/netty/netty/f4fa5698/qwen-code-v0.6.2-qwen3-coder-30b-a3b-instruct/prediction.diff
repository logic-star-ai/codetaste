+    protected abstract EventExecutor newChild(ThreadFactory threadFactory, Object... args) throws Exception;
+
+    @Override
+    public EventExecutor next() {
+        return children[Math.abs(childIndex.getAndIncrement() % children.length)];
+    }
+
+    @Override
