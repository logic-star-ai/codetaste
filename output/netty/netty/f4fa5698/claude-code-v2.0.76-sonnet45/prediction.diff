+package io.netty.channel;
+
+import java.util.concurrent.TimeUnit;
+
+/**
+ * The {@link EventExecutorGroup} is responsible for providing {@link EventExecutor}s to use
+ * via its {@link #next()} method. Besides this it also handles their life-cycle and allows
+ * to shut them down in a global fashion.
+ */
