+ */
+package io.netty.handler.codec.dns;
+
+import io.netty.buffer.ByteBuf;
+import io.netty.channel.ChannelHandler;
+import io.netty.channel.ChannelHandlerContext;
+import io.netty.channel.socket.DatagramPacket;
+import io.netty.handler.codec.MessageToMessageDecoder;
+import io.netty.util.ReferenceCountUtil;
+
+import java.util.List;
+
+/**
+ * Decodes {@link DatagramPacket} into {@link DatagramDnsResponse}.
+ */
+@ChannelHandler.Sharable
+public class DatagramDnsResponseDecoder extends MessageToMessageDecoder<DatagramPacket> {
+
+    private final DnsRecordDecoder recordDecoder;
+
+    public DatagramDnsResponseDecoder() {
+        this(new DefaultDnsRecordDecoder());
+    }
+
+    public DatagramDnsResponseDecoder(DnsRecordDecoder recordDecoder) {
+        if (recordDecoder == null) {
+            throw new NullPointerException("recordDecoder");
+        }
+        this.recordDecoder = recordDecoder;
+    }
+
+    @Override
+    protected void decode(ChannelHandlerContext ctx, DatagramPacket packet, List<Object> out) throws Exception {
+        ByteBuf buf = packet.content();
+
+        int id = buf.readUnsignedShort();
+        DefaultDnsResponse response = new DefaultDnsResponse(id);
+
+        boolean success = false;
+        try {
+            int flags = buf.readUnsignedShort();
+            response.setOpCode(DnsOpCode.valueOf(flags >> 11 & 0xf));
+            response.setRecursionDesired((flags >> 8 & 1) == 1);
+            response.setAuthoritativeAnswer((flags >> 10 & 1) == 1);
+            response.setTruncated((flags >> 9 & 1) == 1);
+            response.setRecursionAvailable((flags >> 7 & 1) == 1);
+            response.setZ(flags >> 4 & 0x7);
+            response.setCode(DnsResponseCode.valueOf(flags & 0xf));
+
+            int questions = buf.readUnsignedShort();
+            int answers = buf.readUnsignedShort();
+            int authorities = buf.readUnsignedShort();
+            int additionals = buf.readUnsignedShort();
+
+            for (int i = 0; i < questions; i++) {
+                response.addRecord(DnsSection.QUESTION, decodeQuestion(buf));
+            }
+
+            if (response.code() == DnsResponseCode.NOERROR) {
+                for (int i = 0; i < answers; i++) {
+                    response.addRecord(DnsSection.ANSWER, decodeRecord(buf));
+                }
+                for (int i = 0; i < authorities; i++) {
+                    response.addRecord(DnsSection.AUTHORITY, decodeRecord(buf));
+                }
+                for (int i = 0; i < additionals; i++) {
+                    response.addRecord(DnsSection.ADDITIONAL, decodeRecord(buf));
+                }
+            }
+
+            out.add(new DatagramDnsResponse(response, packet.recipient(), packet.sender()));
+            success = true;
+        } finally {
+            if (!success) {
+                ReferenceCountUtil.safeRelease(response);
+            }
+        }
+    }
+
+    private static DnsQuestion decodeQuestion(ByteBuf buf) {
+        String name = DnsCodecUtil.decodeName(buf);
+        DnsRecordType type = DnsRecordType.valueOf(buf.readUnsignedShort());
+        int dnsClass = buf.readUnsignedShort();
+        return new DefaultDnsQuestion(name, type, dnsClass);
+    }
+
+    private DnsRecord decodeRecord(ByteBuf buf) throws Exception {
+        String name = DnsCodecUtil.decodeName(buf);
+        DnsRecordType type = DnsRecordType.valueOf(buf.readUnsignedShort());
+        int dnsClass = buf.readUnsignedShort();
+        long ttl = buf.readUnsignedInt();
+        int rdLength = buf.readUnsignedShort();
+
+        int readerIndex = buf.readerIndex();
+        ByteBuf rdata = buf.duplicate().setIndex(readerIndex, readerIndex + rdLength).retain();
+        buf.readerIndex(readerIndex + rdLength);
+        try {
+            return recordDecoder.decodeRecord(name, type, dnsClass, ttl, rdata);
+        } finally {
+            rdata.release();
+        }
+    }
+}
