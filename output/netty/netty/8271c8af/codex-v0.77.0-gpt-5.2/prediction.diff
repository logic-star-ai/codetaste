+package io.netty.handler.codec.dns;
+
+/**
+ * DNS operation codes (OPCODE).
+ */
+public final class DnsOpCode implements Comparable<DnsOpCode> {
+
+    public static final DnsOpCode QUERY = new DnsOpCode(0, "QUERY");
+
+    @Deprecated
+    public static final DnsOpCode IQUERY = new DnsOpCode(1, "IQUERY");
+
+    public static final DnsOpCode STATUS = new DnsOpCode(2, "STATUS");
+
+    private final int byteValue;
+    private final String name;
+
+    public static DnsOpCode valueOf(int byteValue) {
+        switch (byteValue) {
+        case 0:
+            return QUERY;
+        case 1:
+            return IQUERY;
+        case 2:
+            return STATUS;
+        default:
+            return new DnsOpCode(byteValue, "UNKNOWN");
+        }
+    }
+
+    public DnsOpCode(int byteValue, String name) {
+        if ((byteValue & 0xf) != byteValue) {
+            throw new IllegalArgumentException("byteValue: " + byteValue + " (expected: 0 ~ 15)");
+        }
+        this.byteValue = byteValue;
+        this.name = name;
+    }
+
+    public int intValue() {
+        return byteValue;
+    }
+
+    @Override
+    public int compareTo(DnsOpCode o) {
+        return intValue() - o.intValue();
+    }
+
+    @Override
+    public int hashCode() {
+        return intValue();
+    }
+
+    @Override
+    public boolean equals(Object o) {
+        return o instanceof DnsOpCode && ((DnsOpCode) o).byteValue == byteValue;
+    }
+
+    @Override
+    public String toString() {
+        return name;
+    }
+}
