+package io.netty.handler.codec.dns;
+
+import io.netty.buffer.ByteBuf;
+import io.netty.channel.ChannelHandler;
+import io.netty.channel.ChannelHandlerContext;
+import io.netty.channel.socket.DatagramPacket;
+import io.netty.handler.codec.MessageToMessageEncoder;
+import io.netty.util.CharsetUtil;
+
+import java.nio.charset.Charset;
+import java.util.List;
+
+/**
+ * Encodes {@link DatagramDnsQuery} into a {@link DatagramPacket}.
+ */
+@ChannelHandler.Sharable
+public class DatagramDnsQueryEncoder extends MessageToMessageEncoder<DatagramDnsQuery> {
+
+    private final DnsRecordEncoder recordEncoder;
+
+    public DatagramDnsQueryEncoder() {
+        this(new DefaultDnsRecordEncoder());
+    }
+
+    public DatagramDnsQueryEncoder(DnsRecordEncoder recordEncoder) {
+        if (recordEncoder == null) {
+            throw new NullPointerException("recordEncoder");
+        }
+        this.recordEncoder = recordEncoder;
+    }
+
+    @Override
+    protected void encode(ChannelHandlerContext ctx, DatagramDnsQuery query, List<Object> out) throws Exception {
+        ByteBuf buf = ctx.alloc().buffer(512);
+        boolean success = false;
+        try {
+            encodeHeader(query.content(), buf);
+            encodeQuestions(query.content().questions(), CharsetUtil.US_ASCII, buf);
+            encodeRecords(query.content(), DnsSection.ANSWER, CharsetUtil.US_ASCII, buf);
+            encodeRecords(query.content(), DnsSection.AUTHORITY, CharsetUtil.US_ASCII, buf);
+            encodeRecords(query.content(), DnsSection.ADDITIONAL, CharsetUtil.US_ASCII, buf);
+            out.add(new DatagramPacket(buf, query.recipient(), query.sender()));
+            success = true;
+        } finally {
+            if (!success) {
+                buf.release();
+            }
+        }
+    }
+
+    private static void encodeHeader(DnsMessage message, ByteBuf out) {
+        out.writeShort(message.id());
+
+        int flags = 0;
+        flags |= (message.opCode().intValue() & 0xf) << 11;
+        flags |= message.isRecursionDesired() ? 1 << 8 : 0;
+        flags |= (message.z() & 0x7) << 4;
+        out.writeShort(flags);
+
+        out.writeShort(message.count(DnsSection.QUESTION));
+        out.writeShort(message.count(DnsSection.ANSWER));
+        out.writeShort(message.count(DnsSection.AUTHORITY));
+        out.writeShort(message.count(DnsSection.ADDITIONAL));
+    }
+
+    private static void encodeQuestions(List<DnsQuestion> questions, Charset charset, ByteBuf out) {
+        for (DnsQuestion question : questions) {
+            DnsCodecUtil.encodeName(question.name(), charset, out);
+            out.writeShort(question.type().intValue());
+            out.writeShort(question.dnsClass());
+        }
+    }
+
+    private void encodeRecords(DnsMessage message, DnsSection section, Charset charset, ByteBuf out) throws Exception {
+        int count = message.count(section);
+        for (int i = 0; i < count; i++) {
+            DnsRecord record = message.recordAt(section, i);
+            DnsCodecUtil.encodeName(record.name(), charset, out);
+            out.writeShort(record.type().intValue());
+            out.writeShort(record.dnsClass());
+            out.writeInt((int) record.timeToLive());
+
+            int rdLengthIndex = out.writerIndex();
+            out.writeShort(0);
+            int start = out.writerIndex();
+            recordEncoder.encodeRecord(record, out);
+            int rdLength = out.writerIndex() - start;
+            out.setShort(rdLengthIndex, rdLength);
+        }
+    }
+}
+
