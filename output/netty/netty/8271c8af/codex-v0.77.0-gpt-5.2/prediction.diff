+package io.netty.handler.codec.dns;
+
+import io.netty.util.AbstractReferenceCounted;
+import io.netty.util.ReferenceCountUtil;
+import io.netty.util.ResourceLeak;
+import io.netty.util.ResourceLeakDetector;
+import io.netty.util.internal.StringUtil;
+
+import java.util.Collections;
+import java.util.LinkedList;
+import java.util.List;
+
+/**
+ * Base class for {@link DnsMessage} implementations.
+ */
+public abstract class AbstractDnsMessage extends AbstractReferenceCounted implements DnsMessage {
+
+    private static final ResourceLeakDetector<AbstractDnsMessage> LEAK_DETECTOR =
+            new ResourceLeakDetector<AbstractDnsMessage>(AbstractDnsMessage.class);
+
+    private final ResourceLeak leak;
+
+    private int id;
+    private DnsOpCode opCode = DnsOpCode.QUERY;
+    private boolean recursionDesired;
+    private int z;
+
+    private List<DnsQuestion> questions;
+    private List<DnsRecord> answers;
+    private List<DnsRecord> authorities;
+    private List<DnsRecord> additionals;
+
+    protected AbstractDnsMessage(int id) {
+        setId(id);
+        leak = LEAK_DETECTOR.open(this);
+    }
+
+    @Override
+    public int id() {
+        return id;
+    }
+
+    @Override
+    public DnsMessage setId(int id) {
+        if ((id & 0xffff) != id) {
+            throw new IllegalArgumentException("id: " + id + " (expected: 0 ~ 65535)");
+        }
+        this.id = id;
+        return this;
+    }
+
+    @Override
+    public DnsOpCode opCode() {
+        return opCode;
+    }
+
+    @Override
+    public DnsMessage setOpCode(DnsOpCode opCode) {
+        if (opCode == null) {
+            throw new NullPointerException("opCode");
+        }
+        this.opCode = opCode;
+        return this;
+    }
+
+    @Override
+    public boolean isRecursionDesired() {
+        return recursionDesired;
+    }
+
+    @Override
+    public DnsMessage setRecursionDesired(boolean recursionDesired) {
+        this.recursionDesired = recursionDesired;
+        return this;
+    }
+
+    @Override
+    public int z() {
+        return z;
+    }
+
+    @Override
+    public DnsMessage setZ(int z) {
+        if ((z & 0x7) != z) {
+            throw new IllegalArgumentException("z: " + z + " (expected: 0 ~ 7)");
+        }
+        this.z = z;
+        return this;
+    }
+
+    @Override
+    public List<DnsQuestion> questions() {
+        if (questions == null) {
+            return Collections.emptyList();
+        }
+        return Collections.unmodifiableList(questions);
+    }
+
+    @Override
+    public List<DnsRecord> answers() {
+        if (answers == null) {
+            return Collections.emptyList();
+        }
+        return Collections.unmodifiableList(answers);
+    }
+
+    @Override
+    public List<DnsRecord> authorityRecords() {
+        if (authorities == null) {
+            return Collections.emptyList();
+        }
+        return Collections.unmodifiableList(authorities);
+    }
+
+    @Override
+    public List<DnsRecord> additionalRecords() {
+        if (additionals == null) {
+            return Collections.emptyList();
+        }
+        return Collections.unmodifiableList(additionals);
+    }
+
+    @Override
+    public int count(DnsSection section) {
+        switch (section) {
+        case QUESTION:
+            return questions == null ? 0 : questions.size();
+        case ANSWER:
+            return answers == null ? 0 : answers.size();
+        case AUTHORITY:
+            return authorities == null ? 0 : authorities.size();
+        case ADDITIONAL:
+            return additionals == null ? 0 : additionals.size();
+        default:
+            throw new Error();
+        }
+    }
+
+    @Override
+    public DnsRecord recordAt(DnsSection section, int index) {
+        switch (section) {
+        case QUESTION:
+            return questions().get(index);
+        case ANSWER:
+            return answers().get(index);
+        case AUTHORITY:
+            return authorityRecords().get(index);
+        case ADDITIONAL:
+            return additionalRecords().get(index);
+        default:
+            throw new Error();
+        }
+    }
+
+    @Override
+    public DnsMessage setRecord(DnsSection section, int index, DnsRecord record) {
+        if (record == null) {
+            throw new NullPointerException("record");
+        }
+        switch (section) {
+        case QUESTION:
+            if (!(record instanceof DnsQuestion)) {
+                throw new IllegalArgumentException("record must be a DnsQuestion");
+            }
+            ReferenceCountUtil.release(ensureQuestions().set(index, (DnsQuestion) record));
+            break;
+        case ANSWER:
+            ReferenceCountUtil.release(ensureAnswers().set(index, record));
+            break;
+        case AUTHORITY:
+            ReferenceCountUtil.release(ensureAuthorities().set(index, record));
+            break;
+        case ADDITIONAL:
+            ReferenceCountUtil.release(ensureAdditionals().set(index, record));
+            break;
+        default:
+            throw new Error();
+        }
+        return this;
+    }
+
+    @Override
+    public DnsMessage addRecord(DnsSection section, DnsRecord record) {
+        if (record == null) {
+            throw new NullPointerException("record");
+        }
+        switch (section) {
+        case QUESTION:
+            if (!(record instanceof DnsQuestion)) {
+                throw new IllegalArgumentException("record must be a DnsQuestion");
+            }
+            ensureQuestions().add((DnsQuestion) record);
+            break;
+        case ANSWER:
+            ensureAnswers().add(record);
+            break;
+        case AUTHORITY:
+            ensureAuthorities().add(record);
+            break;
+        case ADDITIONAL:
+            ensureAdditionals().add(record);
+            break;
+        default:
+            throw new Error();
+        }
+        return this;
+    }
+
+    @Override
+    public DnsRecord removeRecord(DnsSection section, int index) {
+        switch (section) {
+        case QUESTION:
+            return ensureQuestions().remove(index);
+        case ANSWER:
+            return ensureAnswers().remove(index);
+        case AUTHORITY:
+            return ensureAuthorities().remove(index);
+        case ADDITIONAL:
+            return ensureAdditionals().remove(index);
+        default:
+            throw new Error();
+        }
+    }
+
+    @Override
+    public DnsMessage clear(DnsSection section) {
+        switch (section) {
+        case QUESTION:
+            clearAndRelease(questions);
+            questions = null;
+            break;
+        case ANSWER:
+            clearAndRelease(answers);
+            answers = null;
+            break;
+        case AUTHORITY:
+            clearAndRelease(authorities);
+            authorities = null;
+            break;
+        case ADDITIONAL:
+            clearAndRelease(additionals);
+            additionals = null;
+            break;
+        default:
+            throw new Error();
+        }
+        return this;
+    }
+
+    @Override
+    public DnsMessage clear() {
+        clear(DnsSection.QUESTION);
+        clear(DnsSection.ANSWER);
+        clear(DnsSection.AUTHORITY);
+        clear(DnsSection.ADDITIONAL);
+        return this;
+    }
+
+    private static void clearAndRelease(List<?> records) {
+        if (records == null) {
+            return;
+        }
+        for (Object r: records) {
+            ReferenceCountUtil.release(r);
+        }
+        records.clear();
+    }
+
+    private List<DnsQuestion> ensureQuestions() {
+        if (questions == null) {
+            questions = new LinkedList<DnsQuestion>();
+        }
+        return questions;
+    }
+
+    private List<DnsRecord> ensureAnswers() {
+        if (answers == null) {
+            answers = new LinkedList<DnsRecord>();
+        }
+        return answers;
+    }
+
+    private List<DnsRecord> ensureAuthorities() {
+        if (authorities == null) {
+            authorities = new LinkedList<DnsRecord>();
+        }
+        return authorities;
+    }
+
+    private List<DnsRecord> ensureAdditionals() {
+        if (additionals == null) {
+            additionals = new LinkedList<DnsRecord>();
+        }
+        return additionals;
+    }
+
+    @Override
+    protected void deallocate() {
+        clear();
+        if (leak != null) {
+            leak.close();
+        }
+    }
+
+    @Override
+    public AbstractDnsMessage retain() {
+        super.retain();
+        return this;
+    }
+
+    @Override
+    public AbstractDnsMessage retain(int increment) {
+        super.retain(increment);
+        return this;
+    }
+
+    @Override
+    public AbstractDnsMessage touch() {
+        return touch(null);
+    }
+
+    @Override
+    public AbstractDnsMessage touch(Object hint) {
+        if (leak != null) {
+            leak.record(hint);
+        }
+        touchAll(questions, hint);
+        touchAll(answers, hint);
+        touchAll(authorities, hint);
+        touchAll(additionals, hint);
+        return this;
+    }
+
+    private static void touchAll(List<?> records, Object hint) {
+        if (records == null) {
+            return;
+        }
+        for (Object r: records) {
+            ReferenceCountUtil.touch(r, hint);
+        }
+    }
+
+    @Override
+    public String toString() {
+        return new StringBuilder(256)
+                .append(StringUtil.simpleClassName(this))
+                .append("(id: ").append(id)
+                .append(", opCode: ").append(opCode)
+                .append(", rd: ").append(recursionDesired)
+                .append(", z: ").append(z)
+                .append(", questions: ").append(count(DnsSection.QUESTION))
+                .append(", answers: ").append(count(DnsSection.ANSWER))
+                .append(", authorities: ").append(count(DnsSection.AUTHORITY))
+                .append(", additionals: ").append(count(DnsSection.ADDITIONAL))
+                .append(')').toString();
+    }
+}
