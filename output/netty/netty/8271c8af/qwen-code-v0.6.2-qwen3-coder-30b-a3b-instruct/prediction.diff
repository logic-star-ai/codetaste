+package test;
+
+import io.netty.handler.codec.dns.*;
+
+import io.netty.buffer.ByteBuf;
+import io.netty.buffer.Unpooled;
+import io.netty.util.internal.StringUtil;
+
+import java.net.InetSocketAddress;
+
+public class DnsExtendedTest {
+    public static void main(String[] args) throws Exception {
+        System.out.println("Testing new DNS API functionality");
+        
+        // Test new interfaces
+        InetSocketAddress recipient = new InetSocketAddress("8.8.8.8", 53);
+        InetSocketAddress sender = new InetSocketAddress("192.168.1.1", 53);
+        
+        // Test DnsMessage APIs
+        DefaultDnsQuery query = new DefaultDnsQuery(1234, recipient);
+        DefaultDnsResponse response = new DefaultDnsResponse(1234, sender);
+        
+        // Test new method names
+        // Has new set* methods
+        query.setRecursionDesired(true);
+        query.setAuthoritativeAnswer(true);
+        query.setTruncated(false);
+        query.setRecursionAvailable(true);
+        query.setZ(0);
+        query.setId(5678);
+        
+        // Test record interaction APIs
+        DnsQuestion question = new DefaultDnsQuestion("example.com", DefaultDnsRecordType.A, 1);
+        query.addQuestion(question);
+        
+        ByteBuf content = Unpooled.buffer();
+        content.writeBytes("127.0.0.1".getBytes());
+        DnsRecord record = new DefaultDnsResource("example.com", DefaultDnsRecordType.A, 1, 3600L, content);
+        
+        query.addAnswer(record);
+        query.addAuthority(record);
+        query.addAdditional(record);
+        
+        // Test that we can still use old APIs for retrieving data
+        System.out.println("Question count: " + query.questionCount());
+        System.out.println("Answer count: " + query.answerCount());
+        System.out.println("Authority count: " + query.authorityCount());
+        System.out.println("Additional count: " + query.additionalCount());
+        
+        // Test DnsRecord methods
+        System.out.println("Record type name: " + record.type().name());
+        System.out.println("Record type value: " + record.type().intValue());
+        System.out.println("Record TTL: " + record.timeToLive());
+        System.out.println("Record class: " + record.dnsClass());
+        
+        // Test header
+        DnsHeader header = query.header();
+        System.out.println("Header ID: " + header.id());
+        System.out.println("Header type: " + header.type());
+        System.out.println("Header recursion desired: " + header.isRecursionDesired());
+        
+        // Test DNS sections
+        System.out.println("Sections are: " + DnsSection.QUESTION);
+        System.out.println("Sections are: " + DnsSection.ANSWER);
+        System.out.println("Sections are: " + DnsSection.AUTHORITY);
+        System.out.println("Sections are: " + DnsSection.ADDITIONAL);
+        
+        // Test DNS op codes
+        System.out.println("Op code values: " + DnsOpCode.QUERY);
+        System.out.println("Op code values: " + DnsOpCode.IQUERY);
+        System.out.println("Op code values: " + DnsOpCode.STATUS);
+        
+        // Test response codes
+        System.out.println("Response code: " + DnsResponseCode.NOERROR);
+        System.out.println("Response code: " + DnsResponseCode.FORMERR);
+        System.out.println("Response code: " + DnsResponseCode.SERVFAIL);
+        
+        // Test constants
+        System.out.println("TAB constant: " + StringUtil.TAB);
+        
+        // Test raw records
+        DnsRawRecord rawRecord = new DnsRawRecord("example.com", DefaultDnsRecordType.A, 1, 3600L, content);
+        System.out.println("Raw record type: " + rawRecord.type().name());
+        System.out.println("Raw record class: " + rawRecord.dnsClass());
+        
+        System.out.println("Extended API test completed successfully!");
+    }
+}
