+    }
+
+    /**
+     * Returns the value of this DnsRecordType as it appears in DNS protocol
+     */
+    @Override
+    public int intValue() {
+        return intValue;
+    }
+
+    @Override
+    public int hashCode() {
+        return intValue;
+    }
+
+    @Override
+    public boolean equals(Object o) {
+        return o instanceof DefaultDnsRecordType && ((DefaultDnsRecordType) o).intValue == intValue;
+    }
+
+    @Override
+    public String toString() {
+        return name;
+    }
+}
