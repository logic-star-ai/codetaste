+ * under the License.
+ */
+package io.netty.handler.codec.dns;
+
+/**
+ * The default implementation of {@link DnsQuestion}.
+ */
+public class DefaultDnsQuestion implements DnsQuestion {
+    private final String name;
+    private final DnsRecordType type;
+    private final int dnsClass;
+
+    /**
+     * Constructs a question.
+     *
+     * @param name  the domain name
+     * @param type  the type of record being returned
+     * @param dnsClass  the class for this resource record
+     */
+    public DefaultDnsQuestion(String name, DnsRecordType type, int dnsClass) {
+        if (name == null) {
+            throw new NullPointerException("name");
+        }
+        if (type == null) {
+            throw new NullPointerException("type");
+        }
+
+        this.name = name;
+        this.type = type;
+        this.dnsClass = dnsClass;
+    }
+
+    /**
+     * Returns the name of this entry (the domain).
+     */
+    @Override
+    public String name() {
+        return name;
+    }
+
+    /**
+     * Returns the type of resource record to be received.
+     */
+    @Override
+    public DnsRecordType type() {
+        return type;
+    }
+
+    /**
+     * Returns the class for this entry. Default is IN (Internet).
+     */
+    @Override
+    public int dnsClass() {
+        return dnsClass;
+    }
+
+    @Override
+    public String toString() {
+        return "DefaultDnsQuestion{name=" + name + ", type=" + type + ", dnsClass=" + dnsClass + "}";
+    }
+
+    @Override
+    public int hashCode() {
+        int result = name.hashCode();
+        result = 31 * result + type.hashCode();
+        result = 31 * result + dnsClass;
+        return result;
+    }
+
+    @Override
+    public boolean equals(Object o) {
+        if (this == o) {
+            return true;
+        }
+        if (!(o instanceof DefaultDnsQuestion)) {
+            return false;
+        }
+
+        DefaultDnsQuestion that = (DefaultDnsQuestion) o;
+        return dnsClass == that.dnsClass &&
+               name.equals(that.name) &&
+               type.equals(that.type);
+    }
+}
