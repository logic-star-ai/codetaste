+        }
+        return result;
+    }
+
+    public static DefaultDnsRecordType valueOf(String name) {
+        DefaultDnsRecordType result = BY_NAME.get(name);
+        if (result == null) {
+            throw new IllegalArgumentException("name: " + name + EXPECTED);
+        }
+        return result;
+    }
+
+    /**
+     * Returns a new instance.
+     */
+    public static DefaultDnsRecordType valueOf(int intValue, String name) {
