+package io.netty.handler.codec.dns;
+
+import io.netty.buffer.ByteBuf;
+import io.netty.buffer.ByteBufHolder;
+import io.netty.util.AbstractReferenceCounted;
+import io.netty.util.ReferenceCountUtil;
+
+import java.util.List;
+
+/**
+ * Represents any resource record (answer, authority, or additional resource
+ * records). This is a base implementation for DNS records that can handle
+ * existing structures.
+ */
+public class DefaultDnsResource implements DnsRecord {
+
+    private final String name;
+    private final DnsRecordType type;
+    private final int dnsClass;
+    private final long ttl;
+    private final ByteBuf content;
+
+    /**
+     * Constructs a resource record.
+     *
+     * @param name    the domain name
+     * @param type    the type of record being returned
+     * @param dnsClass the class for this resource record
+     * @param ttl     the time to live after reading
+     * @param content the data contained in this record
+     */
+    public DefaultDnsResource(String name, DnsRecordType type, int dnsClass, long ttl, ByteBuf content) {
+        if (name == null) {
+            throw new NullPointerException("name");
+        }
+        if (type == null) {
+            throw new NullPointerException("type");
+        }
+        if (content == null) {
+            throw new NullPointerException("content");
+        }
+        this.name = name;
+        this.type = type;
+        this.dnsClass = dnsClass;
+        this.ttl = ttl;
+        this.content = content;
+    }
+
+    /**
+     * Returns the name of this entry (the domain).
+     */
+    @Override
+    public String name() {
+        return name;
+    }
+
+    /**
+     * Returns the type of resource record to be received.
+     */
+    @Override
+    public DnsRecordType type() {
+        return type;
+    }
+
+    /**
+     * Returns the class for this entry. Default is IN (Internet).
+     */
+    @Override
+    public int dnsClass() {
+        return dnsClass;
+    }
+
+    /**
+     * Returns the time to live after reading for this resource record.
+     */
+    @Override
+    public long timeToLive() {
+        return ttl;
+    }
+
+    /**
+     * Returns the data contained in this resource record.
+     */
+    @Override
+    public ByteBuf content() {
+        return content;
+    }
+
+    /**
+     * Returns a deep copy of this resource record.
+     */
+    @Override
+    public DefaultDnsResource copy() {
+        return new DefaultDnsResource(name, type, dnsClass, ttl, content.copy());
+    }
+
+    /**
+     * Returns a duplicate of this resource record.
+     */
+    @Override
+    public DefaultDnsResource duplicate() {
+        return new DefaultDnsResource(name, type, dnsClass, ttl, content.duplicate());
+    }
+
+    @Override
+    public int refCnt() {
+        return content.refCnt();
+    }
+
+    @Override
+    public DefaultDnsResource retain() {
+        content.retain();
+        return this;
+    }
+
+    @Override
+    public DefaultDnsResource retain(int increment) {
+        content.retain(increment);
+        return this;
+    }
+
+    @Override
+    public boolean release() {
+        return content.release();
+    }
+
+    @Override
+    public boolean release(int decrement) {
+        return content.release(decrement);
+    }
+
+    @Override
+    public DefaultDnsResource touch() {
+        content.touch();
+        return this;
+    }
+
+    @Override
+    public DefaultDnsResource touch(Object hint) {
+        content.touch(hint);
+        return this;
+    }
+
+    @Override
+    public String toString() {
+        return "DefaultDnsResource{name=" + name + ", type=" + type + ", dnsClass=" + dnsClass + ", ttl=" + ttl + "}";
+    }
+
+    @Override
+    protected void deallocate() {
+        // NOOP
+    }
+}
