+import java.util.Collections;
+import java.util.LinkedList;
+import java.util.List;
+
+/**
+ * Abstract base implementation for DNS messages.
+ */
+public abstract class AbstractDnsMessage extends AbstractReferenceCounted implements DnsMessage {
+    private List<DnsQuestion> questions;
+    private List<DnsRecord> answers;
+    private List<DnsRecord> authority;
+    private List<DnsRecord> additional;
+
+    private final DnsHeader header;
+
+    // Only allow to extend from same package
+    protected AbstractDnsMessage(int id) {
+        header = newHeader(id);
+    }
+
+    /**
+     * Returns the header belonging to this message.
+     */
+    @Override
+    public DnsHeader header() {
+        return header;
+    }
+
+    /**
+     * Returns a list of all the questions in this message.
+     */
+    @Override
+    public List<DnsQuestion> questions() {
+        if (questions == null) {
+            return Collections.emptyList();
+        }
+        return Collections.unmodifiableList(questions);
+    }
+
+    /**
+     * Returns a list of all the answer resource records in this message.
+     */
+    @Override
+    public List<DnsRecord> answers() {
+        if (answers == null) {
+            return Collections.emptyList();
+        }
+        return Collections.unmodifiableList(answers);
+    }
+
+    /**
+     * Returns a list of all the authority resource records in this message.
+     */
+    @Override
+    public List<DnsRecord> authority() {
+        if (authority == null) {
+            return Collections.emptyList();
+        }
+        return Collections.unmodifiableList(authority);
+    }
+
+    /**
+     * Returns a list of all the additional resource records in this message.
+     */
+    @Override
+    public List<DnsRecord> additional() {
+        if (additional == null) {
+            return Collections.emptyList();
+        }
+        return Collections.unmodifiableList(additional);
+    }
+
+    /**
+     * Adds an answer resource record to this message.
+     *
+     * @param answer
+     *            the answer resource record to be added
+     * @return the message to allow method chaining
+     */
+    @Override
+    public DnsMessage addAnswer(DnsRecord answer) {
+        if (answers == null) {
+            answers = new LinkedList<DnsRecord>();
+        }
+        answers.add(answer);
+        return this;
+    }
+
+    /**
+     * Adds a question to this message.
+     *
+     * @param question
+     *            the question to be added
+     * @return the message to allow method chaining
+     */
+    @Override
+    public DnsMessage addQuestion(DnsQuestion question) {
+        if (questions == null) {
+            questions = new LinkedList<DnsQuestion>();
+        }
+        questions.add(question);
+        return this;
+    }
+
+    /**
+     * Adds an authority resource record to this message.
+     *
+     * @param resource
+     *            the authority resource record to be added
+     * @return the message to allow method chaining
+     */
+    @Override
+    public DnsMessage addAuthority(DnsRecord resource) {
+        if (authority == null) {
+            authority = new LinkedList<DnsRecord>();
+        }
+        authority.add(resource);
+        return this;
+    }
+
+    /**
+     * Adds an additional resource record to this message.
+     *
+     * @param resource
+     *            the additional resource record to be added
+     * @return the message to allow method chaining
+     */
+    @Override
+    public DnsMessage addAdditional(DnsRecord resource) {
+        if (additional == null) {
+            additional = new LinkedList<DnsRecord>();
+        }
+        additional.add(resource);
+        return this;
+    }
+
+    /**
+     * {@inheritDoc}
+     */
+    @Override
+    protected void deallocate() {
+        // NOOP
+    }
+
+    /**
+     * {@inheritDoc}
+     */
+    @Override
+    public boolean release() {
+        release(questions());
+        release(answers());
+        release(additional());
+        release(authority());
+        return super.release();
+    }
+
+    private static void release(List<?> resources) {
+        for (Object resource: resources) {
+            ReferenceCountUtil.release(resource);
+        }
+    }
+
+    /**
+     * {@inheritDoc}
+     */
+    @Override
+    public boolean release(int decrement) {
+        release(questions(), decrement);
+        release(answers(), decrement);
+        release(additional(), decrement);
+        release(authority(), decrement);
+        return super.release(decrement);
+    }
+
+    private static void release(List<?> resources, int decrement) {
+        for (Object resource: resources) {
+            ReferenceCountUtil.release(resource, decrement);
+        }
+    }
+
+    /**
+     * {@inheritDoc}
+     */
+    @Override
+    public DnsMessage touch(Object hint) {
+        touch(questions(), hint);
+        touch(answers(), hint);
+        touch(additional(), hint);
+        touch(authority(), hint);
+        return this;
+    }
+
+    private static void touch(List<?> resources, Object hint) {
+        for (Object resource: resources) {
+            ReferenceCountUtil.touch(resource, hint);
+        }
+    }
+
+    /**
+     * {@inheritDoc}
+     */
+    @Override
+    public DnsMessage retain() {
+        retain(questions());
+        retain(answers());
+        retain(additional());
+        retain(authority());
+        super.retain();
+        return this;
+    }
+
+    private static void retain(List<?> resources) {
+        for (Object resource: resources) {
+            ReferenceCountUtil.retain(resource);
+        }
+    }
+
+    /**
+     * {@inheritDoc}
+     */
+    @Override
+    public DnsMessage retain(int increment) {
+        retain(questions(), increment);
+        retain(answers(), increment);
+        retain(additional(), increment);
+        retain(authority(), increment);
+        super.retain(increment);
+        return this;
+    }
+
+    private static void retain(List<?> resources, int increment) {
+        for (Object resource: resources) {
+            ReferenceCountUtil.retain(resource, increment);
+        }
+    }
+
+    /**
+     * {@inheritDoc}
+     */
+    @Override
+    public DnsMessage touch() {
+        super.touch();
+        return this;
+    }
+
+    @Override
+    public boolean isQuery() {
+        return header().type() == DnsHeader.TYPE_QUERY;
+    }
+
+    @Override
+    public boolean isResponse() {
+        return header().type() == DnsHeader.TYPE_RESPONSE;
+    }
+
+    @Override
+    public DnsOpCode opcode() {
+        return header().opcode();
+    }
+
+    @Override
+    public DnsMessage setOpCode(DnsOpCode opcode) {
+        header().setOpcode(opcode);
+        return this;
+    }
+
+    @Override
+    public DnsResponseCode responseCode() {
+        return header().responseCode();
+    }
+
+    @Override
+    public DnsMessage setResponseCode(DnsResponseCode code) {
+        header().setResponseCode(code);
+        return this;
+    }
+
+    @Override
+    public boolean isRecursionDesired() {
+        return header().isRecursionDesired();
+    }
+
+    @Override
+    public DnsMessage setRecursionDesired(boolean recursionDesired) {
+        header().setRecursionDesired(recursionDesired);
+        return this;
+    }
+
+    @Override
+    public boolean isAuthoritativeAnswer() {
+        return header().isAuthoritativeAnswer();
+    }
+
+    @Override
+    public DnsMessage setAuthoritativeAnswer(boolean authoritativeAnswer) {
+        header().setAuthoritativeAnswer(authoritativeAnswer);
+        return this;
+    }
+
+    @Override
+    public boolean isTruncated() {
+        return header().isTruncated();
+    }
+
+    @Override
+    public DnsMessage setTruncated(boolean truncated) {
+        header().setTruncated(truncated);
+        return this;
+    }
+
+    @Override
+    public int z() {
+        return header().z();
+    }
+
+    @Override
+    public DnsMessage setZ(int z) {
+        header().setZ(z);
+        return this;
+    }
+
+    @Override
+    public int id() {
+        return header().id();
+    }
+
+    @Override
+    public DnsMessage setId(int id) {
+        header().setId(id);
+        return this;
+    }
+
+    @Override
+    public boolean isRecursionAvailable() {
+        return header().isRecursionAvailable();
+    }
+
+    @Override
+    public DnsMessage setRecursionAvailable(boolean recursionAvailable) {
+        header().setRecursionAvailable(recursionAvailable);
+        return this;
+    }
+
+    @Override
+    public int questionCount() {
+        return header().questionCount();
+    }
+
+    @Override
+    public int answerCount() {
+        return header().answerCount();
+    }
+
+    @Override
+    public int authorityCount() {
+        return header().authorityResourceCount();
+    }
+
+    @Override
+    public int additionalCount() {
+        return header().additionalResourceCount();
+    }
+
+    @Override
+    public DnsMessage setQuestionCount(int count) {
+        header().setQuestionCount(count);
+        return this;
+    }
+
+    @Override
+    public DnsMessage setAnswerCount(int count) {
+        header().setAnswerCount(count);
+        return this;
+    }
+
+    @Override
+    public DnsMessage setAuthorityCount(int count) {
+        header().setAuthorityResourceCount(count);
+        return this;
+    }
+
+    @Override
+    public DnsMessage setAdditionalCount(int count) {
+        header().setAdditionalResourceCount(count);
+        return this;
+    }
+
+    @Override
+    public DnsMessage clearCounts() {
+        header().setQuestionCount(0)
+                .setAnswerCount(0)
+                .setAuthorityResourceCount(0)
+                .setAdditionalResourceCount(0);
+        return this;
+    }
+
+    protected abstract DnsHeader newHeader(int id);
+}
