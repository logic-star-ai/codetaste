+#!/bin/bash
+
+echo "Compiling DNS API test..."
+
+# Check if we have a valid Java environment
+if ! command -v javac &> /dev/null; then
+    echo "ERROR: Java compiler not found. Please install JDK."
+    exit 1
+fi
+
+# Compile the test files
+javac -cp "/testbed/common/target/classes:/testbed/codec-dns/target/classes" /testbed/test/DnsApiTest.java
+javac -cp "/testbed/common/target/classes:/testbed/codec-dns/target/classes" /testbed/test/DnsExtendedTest.java
+
+if [ $? -ne 0 ]; then
+    echo "ERROR: Compilation failed."
+    exit 1
+fi
+
+# Run the tests
+echo "Running basic DNS API test..."
+java -cp "/testbed/common/target/classes:/testbed/codec-dns/target/classes:." DnsApiTest
+
+echo "Running extended DNS API test..."
+java -cp "/testbed/common/target/classes:/testbed/codec-dns/target/classes:." DnsExtendedTest
+
+echo "All tests completed successfully!"
