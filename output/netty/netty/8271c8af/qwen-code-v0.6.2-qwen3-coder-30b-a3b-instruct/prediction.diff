+ * distributed under the License is distributed on an "AS IS" BASIS, WITHOUT
+ * WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied. See the
+ * License for the specific language governing permissions and limitations
+ * under the License.
+ */
+package test;
+
+import io.netty.handler.codec.dns.*;
+
+import io.netty.buffer.ByteBuf;
+import io.netty.buffer.Unpooled;
+import io.netty.util.internal.StringUtil;
+
+import java.net.InetSocketAddress;
+import java.util.List;
+
+public class DnsApiTest {
+    public static void main(String[] args) throws Exception {
+        System.out.println("Testing new DNS API");
+        
+        // Test 1: Creating query and response using new interfaces
+        InetSocketAddress recipient = new InetSocketAddress("8.8.8.8", 53);
+        InetSocketAddress sender = new InetSocketAddress("192.168.1.1", 53);
+        
+        // Create DnsQuery with new interface
+        DefaultDnsQuery query = new DefaultDnsQuery(1234, recipient);
+        
+        // Add a question
+        DnsQuestion question = new DefaultDnsQuestion("example.com", DefaultDnsRecordType.A, 1);
+        query.addQuestion(question);
+        
+        // Create DnsResponse with new interface
+        DefaultDnsResponse response = new DefaultDnsResponse(1234, sender);
+        
+        // Add an answer
+        ByteBuf content = Unpooled.buffer();
+        content.writeBytes("127.0.0.1".getBytes());
+        DnsRecord answer = new DefaultDnsResource("example.com", DefaultDnsRecordType.A, 1, 3600L, content);
+        response.addAnswer(answer);
+        
+        // Test new interfaces and methods
+        System.out.println("Query type: " + (query.isQuery() ? "QUERY" : "NOT QUERY"));
+        System.out.println("Response type: " + (response.isResponse() ? "RESPONSE" : "NOT RESPONSE"));
+        
+        System.out.println("Query question count: " + query.questionCount());
+        System.out.println("Response answer count: " + response.answerCount());
+        
+        // Test header access
+        DnsHeader header = query.header();
+        System.out.println("Header type: " + header.type());
+        System.out.println("Header id: " + header.id());
+        
+        // Test record interfaces
+        System.out.println("Record type: " + answer.type().name());
+        System.out.println("Record class: " + answer.dnsClass());
+        System.out.println("Record TTL: " + answer.timeToLive());
+        
+        // Test sections
+        System.out.println("Available sections: " + DnsSection.values());
+        System.out.println("Query opcode: " + query.opcode());
+        System.out.println("Response code: " + response.responseCode());
+        
+        // Test the tabs constant
+        System.out.println("TAB character: " +StringUtil.TAB);
+        
+        System.out.println("API test completed successfully!");
+    }
+}
