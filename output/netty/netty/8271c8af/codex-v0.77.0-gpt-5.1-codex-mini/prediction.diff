+ * under the License.
+ */
+package io.netty.handler.codec.dns;
+
+import io.netty.buffer.ByteBuf;
+import io.netty.handler.codec.UnsupportedMessageTypeException;
+import io.netty.util.CharsetUtil;
+
+/**
+ * Default {@link DnsRecordEncoder} implementation.
+ */
+public class DefaultDnsRecordEncoder implements DnsRecordEncoder {
+
+    @Override
+    public void encodeQuestion(DnsQuestion question, ByteBuf out) throws Exception {
+        DnsCodecUtil.encodeDomainName(question.name(), CharsetUtil.US_ASCII, out);
+        out.writeShort(question.type().intValue());
+        out.writeShort(question.dnsClass());
+    }
+
+    @Override
+    public void encodeRecord(DnsRecord record, ByteBuf out) throws Exception {
+        if (!(record instanceof DnsRawRecord)) {
+            throw new UnsupportedMessageTypeException(record, DnsRawRecord.class);
+        }
+
+        DnsRawRecord rawRecord = (DnsRawRecord) record;
+        DnsCodecUtil.encodeDomainName(rawRecord.name(), CharsetUtil.US_ASCII, out);
+        out.writeShort(rawRecord.type().intValue());
+        out.writeShort(rawRecord.dnsClass());
+        out.writeInt((int) rawRecord.timeToLive());
+
+        ByteBuf content = rawRecord.content();
+        int contentLen = content.readableBytes();
+        out.writeShort(contentLen);
+        out.writeBytes(content, content.readerIndex(), contentLen);
+    }
+}
+
