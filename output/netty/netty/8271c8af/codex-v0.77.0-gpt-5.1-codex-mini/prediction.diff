+package io.netty.handler.codec.dns;
+
+import io.netty.util.internal.StringUtil;
+
+import static io.netty.util.internal.ObjectUtil.checkNotNull;
+
+/**
+ * Default base implementation for {@link DnsRecord}.
+ */
+public class AbstractDnsRecord implements DnsRecord {
+
+    private final String name;
+    private final DnsRecordType type;
+    private final int dnsClass;
+    private final long timeToLive;
+
+    protected AbstractDnsRecord(String name, DnsRecordType type, int dnsClass, long timeToLive) {
+        this.name = checkNotNull(name, "name");
+        this.type = checkNotNull(type, "type");
+
+        if ((dnsClass & 0xffff) != dnsClass) {
+            throw new IllegalArgumentException("dnsClass: " + dnsClass + " (expected: 0 ~ 65535)");
+        }
+        if ((timeToLive & 0xffffffffL) != timeToLive) {
+            throw new IllegalArgumentException("timeToLive: " + timeToLive + " (expected: 0 ~ 4294967295)");
+        }
+
+        this.dnsClass = dnsClass;
+        this.timeToLive = timeToLive;
+    }
+
+    @Override
+    public String name() {
+        return name;
+    }
+
+    @Override
+    public DnsRecordType type() {
+        return type;
+    }
+
+    @Override
+    public int dnsClass() {
+        return dnsClass;
+    }
+
+    @Override
+    public long timeToLive() {
+        return timeToLive;
+    }
+
+    @Override
+    public int hashCode() {
+        final int nameHash = name.hashCode();
+        final int typeHash = type.hashCode();
+        final int ttlHash = (int) timeToLive;
+        return ((nameHash * 31 + typeHash) * 31 + dnsClass) * 31 + ttlHash;
+    }
+
+    @Override
+    public boolean equals(Object o) {
+        if (!(o instanceof DnsRecord)) {
+            return false;
+        }
+        if (this == o) {
+            return true;
+        }
+
+        DnsRecord that = (DnsRecord) o;
+        return type().intValue() == that.type().intValue() &&
+               dnsClass() == that.dnsClass() &&
+               timeToLive() == that.timeToLive() &&
+               name().equals(that.name());
+    }
+
+    @Override
+    public String toString() {
+        return new StringBuilder(128).append(StringUtil.simpleClassName(this))
+                .append("(name: ").append(name)
+                .append(", type: ").append(type)
+                .append(", dnsClass: ").append(dnsClass)
+                .append(", timeToLive: ").append(timeToLive)
+                .append(')').toString();
+    }
+}
