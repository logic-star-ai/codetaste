+package io.netty.handler.codec.dns;
+
+import io.netty.buffer.ByteBuf;
+import io.netty.channel.AddressedEnvelope;
+import io.netty.channel.ChannelHandler;
+import io.netty.channel.ChannelHandlerContext;
+import io.netty.channel.socket.DatagramPacket;
+import io.netty.handler.codec.MessageToMessageEncoder;
+
+import java.net.InetSocketAddress;
+import java.util.List;
+
+import static io.netty.util.internal.ObjectUtil.checkNotNull;
+
+/**
+ * Encodes {@link DnsQuery} into {@link DatagramPacket}.
+ */
+@ChannelHandler.Sharable
+public class DatagramDnsQueryEncoder extends MessageToMessageEncoder<AddressedEnvelope<DnsQuery, InetSocketAddress>> {
+
+    private final DnsRecordEncoder recordEncoder;
+
+    public DatagramDnsQueryEncoder() {
+        this(new DefaultDnsRecordEncoder());
+    }
+
+    public DatagramDnsQueryEncoder(DnsRecordEncoder recordEncoder) {
+        this.recordEncoder = checkNotNull(recordEncoder, "recordEncoder");
+    }
+
+    @Override
+    protected void encode(ChannelHandlerContext ctx, AddressedEnvelope<DnsQuery, InetSocketAddress> in,
+                          List<Object> out) throws Exception {
+        DnsQuery query = in.content();
+        ByteBuf buf = ctx.alloc().buffer();
+        boolean success = false;
+        try {
+            encodeHeader(query, buf);
+            encodeQuestions(query, buf);
+            encodeRecords(query, DnsSection.ADDITIONAL, buf);
+            out.add(new DatagramPacket(buf, in.recipient(), in.sender()));
+            success = true;
+        } finally {
+            if (!success) {
+                buf.release();
+            }
+        }
+    }
+
+    private void encodeHeader(DnsQuery query, ByteBuf out) {
+        out.writeShort(query.id());
+
+        int flags = 0;
+        flags |= (query.opCode().intValue() & 0xf) << 11;
+        if (query.isRecursionDesired()) {
+            flags |= 1 << 8;
+        }
+        flags |= (query.z() & 0x7) << 4;
+        out.writeShort(flags);
+
+        out.writeShort(query.count(DnsSection.QUESTION));
+        out.writeShort(0);
+        out.writeShort(0);
+        out.writeShort(query.count(DnsSection.ADDITIONAL));
+    }
+
+    private void encodeQuestions(DnsQuery query, ByteBuf out) throws Exception {
+        int count = query.count(DnsSection.QUESTION);
+        for (int i = 0; i < count; i++) {
+            DnsQuestion question = query.recordAt(DnsSection.QUESTION, i);
+            recordEncoder.encodeQuestion(question, out);
+        }
+    }
+
+    private void encodeRecords(DnsMessage message, DnsSection section, ByteBuf out) throws Exception {
+        int count = message.count(section);
+        for (int i = 0; i < count; i++) {
+            DnsRecord record = message.recordAt(section, i);
+            recordEncoder.encodeRecord(record, out);
+        }
+    }
+}
+
