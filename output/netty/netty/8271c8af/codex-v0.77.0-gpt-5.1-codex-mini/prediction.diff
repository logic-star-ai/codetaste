+ * under the License.
+ */
+package io.netty.handler.codec.dns;
+
+import io.netty.buffer.ByteBuf;
+
+/**
+ * Default {@link DnsRecordDecoder} implementation which decodes resource records as {@link DnsRawRecord}s.
+ */
+public class DefaultDnsRecordDecoder implements DnsRecordDecoder {
+
+    @Override
+    public DnsQuestion decodeQuestion(ByteBuf in) throws Exception {
+        String name = DnsCodecUtil.decodeDomainName(in);
+        DnsRecordType type = DnsRecordType.valueOf(in.readUnsignedShort());
+        int dnsClass = in.readUnsignedShort();
+        return new DefaultDnsQuestion(name, type, dnsClass);
+    }
+
+    @Override
+    public DnsRecord decodeRecord(ByteBuf in) throws Exception {
+        String name = DnsCodecUtil.decodeDomainName(in);
+        DnsRecordType type = DnsRecordType.valueOf(in.readUnsignedShort());
+        int dnsClass = in.readUnsignedShort();
+        long ttl = in.readUnsignedInt();
+        int len = in.readUnsignedShort();
+
+        int readerIndex = in.readerIndex();
+        ByteBuf payload = in.duplicate().setIndex(readerIndex, readerIndex + len).retain();
+        in.readerIndex(readerIndex + len);
+
+        return new DefaultDnsRawRecord(name, type, dnsClass, ttl, payload);
+    }
+}
