+package io.netty.handler.codec.dns;
+
+import io.netty.util.AbstractReferenceCounted;
+import io.netty.util.ReferenceCountUtil;
+import io.netty.util.ResourceLeak;
+import io.netty.util.ResourceLeakDetector;
+
+import java.util.ArrayList;
+import java.util.List;
+
+import static io.netty.util.internal.ObjectUtil.checkNotNull;
+
+/**
+ * Default base implementation of {@link DnsMessage}.
+ */
+public abstract class AbstractDnsMessage extends AbstractReferenceCounted implements DnsMessage {
+
+    private static final ResourceLeakDetector<DnsMessage> LEAK_DETECTOR = new ResourceLeakDetector<DnsMessage>(
+            DnsMessage.class);
+
+    private final ResourceLeak leak;
+
+    private int id;
+    private DnsOpCode opCode = DnsOpCode.QUERY;
+    private boolean recursionDesired;
+    private int z;
+
+    private List<DnsRecord> questions;
+    private List<DnsRecord> answers;
+    private List<DnsRecord> authorities;
+    private List<DnsRecord> additionals;
+
+    protected AbstractDnsMessage(int id) {
+        setId(id);
+        leak = LEAK_DETECTOR.open(this);
+    }
+
+    @Override
+    public int id() {
+        return id;
+    }
+
+    @Override
+    public DnsMessage setId(int id) {
+        if ((id & 0xffff) != id) {
+            throw new IllegalArgumentException("id: " + id + " (expected: 0 ~ 65535)");
+        }
+        this.id = id;
+        return this;
+    }
+
+    @Override
+    public DnsOpCode opCode() {
+        return opCode;
+    }
+
+    @Override
+    public DnsMessage setOpCode(DnsOpCode opCode) {
+        this.opCode = checkNotNull(opCode, "opCode");
+        return this;
+    }
+
+    @Override
+    public boolean isRecursionDesired() {
+        return recursionDesired;
+    }
+
+    @Override
+    public DnsMessage setRecursionDesired(boolean recursionDesired) {
+        this.recursionDesired = recursionDesired;
+        return this;
+    }
+
+    @Override
+    public int z() {
+        return z;
+    }
+
+    @Override
+    public DnsMessage setZ(int z) {
+        if ((z & 0x7) != z) {
+            throw new IllegalArgumentException("z: " + z + " (expected: 0 ~ 7)");
+        }
+        this.z = z;
+        return this;
+    }
+
+    @Override
+    public int count(DnsSection section) {
+        List<DnsRecord> records = sectionRecords(section);
+        return records == null ? 0 : records.size();
+    }
+
+    @SuppressWarnings("unchecked")
+    @Override
+    public <T extends DnsRecord> T recordAt(DnsSection section) {
+        return recordAt(section, 0);
+    }
+
+    @SuppressWarnings("unchecked")
+    @Override
+    public <T extends DnsRecord> T recordAt(DnsSection section, int index) {
+        List<DnsRecord> records = sectionRecords(section);
+        if (records == null) {
+            throw new IndexOutOfBoundsException();
+        }
+        return (T) records.get(index);
+    }
+
+    @Override
+    public DnsMessage setRecord(DnsSection section, DnsRecord record) {
+        clear(section);
+        return addRecord(section, record);
+    }
+
+    @Override
+    public DnsMessage setRecord(DnsSection section, int index, DnsRecord record) {
+        checkNotNull(record, "record");
+        List<DnsRecord> records = sectionRecordsOrCreate(section);
+        DnsRecord old = records.set(index, record);
+        ReferenceCountUtil.release(old);
+        return this;
+    }
+
+    @Override
+    public DnsMessage addRecord(DnsSection section, DnsRecord record) {
+        checkNotNull(record, "record");
+        sectionRecordsOrCreate(section).add(record);
+        return this;
+    }
+
+    @Override
+    public DnsMessage addRecord(DnsSection section, int index, DnsRecord record) {
+        checkNotNull(record, "record");
+        sectionRecordsOrCreate(section).add(index, record);
+        return this;
+    }
+
+    @SuppressWarnings("unchecked")
+    @Override
+    public <T extends DnsRecord> T removeRecord(DnsSection section, int index) {
+        List<DnsRecord> records = sectionRecords(section);
+        if (records == null) {
+            throw new IndexOutOfBoundsException();
+        }
+        return (T) records.remove(index);
+    }
+
+    @Override
+    public DnsMessage clear(DnsSection section) {
+        List<DnsRecord> records = sectionRecords(section);
+        if (records != null) {
+            for (DnsRecord record : records) {
+                ReferenceCountUtil.release(record);
+            }
+            records.clear();
+        }
+        return this;
+    }
+
+    @Override
+    protected void deallocate() {
+        clear(DnsSection.QUESTION);
+        clear(DnsSection.ANSWER);
+        clear(DnsSection.AUTHORITY);
+        clear(DnsSection.ADDITIONAL);
+        if (leak != null) {
+            leak.close();
+        }
+    }
+
+    @Override
+    public DnsMessage touch(Object hint) {
+        if (leak != null) {
+            leak.record(hint);
+        }
+        touchSection(DnsSection.QUESTION, hint);
+        touchSection(DnsSection.ANSWER, hint);
+        touchSection(DnsSection.AUTHORITY, hint);
+        touchSection(DnsSection.ADDITIONAL, hint);
+        return this;
+    }
+
+    private void touchSection(DnsSection section, Object hint) {
+        List<DnsRecord> records = sectionRecords(section);
+        if (records == null) {
+            return;
+        }
+        for (DnsRecord record : records) {
+            ReferenceCountUtil.touch(record, hint);
+        }
+    }
+
+    @Override
+    public DnsMessage retain() {
+        super.retain();
+        return this;
+    }
+
+    @Override
+    public DnsMessage retain(int increment) {
+        super.retain(increment);
+        return this;
+    }
+
+    @Override
+    public DnsMessage touch() {
+        return touch(null);
+    }
+
+    private List<DnsRecord> sectionRecords(DnsSection section) {
+        switch (section) {
+        case QUESTION:
+            return questions;
+        case ANSWER:
+            return answers;
+        case AUTHORITY:
+            return authorities;
+        case ADDITIONAL:
+            return additionals;
+        default:
+            throw new Error();
+        }
+    }
+
+    private List<DnsRecord> sectionRecordsOrCreate(DnsSection section) {
+        List<DnsRecord> records = sectionRecords(section);
+        if (records == null) {
+            records = new ArrayList<DnsRecord>(2);
+            switch (section) {
+            case QUESTION:
+                questions = records;
+                break;
+            case ANSWER:
+                answers = records;
+                break;
+            case AUTHORITY:
+                authorities = records;
+                break;
+            case ADDITIONAL:
+                additionals = records;
+                break;
+            default:
+                throw new Error();
+            }
+        }
+        return records;
+    }
+}
