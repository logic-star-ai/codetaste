+package io.netty.handler.codec.dns;
+
+import io.netty.util.collection.IntObjectHashMap;
+
+/**
+ * Represents the 4 bit opCode field in the DNS header.
+ */
+public final class DnsOpCode implements Comparable<DnsOpCode> {
+
+    public static final DnsOpCode QUERY = new DnsOpCode(0, "QUERY");
+
+    /**
+     * Inverse queries were obsoleted by RFC 3425.
+     */
+    @Deprecated
+    public static final DnsOpCode IQUERY = new DnsOpCode(1, "IQUERY");
+
+    public static final DnsOpCode STATUS = new DnsOpCode(2, "STATUS");
+
+    private static final IntObjectHashMap<DnsOpCode> BY_CODE = new IntObjectHashMap<DnsOpCode>();
+
+    static {
+        BY_CODE.put(QUERY.intValue(), QUERY);
+        BY_CODE.put(IQUERY.intValue(), IQUERY);
+        BY_CODE.put(STATUS.intValue(), STATUS);
+    }
+
+    public static DnsOpCode valueOf(int intValue) {
+        DnsOpCode result = BY_CODE.get(intValue);
+        if (result == null) {
+            return new DnsOpCode(intValue, "UNKNOWN");
+        }
+        return result;
+    }
+
+    public static DnsOpCode valueOf(int intValue, String name) {
+        return new DnsOpCode(intValue, name);
+    }
+
+    private final int intValue;
+    private final String name;
+
+    private DnsOpCode(int intValue, String name) {
+        if ((intValue & 0xf) != intValue) {
+            throw new IllegalArgumentException("intValue: " + intValue + " (expected: 0 ~ 15)");
+        }
+        this.intValue = intValue;
+        this.name = name;
+    }
+
+    public int intValue() {
+        return intValue;
+    }
+
+    public String name() {
+        return name;
+    }
+
+    @Override
+    public int compareTo(DnsOpCode o) {
+        return intValue() - o.intValue();
+    }
+
+    @Override
+    public int hashCode() {
+        return intValue;
+    }
+
+    @Override
+    public boolean equals(Object o) {
+        return o instanceof DnsOpCode && ((DnsOpCode) o).intValue == intValue;
+    }
+
+    @Override
+    public String toString() {
+        return name;
+    }
+}
