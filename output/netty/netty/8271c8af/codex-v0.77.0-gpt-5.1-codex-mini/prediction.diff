+    DnsRecordType type();
+
+    /**
+     * Returns the class of this record. This is an unsigned 16-bit integer.
+     */
+    int dnsClass();
+
+    /**
+     * Returns the time to live value of this record.
+     * <p>
+     * For questions this value should be 0.
+     */
+    long timeToLive();
+}
