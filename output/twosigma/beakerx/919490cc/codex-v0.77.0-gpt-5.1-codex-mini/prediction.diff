diff --git a/js/notebook/src/plot/interaction/PlotInteraction.ts b/js/notebook/src/plot/interaction/PlotInteraction.ts
new file mode 100644
index 0000000..164259a
--- /dev/null
+++ b/js/notebook/src/plot/interaction/PlotInteraction.ts
@@ -0,0 +1,243 @@
+export default class PlotInteraction {
+  private scope: any;
+
+  constructor(scope: any) {
+    this.scope = scope;
+  }
+
+  onKeyAction(item: any, onKeyEvent: any) {
+    const plotUtils = require('../plotUtils');
+    const key = plotUtils.getKeyCodeConstant(onKeyEvent.keyCode);
+
+    for (let i = 0; i < this.scope.stdmodel.data.length; i++) {
+      const data = this.scope.stdmodel.data[i];
+      if (data.id === item.id || item.id.indexOf(data.id + '_') === 0) {
+        const plotId = this.scope.stdmodel.plotId;
+        const plotIndex = this.scope.stdmodel.plotIndex;
+        if (data.keyTags != null && !require('underscore').isEmpty(data.keyTags[key])) {
+          if (this.scope.model.setActionDetails) {
+            this.scope.model.setActionDetails(plotIndex, data, item).then(
+              function () {
+                plotUtils.evaluateTagCell(data.keyTags[key]);
+              },
+              function () {
+                // eslint-disable-next-line no-console
+                console.error('set action details error');
+              }
+            );
+          } else {
+            const params = plotUtils.getActionObject(this.scope.model.getCellModel().type, item);
+            params.actionType = 'onkey';
+            params.key = key;
+            params.tag = data.keyTags[key];
+            this.scope.plotDisplayModel.send(
+              {event: 'actiondetails', plotId: plotId, itemId: data.uid, params: params},
+              this.scope.plotDisplayView.callbacks()
+            );
+          }
+        } else if (data.keys != null && data.keys.indexOf(key) > -1) {
+          this.scope.legendDone = false;
+          this.scope.legendResetPosition = true;
+          this.scope.doNotLoadState = true;
+          if (this.scope.model.onKey) {
+            this.scope.model.onKey(key, plotIndex, data, item);
+          } else {
+            const params = plotUtils.getActionObject(this.scope.model.getCellModel().type, item);
+            params.key = key;
+            this.scope.plotDisplayModel.send(
+              {event: 'onkey', plotId: plotId, itemId: data.uid, params: params},
+              this.scope.plotDisplayView.callbacks()
+            );
+          }
+        }
+      }
+    }
+  }
+
+  removeOnKeyListeners() {
+    const $ = require('jquery');
+    for (const f in this.scope.onKeyListeners) {
+      if (this.scope.onKeyListeners.hasOwnProperty(f)) {
+        $(document).off('keydown.plot-action', this.scope.onKeyListeners[f]);
+      }
+    }
+    this.scope.onKeyListeners = {};
+  }
+
+  prepareInteraction() {
+    const _ = require('underscore');
+    const $ = require('jquery');
+    const d3 = require('d3');
+    const plotTipModule = require('../plotTip');
+    const plotTip = plotTipModule && plotTipModule.default ? plotTipModule.default : plotTipModule;
+    const plotUtils = require('../plotUtils');
+
+    const model = this.scope.stdmodel;
+    const self = this.scope;
+
+    self.svg.selectAll('.item-clickable').on('click.action', function (e: any) {
+      for (let i = 0; i < model.data.length; i++) {
+        const item = model.data[i];
+        if (item.hasClickAction === true && (item.id === e.id || e.id.indexOf(item.id + '_') === 0)) {
+          const plotId = self.stdmodel.plotId;
+          const plotIndex = self.stdmodel.plotIndex;
+          if (!_.isEmpty(item.clickTag)) {
+            if (self.model.setActionDetails) {
+              self.model.setActionDetails(plotIndex, item, e);
+            } else {
+              const params = plotUtils.getActionObject(self.model.getCellModel().type, e);
+              params.actionType = 'onclick';
+              params.tag = item.clickTag;
+              self.plotDisplayModel.send(
+                {event: 'actiondetails', plotId: plotId, itemId: item.uid, params: params},
+                self.plotDisplayView.callbacks()
+              );
+            }
+          } else {
+            self.legendDone = false;
+            self.legendResetPosition = true;
+            self.doNotLoadState = true;
+            if (self.model.onClick) {
+              self.model.onClick(plotIndex, item, e);
+              return;
+            } else {
+              self.plotDisplayModel.send(
+                {event: 'onclick', plotId: plotId, itemId: item.uid, params: plotUtils.getActionObject(self.model.getCellModel().type, e)},
+                self.plotDisplayView.callbacks()
+              );
+            }
+          }
+        }
+      }
+    });
+
+    const onKeyElements = self.svg.selectAll('.item-onkey');
+    onKeyElements
+      .on('mouseenter.plot-click', function (item: any) {
+        if (!self.onKeyListeners[item.id]) {
+          self.onKeyListeners[item.id] = function (onKeyEvent: any) {
+            self.interaction.onKeyAction(item, onKeyEvent);
+          };
+          $(document).on('keydown.plot-action', self.onKeyListeners[item.id]);
+        }
+      })
+      .on('mouseleave.plot-click', function (item: any) {
+        const keyListener = self.onKeyListeners[item.id];
+        if (keyListener) {
+          delete self.onKeyListeners[item.id];
+          $(document).off('keydown.plot-action', keyListener);
+        }
+      });
+
+    if (model.useToolTip === false) {
+      return;
+    }
+
+    self.svg
+      .selectAll('.plot-resp')
+      .on('mouseenter', function (d: any) {
+        d3.event.stopPropagation();
+
+        self.drawLegendPointer(d);
+        return plotTip.tooltip(self, d, d3.mouse(self.svg.node()));
+      })
+      .on('mousemove', function (d: any) {
+        d3.event.stopPropagation();
+
+        self.removeLegendPointer();
+        self.drawLegendPointer(d);
+        self.tipmoving = true;
+
+        self.tipTimeout && clearTimeout(self.tipTimeout);
+        self.tipTimeout = setTimeout(function () {
+          self.tipmoving = false;
+        }, 50);
+
+        plotTip.movetooltip(self, d, d3.mouse(self.svg.node()));
+      })
+      .on('mouseleave', function (d: any) {
+        d3.event.stopPropagation();
+
+        self.removeLegendPointer();
+        return plotTip.untooltip(self, d);
+      })
+      .on('click.resp', function (d: any) {
+        const model = self.stdmodel;
+        let hasClickAction;
+
+        for (let i = 0; i < model.data.length; i++) {
+          const item = model.data[i];
+          if (item.hasClickAction === true && (item.id === d.id || d.id.indexOf(item.id + '_') === 0)) {
+            hasClickAction = true;
+            break;
+          }
+        }
+
+        return !hasClickAction && plotTip.toggleTooltip(self, d);
+      });
+  }
+
+  toggleVisibility(e: any) {
+    const self = this.scope;
+    const id = e.target.id.split('_')[1];
+    const data = self.stdmodel.data;
+    let line;
+
+    if (id === 'all') {
+      self.showAllItems = !self.showAllItems;
+
+      for (const lineId in self.legendMergedLines) {
+        if (!self.legendMergedLines.hasOwnProperty(lineId)) {
+          continue;
+        }
+        line = self.legendMergedLines[lineId];
+        line.showItem = self.showAllItems;
+        for (let i = 0; i < line.dataIds.length; i++) {
+          const dat = data[line.dataIds[i]];
+          dat.showItem = self.showAllItems;
+          if (dat.showItem === false) {
+            dat.hideTips(self, true);
+            if (dat.isLodItem === true) {
+              dat.lodOn = false;
+            }
+          } else {
+            dat.hideTips(self, false);
+          }
+        }
+        if (line.showItem === false) {
+          if (line.isLodItem === true) {
+            self.setMergedLodHint(line.lodDataIds, lineId);
+          }
+        }
+        self.jqlegendcontainer.find('#legendcheck_' + lineId).prop('checked', line.showItem);
+      }
+
+      self.plotRange.calcRange();
+      self.update();
+      return;
+    }
+
+    line = self.legendMergedLines[id];
+    line.showItem = !line.showItem;
+    for (let j = 0; j < line.dataIds.length; j++) {
+      const dat = data[line.dataIds[j]];
+      dat.showItem = !dat.showItem;
+      if (dat.showItem === false) {
+        dat.hideTips(self, true);
+        if (dat.isLodItem === true) {
+          dat.lodOn = false;
+        }
+      } else {
+        dat.hideTips(self, false);
+      }
+    }
+    if (line.showItem === false) {
+      if (line.isLodItem === true) {
+        self.setMergedLodHint(line.lodDataIds, id);
+      }
+    }
+
+    self.plotRange.calcRange();
+    self.update();
+  }
+}
diff --git a/js/notebook/src/plot/layout/PlotLayout.ts b/js/notebook/src/plot/layout/PlotLayout.ts
new file mode 100644
index 0000000..23e5442
--- /dev/null
