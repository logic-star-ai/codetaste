@@ -0,0 +1,145 @@
+import {GridTextSpec, PlotGridScope} from './types';
+
+const plotUtils = require('../plotUtils');
+const $ = require('jquery');
+
+function measureText(text: string, clazz: string): { width: number; height: number } {
+  const el = $(`<div>${text}</div>`)
+    .css({
+      position: 'absolute',
+      float: 'left',
+      'white-space': 'nowrap',
+      visibility: 'hidden',
+      class: clazz,
+    })
+    .appendTo($('body'));
+  const width = el.width();
+  const height = el.height();
+  el.remove();
+  return {width, height};
+}
+
+export function buildGridLabels(scope: PlotGridScope): GridTextSpec[] {
+  const mapX = scope.plotRange.data2scrX;
+  const mapY = scope.plotRange.data2scrY;
+  const mapY_r = scope.plotRange.data2scrY_r;
+  const model = scope.stdmodel;
+
+  const out: GridTextSpec[] = [];
+
+  if (model.xAxis.showGridlineLabels !== false) {
+    const lines = model.xAxis.getGridlines();
+    const labels = model.xAxis.getGridlineLabels();
+    for (let i = 0; i < labels.length; i++) {
+      const x = mapX(lines[i]);
+      const y = mapY(scope.plotFocus.focus.yl) + scope.labelPadding.y;
+      const text: GridTextSpec = {
+        id: `label_x_${i}`,
+        class: 'plot-label plot-label-x',
+        text: labels[i],
+        x,
+        y,
+        'text-anchor': 'middle',
+        'dominant-baseline': 'hanging',
+      };
+
+      if (
+        model.categoryNamesLabelAngle &&
+        model.categoryNamesLabelAngle !== 0 &&
+        model.orientation === 'VERTICAL'
+      ) {
+        const size = measureText(labels[i], 'plot-label');
+        const degree = -1 * model.categoryNamesLabelAngle * (180 / Math.PI);
+        const delta = degree > 0 ? size.width / 2 : -1 * (size.width / 2);
+        text.transform =
+          `translate(${delta} ${-scope.labelPadding.y}) ` +
+          `rotate(${degree} ${x - delta} ${y + size.height / 2}) `;
+      }
+
+      out.push(text);
+    }
+  }
+
+  if (model.yAxis.showGridlineLabels !== false) {
+    const lines = model.yAxis.getGridlines();
+    const labels = model.yAxis.getGridlineLabels();
+    for (let i = 0; i < labels.length; i++) {
+      const x = mapX(scope.plotFocus.focus.xl) - scope.labelPadding.x;
+      const y = mapY(lines[i]);
+      const text: GridTextSpec = {
+        id: `label_y_${i}`,
+        class: 'plot-label plot-label-y',
+        text: labels[i],
+        x,
+        y,
+        'text-anchor': 'end',
+        'dominant-baseline': 'central',
+      };
+      if (
+        model.categoryNamesLabelAngle &&
+        model.categoryNamesLabelAngle !== 0 &&
+        model.orientation === 'HORIZONTAL'
+      ) {
+        text.transform = `rotate(${model.categoryNamesLabelAngle * (180 / Math.PI)} ${x} ${y})`;
+      }
+      out.push(text);
+    }
+  }
+
+  if (model.yAxisR && model.yAxisR.showGridlineLabels !== false) {
+    const lines = model.yAxisR.getGridlines();
+    const labels = model.yAxisR.getGridlineLabels();
+    for (let i = 0; i < labels.length; i++) {
+      const y = lines[i];
+      out.push({
+        id: `label_yr_${i}`,
+        class: 'plot-label',
+        text: labels[i],
+        x: mapX(scope.plotFocus.focus.xr) + scope.labelPadding.x,
+        y: mapY_r(y),
+        'dominant-baseline': 'central',
+      });
+    }
+  }
+
+  const lMargin = scope.layout.leftLayoutMargin;
+  const bMargin = scope.layout.bottomLayoutMargin;
+
+  if (model.xAxis.label != null) {
+    out.push({
+      id: 'xlabel',
+      class: 'plot-xylabel',
+      text: model.xAxis.axisLabelWithCommon,
+      x: lMargin + (plotUtils.safeWidth(scope.jqsvg) - lMargin) / 2,
+      y: plotUtils.safeHeight(scope.jqsvg) - plotUtils.fonts.labelHeight,
+    });
+  }
+
+  if (model.yAxis.label != null) {
+    const x = plotUtils.fonts.labelHeight * 2;
+    const y = (plotUtils.safeHeight(scope.jqsvg) - bMargin) / 2;
+    out.push({
+      id: 'ylabel',
+      class: 'plot-xylabel',
+      text: model.yAxis.label,
+      x,
+      y,
+      transform: `rotate(-90 ${x} ${y})`,
+    });
+  }
+
+  if (model.yAxisR && model.yAxisR.label != null) {
+    const x = plotUtils.safeWidth(scope.jqsvg) - plotUtils.fonts.labelHeight;
+    const y = (plotUtils.safeHeight(scope.jqsvg) - bMargin) / 2;
+    out.push({
+      id: 'yrlabel',
+      class: 'plot-xylabel',
+      text: model.yAxisR.label,
+      x,
+      y,
+      transform: `rotate(-90 ${x} ${y})`,
+    });
+  }
+
+  return out;
+}
