+  static sortModel(model: any) {
+    const data = model.data;
+    for (let i = 0; i < data.length; i++) {
+      const item = data[i];
+      if (item.type === 'treemapnode' || item.type === 'constline' || item.type === 'constband' || item.type === 'heatmap') {
+        continue;
+      }
+
+      const eles = item.elements;
+      let unordered = false;
+      for (let j = 1; j < eles.length; j++) {
+        if (plotUtils.lt(eles[j].x, eles[j - 1].x)) {
+          unordered = true;
+          break;
+        }
+      }
+      if (unordered === true) {
+        if (item.type === 'bar' || item.type === 'stem' || item.type === 'point' || item.type === 'text') {
