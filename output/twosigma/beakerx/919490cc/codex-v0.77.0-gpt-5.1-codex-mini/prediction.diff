diff --git a/js/notebook/src/plot/size/PlotSize.ts b/js/notebook/src/plot/size/PlotSize.ts
new file mode 100644
index 0000000..0b3c92a
--- /dev/null
+++ b/js/notebook/src/plot/size/PlotSize.ts
@@ -0,0 +1,60 @@
+export default class PlotSize {
+  private scope: any;
+
+  constructor(scope: any) {
+    this.scope = scope;
+  }
+
+  initResizable(): void {
+    const self = this.scope;
+    const _ = require('underscore');
+    const $ = require('jquery');
+
+    self.jqcontainer.resizable({
+      maxWidth: self.element.parent().width(),
+      minWidth: 150,
+      minHeight: 150,
+      handles: 'e, s, se',
+      resize: function (event: any, ui: any) {
+        self.width = ui.size.width;
+        self.height = ui.size.height;
+        _.extend(self.plotSize, ui.size);
+
+        self.jqsvg.css({width: self.width, height: self.height});
+        self.jqplottitle.css({width: self.width});
+        self.numIntervals = {x: self.width / self.intervalStepHint.x, y: self.height / self.intervalStepHint.y};
+        self.plotRange.calcRange();
+        self.plotRange.calcMapping(false);
+        self.emitSizeChange();
+        self.legendDone = false;
+        self.legendResetPosition = true;
+
+        self.update();
+      },
+    });
+
+    self.resizeFunction = function () {
+      self.jqcontainer.resizable('option', 'maxWidth', self.element.parent().width());
+    };
+
+    $(window).resize(self.resizeFunction);
+  }
+
+  adjustModelWidth(): void {
+    this.scope.updateModelWidth(this.getPlotWithLegendWidth());
+  }
+
+  private getPlotWithLegendWidth(): number {
+    const self = this.scope;
+    const containerWidth = self.jqcontainer.parents('.output_subarea').width();
+    const plotWidth = containerWidth && containerWidth < self.plotSize.width ? containerWidth : self.plotSize.width;
+    let legendWidth = self.jqlegendcontainer.find('.plot-legend').width() || 0;
+    const legendPosition = self.stdmodel.legendPosition.position;
+    const isLegendPlacedHorizontaly =
+      ['LEFT', 'RIGTH'].indexOf(legendPosition) !== -1 ||
+      (['TOP', 'BOTTOM'].indexOf(legendPosition) === -1 && self.stdmodel.legendLayout === 'VERTICAL');
+
+    legendWidth = legendWidth ? legendWidth + self.layout.legendMargin + 2 : 0;
+    return isLegendPlacedHorizontaly ? plotWidth - legendWidth : plotWidth;
+  }
+}
