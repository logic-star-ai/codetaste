@@ -0,0 +1,99 @@
+import {GridLineSpec, PlotGridScope} from './types';
+
+export function calcGridlines(scope: PlotGridScope): void {
+  const focus = scope.plotFocus.getFocus();
+  const model = scope.stdmodel;
+
+  model.xAxis.setGridlines(
+    focus.xl,
+    focus.xr,
+    scope.numIntervals.x,
+    model.margin.left,
+    model.margin.right
+  );
+  model.yAxis.setGridlines(
+    focus.yl,
+    focus.yr,
+    scope.numIntervals.y,
+    model.margin.bottom,
+    model.margin.top
+  );
+
+  if (model.yAxisR) {
+    model.yAxisR.setGridlines(
+      focus.yl_r,
+      focus.yr_r,
+      scope.numIntervals.y,
+      model.margin.bottom_r,
+      model.margin.top_r
+    );
+  }
+}
+
+export function buildGridLines(scope: PlotGridScope): GridLineSpec[] {
+  const focus = scope.plotFocus.getFocus();
+  const model = scope.stdmodel;
+  const mapX = scope.plotRange.data2scrX;
+  const mapY = scope.plotRange.data2scrY;
+  const mapY_r = scope.plotRange.data2scrY_r;
+
+  const out: GridLineSpec[] = [];
+
+  if (model.showXGridlines) {
+    const xGridlines = model.xAxis.getGridlines();
+    for (let i = 0; i < xGridlines.length; i++) {
+      const x = xGridlines[i];
+      out.push({
+        id: `gridline_x_${i}`,
+        class: 'plot-gridline',
+        x1: mapX(x),
+        y1: mapY(focus.yl),
+        x2: mapX(x),
+        y2: mapY(focus.yr),
+      });
+    }
+  }
+
+  const yGridlines = model.yAxis.getGridlines();
+  for (let i = 0; i < yGridlines.length; i++) {
+    const y = yGridlines[i];
+    out.push({
+      id: `gridline_y_${i}`,
+      class: 'plot-gridline',
+      x1: mapX(focus.xl),
+      y1: mapY(y),
+      x2: mapX(focus.xr),
+      y2: mapY(y),
+    });
+  }
+
+  out.push({
+    id: 'gridline_x_base',
+    class: 'plot-gridline-base',
+    x1: mapX(focus.xl),
+    y1: mapY(focus.yl),
+    x2: mapX(focus.xr),
+    y2: mapY(focus.yl),
+  });
+  out.push({
+    id: 'gridline_y_base',
+    class: 'plot-gridline-base',
+    x1: mapX(focus.xl),
+    y1: mapY(focus.yl),
+    x2: mapX(focus.xl),
+    y2: mapY(focus.yr),
+  });
+
+  if (focus.yl_r !== undefined && focus.yr_r !== undefined) {
+    out.push({
+      id: 'gridline_yr_base',
+      class: 'plot-gridline-base',
+      x1: mapX(focus.xr),
+      y1: mapY_r(focus.yl_r),
+      x2: mapX(focus.xr),
+      y2: mapY_r(focus.yr_r),
+    });
+  }
+
+  return out;
+}
diff --git a/js/notebook/src/plot/grid/GridTics.ts b/js/notebook/src/plot/grid/GridTics.ts
