diff --git a/js/notebook/src/plot/cursor/PlotCursor.ts b/js/notebook/src/plot/cursor/PlotCursor.ts
new file mode 100644
index 0000000..ab6421b
--- /dev/null
+++ b/js/notebook/src/plot/cursor/PlotCursor.ts
@@ -0,0 +1,118 @@
+const plotUtils = require('../plotUtils');
+const $ = require('jquery');
+
+export default class PlotCursor {
+  private scope: any;
+
+  constructor(scope: any) {
+    this.scope = scope;
+  }
+
+  renderCursor(e: any) {
+    const scope = this.scope;
+    const x = e.offsetX;
+    const y = e.offsetY;
+    const W = plotUtils.safeWidth(scope.jqsvg);
+    const H = plotUtils.safeHeight(scope.jqsvg);
+    const lMargin = scope.layout.leftLayoutMargin;
+    const bMargin = scope.layout.bottomLayoutMargin;
+    const rMargin = scope.layout.rightLayoutMargin;
+    const tMargin = scope.layout.topLayoutMargin;
+    const model = scope.stdmodel;
+
+    if (x < lMargin || (model.yAxisR != null && x > W - rMargin) || y > H - bMargin || y < tMargin) {
+      scope.svg.selectAll('.plot-cursor').remove();
+      scope.jqcontainer.find('.plot-cursorlabel').remove();
+      return;
+    }
+
+    const mapX = scope.plotRange.scr2dataX;
+    if (model.xCursor != null) {
+      const opt = model.xCursor;
+      scope.svg
+        .selectAll('#cursor_x')
+        .data([{}])
+        .enter()
+        .append('line')
+        .attr('id', 'cursor_x')
+        .attr('class', 'plot-cursor')
+        .style('stroke', opt.color)
+        .style('stroke-opacity', opt.color_opacity)
+        .style('stroke-width', opt.width)
+        .style('stroke-dasharray', opt.stroke_dasharray);
+      scope.svg.select('#cursor_x').attr('x1', x).attr('y1', tMargin).attr('x2', x).attr('y2', H - bMargin);
+
+      scope.jqcontainer.find('#cursor_xlabel').remove();
+      const label = $("<div id='cursor_xlabel' class='plot-cursorlabel'></div>")
+        .appendTo(scope.jqcontainer)
+        .text(plotUtils.getTipStringPercent(mapX(x), model.xAxis));
+      const w = label.outerWidth();
+      const h = label.outerHeight();
+      const p = {
+        x: x - w / 2,
+        y: H - bMargin - scope.labelPadding.y - h,
+      };
+      label.css({
+        left: p.x,
+        top: p.y,
+        'background-color': opt.color != null ? opt.color : 'black',
+      });
+    }
+
+    if (model.yCursor != null) {
+      const opt = model.yCursor;
+      scope.svg
+        .selectAll('#cursor_y')
+        .data([{}])
+        .enter()
+        .append('line')
+        .attr('id', 'cursor_y')
+        .attr('class', 'plot-cursor')
+        .style('stroke', opt.color)
+        .style('stroke-opacity', opt.color_opacity)
+        .style('stroke-width', opt.width)
+        .style('stroke-dasharray', opt.stroke_dasharray);
+      scope.svg
+        .select('#cursor_y')
+        .attr('x1', lMargin)
+        .attr('y1', y)
+        .attr('x2', W - rMargin)
+        .attr('y2', y);
+
+      this.renderCursorLabel(model.yAxis, 'cursor_ylabel', y, false);
+      if (model.yAxisR) {
+        this.renderCursorLabel(model.yAxisR, 'cursor_yrlabel', y, true);
+      }
+    }
+  }
+
+  private renderCursorLabel(axis: any, id: string, y: number, alignRight: boolean) {
+    const scope = this.scope;
+    const opt = scope.stdmodel.yCursor;
+    const lMargin = scope.layout.leftLayoutMargin;
+    const rMargin = scope.layout.rightLayoutMargin;
+    const mapY = scope.plotRange.scr2dataY;
+
+    if (axis == null) {
+      return;
+    }
+
+    scope.jqcontainer.find('#' + id).remove();
+    const label = $(`<div id='${id}' class='plot-cursorlabel'></div>`)
+      .appendTo(scope.jqcontainer)
+      .text(plotUtils.getTipStringPercent(mapY(y), axis));
+    const w = label.outerWidth();
+    const h = label.outerHeight();
+    const p = {
+      x: (alignRight ? rMargin : lMargin) + scope.labelPadding.x,
+      y: y - h / 2,
+    };
+    const css: any = {
+      top: p.y,
+      'background-color': opt.color != null ? opt.color : 'black',
+    };
+    css[alignRight ? 'right' : 'left'] = p.x;
+    label.css(css);
+  }
+}
+
diff --git a/js/notebook/src/plot/export/SaveAsContextMenu.ts b/js/notebook/src/plot/export/SaveAsContextMenu.ts
