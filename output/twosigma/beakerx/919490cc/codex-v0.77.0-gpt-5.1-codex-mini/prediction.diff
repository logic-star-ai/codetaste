index 0000000..da65734
--- /dev/null
+++ b/js/notebook/src/plot/legend/PlotLegend.ts
@@ -0,0 +1,462 @@
+import {LegendPosition} from './LegendPosition';
+
+const plotUtils = require('../plotUtils');
+const PointShapeHelper = require('../std/PointShapeHelper.ts').default;
+const $ = require('jquery');
+const _ = require('underscore');
+
+function getColorInfoUid(dat: any) {
+  const color = plotUtils.createColor(dat.color, dat.color_opacity);
+  const border = plotUtils.createColor(dat.stroke, dat.stroke_opacity);
+  return color + border;
+}
+
+function addNewLegendLineData(dat: any, lineUniqueIndex: string, mergedLines: any, lineUniqueAttributesSet: any, i: number) {
+  const line: any = {
+    dataIds: [i],
+    legend: dat.legend,
+    showItem: dat.showItem,
+    isLodItem: dat.isLodItem === true,
+    color: dat.color,
+    color_opacity: dat.color_opacity,
+    stroke: dat.stroke,
+    stroke_opacity: dat.stroke_opacity,
+    shape: dat.type === 'point' ? dat.shape : 'rect',
+  };
+  if (dat.isLodItem === true) {
+    line.lodDataIds = [i];
+  }
+  const lineId = plotUtils.randomString(32);
+  mergedLines[lineId] = line;
+  lineUniqueAttributesSet[lineUniqueIndex] = lineId;
+  return lineId;
+}
+
+function addDataForExistingLegendLine(dat: any, line: any, i: number) {
+  line.dataIds.push(i);
+  if (dat.isLodItem === true) {
+    line.isLodItem = true;
+    if (line.lodDataIds) {
+      line.lodDataIds.push(i);
+    } else {
+      line.lodDataIds = [i];
+    }
+  }
+  if (line.showItem !== true) {
+    line.showItem = dat.showItem;
+  }
+}
+
+export default class PlotLegend {
+  private scope: any;
+  private GradientLegend: any;
+
+  constructor(scope: any, GradientLegend: any) {
+    this.scope = scope;
+    this.GradientLegend = GradientLegend;
+  }
+
+  prepareMergedLegendData() {
+    const data = this.scope.stdmodel.data;
+    const mergedLines: any = {};
+    const lineUniqueAttributesSet: any = {};
+
+    for (let i = 0; i < data.length; i++) {
+      const dat = data[i];
+      if (dat.legend == null || dat.legend === '') {
+        continue;
+      }
+
+      const lineUniqueIndex = dat.legend + getColorInfoUid(dat);
+
+      if (lineUniqueAttributesSet[lineUniqueIndex] == null) {
+        addNewLegendLineData(dat, lineUniqueIndex, mergedLines, lineUniqueAttributesSet, i);
+      } else {
+        addDataForExistingLegendLine(dat, mergedLines[lineUniqueAttributesSet[lineUniqueIndex]], i);
+      }
+    }
+
+    return mergedLines;
+  }
+
+  private getLegendPositionByLayout(legendPosition: LegendPosition, isHorizontal: boolean) {
+    const legend = this.scope.jqlegendcontainer.find('#plotLegend');
+    const margin = this.scope.layout.legendMargin;
+    const legendWidth = legend.outerWidth(true);
+    const containerWidth = this.scope.jqcontainer.outerWidth(true);
+    const containerWidthWithMargin = containerWidth + margin;
+    const legendHeight = legend.height();
+    const legendHeightWithMargin = legendHeight + margin;
+
+    const positionName = (legendPosition as any).position;
+    if (isHorizontal) {
+      switch (positionName) {
+        case 'TOP_LEFT':
+          return {left: 0, top: -legendHeightWithMargin};
+        case 'TOP_RIGHT':
+          return {left: containerWidth - legendWidth, top: -legendHeightWithMargin};
+        case 'BOTTOM_LEFT':
+          return {left: 0, bottom: -legendHeightWithMargin};
+        case 'BOTTOM_RIGHT':
+          return {left: containerWidth - legendWidth, bottom: -legendHeightWithMargin};
+      }
+    } else {
+      switch (positionName) {
+        case 'TOP_LEFT':
+          return {left: 0, top: this.scope.layout.topLayoutMargin};
+        case 'TOP_RIGHT':
+          return {left: containerWidthWithMargin, top: this.scope.layout.topLayoutMargin};
+        case 'BOTTOM_LEFT':
+          return {left: 0, bottom: this.scope.layout.bottomLayoutMargin};
+        case 'BOTTOM_RIGHT':
+          return {left: containerWidthWithMargin, bottom: this.scope.layout.bottomLayoutMargin};
+      }
+    }
+    return undefined;
+  }
+
+  getLegendPosition(legendPosition: LegendPosition, isHorizontal: boolean) {
+    const margin = this.scope.layout.legendMargin;
+    const containerWidth = this.scope.jqcontainer.outerWidth(true);
+    const containerWidthWithMargin = containerWidth + margin;
+    const legend = this.scope.jqlegendcontainer.find('#plotLegend');
+    const legendHeight = legend.height();
+    const legendHeightWithMargin = legendHeight + margin;
+    const verticalCenter = this.scope.jqcontainer.height() / 2 - legendHeight / 2;
+    const horizontalCenter = containerWidth / 2 - legend.width() / 2;
+
+    if (!legendPosition) {
+      return this.getLegendPosition({position: 'TOP_RIGHT'}, isHorizontal);
+    }
+
+    let position: any;
+    if ((legendPosition as any).position) {
+      switch ((legendPosition as any).position) {
+        case 'TOP':
+          position = {left: horizontalCenter, top: -legendHeightWithMargin};
+          break;
+        case 'LEFT':
+          position = {left: 0, top: verticalCenter};
+          break;
+        case 'BOTTOM':
+          position = {left: horizontalCenter, bottom: -legendHeightWithMargin};
+          break;
+        case 'RIGHT':
+          position = {left: containerWidthWithMargin, bottom: verticalCenter};
+          break;
+        default:
+          position = this.getLegendPositionByLayout(legendPosition, isHorizontal);
+      }
+    } else {
+      position = {left: (legendPosition as any).x, top: (legendPosition as any).y};
+    }
+    return position;
+  }
+
+  createLegendContainer(clazz?: string, handle?: string) {
+    const scope = this.scope;
+    const isHorizontal = scope.stdmodel.legendLayout === 'HORIZONTAL';
+    const draggable: any = {
+      containment: 'parent',
+      start: function () {
+        $(this).css({bottom: 'auto'});
+      },
+      stop: function (event: any, ui: any) {
+        scope.legendPosition = {left: ui.position.left, top: ui.position.top};
+      },
+    };
+
+    const legendContainer = $('<div></div>')
+      .appendTo(scope.jqlegendcontainer)
+      .attr('id', 'plotLegend')
+      .attr('class', 'plot-legend')
+      .draggable(draggable)
+      .css(
+        'max-height',
+        plotUtils.safeHeight(scope.jqsvg) - scope.layout.bottomLayoutMargin - scope.layout.topLayoutMargin
+      );
+
+    if (clazz != null) {
+      legendContainer.addClass(clazz);
+    }
+
+    if (handle != null) {
+      draggable.handle = handle;
+    } else {
+      legendContainer.addClass('plot-legenddraggable');
+    }
+
+    if (isHorizontal) {
+      legendContainer.css('max-width', scope.jqcontainer.width());
+    }
+
+    return legendContainer;
+  }
+
+  getLodLabel(lodType: string) {
+    switch (lodType) {
+      case 'box':
+        return 'group into boxes';
+      case 'river':
+        return 'group into river';
+      case 'off':
+        return 'no grouping';
+      default:
+        return lodType;
+    }
+  }
+
+  render() {
+    const scope = this.scope;
+    if (scope.legendableItem === 0 || scope.stdmodel.showLegend === false || scope.legendDone === true) {
+      return;
+    }
+
+    const data = scope.stdmodel.data;
+    const isHorizontal = scope.stdmodel.legendLayout === 'HORIZONTAL';
+
+    scope.jqlegendcontainer.find('#plotLegend').remove();
+    scope.legendDone = true;
+
+    let legendContainer;
+    if (scope.model.getCellModel().type === 'HeatMap') {
+      legendContainer = this.createLegendContainer();
+    } else {
+      legendContainer = this.createLegendContainer('plot-legendscrollablecontainer', '#legendDraggableContainer');
+    }
+
+    if (scope.model.getCellModel().type === 'HeatMap') {
+      scope.gradientLegend = new this.GradientLegend(data);
+      scope.gradientLegend.render(legendContainer, data[0].colors);
+      this.updateLegendPosition();
+      return;
+    }
+
+    const legendDraggableContainer = $('<div></div>')
+      .appendTo(legendContainer)
+      .attr('id', 'legendDraggableContainer')
+      .attr('class', 'plot-legenddraggable');
+
+    const legendUnit = '<div></div>';
+    const legendLineUnit = isHorizontal ? "<div class='plot-legenditeminline'></div>" : "<div class='plot-legenditeminrow'></div>";
+    const legend = $(legendUnit).appendTo(legendDraggableContainer).attr('id', 'legends');
+
+    scope.legendMergedLines = this.prepareMergedLegendData();
+
+    if (!scope.stdmodel.omitCheckboxes && Object.keys(scope.legendMergedLines).length > 1) {
+      const allLegendId = plotUtils.randomString(32);
+      const unit = $(legendLineUnit).appendTo(legend).attr('id', 'legend_all').addClass('plot-legendline');
+      $("<input type='checkbox' />")
+        .attr('id', 'legendcheck_all_' + allLegendId)
+        .attr('class', 'plot-legendcheckbox beforeCheckbox')
+        .prop('checked', scope.showAllItems)
+        .click((e: any) => scope.interaction.toggleVisibility(e))
+        .appendTo($(unit));
+      $('<span></span>').attr('id', 'legendbox_all').attr('class', 'plot-legendbox').css('background-color', 'none').appendTo($(unit));
+      $('<label></label>')
+        .attr('id', 'legendtext_all')
+        .attr('for', 'legendcheck_all_' + allLegendId)
+        .attr('class', 'plot-label')
+        .text('All')
+        .appendTo($(unit));
+    }
+
+    scope.lodTypeMenuItems = {};
+
+    for (const id in scope.legendMergedLines) {
+      if (!scope.legendMergedLines.hasOwnProperty(id)) {
+        continue;
+      }
+      const line = scope.legendMergedLines[id];
+      if (line.legend == null || line.legend === '') {
+        continue;
+      }
+      let highlightTimeoutId: any;
+      const unit = $(legendLineUnit)
+        .appendTo(legend)
+        .attr('id', 'legend_' + id)
+        .addClass('plot-legendline')
+        .mouseenter(function () {
+          const legendLine = $(this)[0];
+          highlightTimeoutId = setTimeout(function () {
+            scope.highlightElements(legendLine.id.split('_')[1], true);
+          }, 300);
+        })
+        .mouseleave(function () {
+          clearTimeout(highlightTimeoutId);
+          scope.highlightElements($(this)[0].id.split('_')[1], false);
+        });
+
+      if (!scope.stdmodel.omitCheckboxes) {
+        $("<input type='checkbox'/>")
+          .attr('id', 'legendcheck_' + id)
+          .attr('class', 'plot-legendcheckbox beforeCheckbox')
+          .prop('checked', line.showItem)
+          .click((e: any) => scope.interaction.toggleVisibility(e))
+          .appendTo(unit);
+      }
+
+      $('<span></span>')
+        .attr('id', 'legendbox_' + id)
+        .attr('class', 'plot-legendbox')
+        .attr('title', line.color == null ? 'Element-based colored item' : '')
+        .appendTo(unit)
+        .append(PointShapeHelper.createLegendMarker(line));
+
+      $('<label></label>')
+        .appendTo(unit)
+        .attr('id', 'legendtext_' + id)
+        .attr('for', 'legendcheck_' + id)
+        .attr('class', 'plot-label')
+        .text(line.legend);
+
+      if (line.isLodItem === true) {
+        const applyLodType = (lodType: string, legendLineId: string) => {
+          const dataIds = scope.legendMergedLines[legendLineId].dataIds;
+
+          if (lodType === 'off') {
+            if (scope.getMergedLodInfo(dataIds).lodType === 'off') {
+              return;
+            }
+            scope.removePipe.push('msg_lodoff');
+            scope.message.render(
+              'LOD is being turned off. Are you sure?',
+              [
+                'You are trying to turning off LOD. Loading full resolution data is going to take time and may potentially crash the browser.',
+                'PROCEED (left click) / CANCEL (right click)',
+              ],
+              'msg_lodoff',
+              () => {
+                _.forEach(dataIds, function (dataId: number) {
+                  const loadLoader = scope.stdmodel.data[dataId];
+                  if (loadLoader.toggleLod) {
+                    loadLoader.toggleLod(scope);
+                  }
+                });
+                scope.update();
+                scope.setMergedLodHint(dataIds, legendLineId);
+              }
+            );
+          } else {
+            let hasChanged = false;
+            _.forEach(dataIds, function (dataId: number) {
+              const loadLoader = scope.stdmodel.data[dataId];
+              if (!loadLoader.lodType || loadLoader.lodType === lodType) {
+                return;
+              }
+              loadLoader.clear(scope);
+              loadLoader.applyLodType(lodType);
+              loadLoader.zoomLevelChanged(scope);
+              hasChanged = true;
+            });
+            if (hasChanged) {
+              scope.update();
+              scope.setMergedLodHint(dataIds, legendLineId);
+            }
+          }
+        };
+
+        const createLodTypeMenuItem = (lodType: string, lineId: string) => ({
+          lodType,
+          lineId,
+          name: this.getLodLabel(lodType),
+          action: function () {
+            applyLodType(this.lodType, this.lineId);
+          },
+        });
+
+        const lodTypeMenuItems: any[] = [];
+        _.forEach(line.dataIds, function (dataId: number) {
+          const graphics = scope.stdmodel.data[dataId];
+          _.forEach(graphics.lodTypes, function (lodType: string) {
+            if (
+              !_.some(lodTypeMenuItems, function (item: any) {
+                return item.lodType === lodType;
+              })
+            ) {
+              lodTypeMenuItems.push(createLodTypeMenuItem(lodType, id));
+            }
+          });
+        });
+        lodTypeMenuItems.push(createLodTypeMenuItem('off', id));
+
+        const lodhint = $(
+          '<div style="width: auto;">' +
+            '<div class="dropdown dropdown-promoted lod-dropdown-menu">' +
+            '<a class="dropdown-toggle plot-legendlodtype"></a>' +
+            '<ul class="dropdown-menu"></ul>' +
+            '</div>' +
+            '</div>'
+        );
+
+        const dropdownMenuElement = lodhint.find('ul.dropdown-menu');
+
+        lodTypeMenuItems.forEach(function (item: any) {
+          const liElem = $('<li class=""><a>' + item.name + '</a></li>');
+          liElem.children('a').on('click', function () {
+            item.action();
+            $(this).parents('.lod-dropdown-menu').removeClass('open');
+          });
+          dropdownMenuElement.append(liElem);
+        });
+
+        lodhint.find('a.dropdown-toggle').on('click', function () {
+          const parent = $(this).parent();
+          $('.lod-dropdown-menu').not(parent).removeClass('open');
+          parent.toggleClass('open');
+        });
+
+        scope.lodTypeMenuItems[id] = lodTypeMenuItems;
+        unit.append(lodhint);
+        lodhint.attr('id', 'hint_' + id).attr('class', 'plot-legendlod');
+        scope.setMergedLodHint(line.lodDataIds, id);
+      }
+    }
+
+    this.updateLegendPosition();
+  }
+
+  updateLegendPosition() {
+    const scope = this.scope;
+    const legendContainer = scope.jqlegendcontainer.find('#plotLegend');
+    const isHorizontal = scope.stdmodel.legendLayout === 'HORIZONTAL';
+    const margin = scope.layout.legendMargin;
+    if (scope.legendResetPosition === true) {
+      scope.legendPosition = this.getLegendPosition(scope.stdmodel.legendPosition, isHorizontal);
+      scope.legendResetPosition = false;
+    }
+    legendContainer.css(scope.legendPosition);
+
+    if (scope.stdmodel.legendPosition.position === 'LEFT') {
+      scope.jqcontainer.css('margin-left', legendContainer.width() + margin);
+    }
+    if (scope.stdmodel.legendPosition.position === 'TOP') {
+      scope.jqcontainer.css('margin-top', legendContainer.height() + margin);
+    }
+    if (scope.stdmodel.legendPosition.position === 'BOTTOM') {
+      scope.jqcontainer.css('margin-bottom', legendContainer.height() + margin);
+    }
+    if (isHorizontal) {
+      if (['TOP_LEFT', 'TOP_RIGHT'].indexOf(scope.stdmodel.legendPosition.position) !== -1) {
+        scope.jqcontainer.css('margin-top', legendContainer.height() + margin);
+      }
+      if (['BOTTOM_LEFT', 'BOTTOM_RIGHT'].indexOf(scope.stdmodel.legendPosition.position) !== -1) {
+        scope.jqcontainer.css('margin-bottom', legendContainer.height() + margin);
+      }
+    } else {
+      if (['TOP_LEFT', 'BOTTOM_LEFT'].indexOf(scope.stdmodel.legendPosition.position) !== -1) {
+        scope.jqcontainer.css('margin-left', legendContainer.width() + margin);
+      }
+    }
+
+    if (legendContainer.length) {
+      const legenddraggable = legendContainer.find('.plot-legenddraggable');
+      if (legendContainer.get(0).scrollHeight > legendContainer.get(0).clientHeight) {
+        legenddraggable.addClass('hasScroll');
+      } else {
+        legenddraggable.removeClass('hasScroll');
+      }
+    }
+  }
+}
