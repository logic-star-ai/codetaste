+import * as _ from 'underscore';
+import * as $ from 'jquery';
+
+const plotConverter = require('../plotConverter');
+const plotUtils = require('../plotUtils');
+const plotFactory = require('../plotFactory');
+const heatmapConverter = require('../heatmapconverter');
+const PlotAxisFactory = require('../std/axis/PlotAxisFactory').default;
+
+export default class DefaultPlotModel {
+  static readonly lineDasharrayMap: {[key: string]: string} = {
+    solid: '',
+    dash: '9,5',
+    dot: '2,2',
+    dashdot: '9,5,2,5',
+    longdash: '20,5',
+    '': '',
+  };
+
+  static standardizeModel(_model: any, prefs?: any): any {
+    const model: any = {};
+    $.extend(true, model, _model); // deep copy to prevent changing original JSON
+
+    if (model.graphics_list != null) {
+      model.version = 'groovy';
+    }
+    if (model.version === 'complete') {
+      return model;
+    } else if (model.version === 'groovy') {
+      // keep
+    } else {
+      model.version = 'direct';
+    }
+
+    const newmodel = DefaultPlotModel.createNewModel(model);
+
+    newmodel.lodThreshold = model.lodThreshold
+      ? model.lodThreshold
+      : prefs !== undefined && prefs.lodThreshold !== undefined
+        ? prefs.lodThreshold
+        : 4000;
+
+    newmodel.data = [];
+
+    if (model.version === 'groovy') {
+      switch (model.type) {
+        case 'HeatMap':
+          heatmapConverter.convertGroovyData(newmodel, model);
+          break;
+        default:
+          plotConverter.convertGroovyData(newmodel, model);
+          break;
+      }
+    } else {
+      _.extend(newmodel, model);
+    }
+
+    if (model.type === 'TreeMap') {
+      DefaultPlotModel.formatTreeMapModel(newmodel);
+    } else {
+      DefaultPlotModel.formatModel(newmodel);
+      DefaultPlotModel.sortModel(newmodel);
+
+      const yAxisData: any[] = [];
+      const yAxisRData: any[] = [];
+      for (let i = 0; i < newmodel.data.length; i++) {
+        const item = newmodel.data[i];
+        if (newmodel.showLegend == null && item.legend) {
+          newmodel.showLegend = true;
+        }
+        if (plotUtils.useYAxisR(newmodel, item)) {
+          yAxisRData.push(item);
+        } else {
+          yAxisData.push(item);
+        }
+      }
+
+      newmodel.showLegend = newmodel.showLegend != null ? newmodel.showLegend : false;
+
+      let range = plotUtils.getDataRange(yAxisData).datarange;
+      let rangeR = newmodel.yAxisR ? plotUtils.getDataRange(yAxisRData).datarange : null;
+
+      const applyMargins = function (r: any, axis: any) {
+        axis.lowerMargin = axis.lowerMargin || 0;
+        axis.upperMargin = axis.upperMargin || 0;
+
+        const span = r.yr - r.yl;
+        r.yl -= axis.lowerMargin * span;
+        r.yr += axis.upperMargin * span;
+        r.yspan = r.yr - r.yl;
+        return r;
+      };
+      range = applyMargins(range, newmodel.yAxis);
+      if (rangeR) {
+        rangeR = applyMargins(rangeR, newmodel.yAxisR);
+      }
+
+      if (newmodel.yIncludeZero === true && range.yl > 0) {
+        range.yl = 0;
+        range.yspan = range.yr - range.yl;
+      }
+      if (rangeR && newmodel.yRIncludeZero === true && rangeR.yl > 0) {
+        rangeR.yl = 0;
+        rangeR.yspan = rangeR.yr - rangeR.yl;
+      }
+
+      const margin = newmodel.margin;
+      if (margin.bottom == null) {
+        margin.bottom = 0.05;
+      }
+      if (margin.top == null) {
+        margin.top = 0.05;
+      }
+      if (margin.left == null) {
+        margin.left = 0.05;
+      }
+      if (margin.right == null) {
+        margin.right = 0.05;
+      }
+
+      if (newmodel.vrange == null) {
+        const getModelRange = function (r: any, logx: boolean, logy: boolean) {
+          if (r == null) {
+            return null;
+          }
+          const result: any = {
+            xl: plotUtils.minus(r.xl, r.xspan * 10.0),
+            xr: plotUtils.plus(r.xr, r.xspan * 10.0),
+            yl: r.yl - r.yspan * 10.0,
+            yr: r.yr + r.yspan * 10.0,
+          };
+          if (logx) {
+            result.xl = Math.max(result.xl, r.xl - newmodel.margin.left * r.xspan);
+          }
+          if (logy) {
+            result.yl = Math.max(result.yl, r.yl - newmodel.margin.left * r.yspan);
+          }
+          return result;
+        };
+
+        newmodel.vrange = getModelRange(range, newmodel.xAxis.type === 'log', newmodel.yAxis.type === 'log');
+        if (newmodel.yAxisR) {
+          newmodel.vrangeR = getModelRange(rangeR, newmodel.xAxis.type === 'log', newmodel.yAxisR.type === 'log');
+        }
+
+        const vrange = newmodel.vrange;
+        const vrangeR = newmodel.vrangeR;
+
+        if (newmodel.yPreventNegative === true) {
+          vrange.yl = Math.min(0, range.yl);
+        }
+
+        const focus = newmodel.userFocus;
+        if (focus.xl != null) {
+          vrange.xl = Math.min(focus.xl, vrange.xl);
+        }
+        if (focus.xr != null) {
+          vrange.xr = Math.max(focus.xr, vrange.xr);
+        }
+        if (focus.yl != null) {
+          vrange.yl = Math.min(focus.yl, vrange.yl);
+        }
+        if (focus.yr != null) {
+          vrange.yr = Math.max(focus.yr, vrange.yr);
+        }
+        if (vrangeR && focus.yl_r != null) {
+          vrangeR.yl = Math.min(focus.yl_r, vrangeR.yl);
+        }
+        if (vrangeR && focus.yr_r != null) {
+          vrangeR.yr = Math.max(focus.yr_r, vrangeR.yr);
+        }
+
+        const updateRangeSpan = function (r: any) {
+          if (r) {
+            r.xspan = plotUtils.minus(r.xr, r.xl);
+            r.yspan = r.yr - r.yl;
+          }
+        };
+        updateRangeSpan(vrange);
+        updateRangeSpan(vrangeR);
+      }
+
+      DefaultPlotModel.remapModel(newmodel);
+    }
+
+    newmodel.version = 'complete';
+    return newmodel;
+  }
+
+  private static createNewModel(model: any): any {
+    let newmodel: any;
+
+    if (model.version === 'groovy') {
+      newmodel = {
+        plotId: model.update_id,
+        type: 'plot',
