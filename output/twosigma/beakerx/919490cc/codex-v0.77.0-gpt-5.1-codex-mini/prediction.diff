+const $ = require('jquery');
+
+export default class PlotMessage {
+  private scope: any;
+
+  constructor(scope: any) {
+    this.scope = scope;
+  }
+
+  render(title: string, msgs: string | string[], msgid?: string, callbacky?: () => void, callbackn?: () => void) {
+    const self = this.scope;
+    const message = $('<div></div>')
+      .appendTo(self.jqcontainer)
+      .attr('id', msgid)
+      .attr('class', 'plot-message')
+      .on('mousedown', function (e) {
+        if (e.which === 3) {
+          callbackn && callbackn();
+        } else {
+          callbacky && callbacky();
+        }
+        $(this).remove();
+      });
+
+    if (title != null && title !== '') {
+      $('<div></div>').appendTo(message).attr('class', 'plot-message-title').text(title);
+    }
+
+    const content = $('<div></div>').appendTo(message).attr('class', 'plot-message-content');
+    const list = typeof msgs === 'string' ? [msgs] : msgs;
+    for (let i = 0; i < list.length; i++) {
+      $('<div></div>').appendTo(content).text(list[i]);
+    }
+
+    const w = message.outerWidth();
+    const h = message.outerHeight();
+    const lMargin = self.layout.leftLayoutMargin;
+    const bMargin = self.layout.bottomLayoutMargin;
+    message.css({
+      left: (self.jqcontainer.width() - lMargin) / 2 - w / 2 + lMargin,
+      top: (self.jqcontainer.height() - bMargin) / 2 - h / 2,
+    });
+  }
+}
