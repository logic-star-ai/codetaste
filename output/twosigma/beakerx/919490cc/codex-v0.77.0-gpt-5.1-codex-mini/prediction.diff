@@ -0,0 +1,62 @@
+import {GridTickSpec, PlotGridScope} from './types';
+
+export function buildGridTics(scope: PlotGridScope): GridTickSpec[] {
+  const tickLength = scope.gridlineTickLength;
+  const mapX = scope.plotRange.data2scrX;
+  const mapY = scope.plotRange.data2scrY;
+  const mapY_r = scope.plotRange.data2scrY_r;
+  const focus = scope.plotFocus.getFocus();
+  const model = scope.stdmodel;
+
+  const out: GridTickSpec[] = [];
+
+  if (model.xAxis.showGridlineLabels !== false) {
+    const lines = model.xAxis.getGridlines();
+    const labels = model.xAxis.getGridlineLabels();
+    for (let i = 0; i < labels.length; i++) {
+      const x = lines[i];
+      out.push({
+        id: `tick_x_${i}`,
+        class: 'plot-tick',
+        x1: mapX(x),
+        y1: mapY(focus.yl),
+        x2: mapX(x),
+        y2: mapY(focus.yl) + tickLength,
+      });
+    }
+  }
+
+  if (model.yAxis.showGridlineLabels !== false) {
+    const lines = model.yAxis.getGridlines();
+    const labels = model.yAxis.getGridlineLabels();
+    for (let i = 0; i < labels.length; i++) {
+      const y = lines[i];
+      out.push({
+        id: `tick_y_${i}`,
+        class: 'plot-tick',
+        x1: mapX(focus.xl) - tickLength,
+        y1: mapY(y),
+        x2: mapX(focus.xl),
+        y2: mapY(y),
+      });
+    }
+  }
+
+  if (model.yAxisR && model.yAxisR.showGridlineLabels !== false) {
+    const lines = model.yAxisR.getGridlines();
+    const labels = model.yAxisR.getGridlineLabels();
+    for (let i = 0; i < labels.length; i++) {
+      const y = lines[i];
+      out.push({
+        id: `tick_yr_${i}`,
+        class: 'plot-tick',
+        x1: mapX(focus.xr),
+        y1: mapY_r(y),
+        x2: mapX(focus.xr) + tickLength,
+        y2: mapY_r(y),
+      });
+    }
+  }
+
+  return out;
+}
