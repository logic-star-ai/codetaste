+import {PlotGridScope} from './types';
+import {calcGridlines, buildGridLines} from './GridLines';
+import {buildGridLabels} from './GridLabels';
+import {buildGridTics} from './GridTics';
+
+export default class PlotGrid {
+  private scope: PlotGridScope;
+
+  constructor(scope: PlotGridScope) {
+    this.scope = scope;
+  }
+
+  calc(): void {
+    calcGridlines(this.scope);
+  }
+
+  renderLines(): void {
+    this.scope.rpipeGridlines.push(...buildGridLines(this.scope));
+  }
+
+  renderLabels(): void {
+    this.scope.rpipeTexts.push(...buildGridLabels(this.scope));
+  }
+
+  renderTics(): void {
+    this.scope.rpipeTicks.push(...buildGridTics(this.scope));
+  }
+}
