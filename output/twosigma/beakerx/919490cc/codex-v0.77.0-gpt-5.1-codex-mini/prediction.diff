@@ -0,0 +1,210 @@
+export default class SaveAsContextMenu {
+  private scope: any;
+  private contextMenu: any;
+
+  constructor(scope: any) {
+    this.scope = scope;
+  }
+
+  init(): void {
+    const self = this.scope;
+    if (!self.model.disableContextMenu) {
+      self.saveAsMenuContainer = require('jquery')('div#' + self.wrapperId + ' #' + self.id);
+      const PlotContextMenu = require('../contextMenu/plotContextMenu.ts').default;
+      this.contextMenu = new PlotContextMenu(self);
+      self.contextMenu = this.contextMenu;
+    } else if (self.model && self.model.getSaveAsMenuContainer) {
+      self.saveAsMenuContainer = self.model.getSaveAsMenuContainer();
+    }
+  }
+
+  saveAsSvg(): void {
+    const _ = require('underscore');
+    const plotUtils = require('../plotUtils');
+    const self = this.scope;
+
+    const svgToSave = this.getSvgToSave();
+    plotUtils.addInlineFonts(svgToSave);
+    const html = plotUtils.convertToXHTML(svgToSave.outerHTML);
+    const fileName = _.isEmpty(self.stdmodel.title) ? 'plot' : self.stdmodel.title;
+    plotUtils.download('data:image/svg+xml;base64,' + btoa(unescape(encodeURIComponent(html))), fileName + '.svg');
+  }
+
+  saveAsPng(_scale?: number): void {
+    const _ = require('underscore');
+    const plotUtils = require('../plotUtils');
+    const self = this.scope;
+
+    const svg = this.getSvgToSave();
+    plotUtils.addInlineFonts(svg);
+
+    const scale = _scale === undefined ? 1 : _scale;
+
+    self.canvas.width = svg.getAttribute('width') * scale;
+    self.canvas.height = svg.getAttribute('height') * scale;
+
+    const html = plotUtils.convertToXHTML(svg.outerHTML);
+    const imgsrc = 'data:image/svg+xml;base64,' + btoa(unescape(encodeURIComponent(html)));
+    const fileName = _.isEmpty(self.stdmodel.title) ? 'plot' : self.stdmodel.title;
+    plotUtils.drawPng(self.canvas, imgsrc, fileName + '.png');
+  }
+
+  getSvgToSave(): any {
+    const plotUtils = require('../plotUtils');
+    const d3 = require('d3');
+    const self = this.scope;
+
+    const svg = self.svg.node().cloneNode(true);
+    svg.setAttribute('xmlns', 'http://www.w3.org/2000/svg');
+    if (document.body.classList.contains('improveFonts')) {
+      svg.setAttribute('class', 'svg-export improveFonts');
+    } else {
+      svg.setAttribute('class', 'svg-export');
+    }
+
+    const plotTitle = self.jqplottitle;
+    const titleOuterHeight = plotUtils.getActualCss(plotTitle, 'outerHeight', true);
+
+    this.adjustSvgPositionWithLegend(svg, titleOuterHeight);
+    this.appendLegendToSvg(d3.select(svg));
+    this.appendTooltipsToSvg(d3.select(svg));
+
+    plotUtils.translateChildren(svg, 0, titleOuterHeight);
+    plotUtils.addTitleToSvg(svg, plotTitle, {
+      width: plotTitle.width(),
+      height: plotUtils.getActualCss(plotTitle, 'outerHeight'),
+    });
+
+    const cellModel = self.getCellModel();
+    let extraStyles: string[] = [];
+    let styleString = '';
+    if (cellModel.element_styles) {
+      for (const style in cellModel.element_styles) {
+        styleString = cellModel.element_styles[style];
+        if (style === '.plot-title') {
+          styleString = plotUtils.adjustStyleForSvg(styleString);
+        }
+        extraStyles.push(style + ' {' + styleString + '}');
+      }
+    }
+
+    if (cellModel.custom_styles) {
+      extraStyles = extraStyles.concat(cellModel.custom_styles);
+    }
+
+    plotUtils.addInlineStyles(svg, extraStyles);
+    this.svgReplaceNbspCharacters(svg);
+
+    return svg;
+  }
+
+  private svgReplaceNbspCharacters(svg: any) {
+    svg.innerHTML = svg.innerHTML.replace(/\&nbsp;/g, ' ');
+  }
+
+  private adjustSvgPositionWithLegend(svg: any, titleOuterHeight: number) {
+    const plotUtils = require('../plotUtils');
+    const $ = require('jquery');
+    const self = this.scope;
+
+    const W = plotUtils.outerWidth(self.jqlegendcontainer);
+    let H = plotUtils.outerHeight(self.jqlegendcontainer);
+    H += titleOuterHeight;
+
+    svg.setAttribute('width', W);
+    svg.setAttribute('height', H);
+    $(svg).css('width', W);
+    $(svg).css('height', H);
+  }
+
+  private appendLegendToSvg(svg: any) {
+    const plotUtils = require('../plotUtils');
+    const $ = require('jquery');
+    const self = this.scope;
+
+    const legend = self.jqlegendcontainer.find('#plotLegend');
+    if (self.legendableItem === 0 || self.stdmodel.showLegend === false || !legend.length) {
+      return;
+    }
+    const legendCopy = self.jqlegendcontainer.find('#plotLegend').clone();
+    legendCopy.find('.plot-legendcheckbox').each(function (i: number, item: any) {
+      if (item.checked) {
+        item.setAttribute('checked', true);
+      }
+      item.setAttribute('onclick', 'return false');
+    });
+    legendCopy.css('position', 'inherit');
+
+    legendCopy.css('top', 'auto');
+    legendCopy.css('left', 'auto');
+    legendCopy.css('bottom', 'auto');
+    legendCopy.css('right', 'auto');
+
+    legendCopy.find("[style*='url']").each(function (i: number, item: any) {
+      let style = $(item).attr('style');
+      style = style.replace('/beaker/', '');
+      $(item).attr('style', style);
+    });
+
+    const getPositive = function (value: number) {
+      return value > 0 ? value : 0;
+    };
+
+    const position = plotUtils.getActualCss(legend, 'position');
+    const x = getPositive(position.left);
+    const y = position.top != null ? getPositive(position.top) : getPositive(position.bottom);
+    svg
+      .append('foreignObject')
+      .attr('width', plotUtils.getActualCss(legend, 'outerWidth', true) + 1)
+      .attr('height', plotUtils.getActualCss(legend, 'outerHeight', true) + 1)
+      .attr('x', x)
+      .attr('y', y)
+      .append('xhtml:body')
+      .attr('style', 'position: relative;')
+      .attr('xmlns', 'http://www.w3.org/1999/xhtml')
+      .html(legendCopy[0].outerHTML);
+  }
+
+  private appendTooltipsToSvg(svg: any) {
+    const plotUtils = require('../plotUtils');
+    const $ = require('jquery');
+    const self = this.scope;
+
+    const tooltipElements = self.jqcontainer.find('.plot-tooltip').toArray();
+    const scopeTipsSize = Object.keys(self.tips).length;
+
+    if (scopeTipsSize > 0 && tooltipElements.length > 0) {
+      tooltipElements.forEach(function (tooltip: any) {
+        tooltip = $(tooltip);
+        const tooltipCopy = tooltip.clone();
+
+        tooltipCopy.css({
+          position: 'inherit',
+          top: 'auto',
+          left: 'auto',
+          bottom: 'auto',
+          right: 'auto',
+        });
+
+        const getPositive = function (value: number) {
+          return value > 0 ? value : 0;
+        };
+
+        const position = plotUtils.getActualCss(tooltip, 'position');
+        const x = getPositive(position.left);
+        const y = position.top != null ? getPositive(position.top) : getPositive(position.bottom);
+
+        svg
+          .append('foreignObject')
+          .attr('width', plotUtils.getActualCss(tooltip, 'outerWidth', true) + 1)
+          .attr('height', plotUtils.getActualCss(tooltip, 'outerHeight', true) + 1)
+          .attr('x', x)
+          .attr('y', y)
+          .append('xhtml:body')
+          .attr('style', 'position: relative;')
+          .attr('xmlns', 'http://www.w3.org/1999/xhtml')
+          .html(tooltipCopy[0].outerHTML);
+      });
+    }
+  }
+}
