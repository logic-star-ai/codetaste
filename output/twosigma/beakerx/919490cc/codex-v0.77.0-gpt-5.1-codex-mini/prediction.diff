@@ -0,0 +1,148 @@
+import * as d3 from 'd3';
+import * as $ from 'jquery';
+
+const plotUtils = require('../plotUtils');
+
+export default class PlotLayout {
+  private scope: any;
+
+  constructor(scope: any) {
+    this.scope = scope;
+  }
+
+  init(): void {
+    const self = this.scope;
+    const model = self.stdmodel;
+    const wrapperId = self.wrapperId;
+    const scopeId = self.id;
+
+    if (self.model.getCellModel().x_tickLabels_visible !== undefined) {
+      model.xAxis.showGridlineLabels = self.model.getCellModel().x_tickLabels_visible;
+    }
+
+    if (self.model.getCellModel().y_tickLabels_visible !== undefined) {
+      model.yAxis.showGridlineLabels = self.model.getCellModel().y_tickLabels_visible;
+    }
+
+    self.element
+      .find('.ui-icon-gripsmall-diagonal-se')
+      .removeClass('ui-icon-gripsmall-diagonal-se')
+      .addClass('ui-icon-grip-diagonal-se');
+
+    self.container = d3.select(self.element[0]).select('.plot-plotcontainer');
+    self.jqcontainer = self.element.find('.plot-plotcontainer');
+    self.jqlegendcontainer = self.element.find('#plotLegendContainer');
+    self.svg = self.container.select('svg');
+    self.jqsvg = self.element.find('#svgg');
+    self.canvas = self.element.find('canvas')[0];
+
+    self.canvas.style.display = 'none';
+
+    const plotSize = self.plotSize;
+    self.jqcontainer.css(plotSize);
+    self.jqsvg.css(plotSize);
+
+    const sanitize = require('../plotSanitize').default;
+
+    if (model.customStyles) {
+      const customStyleString = model.customStyles
+        .map((s: string) => '#' + wrapperId + ' #' + scopeId + ' ' + s)
+        .join('\n');
+      $('<style>' + sanitize(customStyleString) + '\n</style>').prependTo(self.element.find('.plot-plotcontainer'));
+    }
+
+    self.jqplottitle = self.element.find('#plotTitle');
+    self.jqplottitle.text(model.title).css('width', plotSize.width);
+
+    if (model['elementStyles']) {
+      const styles: string[] = [];
+      for (const style in model['elementStyles']) {
+        styles.push('#' + wrapperId + ' #' + scopeId + ' ' + style + ' { ' + model['elementStyles'][style] + '}');
+      }
+      $('<style>\n' + sanitize(styles.join('\n')) + '\n</style>').prependTo(self.element.find('.plot-plotcontainer'));
+
+      if (model['elementStyles']['.plot-title']) {
+        const styleString = '.plot-title-' + scopeId + ' { ' + model['elementStyles']['.plot-title'] + '}';
+        $('<style>\n' + sanitize(styleString) + '\n</style>').prependTo(self.element.find('.plot-title-' + scopeId));
+      }
+    }
+
+    self.maing = d3.select(self.element[0]).select('#maing');
+    self.gridg = d3.select(self.element[0]).select('#gridg');
+    self.labelg = d3.select(self.element[0]).select('#labelg');
+    self.jqgridg = self.element.find('#gridg');
+
+    self.renderFixed = 1;
+    self.layout = {
+      bottomLayoutMargin: 30,
+      topLayoutMargin: 30,
+      leftLayoutMargin: calcVertLayoutMargin(self, self.stdmodel.yAxis),
+      rightLayoutMargin: self.stdmodel.yAxisR ? calcVertLayoutMargin(self, self.stdmodel.yAxisR) : 30,
+      legendMargin: 10,
+      legendBoxSize: 10,
+    };
+
+    self.labelPadding = {x: 10, y: 10};
+    self.intervalStepHint = {x: self.model.getCellModel().type === 'NanoPlot' ? 130 : 75, y: 30};
+    if (self.stdmodel.orientation === 'HORIZONTAL') {
+      const tempx = self.intervalStepHint.x;
+      self.intervalStepHint.x = self.intervalStepHint.y;
+      self.intervalStepHint.y = tempx;
+    }
+    self.numIntervals = {
+      x: parseInt(plotSize.width, 10) / self.intervalStepHint.x,
+      y: parseInt(plotSize.height, 10) / self.intervalStepHint.y,
+    };
+    self.plotZoom.boxZoom.resetLocateBox();
+    self.cursor = {x: -1, y: -1};
+    self.gridlineTickLength = 3;
+
+    let factor = 2.0;
+    if (model.xAxis.label == null) {
+      factor -= 1.0;
+    }
+    if (model.xAxis.showGridlineLabels === false) {
+      factor -= 1.0;
+    }
+    self.layout.bottomLayoutMargin += plotUtils.fonts.labelHeight * factor;
+
+    if (model.yAxis.showGridlineLabels !== false) {
+      self.layout.topLayoutMargin += plotUtils.fonts.labelHeight / 2;
+    }
+
+    if (model.yAxis.label != null) {
+      self.layout.leftLayoutMargin += plotUtils.fonts.labelHeight;
+    }
+    if (model.yAxisR != null) {
+      self.layout.rightLayoutMargin += plotUtils.fonts.labelHeight;
+    }
+    self.legendResetPosition = true;
+
+    self.jqcontainer.on('resize', function (e: any) {
+      e.stopPropagation();
+      e.preventDefault();
+      self.updateModelWidth();
+    });
+  }
+}
+
+function calcVertLayoutMargin(scope: any, axis: any) {
+  const MIN_LEFT_MARGIN = 30;
+  const MIN_WIDTH = 500;
+
+  const model = scope.stdmodel;
+  let result;
+
+  if (axis.type === 'log' && axis.label == null) {
+    result = 30;
+  } else {
+    const size = plotUtils.fonts.ticklabelSize;
+    result = size.width + size.height * 2;
+  }
+
+  if (scope.jqcontainer && scope.jqcontainer.width() > MIN_WIDTH && result < MIN_LEFT_MARGIN) {
+    return MIN_LEFT_MARGIN;
+  }
+
+  return result;
+}
