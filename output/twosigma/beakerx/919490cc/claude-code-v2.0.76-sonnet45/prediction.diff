+import * as $ from 'jquery';
+
+export interface CursorOptions {
+  color?: string;
+  color_opacity?: number;
+  width?: number;
+  stroke_dasharray?: string;
+}
+
+export interface LayoutMargins {
+  leftLayoutMargin: number;
+  rightLayoutMargin: number;
+  topLayoutMargin: number;
+  bottomLayoutMargin: number;
+}
+
+export interface LabelPadding {
+  x: number;
+  y: number;
+}
+
+export default class PlotCursor {
+  private svg: any;
+  private jqcontainer: any;
+  private jqsvg: any;
+  private plotRange: any;
+  private layout: LayoutMargins;
+  private labelPadding: LabelPadding;
+  private plotUtils: any;
+
+  constructor(
+    svg: any,
+    jqcontainer: any,
+    jqsvg: any,
+    plotRange: any,
+    layout: LayoutMargins,
+    labelPadding: LabelPadding,
+    plotUtils: any
+  ) {
+    this.svg = svg;
+    this.jqcontainer = jqcontainer;
+    this.jqsvg = jqsvg;
+    this.plotRange = plotRange;
+    this.layout = layout;
+    this.labelPadding = labelPadding;
+    this.plotUtils = plotUtils;
+  }
+
+  public render(event: MouseEvent, xCursorOpts?: CursorOptions, yCursorOpts?: CursorOptions, yAxis?: any, yAxisR?: any): void {
+    const x = (event as any).offsetX;
+    const y = (event as any).offsetY;
+    const W = this.plotUtils.safeWidth(this.jqsvg);
+    const H = this.plotUtils.safeHeight(this.jqsvg);
+    const lMargin = this.layout.leftLayoutMargin;
+    const rMargin = this.layout.rightLayoutMargin;
+    const tMargin = this.layout.topLayoutMargin;
+    const bMargin = this.layout.bottomLayoutMargin;
+
+    // Clear cursors if outside plot area
+    if (x < lMargin || (yAxisR != null && x > W - rMargin) || y > H - bMargin || y < tMargin) {
+      this.clear();
+      return;
+    }
+
+    // Render X cursor
+    if (xCursorOpts != null) {
+      this.renderXCursor(x, y, W, H, tMargin, bMargin, xCursorOpts, yAxis);
+    }
+
+    // Render Y cursor
+    if (yCursorOpts != null) {
+      this.renderYCursor(x, y, W, H, lMargin, rMargin, yCursorOpts, yAxis, yAxisR);
+    }
+  }
+
+  private renderXCursor(
+    x: number,
+    y: number,
+    W: number,
+    H: number,
+    tMargin: number,
+    bMargin: number,
+    opts: CursorOptions,
+    xAxis: any
+  ): void {
+    // Create or update cursor line
+    this.svg.selectAll("#cursor_x").data([{}]).enter().append("line")
+      .attr("id", "cursor_x")
+      .attr("class", "plot-cursor")
+      .style("stroke", opts.color)
+      .style("stroke-opacity", opts.color_opacity)
+      .style("stroke-width", opts.width)
+      .style("stroke-dasharray", opts.stroke_dasharray);
+
+    this.svg.select("#cursor_x")
+      .attr("x1", x)
+      .attr("y1", tMargin)
+      .attr("x2", x)
+      .attr("y2", H - bMargin);
+
+    // Render label
+    this.jqcontainer.find("#cursor_xlabel").remove();
+    const label = $("<div id='cursor_xlabel' class='plot-cursorlabel'></div>")
+      .appendTo(this.jqcontainer)
+      .text(this.plotUtils.getTipStringPercent(this.plotRange.scr2dataX(x), xAxis));
+
+    const w = label.outerWidth();
+    const h = label.outerHeight();
+
+    label.css({
+      "left": x - w / 2,
+      "top": H - bMargin - this.labelPadding.y - h,
+      "background-color": opts.color != null ? opts.color : "black"
+    });
+  }
+
+  private renderYCursor(
+    x: number,
+    y: number,
+    W: number,
+    H: number,
+    lMargin: number,
+    rMargin: number,
+    opts: CursorOptions,
+    yAxis: any,
+    yAxisR?: any
+  ): void {
+    // Create or update cursor line
+    this.svg.selectAll("#cursor_y").data([{}]).enter().append("line")
+      .attr("id", "cursor_y")
+      .attr("class", "plot-cursor")
+      .style("stroke", opts.color)
+      .style("stroke-opacity", opts.color_opacity)
+      .style("stroke-width", opts.width)
+      .style("stroke-dasharray", opts.stroke_dasharray);
+
+    this.svg.select("#cursor_y")
+      .attr("x1", lMargin)
+      .attr("y1", y)
+      .attr("x2", W - rMargin)
+      .attr("y2", y);
+
+    // Render left Y label
+    this.renderCursorLabel(yAxis, "cursor_ylabel", y, false, opts);
+
+    // Render right Y label if exists
+    if (yAxisR) {
+      this.renderCursorLabel(yAxisR, "cursor_yrlabel", y, true, opts);
+    }
+  }
+
+  private renderCursorLabel(axis: any, id: string, y: number, alignRight: boolean, opts: CursorOptions): void {
+    if (axis == null) {
+      return;
+    }
+
+    const lMargin = this.layout.leftLayoutMargin;
+    const rMargin = this.layout.rightLayoutMargin;
+    const mapY = this.plotRange.scr2dataY;
+
+    this.jqcontainer.find(`#${id}`).remove();
+    const label = $(`<div id='${id}' class='plot-cursorlabel'></div>`)
+      .appendTo(this.jqcontainer)
+      .text(this.plotUtils.getTipStringPercent(mapY(y), axis));
+
+    const w = label.outerWidth();
+    const h = label.outerHeight();
+
+    const css: any = {
+      "top": y - h / 2,
+      "background-color": opts.color != null ? opts.color : "black"
+    };
+
+    if (alignRight) {
+      css["right"] = (rMargin as number) + this.labelPadding.x;
+    } else {
+      css["left"] = (lMargin as number) + this.labelPadding.x;
+    }
+
+    label.css(css);
+  }
+
+  public clear(): void {
+    this.svg.selectAll(".plot-cursor").remove();
+    this.jqcontainer.find(".plot-cursorlabel").remove();
+  }
+}
