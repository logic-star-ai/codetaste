+
+export interface PlotModel {
+  xAxis: PlotAxis;
+  yAxis: PlotAxis;
+  yAxisR?: PlotAxis;
+  showXGridlines?: boolean;
+  orientation?: string;
+  margin?: any;
+  categoryNamesLabelAngle?: number;
