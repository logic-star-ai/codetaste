+export interface GridLineData {
+  id: string;
+  class: string;
+  x1: number;
+  y1: number;
+  x2: number;
+  y2: number;
+}
+
+export interface GridLabelData {
+  id: string;
+  class: string;
+  text: string;
+  x: number;
+  y: number;
+  'text-anchor'?: string;
+  'dominant-baseline'?: string;
