+ *  limitations under the License.
+ */
+
+import GridLines from './GridLines';
+import GridLabels, { LabelPadding, LayoutMargins } from './GridLabels';
+import GridTics from './GridTics';
+import { PlotModel, PlotFocusData, GridLineData, GridLabelData, GridTicData } from './GridInterfaces';
+
+export default class PlotGrid {
+  private plotRange: any;
+  private model: PlotModel;
+  private plotFocus: any;
+  private labelPadding: LabelPadding;
+  private layout: LayoutMargins;
+  private jqsvg: any;
+  private fonts: any;
+  private gridlineTickLength: number;
+  private numIntervals: { x: number; y: number };
+
+  constructor(
+    plotRange: any,
+    model: PlotModel,
+    plotFocus: any,
+    labelPadding: LabelPadding,
+    layout: LayoutMargins,
+    jqsvg: any,
+    fonts: any,
+    gridlineTickLength: number,
+    numIntervals: { x: number; y: number }
+  ) {
+    this.plotRange = plotRange;
+    this.model = model;
+    this.plotFocus = plotFocus;
+    this.labelPadding = labelPadding;
+    this.layout = layout;
+    this.jqsvg = jqsvg;
+    this.fonts = fonts;
+    this.gridlineTickLength = gridlineTickLength;
+    this.numIntervals = numIntervals;
+  }
+
+  public calcGridlines(): void {
+    const focus = this.plotFocus.getFocus();
+
+    this.model.xAxis.setGridlines(
+      focus.xl,
+      focus.xr,
+      this.numIntervals.x,
+      this.model.margin?.left,
+      this.model.margin?.right
+    );
+
+    this.model.yAxis.setGridlines(
+      focus.yl,
+      focus.yr,
+      this.numIntervals.y,
+      this.model.margin?.bottom,
+      this.model.margin?.top
+    );
+
+    if (this.model.yAxisR) {
+      this.model.yAxisR.setGridlines(
+        focus.yl_r,
+        focus.yr_r,
+        this.numIntervals.y,
+        this.model.margin?.bottom_r,
+        this.model.margin?.top_r
+      );
+    }
+  }
+
+  public renderGridlines(): GridLineData[] {
+    const focus = this.plotFocus.getFocus();
+    const gridLines = new GridLines(this.plotRange, this.model, focus);
+    return gridLines.renderAll();
+  }
+
+  public renderGridlineLabels(): GridLabelData[] {
+    const focus = this.plotFocus.getFocus();
+    const gridLabels = new GridLabels(
+      this.plotRange,
+      this.model,
+      focus,
+      this.labelPadding,
+      this.layout,
+      this.jqsvg,
+      this.fonts
+    );
+    return gridLabels.renderAll();
+  }
+
+  public renderGridlineTics(): GridTicData[] {
+    const focus = this.plotFocus.getFocus();
+    const gridTics = new GridTics(this.plotRange, this.model, focus, this.gridlineTickLength);
+    return gridTics.renderAll();
+  }
+}
