+/*
+ *  Copyright 2017 TWO SIGMA OPEN SOURCE, LLC
+ *
+ *  Licensed under the Apache License, Version 2.0 (the "License");
+ *  you may not use this file except in compliance with the License.
+ *  You may obtain a copy of the License at
+ *
+ *         http://www.apache.org/licenses/LICENSE-2.0
+ *
+ *  Unless required by applicable law or agreed to in writing, software
+ *  distributed under the License is distributed on an "AS IS" BASIS,
+ *  WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.
+ *  See the License for the specific language governing permissions and
+ *  limitations under the License.
+ */
+
+import { GridLabelData, PlotFocusData, PlotModel } from './GridInterfaces';
+import * as $ from 'jquery';
+
+export interface LabelPadding {
+  x: number;
+  y: number;
+}
+
+export interface LayoutMargins {
+  leftLayoutMargin: number;
+  bottomLayoutMargin: number;
+}
+
+export default class GridLabels {
+  private plotRange: any;
+  private model: PlotModel;
+  private focus: PlotFocusData;
+  private labelPadding: LabelPadding;
+  private layout: LayoutMargins;
+  private jqsvg: any;
+  private fonts: any;
+
+  constructor(
+    plotRange: any,
+    model: PlotModel,
+    focus: PlotFocusData,
+    labelPadding: LabelPadding,
+    layout: LayoutMargins,
+    jqsvg: any,
+    fonts: any
+  ) {
+    this.plotRange = plotRange;
+    this.model = model;
+    this.focus = focus;
+    this.labelPadding = labelPadding;
+    this.layout = layout;
+    this.jqsvg = jqsvg;
+    this.fonts = fonts;
+  }
+
+  private measureTextSize(text: string, clazz?: string): { width: number; height: number } {
+    const o = $(`<div>${text}</div>`)
+      .css({
+        'position': 'absolute',
+        'float': 'left',
+        'white-space': 'nowrap',
+        'visibility': 'hidden',
+        'class': clazz || ''
+      })
+      .appendTo($('body'));
+
+    const w = o.width();
+    const h = o.height();
+    o.remove();
+
+    return { width: w, height: h };
+  }
+
+  public renderXLabels(): GridLabelData[] {
+    const labels: GridLabelData[] = [];
+
+    if (this.model.xAxis.showGridlineLabels === false) {
+      return labels;
+    }
+
+    const lines = this.model.xAxis.getGridlines();
+    const labelTexts = this.model.xAxis.getGridlineLabels();
+    const mapX = this.plotRange.data2scrX;
+    const mapY = this.plotRange.data2scrY;
+
+    for (let i = 0; i < labelTexts.length; i++) {
+      const x = mapX(lines[i]);
+      const y = mapY(this.focus.yl) + this.labelPadding.y;
+
+      const labelData: GridLabelData = {
+        id: `label_x_${i}`,
+        class: 'plot-label plot-label-x',
+        text: labelTexts[i],
+        x: x,
+        y: y,
+        'text-anchor': 'middle',
+        'dominant-baseline': 'hanging'
+      };
+
+      // Handle category name label angles
+      if (this.model.categoryNamesLabelAngle &&
+          this.model.categoryNamesLabelAngle !== 0 &&
+          this.model.orientation === 'VERTICAL') {
+        const size = this.measureTextSize(labelTexts[i], 'plot-label');
+        const degree = -1 * this.model.categoryNamesLabelAngle * (180 / Math.PI);
+        const delta = degree > 0 ? (size.width / 2) : -1 * (size.width / 2);
+
+        labelData.transform =
+          `translate(${delta} ${-this.labelPadding.y}) ` +
+          `rotate(${degree} ${x - delta} ${y + size.height / 2})`;
+      }
+
+      labels.push(labelData);
+    }
+
+    return labels;
+  }
+
+  public renderYLabels(): GridLabelData[] {
+    const labels: GridLabelData[] = [];
+
+    if (this.model.yAxis.showGridlineLabels === false) {
+      return labels;
+    }
+
+    const lines = this.model.yAxis.getGridlines();
+    const labelTexts = this.model.yAxis.getGridlineLabels();
+    const mapX = this.plotRange.data2scrX;
+    const mapY = this.plotRange.data2scrY;
+
+    for (let i = 0; i < labelTexts.length; i++) {
+      const x = mapX(this.focus.xl) - this.labelPadding.x;
+      const y = mapY(lines[i]);
+
+      const labelData: GridLabelData = {
+        id: `label_y_${i}`,
+        class: 'plot-label plot-label-y',
+        text: labelTexts[i],
+        x: x,
+        y: y,
+        'text-anchor': 'end',
+        'dominant-baseline': 'central'
+      };
+
+      // Handle category name label angles for horizontal orientation
+      if (this.model.categoryNamesLabelAngle &&
+          this.model.categoryNamesLabelAngle !== 0 &&
+          this.model.orientation === 'HORIZONTAL') {
+        labelData.transform =
+          `rotate(${this.model.categoryNamesLabelAngle * (180 / Math.PI)} ${x} ${y})`;
+      }
+
+      labels.push(labelData);
+    }
+
+    return labels;
+  }
+
+  public renderYRLabels(): GridLabelData[] {
+    const labels: GridLabelData[] = [];
+
+    if (!this.model.yAxisR || this.model.yAxisR.showGridlineLabels === false) {
+      return labels;
+    }
+
+    const lines = this.model.yAxisR.getGridlines();
+    const labelTexts = this.model.yAxisR.getGridlineLabels();
+    const mapX = this.plotRange.data2scrX;
+    const mapY_r = this.plotRange.data2scrY_r;
+
+    for (let i = 0; i < labelTexts.length; i++) {
+      const y = lines[i];
+      labels.push({
+        id: `label_yr_${i}`,
+        class: 'plot-label',
+        text: labelTexts[i],
+        x: mapX(this.focus.xr) + this.labelPadding.x,
+        y: mapY_r(y),
+        'dominant-baseline': 'central'
+      });
+    }
+
+    return labels;
+  }
+
+  public renderAxisLabels(): GridLabelData[] {
+    const labels: GridLabelData[] = [];
+    const safeWidth = (jq: any) => parseInt(jq.css('width').replace('px', ''));
+    const safeHeight = (jq: any) => parseInt(jq.css('height').replace('px', ''));
+
+    // X-axis label
+    if (this.model.xAxis.label != null) {
+      labels.push({
+        id: 'xlabel',
+        class: 'plot-xylabel',
+        text: this.model.xAxis.axisLabelWithCommon,
+        x: this.layout.leftLayoutMargin + (safeWidth(this.jqsvg) - this.layout.leftLayoutMargin) / 2,
+        y: safeHeight(this.jqsvg) - this.fonts.labelHeight
+      });
+    }
+
+    // Y-axis label
+    if (this.model.yAxis.label != null) {
+      const x = this.fonts.labelHeight * 2;
+      const y = (safeHeight(this.jqsvg) - this.layout.bottomLayoutMargin) / 2;
+      labels.push({
+        id: 'ylabel',
+        class: 'plot-xylabel',
+        text: this.model.yAxis.label,
+        x: x,
+        y: y,
+        transform: `rotate(-90 ${x} ${y})`
+      });
+    }
+
+    // Right Y-axis label
+    if (this.model.yAxisR && this.model.yAxisR.label != null) {
+      const x = safeWidth(this.jqsvg) - this.fonts.labelHeight;
+      const y = (safeHeight(this.jqsvg) - this.layout.bottomLayoutMargin) / 2;
+      labels.push({
+        id: 'yrlabel',
+        class: 'plot-xylabel',
+        text: this.model.yAxisR.label,
+        x: x,
+        y: y,
+        transform: `rotate(90 ${x} ${y})`
+      });
+    }
+
+    return labels;
+  }
+
+  public renderAll(): GridLabelData[] {
+    return [
+      ...this.renderXLabels(),
+      ...this.renderYLabels(),
+      ...this.renderYRLabels(),
+      ...this.renderAxisLabels()
+    ];
+  }
+}
