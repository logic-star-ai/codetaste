+import { GridTicData, PlotFocusData, PlotModel } from './GridInterfaces';
+
+export default class GridTics {
+  private plotRange: any;
+  private model: PlotModel;
+  private focus: PlotFocusData;
+  private ticLength: number;
+
+  constructor(plotRange: any, model: PlotModel, focus: PlotFocusData, ticLength: number) {
+    this.plotRange = plotRange;
+    this.model = model;
+    this.focus = focus;
+    this.ticLength = ticLength;
+  }
+
+  public renderXTics(): GridTicData[] {
+    const tics: GridTicData[] = [];
+
+    if (!this.model.showXGridlines || this.model.xAxis.showGridlineLabels === false) {
+      return tics;
+    }
+
+    const xGridlines = this.model.xAxis.getGridlines();
+    const mapX = this.plotRange.data2scrX;
+    const mapY = this.plotRange.data2scrY;
+    const yBase = mapY(this.focus.yl);
+
+    for (let i = 0; i < xGridlines.length; i++) {
+      const x = xGridlines[i];
+      const scrX = mapX(x);
+
+      tics.push({
+        id: `tic_x_${i}`,
+        class: 'plot-gridline-tic',
+        x1: scrX,
+        y1: yBase,
+        x2: scrX,
+        y2: yBase + this.ticLength
+      });
+    }
+
+    return tics;
+  }
+
+  public renderYTics(): GridTicData[] {
+    const tics: GridTicData[] = [];
+
+    if (this.model.yAxis.showGridlineLabels === false) {
+      return tics;
+    }
+
+    const yGridlines = this.model.yAxis.getGridlines();
+    const mapX = this.plotRange.data2scrX;
+    const mapY = this.plotRange.data2scrY;
+    const xBase = mapX(this.focus.xl);
+
+    for (let i = 0; i < yGridlines.length; i++) {
+      const y = yGridlines[i];
+      const scrY = mapY(y);
+
+      tics.push({
+        id: `tic_y_${i}`,
+        class: 'plot-gridline-tic',
+        x1: xBase - this.ticLength,
+        y1: scrY,
+        x2: xBase,
+        y2: scrY
+      });
+    }
+
+    return tics;
+  }
+
+  public renderYRTics(): GridTicData[] {
+    const tics: GridTicData[] = [];
+
+    if (!this.model.yAxisR || this.model.yAxisR.showGridlineLabels === false) {
+      return tics;
+    }
+
+    const yGridlines = this.model.yAxisR.getGridlines();
+    const mapX = this.plotRange.data2scrX;
+    const mapY_r = this.plotRange.data2scrY_r;
+    const xBase = mapX(this.focus.xr);
+
+    for (let i = 0; i < yGridlines.length; i++) {
+      const y = yGridlines[i];
+      const scrY = mapY_r(y);
+
+      tics.push({
+        id: `tic_yr_${i}`,
+        class: 'plot-gridline-tic',
+        x1: xBase,
+        y1: scrY,
+        x2: xBase + this.ticLength,
+        y2: scrY
+      });
+    }
+
+    return tics;
+  }
+
+  public renderAll(): GridTicData[] {
+    return [
+      ...this.renderXTics(),
+      ...this.renderYTics(),
+      ...this.renderYRTics()
+    ];
+  }
+}
