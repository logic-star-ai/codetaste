+import { GridLineData, PlotFocusData, PlotModel } from './GridInterfaces';
+
+export default class GridLines {
+  private plotRange: any;
+  private model: PlotModel;
+  private focus: PlotFocusData;
+
+  constructor(plotRange: any, model: PlotModel, focus: PlotFocusData) {
+    this.plotRange = plotRange;
+    this.model = model;
+    this.focus = focus;
+  }
+
+  public renderXGridlines(): GridLineData[] {
+    const gridlines: GridLineData[] = [];
+
+    if (!this.model.showXGridlines) {
+      return gridlines;
+    }
+
+    const xGridlines = this.model.xAxis.getGridlines();
+    const mapX = this.plotRange.data2scrX;
+    const mapY = this.plotRange.data2scrY;
+
+    for (let i = 0; i < xGridlines.length; i++) {
+      const x = xGridlines[i];
+      gridlines.push({
+        id: `gridline_x_${i}`,
+        class: 'plot-gridline',
+        x1: mapX(x),
+        y1: mapY(this.focus.yl),
+        x2: mapX(x),
+        y2: mapY(this.focus.yr)
+      });
+    }
+
+    return gridlines;
+  }
+
+  public renderYGridlines(): GridLineData[] {
+    const gridlines: GridLineData[] = [];
+    const yGridlines = this.model.yAxis.getGridlines();
+    const mapX = this.plotRange.data2scrX;
+    const mapY = this.plotRange.data2scrY;
+
+    for (let i = 0; i < yGridlines.length; i++) {
+      const y = yGridlines[i];
+      gridlines.push({
+        id: `gridline_y_${i}`,
+        class: 'plot-gridline',
+        x1: mapX(this.focus.xl),
+        y1: mapY(y),
+        x2: mapX(this.focus.xr),
+        y2: mapY(y)
+      });
+    }
+
+    return gridlines;
+  }
+
+  public renderBaseGridlines(): GridLineData[] {
+    const gridlines: GridLineData[] = [];
+    const mapX = this.plotRange.data2scrX;
+    const mapY = this.plotRange.data2scrY;
+    const mapY_r = this.plotRange.data2scrY_r;
+
+    // X base gridline
+    gridlines.push({
+      id: 'gridline_x_base',
+      class: 'plot-gridline-base',
+      x1: mapX(this.focus.xl),
+      y1: mapY(this.focus.yl),
+      x2: mapX(this.focus.xr),
+      y2: mapY(this.focus.yl)
+    });
+
+    // Y base gridline
+    gridlines.push({
+      id: 'gridline_y_base',
+      class: 'plot-gridline-base',
+      x1: mapX(this.focus.xl),
+      y1: mapY(this.focus.yl),
+      x2: mapX(this.focus.xl),
+      y2: mapY(this.focus.yr)
+    });
+
+    // YR base gridline (right Y-axis)
+    if (this.focus.yl_r !== undefined && this.focus.yr_r !== undefined) {
+      gridlines.push({
+        id: 'gridline_yr_base',
+        class: 'plot-gridline-base',
+        x1: mapX(this.focus.xr),
+        y1: mapY_r(this.focus.yl_r),
+        x2: mapX(this.focus.xr),
+        y2: mapY_r(this.focus.yr_r)
+      });
+    }
+
+    return gridlines;
+  }
+
+  public renderAll(): GridLineData[] {
+    return [
+      ...this.renderXGridlines(),
+      ...this.renderYGridlines(),
+      ...this.renderBaseGridlines()
+    ];
+  }
+}
