+ *  limitations under the License.
+ */
+
+export interface LegendPositionConfig {
+  position: string;
+  x?: number;
+  y?: number;
+}
+
+export interface LegendDimensions {
+  width: number;
+  height: number;
+}
+
+export interface ContainerDimensions {
+  width: number;
+  height: number;
+}
+
+export default class LegendPosition {
+  private config: LegendPositionConfig;
+  private containerDimensions: ContainerDimensions;
+
+  constructor(config: LegendPositionConfig, containerDimensions: ContainerDimensions) {
+    this.config = config;
+    this.containerDimensions = containerDimensions;
+  }
+
+  public calculatePosition(legendDimensions: LegendDimensions): { left: number; top: number } {
+    // If explicit coordinates are provided, use them
+    if (this.config.x !== undefined && this.config.y !== undefined) {
+      return {
+        left: this.config.x,
+        top: this.config.y
+      };
+    }
+
+    // Calculate based on position string
+    const position = this.config.position || 'TOP_RIGHT';
+    const margin = 10;
+
+    switch (position.toUpperCase()) {
+      case 'TOP_LEFT':
+        return {
+          left: margin,
+          top: margin
+        };
+
+      case 'TOP_RIGHT':
+        return {
+          left: this.containerDimensions.width - legendDimensions.width - margin,
+          top: margin
+        };
+
+      case 'BOTTOM_LEFT':
+        return {
+          left: margin,
+          top: this.containerDimensions.height - legendDimensions.height - margin
+        };
+
+      case 'BOTTOM_RIGHT':
+        return {
+          left: this.containerDimensions.width - legendDimensions.width - margin,
+          top: this.containerDimensions.height - legendDimensions.height - margin
+        };
+
+      case 'LEFT':
+        return {
+          left: margin,
+          top: (this.containerDimensions.height - legendDimensions.height) / 2
+        };
+
+      case 'RIGHT':
+        return {
+          left: this.containerDimensions.width - legendDimensions.width - margin,
+          top: (this.containerDimensions.height - legendDimensions.height) / 2
+        };
+
+      case 'TOP':
+        return {
+          left: (this.containerDimensions.width - legendDimensions.width) / 2,
+          top: margin
+        };
+
+      case 'BOTTOM':
+        return {
+          left: (this.containerDimensions.width - legendDimensions.width) / 2,
+          top: this.containerDimensions.height - legendDimensions.height - margin
+        };
+
+      default:
+        // Default to TOP_RIGHT
+        return {
+          left: this.containerDimensions.width - legendDimensions.width - margin,
+          top: margin
+        };
+    }
+  }
+
+  public updateConfig(config: Partial<LegendPositionConfig>): void {
+    Object.assign(this.config, config);
+  }
+
+  public updateContainerDimensions(dimensions: ContainerDimensions): void {
+    this.containerDimensions = dimensions;
+  }
+}
