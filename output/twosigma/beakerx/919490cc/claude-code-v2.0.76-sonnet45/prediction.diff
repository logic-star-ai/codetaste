+ *  WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.
+ *  See the License for the specific language governing permissions and
+ *  limitations under the License.
+ */
+
+import * as $ from 'jquery';
+
+export interface VisibilityEventHandler {
+  (e: any): void;
+}
+
+export default class PlotInteraction {
+  private scope: any;
+  private svg: any;
+  private onKeyListeners: { [id: string]: any };
+
+  constructor(scope: any, svg: any) {
+    this.scope = scope;
+    this.svg = svg;
+    this.onKeyListeners = {};
+  }
+
+  public prepareInteraction(
+    model: any,
+    plotDisplayModel: any,
+    plotDisplayView: any,
+    plotUtils: any,
+    plotTip: any,
+    onKeyAction: (item: any, onKeyEvent: any) => void,
+    drawLegendPointer: (d: any) => void,
+    removeLegendPointer: () => void
+  ): void {
+    const self = this.scope;
+
+    // Click action handlers
+    this.svg.selectAll(".item-clickable")
+      .on('click.action', function (e) {
+        for (let i = 0; i < model.data.length; i++) {
+          const item = model.data[i];
+          if (item.hasClickAction === true && (item.id === e.id || e.id.indexOf(item.id + "_") === 0)) {
+            const plotId = model.plotId;
+            const plotIndex = model.plotIndex;
+
+            if (item.clickTag && item.clickTag.length > 0) {
+              if (self.model.setActionDetails) {
+                self.model.setActionDetails(plotIndex, item, e);
+              } else {
+                const params = plotUtils.getActionObject(self.model.getCellModel().type, e);
+                params.actionType = 'onclick';
+                params.tag = item.clickTag;
+                plotDisplayModel.send({
+                  event: 'actiondetails',
+                  plotId: plotId,
+                  itemId: item.uid,
+                  params: params
+                }, plotDisplayView.callbacks());
+              }
+            } else {
+              self.legendDone = false;
+              self.legendResetPosition = true;
+              self.doNotLoadState = true;
+              if (self.model.onClick) {
+                self.model.onClick(plotIndex, item, e);
+                return;
+              } else {
+                plotDisplayModel.send(
+                  {
+                    event: 'onclick',
+                    plotId: plotId,
+                    itemId: item.uid,
+                    params: plotUtils.getActionObject(self.model.getCellModel().type, e)
+                  },
+                  plotDisplayView.callbacks()
+                );
+              }
+            }
+          }
+        }
+      });
+
+    // Key action handlers
+    const onKeyElements = this.svg.selectAll(".item-onkey");
+    onKeyElements
+      .on("mouseenter.plot-click", (item) => {
+        if (!this.onKeyListeners[item.id]) {
+          this.onKeyListeners[item.id] = (onKeyEvent) => {
+            onKeyAction(item, onKeyEvent);
+          };
+          $(document).on("keydown.plot-action", this.onKeyListeners[item.id]);
+        }
+      })
+      .on("mouseleave.plot-click", (item) => {
+        const keyListener = this.onKeyListeners[item.id];
+        if (keyListener) {
+          delete this.onKeyListeners[item.id];
+          $(document).off("keydown.plot-action", keyListener);
+        }
+      });
+
+    // Tooltip handlers
+    if (model.useToolTip !== false) {
+      this.svg.selectAll(".plot-resp")
+        .on('mouseenter', function (d) {
+          (window as any).d3.event.stopPropagation();
+          drawLegendPointer(d);
+          return plotTip.tooltip(self, d, (window as any).d3.mouse(self.svg.node()));
+        })
+        .on('mousemove', function (d) {
+          (window as any).d3.event.stopPropagation();
+          removeLegendPointer();
+          drawLegendPointer(d);
+          self.tipmoving = true;
+
+          self.tipTimeout && clearTimeout(self.tipTimeout);
+          self.tipTimeout = setTimeout(function () {
+            self.tipmoving = false;
+          }, 50);
+
+          plotTip.movetooltip(self, d, (window as any).d3.mouse(self.svg.node()));
+        })
+        .on("mouseleave", function (d) {
+          (window as any).d3.event.stopPropagation();
+          removeLegendPointer();
+          return plotTip.untooltip(self, d);
+        })
+        .on("click.resp", function (d) {
+          let hasClickAction = false;
+
+          for (let i = 0; i < model.data.length; i++) {
+            const item = model.data[i];
+            if (item.hasClickAction === true && (item.id === d.id || d.id.indexOf(item.id + "_") === 0)) {
+              hasClickAction = true;
+              break;
+            }
+          }
+
+          return !hasClickAction && plotTip.toggleTooltip(self, d);
+        });
+    }
+  }
+
+  public removeOnKeyListeners(): void {
+    for (const f in this.onKeyListeners) {
+      if (this.onKeyListeners.hasOwnProperty(f)) {
+        $(document).off("keydown.plot-action", this.onKeyListeners[f]);
+      }
+    }
+    this.onKeyListeners = {};
+  }
+
+  public toggleVisibility(event: any): void {
+    // This method is called from legend checkbox clicks
+    // Implementation would handle showing/hiding plot elements
+    // The actual implementation depends on the scope context
+    if (this.scope.toggleVisibility) {
+      this.scope.toggleVisibility(event);
+    }
+  }
+}
