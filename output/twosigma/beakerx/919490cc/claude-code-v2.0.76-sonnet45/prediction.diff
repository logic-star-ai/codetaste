+
+import * as $ from 'jquery';
+
+export type MessageCallback = () => void;
+
+export default class PlotMessage {
+  private jqcontainer: any;
+  private removePipe: string[];
+
+  constructor(jqcontainer: any, removePipe: string[]) {
+    this.jqcontainer = jqcontainer;
+    this.removePipe = removePipe;
+  }
+
+  public render(
+    title: string,
+    msgs: string[],
+    msgid: string,
+    callbacky: MessageCallback | null,
+    callbackn: MessageCallback | null
+  ): void {
+    const self = this;
+
+    this.jqcontainer.find(`#${msgid}`).remove();
+
+    const message = $("<div></div>")
+      .appendTo(this.jqcontainer)
+      .attr("id", msgid)
+      .attr("class", "plot-message")
+      .html(`<div class='plot-message-title'>${title}</div>`);
+
+    for (let i = 0; i < msgs.length; i++) {
+      message.append(`<div class='plot-message-content'>${msgs[i]}</div>`);
+    }
+
+    message
+      .css("top", this.jqcontainer.height() / 2)
+      .css("left", this.jqcontainer.width() / 2);
+
+    message.on("click", function (e) {
+      if (e.which === 1 && callbacky != null) {
+        // Left click - execute positive callback
+        callbacky();
+      }
+      message.remove();
+      const idx = self.removePipe.indexOf(msgid);
+      if (idx > -1) {
+        self.removePipe.splice(idx, 1);
+      }
+    });
+
+    message.on("contextmenu", function (e) {
+      e.preventDefault();
+      if (callbackn != null) {
+        // Right click - execute negative callback
+        callbackn();
+      }
+      message.remove();
+      const idx = self.removePipe.indexOf(msgid);
+      if (idx > -1) {
+        self.removePipe.splice(idx, 1);
+      }
+    });
+  }
+
+  public remove(msgid: string): void {
+    this.jqcontainer.find(`#${msgid}`).remove();
+    const idx = this.removePipe.indexOf(msgid);
+    if (idx > -1) {
+      this.removePipe.splice(idx, 1);
+    }
+  }
+
+  public removeAll(): void {
+    this.removePipe.forEach(msgid => {
+      this.jqcontainer.find(`#${msgid}`).remove();
+    });
+    this.removePipe.length = 0;
+  }
+}
