+}
+
+export interface PlotAxis {
+  label?: string;
+  showGridlineLabels?: boolean;
+  axisLabelWithCommon?: string;
+  setGridlines(min: number, max: number, numIntervals: number, marginMin?: number, marginMax?: number): void;
+  getGridlines(): number[];
+  getGridlineLabels(): string[];
+}
+
+export interface PlotFocusData {
+  xl: number;
+  xr: number;
+  yl: number;
+  yr: number;
+  yl_r?: number;
