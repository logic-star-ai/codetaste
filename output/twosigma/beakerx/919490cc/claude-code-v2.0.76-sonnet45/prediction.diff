+ */
+
+import LegendPosition, { LegendPositionConfig } from './LegendPosition';
+import * as $ from 'jquery';
+
+export interface LegendItem {
+  id: string;
+  legend: string;
+  showItem: boolean;
+  color?: string;
+  color_opacity?: number;
+  stroke?: string;
+  stroke_opacity?: number;
+  isLodItem?: boolean;
+  dataIds: number[];
+}
+
+export interface LegendConfig {
+  showLegend: boolean;
+  legendPosition: LegendPositionConfig;
+  legendLayout: string;
+  omitCheckboxes?: boolean;
+}
+
+export default class PlotLegend {
+  private config: LegendConfig;
+  private legendContainer: any;
+  private legendPosition: LegendPosition;
+  private items: { [id: string]: LegendItem };
+  private isDone: boolean;
+  private shouldResetPosition: boolean;
+
+  constructor(config: LegendConfig, legendContainer: any, containerDimensions: any) {
+    this.config = config;
+    this.legendContainer = legendContainer;
+    this.legendPosition = new LegendPosition(config.legendPosition, containerDimensions);
+    this.items = {};
+    this.isDone = false;
+    this.shouldResetPosition = true;
+  }
+
+  public shouldRender(): boolean {
+    if (Object.keys(this.items).length === 0 ||
+        this.config.showLegend === false ||
+        this.isDone === true) {
+      return false;
+    }
+    return true;
+  }
+
+  public setItems(items: { [id: string]: LegendItem }): void {
+    this.items = items;
+  }
+
+  public markAsDone(): void {
+    this.isDone = true;
+  }
+
+  public markAsNotDone(): void {
+    this.isDone = false;
+  }
+
+  public resetPosition(): void {
+    this.shouldResetPosition = true;
+  }
+
+  public createLegendContainer(scrollableClass?: string, draggableSelector?: string): any {
+    this.legendContainer.find("#plotLegend").remove();
+
+    const legendElement = $("<div></div>")
+      .appendTo(this.legendContainer)
+      .attr("id", "plotLegend")
+      .attr("class", "plot-legend");
+
+    if (scrollableClass) {
+      const scrollable = $("<div></div>")
+        .appendTo(legendElement)
+        .attr("class", scrollableClass);
+      return scrollable;
+    }
+
+    return legendElement;
+  }
+
+  public updatePosition(jqcontainer: any, layoutMargin: number): { left: number; top: number } {
+    const legendElement = this.legendContainer.find("#plotLegend");
+    const isHorizontal = this.config.legendLayout === "HORIZONTAL";
+
+    let position: { left: number; top: number };
+
+    if (this.shouldResetPosition === true) {
+      const legendDimensions = {
+        width: legendElement.width(),
+        height: legendElement.height()
+      };
+      position = this.legendPosition.calculatePosition(legendDimensions);
+      this.shouldResetPosition = false;
+    } else {
+      position = {
+        left: parseFloat(legendElement.css('left')),
+        top: parseFloat(legendElement.css('top'))
+      };
+    }
+
+    legendElement.css(position);
+
+    // Adjust plot container margins based on legend position
+    this.adjustContainerMargins(jqcontainer, legendElement, layoutMargin, isHorizontal);
+
+    // Handle scrolling
+    if (legendElement.length) {
+      const legendDraggable = legendElement.find(".plot-legenddraggable");
+      if (legendElement.get(0).scrollHeight > legendElement.get(0).clientHeight) {
+        legendDraggable.addClass("hasScroll");
+      } else {
+        legendDraggable.removeClass("hasScroll");
+      }
+    }
+
+    return position;
+  }
+
+  private adjustContainerMargins(
+    jqcontainer: any,
+    legendElement: any,
+    margin: number,
+    isHorizontal: boolean
+  ): void {
+    const position = this.config.legendPosition.position;
+
+    // Reset margins
+    jqcontainer.css({
+      "margin-left": "",
+      "margin-top": "",
+      "margin-bottom": "",
+      "margin-right": ""
+    });
+
+    // Set margins based on position
+    if (position === "LEFT") {
+      jqcontainer.css("margin-left", legendElement.width() + margin);
+    }
+    if (position === "TOP") {
+      jqcontainer.css("margin-top", legendElement.height() + margin);
+    }
+    if (position === "BOTTOM") {
+      jqcontainer.css("margin-bottom", legendElement.height() + margin);
+    }
+
+    if (isHorizontal) {
+      if (["TOP_LEFT", "TOP_RIGHT"].indexOf(position) !== -1) {
+        jqcontainer.css("margin-top", legendElement.height() + margin);
+      }
+      if (["BOTTOM_LEFT", "BOTTOM_RIGHT"].indexOf(position) !== -1) {
+        jqcontainer.css("margin-bottom", legendElement.height() + margin);
+      }
+    } else {
+      if (["TOP_LEFT", "BOTTOM_LEFT"].indexOf(position) !== -1) {
+        jqcontainer.css("margin-left", legendElement.width() + margin);
+      }
+    }
+  }
+
+  public getItems(): { [id: string]: LegendItem } {
+    return this.items;
+  }
+
+  public updateLegendPositionConfig(config: Partial<LegendPositionConfig>): void {
+    this.legendPosition.updateConfig(config);
+  }
+}
