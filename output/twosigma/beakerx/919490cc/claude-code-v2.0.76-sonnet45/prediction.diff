+ *  WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.
+ *  See the License for the specific language governing permissions and
+ *  limitations under the License.
+ */
+
+export interface LayoutMargins {
+  bottomLayoutMargin: number;
+  topLayoutMargin: number;
+  leftLayoutMargin: number;
+  rightLayoutMargin: number;
+  legendMargin: number;
+  legendBoxSize: number;
+}
+
+export interface PlotSize {
+  width: number | string;
+  height: number | string;
+}
+
+export interface PlotAxis {
+  label?: string;
+  showGridlineLabels?: boolean;
+}
+
+export default class PlotLayout {
+  private model: any;
+  private plotSize: PlotSize;
+  private fonts: any;
+  private layout: LayoutMargins;
+
+  constructor(model: any, plotSize: PlotSize, fonts: any) {
+    this.model = model;
+    this.plotSize = plotSize;
+    this.fonts = fonts;
+    this.layout = this.initializeLayout();
+  }
+
+  private initializeLayout(): LayoutMargins {
+    const layout: LayoutMargins = {
+      bottomLayoutMargin: 30,
+      topLayoutMargin: 30,
+      leftLayoutMargin: this.calculateVertLayoutMargin(this.model.yAxis),
+      rightLayoutMargin: this.model.yAxisR ? this.calculateVertLayoutMargin(this.model.yAxisR) : 30,
+      legendMargin: 10,
+      legendBoxSize: 10
+    };
+
+    // Adjust bottom margin based on x-axis configuration
+    let factor = 2.0;
+    if (this.model.xAxis.label == null) {
+      factor -= 1.0;
+    }
+    if (this.model.xAxis.showGridlineLabels === false) {
+      factor -= 1.0;
+    }
+    layout.bottomLayoutMargin += this.fonts.labelHeight * factor;
+
+    // Adjust top margin if y-axis labels are shown
+    if (this.model.yAxis.showGridlineLabels !== false) {
+      layout.topLayoutMargin += this.fonts.labelHeight / 2;
+    }
+
+    // Adjust left margin if y-axis has a label
+    if (this.model.yAxis.label != null) {
+      layout.leftLayoutMargin += this.fonts.labelHeight;
+    }
+
+    // Adjust right margin if right y-axis has a label
+    if (this.model.yAxisR != null && this.model.yAxisR.label != null) {
+      layout.rightLayoutMargin += this.fonts.labelHeight;
+    }
+
+    return layout;
+  }
+
+  private calculateVertLayoutMargin(axis: PlotAxis): number {
+    if (!axis || axis.showGridlineLabels === false) {
+      return 30;
+    }
+    return 80;
+  }
+
+  public getLayout(): LayoutMargins {
+    return this.layout;
+  }
+
+  public updateLayout(updates: Partial<LayoutMargins>): void {
+    Object.assign(this.layout, updates);
+  }
+
+  public getPlotSize(): PlotSize {
+    return this.plotSize;
+  }
+
+  public setPlotSize(size: PlotSize): void {
+    this.plotSize = size;
+  }
+}
