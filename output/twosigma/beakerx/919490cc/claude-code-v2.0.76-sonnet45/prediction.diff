+ */
+
+import * as $ from 'jquery';
+
+export interface ResizeHandler {
+  (width: number, height: number): void;
+}
+
+export default class PlotSize {
+  private jqcontainer: any;
+  private jqsvg: any;
+  private model: any;
+  private resizeHandlers: ResizeHandler[];
+
+  constructor(jqcontainer: any, jqsvg: any, model: any) {
+    this.jqcontainer = jqcontainer;
+    this.jqsvg = jqsvg;
+    this.model = model;
+    this.resizeHandlers = [];
+  }
+
+  public setupResize(
+    onResize: () => void
+  ): void {
+    const self = this;
+
+    this.jqcontainer.on('resize', function (e, ui) {
+      e.stopPropagation();
+      e.preventDefault();
+      onResize();
+    });
+
+    $(window).resize(() => {
+      onResize();
+    });
+  }
+
+  public updateModelWidth(newWidth?: number): void {
+    const width = newWidth || this.jqcontainer.width();
+
+    if (this.model.width === width) {
+      return;
+    }
+
+    this.model.width = width;
+    this.jqcontainer.css("width", width);
+    this.jqsvg.css("width", width);
+
+    // Notify all resize handlers
+    this.resizeHandlers.forEach(handler => {
+      handler(width, this.jqcontainer.height());
+    });
+  }
+
+  public emitSizeChange(useMinWidth?: boolean): void {
+    if (this.model.updateWidth !== null && this.model.updateWidth !== undefined) {
+      this.model.updateWidth(this.model.width, useMinWidth);
+    }
+  }
+
+  public addResizeHandler(handler: ResizeHandler): void {
+    this.resizeHandlers.push(handler);
+  }
+
+  public removeResizeHandler(handler: ResizeHandler): void {
+    const index = this.resizeHandlers.indexOf(handler);
+    if (index > -1) {
+      this.resizeHandlers.splice(index, 1);
+    }
+  }
+
+  public getWidth(): number {
+    return this.jqcontainer.width();
+  }
+
+  public getHeight(): number {
+    return this.jqcontainer.height();
+  }
+}
