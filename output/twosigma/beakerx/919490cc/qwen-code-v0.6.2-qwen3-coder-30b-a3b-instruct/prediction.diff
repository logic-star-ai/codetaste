+// Axis types for the plot
+export enum AxisType {
+  LINEAR = 'linear',
+  LOG = 'log',
+  CATEGORY = 'category',
+  TIME = 'time',
+  NANOTIME = 'nanotime'
+}
+
+// Common interface for plot axes
+export interface PlotAxisConfig {
+  type?: AxisType;
+  label?: string;
+  lowerMargin?: number;
+  upperMargin?: number;
+  base?: number;
+  timezone?: string;
+  // Additional axis-specific properties
+}
+
+export class PlotAxis {
+  protected type: AxisType;
+  protected label: string;
+  protected lowerMargin: number;
+  protected upperMargin: number;
+  protected base: number;
+  protected timezone: string;
+  protected gridlines: number[];
+  protected gridlineLabels: string[];
+  protected rangeStart: number;
+  protected rangeEnd: number;
+  
+  constructor(config: PlotAxisConfig = {}) {
+    this.type = config.type || AxisType.LINEAR;
+    this.label = config.label || '';
+    this.lowerMargin = config.lowerMargin || 0;
+    this.upperMargin = config.upperMargin || 0;
+    this.base = config.base || 10;
+    this.timezone = config.timezone || '';
+    this.gridlines = [];
+    this.gridlineLabels = [];
+  }
+  
+  // Initialize range and set up gridlines
+  setRange(start: number, end: number, logBase?: number): void {
+    this.rangeStart = start;
+    this.rangeEnd = end;
+    if (logBase) {
+      this.base = logBase;
+    }
+    
+    // Calculate some basic gridlines based on domain
+    this.generateGridLines();
+  }
+  
+  // Generate gridlines based on range
+  private generateGridLines(): void {
+    // Basic implementation to create evenly spaced gridlines
+    // In a real implementation, this would be more sophisticated
+    const step = (this.rangeEnd - this.rangeStart) / 10;
+    this.gridlines = [];
+    this.gridlineLabels = [];
+    
+    for (let i = 0; i < 10; i++) {
+      const value = this.rangeStart + (i * step);
+      this.gridlines.push(value);
+      this.gridlineLabels.push(value.toFixed(2));
+    }
+  }
+  
+  // Get gridlines
+  getGridlines(): number[] {
+    return this.gridlines;
+  }
+  
+  // Get gridline labels
+  getGridlineLabels(): string[] {
+    return this.gridlineLabels;
+  }
+  
+  // Get axis type
+  getType(): AxisType {
+    return this.type;
+  }
+  
+  // Set axis type
+  setType(type: AxisType): void {
+    this.type = type;
+  }
+  
+  // Get axis label
+  getLabel(): string {
+    return this.label;
+  }
+  
+  // Set axis label
+  setLabel(label: string): void {
+    this.label = label;
+  }
+  
+  // Set the category names for this axis (if it's a category axis)
+  setCategoryNames(names: string[], labels?: any[]): void {
+    // Implementation for category axis specific logic
+  }
+  
+  // Update axis configuration
+  updateConfig(config: PlotAxisConfig): void {
+    Object.assign(this, config);
+    this.generateGridLines(); // regenerate after update
+  }
+  
+  // Get percentage of value in range (for mapping)
+  getPercent(value: number): number {
+    if (this.rangeStart === this.rangeEnd) return 0;
+    return (value - this.rangeStart) / (this.rangeEnd - this.rangeStart);
+  }
+}
