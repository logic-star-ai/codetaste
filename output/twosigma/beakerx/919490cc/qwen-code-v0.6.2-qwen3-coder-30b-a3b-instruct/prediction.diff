+  }
+  
+  // Get the entire configuration
+  getConfig(): PlotModelConfig {
+    return this.config;
+  }
+  
+  // Set the entire configuration
+  setConfig(config: PlotModelConfig): void {
+    this.config = config;
+  }
+  
+  // Get model with preformatting applied
+  getFormattedModel(): any {
+    // This would implement the preformatting logic of plotFormatter
+    return this.config;
+  }
