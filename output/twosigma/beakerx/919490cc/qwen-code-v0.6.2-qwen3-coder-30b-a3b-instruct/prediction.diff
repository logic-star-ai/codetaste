+  yCursor?: any; // Placeholder
+  timezone?: string;
+  categoryNames?: string[];
+  showXGridlines?: boolean;
+  categoryMargin?: number;
+  categoryNamesLabelAngle?: number;
+  cumulative?: boolean;
+  binCount?: number;
