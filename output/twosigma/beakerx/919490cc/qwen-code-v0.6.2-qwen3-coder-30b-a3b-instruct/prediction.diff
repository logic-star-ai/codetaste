+export class PlotSize {
+  private width: number;
+  private height: number;
+  
+  constructor(width: number = 1200, height: number = 700) {
+    this.width = width;
+    this.height = height;
+  }
+  
+  // Get current width
+  getWidth(): number {
+    return this.width;
+  }
+  
+  // Get current height
+  getHeight(): number {
+    return this.height;
+  }
+  
+  // Set width
+  setWidth(width: number): void {
+    this.width = width;
+  }
+  
+  // Set height
+  setHeight(height: number): void {
+    this.height = height;
+  }
+  
+  // Set both width and height
+  setSize(width: number, height: number): void {
+    this.width = width;
+    this.height = height;
+  }
+  
+  // Apply to element (this would be used in DOM manipulation)
+  applyToElement(element: any): void {
+    // Apply size styling to a DOM element
+    element.style.width = this.width + 'px';
+    element.style.height = this.height + 'px';
+  }
+  
+  // Update size based on container resizing
+  resize(width: number, height: number): void {
+    this.setSize(width, height);
+  }
+  
+  // Get size as an object
+  getSize(): { width: number, height: number } {
+    return { width: this.width, height: this.height };
+  }
+  
+  // Get aspect ratio
+  getAspectRatio(): number {
+    return this.width / this.height;
+  }
+}
