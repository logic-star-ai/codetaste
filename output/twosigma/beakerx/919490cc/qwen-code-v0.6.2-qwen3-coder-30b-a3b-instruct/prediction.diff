+export interface PlotModelData {
+  // Define the properties that data items should have
+  id: string;
+  type: string;
+  elements: any[];
+  // Other properties specific to data items
+}
+
+export interface PlotModelConfig {
+  title?: string;
+  showLegend?: boolean;
+  legendPosition?: any; // Placeholder
+  legendLayout?: 'VERTICAL' | 'HORIZONTAL';
+  useToolTip?: boolean;
+  margin?: any; // Placeholder
+  plotSize?: PlotSize;
