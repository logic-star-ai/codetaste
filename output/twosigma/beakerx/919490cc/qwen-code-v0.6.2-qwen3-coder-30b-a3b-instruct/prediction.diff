+
+export interface MessageOptions {
+  type: 'info' | 'warning' | 'error' | 'success';
+  duration?: number; // in milliseconds
+  persistent?: boolean;
+}
+
+export class PlotMessage {
+  private messages: { id: string, message: string, options: MessageOptions }[];
+  
+  constructor() {
+    this.messages = [];
+  }
+  
+  // Show a message with options
+  showMessage(message: string, options: MessageOptions = { type: 'info' }): string {
+    const id = this.generateId();
+    this.messages.push({ id, message, options });
+    // Implementation to render the message
+    return id;
+  }
+  
+  // Show error message
+  showError(message: string, options?: MessageOptions): string {
+    return this.showMessage(message, { ...options, type: 'error' });
+  }
+  
+  // Show warning message
+  showWarning(message: string, options?: MessageOptions): string {
+    return this.showMessage(message, { ...options, type: 'warning' });
+  }
+  
+  // Show info message (default)
+  showInfo(message: string, options?: MessageOptions): string {
+    return this.showMessage(message, { ...options, type: 'info' });
+  }
+  
+  // Show success message
+  showSuccess(message: string, options?: MessageOptions): string {
+    return this.showMessage(message, { ...options, type: 'success' });
+  }
+  
+  // Hide a specific message by ID
+  hideMessage(id: string): boolean {
+    const index = this.messages.findIndex(msg => msg.id === id);
+    if (index !== -1) {
+      this.messages.splice(index, 1);
+      // Implementation to remove from UI
+      return true;
+    }
+    return false;
+  }
+  
+  // Hide all messages
+  hideAllMessages(): void {
+    this.messages = [];
+    // Implementation to remove all from UI
+  }
+  
+  // Generate unique ID for messages
+  private generateId(): string {
+    return Date.now().toString() + Math.random().toString(36).substr(2, 9);
+  }
+  
+  // Get current messages
+  getMessages(): { id: string, message: string, options: MessageOptions }[] {
+    return this.messages;
+  }
+}
