+    const width = this.size.getWidth();
+    const height = this.size.getHeight();
+    
+    // Assign the values to the config for easier access
+    this.config.bottomLayoutMargin = this.margins.bottom;
+    this.config.topLayoutMargin = this.config.topLayoutMargin;
+    this.config.leftLayoutMargin = this.config.leftLayoutMargin;
+    this.config.rightLayoutMargin = this.config.rightLayoutMargin;
+    
+    return this.config;
+  }
+  
+  // Get computed margins
+  getMargins(): LayoutMargins {
+    return this.margins;
+  }
+  
+  // Get calculated layout configuration
+  getLayout(): LayoutConfig {
+    return this.config;
+  }
+  
+  // Set a specific margin
+  setMargin(side: keyof LayoutMargins, value: number): void {
+    this.margins[side] = value;
+  }
+  
+  // Get the number of intervals for x and y axes
+  getNumIntervals(): { x: number, y: number } {
+    const width = this.size.getWidth();
+    const height = this.size.getHeight();
+    
+    const intervalStepHint = {
+      x: this.model.getCellModel().type === 'NanoPlot' ? 130 : 75,
+      y: 30
+    };
+    
+    if (this.model.getOrientation() === 'HORIZONTAL') {
+      const tempX = intervalStepHint.x;
+      intervalStepHint.x = intervalStepHint.y;
+      intervalStepHint.y = tempX;
+    }
+    
+    return {
+      x: Math.floor(width / intervalStepHint.x),
+      y: Math.floor(height / intervalStepHint.y)
+    };
+  }
