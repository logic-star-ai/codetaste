+// WithGlobalFlags returns a context that includes values derived from global CLI flags.
+func WithGlobalFlags(c *cli.Context) context.Context {
+	if c == nil {
+		return context.Background()
+	}
+	ctx := c.Context
+	if ctx == nil {
+		ctx = context.Background()
+	}
+	if c.Bool("yes") {
+		ctx = WithAlwaysYes(ctx, true)
+	}
+	return ctx
+}
