+// WithGlobalFlags parses global flags from the CLI context and returns
+// an enriched context with those flags set
+func WithGlobalFlags(c *cli.Context) context.Context {
+	ctx := c.Context
+	if c.Bool("yes") {
+		ctx = WithAlwaysYes(ctx, true)
+	}
+	if c.Bool("clip") {
+		ctx = WithAutoClip(ctx, true)
+	}
+	if c.Bool("alsoclip") {
+		ctx = WithAutoClip(ctx, true)
+	}
+	return ctx
+}
diff --git a/update_all_tests.sh b/update_all_tests.sh
new file mode 100755
index 0000000..714b010
--- /dev/null
+++ b/update_all_tests.sh
@@ -0,0 +1,111 @@
+#!/bin/bash
+# Script to update all test files to set c.Context = ctx before calling action methods
+
+# Function to update a single file
+update_file() {
+    local file="$1"
+    local tmpfile="${file}.tmp"
+    
+    # Skip if file doesn't exist
+    if [ ! -f "$file" ]; then
+        return
+    fi
+    
+    echo "Processing: $file"
+    
+    # Use awk to intelligently add c.Context = ctx and update function calls
+    awk '
+    BEGIN {
+        in_function = 0
+        last_context_line = 0
+        buffer_size = 0
+    }
+    
+    {
+        # Buffer the current line
+        buffer[buffer_size] = $0
+        buffer_size++
+        
+        # Check if we need to process buffered lines
+        if (buffer_size > 50 || NF == 0) {
+            for (i = 0; i < buffer_size; i++) {
+                print buffer[i]
+            }
+            buffer_size = 0
+        }
+    }
+    
+    END {
+        # Print remaining buffered lines
+        for (i = 0; i < buffer_size; i++) {
+            print buffer[i]
+        }
+    }
+    ' "$file" > "$tmpfile"
+    
+    # Simpler approach using Python
+    python3 << 'PYTHON' "$file" "$tmpfile"
+import sys
+import re
+
+file = sys.argv[1]
+tmpfile = sys.argv[2]
+
+with open(file, 'r') as f:
+    lines = f.readlines()
+
+new_lines = []
+i = 0
+
+while i < len(lines):
+    line = lines[i]
+    new_lines.append(line)
+    
+    # Check if this line creates a cli.Context
+    if 'cli.NewContext(' in line and (' c :=' in line or ' c =' in line):
+        # Look ahead for action method calls
+        j = i + 1
+        while j < min(i + 15, len(lines)):
+            next_line = lines[j]
+            
+            # Check if this line calls a method with (ctx, c)
+            if re.search(r'\b(act|binary|create|xc)\.\w+\(ctx, c[,\)]', next_line):
+                # Insert c.Context = ctx before this line
+                indent = len(next_line) - len(next_line.lstrip())
+                new_lines.append(' ' * indent + 'c.Context = ctx\n')
+                break
+            elif 'cli.NewContext(' in next_line:
+                # Another context creation, stop
+                break
+            elif next_line.strip() and not next_line.strip().startswith('//'):
+                # Non-empty, non-comment line without action call
+                j += 1
+            else:
+                j += 1
+    
+    i += 1
+
+# Write output
+with open(tmpfile, 'w') as f:
+    f.writelines(new_lines)
+
+PYTHON
+    
+    # Now replace (ctx, c) patterns with just (c)
+    sed -i 's/\bact\.\([a-zA-Z]*\)(ctx, c)/act.\1(c)/g' "$tmpfile"
+    sed -i 's/\bbinary\.\([a-zA-Z]*\)(ctx, c/binary.\1(c/g' "$tmpfile"
+    sed -i 's/\bcreate\.\([a-zA-Z]*\)(ctx, c/create.\1(c/g' "$tmpfile"
+    sed -i 's/\bxc\.\([a-zA-Z]*\)(ctx, c/xc.\1(c/g' "$tmpfile"
+    
+    # Move temp file to original
+    mv "$tmpfile" "$file"
+    
+    echo "Updated: $file"
+}
+
+# Find and update all test files
+find /testbed/pkg/action -name '*_test.go' -type f | while read file; do
+    update_file "$file"
+done
+
+echo "All files processed!"
diff --git a/update_tests.py b/update_tests.py
new file mode 100644
index 0000000..bfc6b2c
--- /dev/null
+++ b/update_tests.py
@@ -0,0 +1,138 @@
+#!/usr/bin/env python3
+"""
+Script to update all test files to set c.Context = ctx before calling action methods.
+"""
+
+import re
+import sys
+from pathlib import Path
+
+def update_test_file(filepath):
+    """Update a single test file with the context pattern."""
+    with open(filepath, 'r') as f:
+        content = f.read()
+
+    original_content = content
+    changes_made = []
+
+    # Pattern 1: Find places where cli.NewContext is created and followed by an action call
+    # We need to add c.Context = ctx after creating a new context
+
+    # Pattern: c := cli.NewContext(...) OR c = cli.NewContext(...)
+    # followed by (possibly other code) and then act.Method(ctx, c) or similar
+
+    # Strategy: Find all patterns like "act.Something(ctx, c)" or "binary.Something(ctx, c)"
+    # and replace with setting context first
+
+    # Find all instances where we call methods with (ctx, c) pattern
+    patterns = [
+        # Pattern: act.MethodName(ctx, c)
+        (r'(\s+)(assert\.\w+\(t, )?act\.(\w+)\(ctx, c\)', r'\1\2act.\3(c)'),
+        # Pattern: if err := act.MethodName(ctx, c)
+        (r'if err := act\.(\w+)\(ctx, c\)', r'if err := act.\1(c)'),
+        # Pattern: assert.NoError(t, act.MethodName(ctx, c))
+        (r'assert\.NoError\(t, act\.(\w+)\(ctx, c\)\)', r'assert.NoError(t, act.\1(c))'),
+        # Pattern: assert.Error(t, act.MethodName(ctx, c))
+        (r'assert\.Error\(t, act\.(\w+)\(ctx, c\)\)', r'assert.Error(t, act.\1(c))'),
+        # Pattern: other function calls with ctx, c pattern
+        (r'(\s+)(assert\.\w+\(t, )?(\w+)\.(\w+)\(ctx, c([,\)])', r'\1\2\3.\4(c\5'),
+    ]
+
+    # First pass: identify where we need to add c.Context = ctx
+    # Look for patterns where a cli.Context is created and then used with (ctx, c)
+    lines = content.split('\n')
+    new_lines = []
+    i = 0
+
+    while i < len(lines):
+        line = lines[i]
+
+        # Check if this line creates a new cli.Context
+        if 'cli.NewContext(' in line and ('c :=' in line or 'c =' in line):
+            new_lines.append(line)
+
+            # Check if the next few lines have an action call with (ctx, c)
+            # We need to insert c.Context = ctx before that call
+            j = i + 1
+            inserted = False
+
+            # Look ahead up to 10 lines
+            while j < min(i + 20, len(lines)) and not inserted:
+                next_line = lines[j]
+
+                # Skip empty lines and certain patterns
+                if next_line.strip() == '' or next_line.strip().startswith('//'):
+                    new_lines.append(next_line)
+                    j += 1
+                    continue
+
+                # Check if this line has an action call pattern with (ctx, c)
+                has_ctx_c_call = False
+                patterns_to_check = [
+                    r'act\.\w+\(ctx, c',
+                    r'\w+\.\w+\(ctx, c',
+                    r'err := act\.\w+\(ctx, c',
+                    r'assert\.\w+\(.*, act\.\w+\(ctx, c',
+                ]
+
+                for pattern in patterns_to_check:
+                    if re.search(pattern, next_line):
+                        has_ctx_c_call = True
+                        break
+
+                if has_ctx_c_call:
+                    # Insert c.Context = ctx before this line
+                    indent = len(next_line) - len(next_line.lstrip())
+                    new_lines.append(' ' * indent + 'c.Context = ctx')
+                    changes_made.append(f"Line {j+1}: Added c.Context = ctx")
+                    inserted = True
+                    new_lines.append(next_line)
+                    j += 1
+                    break
+                elif 'cli.NewContext(' in next_line:
+                    # Another context creation, stop looking
+                    break
+                else:
+                    new_lines.append(next_line)
+                    j += 1
+
+            i = j
+        else:
+            new_lines.append(line)
+            i += 1
+
+    content = '\n'.join(new_lines)
+
+    # Second pass: replace (ctx, c) patterns with just (c)
+    for pattern, replacement in patterns:
+        old_content = content
+        content = re.sub(pattern, replacement, content)
+        if content != old_content:
+            changes_made.append(f"Pattern: {pattern}")
+
+    # Check if any changes were made
+    if content != original_content:
+        with open(filepath, 'w') as f:
+            f.write(content)
+        return True, changes_made
+
+    return False, []
+
+def main():
+    # Find all test files in pkg/action
+    test_files = list(Path('/testbed/pkg/action').rglob('*_test.go'))
+
+    updated_files = []
+    for test_file in sorted(test_files):
+        changed, changes = update_test_file(test_file)
+        if changed:
+            updated_files.append(str(test_file))
+            print(f"Updated: {test_file}")
+            for change in changes[:5]:  # Show first 5 changes
+                print(f"  - {change}")
+
+    print(f"\nTotal files updated: {len(updated_files)}")
+    return 0
+
+if __name__ == '__main__':
+    sys.exit(main())
