+
+// withGlobalFlags is a helper to set global flags on the context
+func withGlobalFlags(ctx context.Context, c *cli.Context) context.Context {
+	if c.Bool("yes") {
+		ctx = ctxutil.WithAlwaysYes(ctx, true)
+	}
+	if c.Bool("clip") {
+		ctx = ctxutil.WithAutoClip(ctx, true)
+	}
+	if c.Bool("alsoclip") {
+		ctx = ctxutil.WithAutoClip(ctx, true)
+	}
+	return ctx
