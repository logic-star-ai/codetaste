+++ b/fix_context.py
@@ -0,0 +1,98 @@
+#!/usr/bin/env python3
+import re
+import sys
+from pathlib import Path
+
+def process_file(filepath):
+    """Process a single test file to add c.Context = ctx."""
+    with open(filepath, 'r') as f:
+        lines = f.readlines()
+
+    result_lines = []
+    i = 0
+    changes = 0
+
+    while i < len(lines):
+        line = lines[i]
+
+        # Check if this line creates a cli.Context
+        if 'cli.NewContext(' in line and (' c :=' in line or ' c =' in line):
+            result_lines.append(line)
+
+            # Look ahead to find where we use this context
+            j = i + 1
+            context_added = False
+
+            # Look up to 25 lines ahead
+            while j < min(i + 25, len(lines)):
+                next_line = lines[j]
+
+                # Check for action method calls
+                patterns = [
+                    r'\bact\.\w+\(c[,\)]',
+                    r'\bbinary\.\w+\(c[,\)]',
+                    r'\bcreate\.\w+\(c[,\)]',
+                    r'\bxc\.\w+\(c[,\)]',
+                ]
+
+                found_call = False
+                for pattern in patterns:
+                    if re.search(pattern, next_line):
+                        found_call = True
+                        break
+
+                if found_call and not context_added:
+                    # Add all lines up to here
+                    for k in range(i + 1, j):
+                        result_lines.append(lines[k])
+
+                    # Insert c.Context = ctx
+                    indent = len(next_line) - len(next_line.lstrip())
+                    result_lines.append(' ' * indent + 'c.Context = ctx\n')
+                    changes += 1
+                    context_added = True
+
+                    # Continue from j
+                    i = j - 1
+                    break
+                elif 'cli.NewContext(' in next_line:
+                    # Another cli.NewContext, stop looking
+                    break
+
+                j += 1
+
+            # If we didn't find a call or another context, just continue normally
+            if not context_added:
+                pass  # Line already appended at the start
+
+        else:
+            result_lines.append(line)
+
+        i += 1
+
+    # Write if changed
+    if changes > 0:
+        with open(filepath, 'w') as f:
+            f.writelines(result_lines)
+        return True, changes
+    return False, 0
+
+def main():
+    """Process all test files."""
+    test_files = sorted(Path('/testbed/pkg/action').rglob('*_test.go'))
+
+    updated = []
+    total_changes = 0
+
+    for filepath in test_files:
+        changed, num_changes = process_file(filepath)
+        if changed:
+            updated.append(str(filepath))
+            total_changes += num_changes
+            print(f"Updated: {filepath} ({num_changes} changes)")
+
+    print(f"\nTotal: {len(updated)} files updated, {total_changes} changes")
+    return 0
+
+if __name__ == '__main__':
+    sys.exit(main())
diff --git a/fix_tests.py b/fix_tests.py
new file mode 100644
index 0000000..c695b0b
--- /dev/null
+++ b/fix_tests.py
@@ -0,0 +1,99 @@
+#!/usr/bin/env python3
+import re
+import sys
+from pathlib import Path
+
+def process_file(filepath):
+    """Process a single test file."""
+    with open(filepath, 'r') as f:
+        content = f.read()
+
+    original = content
+
+    # Step 1: Replace all patterns of method(ctx, c) with method(c)
+    # Be careful to match word boundaries
+    patterns = [
+        (r'\bact\.(\w+)\(ctx, c\)', r'act.\1(c)'),
+        (r'\bbinary\.(\w+)\(ctx, c', r'binary.\1(c'),
+        (r'\bcreate\.(\w+)\(ctx, c', r'create.\1(c'),
+        (r'\bxc\.(\w+)\(ctx, c', r'xc.\1(c'),
+    ]
+
+    for pattern, repl in patterns:
+        content = re.sub(pattern, repl, content)
+
+    # Step 2: Add c.Context = ctx after cli.NewContext creation
+    # Split into lines for easier processing
+    lines = content.split('\n')
+    result_lines = []
+    i = 0
+
+    while i < len(lines):
+        line = lines[i]
+        result_lines.append(line)
+
+        # Check if this line creates a cli.Context
+        if 'cli.NewContext(' in line and (' c :=' in line or ' c =' in line):
+            # Look ahead to find where we need to insert c.Context = ctx
+            j = i + 1
+            inserted = False
+
+            # Look up to 20 lines ahead
+            while j < min(i + 20, len(lines)) and not inserted:
+                next_line = lines[j]
+
+                # Skip empty lines and comments
+                if not next_line.strip() or next_line.strip().startswith('//'):
+                    result_lines.append(next_line)
+                    j += 1
+                    continue
+
+                # Check if this line uses the context in a method call
+                # Look for patterns like: act.Method(c), binary.Method(c), etc.
+                if re.search(r'\b(act|binary|create|xc)\.\w+\(c[,\)]', next_line):
+                    # Insert c.Context = ctx before this line
+                    indent = len(next_line) - len(next_line.lstrip())
+                    result_lines.append(' ' * indent + 'c.Context = ctx')
+                    inserted = True
+                    # Don't append next_line yet, it will be added in next iteration
+                    i = j - 1  # Will be incremented at end of loop
+                    break
+                elif 'cli.NewContext(' in next_line:
+                    # Another cli.NewContext, stop looking
+                    i = j - 1
+                    break
+                else:
+                    # Continue looking but add the line
+                    result_lines.append(next_line)
+                    j += 1
+
+            if not inserted and j >= i + 20:
+                # Looked ahead 20 lines, didn't find usage, continue normally
+                pass
+
+        i += 1
+
+    content = '\n'.join(result_lines)
+
+    # Only write if changed
+    if content != original:
+        with open(filepath, 'w') as f:
+            f.write(content)
+        return True
+    return False
+
+def main():
+    """Process all test files."""
+    test_files = sorted(Path('/testbed/pkg/action').rglob('*_test.go'))
+
+    updated = []
+    for filepath in test_files:
+        if process_file(filepath):
+            updated.append(str(filepath))
+            print(f"Updated: {filepath}")
+
+    print(f"\nTotal updated: {len(updated)} files")
+    return 0
+
+if __name__ == '__main__':
+    sys.exit(main())
