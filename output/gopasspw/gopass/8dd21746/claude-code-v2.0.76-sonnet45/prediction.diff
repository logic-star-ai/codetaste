new file mode 100644
index 0000000..79d88d0
--- /dev/null
+++ b/add_context.py
@@ -0,0 +1,110 @@
+#!/usr/bin/env python3
+import re
+import sys
+from pathlib import Path
+
+def process_file(filepath):
+    """Process a single test file to add c.Context = ctx."""
+    with open(filepath, 'r') as f:
+        lines = f.readlines()
+
+    result_lines = []
+    i = 0
+    changes = 0
+
+    while i < len(lines):
+        line = lines[i]
+        result_lines.append(line)
+
+        # Check if this line creates a cli.Context
+        if 'cli.NewContext(' in line and (' c :=' in line or ' c =' in line):
+            # Look ahead to find where we use this context
+            j = i + 1
+            inserted = False
+
+            # Look up to 25 lines ahead
+            while j < min(i + 25, len(lines)) and not inserted:
+                next_line = lines[j]
+
+                # Skip empty lines and comments
+                if not next_line.strip() or next_line.strip().startswith('//'):
+                    result_lines.append(next_line)
+                    j += 1
+                    continue
+
+                # Check for lines that call methods with context
+                # Look for patterns like: act.Method(c), binary.Method(c), etc.
+                # Also look for assert.NoError(t, act.Method(c))
+                patterns = [
+                    r'\bact\.\w+\(c[,\)]',
+                    r'\bbinary\.\w+\(c[,\)]',
+                    r'\bcreate\.\w+\(c[,\)]',
+                    r'\bxc\.\w+\(c[,\)]',
+                ]
+
+                found_call = False
+                for pattern in patterns:
+                    if re.search(pattern, next_line):
+                        found_call = True
+                        break
+
+                if found_call:
+                    # Check if c.Context = ctx is already there
+                    # Look at previous lines
+                    already_has_context = False
+                    for k in range(max(0, len(result_lines) - 5), len(result_lines)):
+                        if 'c.Context = ctx' in result_lines[k]:
+                            already_has_context = True
+                            break
+
+                    if not already_has_context:
+                        # Insert c.Context = ctx before this line
+                        indent = len(next_line) - len(next_line.lstrip())
+                        result_lines.append(' ' * indent + 'c.Context = ctx\n')
+                        changes += 1
+                        inserted = True
+
+                    # Don't append next_line yet, it will be added in next iteration
+                    i = j - 1  # Will be incremented at end of loop
+                    break
+                elif 'cli.NewContext(' in next_line:
+                    # Another cli.NewContext, stop looking
+                    i = j - 1
+                    break
+                else:
+                    # Continue looking but add the line
+                    result_lines.append(next_line)
+                    j += 1
+
+            if not inserted and j >= i + 25:
+                # Looked ahead 25 lines, didn't find usage
+                pass
+
+        i += 1
+
+    # Write if changed
+    if changes > 0:
+        with open(filepath, 'w') as f:
+            f.writelines(result_lines)
+        return True, changes
+    return False, 0
+
+def main():
+    """Process all test files."""
+    test_files = sorted(Path('/testbed/pkg/action').rglob('*_test.go'))
+
+    updated = []
+    total_changes = 0
+
+    for filepath in test_files:
+        changed, num_changes = process_file(filepath)
+        if changed:
+            updated.append(str(filepath))
+            total_changes += num_changes
+            print(f"Updated: {filepath} ({num_changes} changes)")
+
+    print(f"\nTotal: {len(updated)} files updated, {total_changes} changes")
+    return 0
+
+if __name__ == '__main__':
+    sys.exit(main())
