index 0000000..880a7ec
--- /dev/null
+++ b/pkg/ctxutil/global_flags.go
@@ -0,0 +1,23 @@
+package ctxutil
+
+import (
+	"context"
+
+	"github.com/urfave/cli/v2"
+)
+
+// WithGlobalFlags parses global flags from the CLI context and returns
+// a derived context that carries them.
+func WithGlobalFlags(c *cli.Context) context.Context {
+	var ctx context.Context = context.Background()
+	if c != nil && c.Context != nil {
+		ctx = c.Context
+	}
+
+	if c != nil && c.Bool("yes") {
+		ctx = WithAlwaysYes(ctx, true)
+	}
+
+	return ctx
+}
+
