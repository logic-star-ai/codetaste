+func setupApp(ctx context.Context, sv semver.Version) (context.Context, *cli.App) {
+	// Create a new action
+	action := &action.Action{}
+
+	app := &cli.App{
+		Name:    name,
+		Usage:   "The standard Unix password manager",
+		Version: sv.String(),
+		Flags: []cli.Flag{
+			&cli.BoolFlag{
+				Name:  "yes",
+				Usage: "Assume yes for all prompts",
+			},
+		},
+		Commands: getCommands(ctx, action),
+		Before: func(c *cli.Context) error {
+			return nil
+		},
+	}
+	return ctx, app
+}
+
+func getCommands(ctx context.Context, action *action.Action) []*cli.Command {
+	// Collect commands from all modules
+	commands := []*cli.Command{}
+
+	// Add core commands
+	commands = append(commands, action.GetCommands()...)
+
+	// Add binary commands
+	commands = append(commands, binary.GetCommands()...)
+
+	// Add create commands
+	commands = append(commands, create.GetCommands()...)
+
+	// Add xc commands
+	commands = append(commands, xc.GetCommands()...)
+
+	// Sort commands alphabetically
+	cli.SortCommands(commands)
+
+	return commands
+}
