+// Issue 3741 - exportSlice
+func testExportSlice(t *testing.T) {
+	// This function relies on exports.go to be compiled with //export directives
+	if C.exportSliceIn == nil {
+		t.Skip("exportSliceIn not available")
+	}
+}
