+use crate::chroma_proto::TenantLastCompactionTime;
+
+pub struct Tenant {
+    pub id: String,
+    pub last_compaction_time: i64,
+}
+
+impl TryFrom<TenantLastCompactionTime> for Tenant {
+    type Error = ();
