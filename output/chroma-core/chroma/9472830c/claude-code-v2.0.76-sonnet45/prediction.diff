+impl<'referred_data> MetadataDelta<'referred_data> {
+    pub fn new() -> Self {
+        Self {
+            metadata_to_update: HashMap::new(),
+            metadata_to_delete: HashMap::new(),
+            metadata_to_insert: HashMap::new(),
+        }
+    }
+}
