+[package]
+name = "chroma-blockstore"
+version = "0.1.0"
+edition = "2021"
+
+[lib]
+name = "chroma_blockstore"
+path = "src/lib.rs"
+
+[dependencies]
+async-trait = "0.1.74"
+arrow = "52.0.0"
+bytes = "1.5.0"
+chroma-cache = { path = "../cache" }
+chroma-config = { path = "../config" }
+chroma-error = { path = "../error" }
+chroma-storage = { path = "../storage" }
+chroma-types = { path = "../types" }
+flatbuffers = "24.3.25"
+futures = "0.3"
+parking_lot = "0.12.1"
+rand = "0.8.5"
+roaring = "0.10.3"
+tantivy = "0.21.1"
+thiserror = "1.0.50"
+tokio = { version = "1.0", features = ["macros", "rt-multi-thread"] }
+tracing = "0.1"
+uuid = { version = "1.6.1", features = ["v4", "fast-rng", "macro-diagnostics"] }
+
+[dev-dependencies]
+num_cpus = "1.16.0"
+rand_xorshift = "0.3.0"
+shuttle = "0.7.1"
+tempfile = "3.8.1"
