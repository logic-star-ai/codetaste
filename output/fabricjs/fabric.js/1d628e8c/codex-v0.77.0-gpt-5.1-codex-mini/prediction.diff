diff --git a/src/env/glProbe.ts b/src/env/glProbe.ts
new file mode 100644
index 0000000..4a822c3
--- /dev/null
+++ b/src/env/glProbe.ts
@@ -0,0 +1,71 @@
+export enum GLPrecision {
+  low = 'lowp',
+  medium = 'mediump',
+  high = 'highp',
+}
+
+/**
+ * Shared logic for probing WebGL capabilities.
+ */
+export abstract class GLProbe {
+  public maxTextureSize?: number;
+  public precision?: GLPrecision;
+
+  /**
+   * Attempts to create a WebGL context and evaluate its capabilities.
+   */
+  query(): void {
+    const gl = this.createContext();
+    if (!gl) {
+      return;
+    }
+    this.maxTextureSize = gl.getParameter(gl.MAX_TEXTURE_SIZE);
+    this.precision = Object.values(GLPrecision).find((precision) =>
+      this.testPrecision(gl, precision)
+    );
+    console.log(`fabric: max texture size ${this.maxTextureSize}`);
+  }
+
+  /**
+   * Whether the current environment is able to handle the requested texture size.
+   */
+  isSupported(textureSize: number): boolean {
+    return !!this.maxTextureSize && this.maxTextureSize >= textureSize;
+  }
+
+  protected abstract createContext(): WebGLRenderingContext | null;
+
+  private testPrecision(
+    gl: WebGLRenderingContext,
+    precision: GLPrecision
+  ): boolean {
+    const fragmentSource = `precision ${precision} float;\nvoid main(){}`;
+    const fragmentShader = gl.createShader(gl.FRAGMENT_SHADER);
+    if (!fragmentShader) {
+      return false;
+    }
+    gl.shaderSource(fragmentShader, fragmentSource);
+    gl.compileShader(fragmentShader);
+    return !!gl.getShaderParameter(fragmentShader, gl.COMPILE_STATUS);
+  }
+}
+
+export class BrowserWebGLProbe extends GLProbe {
+  constructor(private readonly document: Document) {
+    super();
+  }
+
+  protected createContext(): WebGLRenderingContext | null {
+    const canvas = this.document.createElement('canvas');
+    return (
+      (canvas.getContext('webgl') ||
+        canvas.getContext('experimental-webgl')) as WebGLRenderingContext | null
+    );
+  }
+}
+
+export class NodeGLProbe extends GLProbe {
+  protected createContext(): WebGLRenderingContext | null {
+    return null;
+  }
+}
