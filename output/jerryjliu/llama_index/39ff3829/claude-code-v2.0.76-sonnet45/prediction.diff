@@ -0,0 +1,521 @@
+"""Base prompt template classes - LangChain-independent implementation."""
+
+from abc import ABC, abstractmethod
+from copy import deepcopy
+from string import Formatter
+from typing import Any, Callable, Dict, List, Optional, Tuple
+
+from llama_index.llms.base import LLM, ChatMessage, MessageRole
+from llama_index.types import BaseOutputParser
+
+
+class BasePromptTemplate(ABC):
+    """Abstract base class for all prompt templates.
+
+    This class provides an explicit, self-contained interface for prompt templates,
+    removing the dependency on LangChain's prompt template system.
+    """
+
+    def __init__(
+        self,
+        metadata: Optional[Dict[str, Any]] = None,
+        template_var_mappings: Optional[Dict[str, Any]] = None,
+        output_parser: Optional[BaseOutputParser] = None,
+    ) -> None:
+        """Initialize the base prompt template.
+
+        Args:
+            metadata: Optional metadata dictionary
+            template_var_mappings: Optional variable mappings for templates
+            output_parser: Optional output parser
+        """
+        self.metadata = metadata or {}
+        self.template_var_mappings = template_var_mappings or {}
+        self.output_parser = output_parser
+
+    @abstractmethod
+    def format(self, llm: Optional[LLM] = None, **kwargs: Any) -> str:
+        """Format the prompt into a string.
+
+        Args:
+            llm: Optional LLM for LLM-specific formatting
+            **kwargs: Template variables
+
+        Returns:
+            Formatted prompt string
+        """
+        pass
+
+    @abstractmethod
+    def format_messages(
+        self, llm: Optional[LLM] = None, **kwargs: Any
+    ) -> List[ChatMessage]:
+        """Format the prompt into a list of chat messages.
+
+        Args:
+            llm: Optional LLM for LLM-specific formatting
+            **kwargs: Template variables
+
+        Returns:
+            List of chat messages
+        """
+        pass
+
+    @abstractmethod
+    def get_template_vars(self) -> List[str]:
+        """Get the template variables.
+
+        Returns:
+            List of template variable names
+        """
+        pass
+
+    @abstractmethod
+    def partial_format(self, **kwargs: Any) -> "BasePromptTemplate":
+        """Partially format the prompt.
+
+        Args:
+            **kwargs: Partial template variables
+
+        Returns:
+            New prompt template with partially filled values
+        """
+        pass
+
+
+class PromptTemplate(BasePromptTemplate):
+    """Basic text-based prompt template.
+
+    This template uses Python's string formatting to create prompts from templates.
+    """
+
+    def __init__(
+        self,
+        template: str,
+        template_vars: Optional[List[str]] = None,
+        partial_dict: Optional[Dict[str, Any]] = None,
+        **kwargs: Any,
+    ) -> None:
+        """Initialize the prompt template.
+
+        Args:
+            template: The template string with {variable} placeholders
+            template_vars: Optional list of template variable names (auto-detected if None)
+            partial_dict: Optional dictionary of partially filled values
+            **kwargs: Additional arguments passed to BasePromptTemplate
+        """
+        super().__init__(**kwargs)
+        self.template = template
+        self.partial_dict = partial_dict or {}
+
+        # Auto-detect template variables if not provided
+        if template_vars is None:
+            self.template_vars = self._extract_template_vars(template)
+        else:
+            self.template_vars = template_vars
+
+    def _extract_template_vars(self, template: str) -> List[str]:
+        """Extract template variables from a template string.
+
+        Args:
+            template: Template string
+
+        Returns:
+            List of variable names
+        """
+        formatter = Formatter()
+        vars_list = []
+        for _, var_name, _, _ in formatter.parse(template):
+            if var_name is not None and var_name not in vars_list:
+                vars_list.append(var_name)
+        return vars_list
+
+    def format(self, llm: Optional[LLM] = None, **kwargs: Any) -> str:
+        """Format the prompt into a string.
+
+        Args:
+            llm: Optional LLM (unused in basic template)
+            **kwargs: Template variables
+
+        Returns:
+            Formatted prompt string
+        """
+        # Merge partial values with provided kwargs
+        all_kwargs = {**self.partial_dict, **kwargs}
+        return self.template.format(**all_kwargs)
+
+    def format_messages(
+        self, llm: Optional[LLM] = None, **kwargs: Any
+    ) -> List[ChatMessage]:
+        """Format the prompt into a list of chat messages.
+
+        For basic text templates, this creates a single user message.
+
+        Args:
+            llm: Optional LLM (unused in basic template)
+            **kwargs: Template variables
+
+        Returns:
+            List with a single user message
+        """
+        formatted_str = self.format(llm=llm, **kwargs)
+        return [ChatMessage(role=MessageRole.USER, content=formatted_str)]
+
+    def get_template_vars(self) -> List[str]:
+        """Get the template variables.
+
+        Returns:
+            List of template variable names
+        """
+        return [var for var in self.template_vars if var not in self.partial_dict]
+
+    def partial_format(self, **kwargs: Any) -> "PromptTemplate":
+        """Partially format the prompt.
+
+        Args:
+            **kwargs: Partial template variables
+
+        Returns:
+            New prompt template with partially filled values
+        """
+        # Handle output parser deepcopy issue
+        output_parser = self.output_parser
+        self.output_parser = None
+
+        # Create a deep copy
+        new_template = deepcopy(self)
+        new_template.output_parser = output_parser
+        new_template.partial_dict = {**self.partial_dict, **kwargs}
+
+        # Restore original output parser
+        self.output_parser = output_parser
+
+        return new_template
+
+
+class ChatMessageTemplateInfo:
+    """Information about a chat message template."""
+
+    def __init__(
+        self,
+        role: MessageRole,
+        content: str,
+        template_vars: Optional[List[str]] = None,
+    ) -> None:
+        """Initialize chat message template info.
+
+        Args:
+            role: Message role (system, user, assistant, function)
+            content: Message content template
+            template_vars: Optional list of template variable names
+        """
+        self.role = role
+        self.content = content
+
+        # Auto-detect template variables if not provided
+        if template_vars is None:
+            formatter = Formatter()
+            self.template_vars = []
+            for _, var_name, _, _ in formatter.parse(content):
+                if var_name is not None and var_name not in self.template_vars:
+                    self.template_vars.append(var_name)
+        else:
+            self.template_vars = template_vars
+
+
+class ChatPromptTemplate(BasePromptTemplate):
+    """Chat-based prompt template.
+
+    This template creates structured chat messages with different roles
+    (system, user, assistant, function).
+    """
+
+    def __init__(
+        self,
+        message_templates: List[ChatMessageTemplateInfo],
+        partial_dict: Optional[Dict[str, Any]] = None,
+        **kwargs: Any,
+    ) -> None:
+        """Initialize the chat prompt template.
+
+        Args:
+            message_templates: List of message template information
+            partial_dict: Optional dictionary of partially filled values
+            **kwargs: Additional arguments passed to BasePromptTemplate
+        """
+        super().__init__(**kwargs)
+        self.message_templates = message_templates
+        self.partial_dict = partial_dict or {}
+
+    def format(self, llm: Optional[LLM] = None, **kwargs: Any) -> str:
+        """Format the prompt into a string.
+
+        For chat templates, this concatenates all messages.
+
+        Args:
+            llm: Optional LLM (unused in basic template)
+            **kwargs: Template variables
+
+        Returns:
+            Formatted prompt string (concatenated messages)
+        """
+        messages = self.format_messages(llm=llm, **kwargs)
+        return "\n\n".join([f"{msg.role}: {msg.content}" for msg in messages])
+
+    def format_messages(
+        self, llm: Optional[LLM] = None, **kwargs: Any
+    ) -> List[ChatMessage]:
+        """Format the prompt into a list of chat messages.
+
+        Args:
+            llm: Optional LLM (unused in basic template)
+            **kwargs: Template variables
+
+        Returns:
+            List of formatted chat messages
+        """
+        # Merge partial values with provided kwargs
+        all_kwargs = {**self.partial_dict, **kwargs}
+
+        messages = []
+        for msg_template in self.message_templates:
+            content = msg_template.content.format(**all_kwargs)
+            additional_kwargs = {}
+
+            # Extract additional_kwargs if present
+            if "additional_kwargs" in all_kwargs:
+                additional_kwargs = all_kwargs["additional_kwargs"]
+
+            messages.append(
+                ChatMessage(
+                    role=msg_template.role,
+                    content=content,
+                    additional_kwargs=additional_kwargs,
+                )
+            )
+
+        return messages
+
+    def get_template_vars(self) -> List[str]:
+        """Get the template variables.
+
+        Returns:
+            List of template variable names
+        """
+        all_vars = []
+        for msg_template in self.message_templates:
+            for var in msg_template.template_vars:
+                if var not in self.partial_dict and var not in all_vars:
+                    all_vars.append(var)
+        return all_vars
+
+    def partial_format(self, **kwargs: Any) -> "ChatPromptTemplate":
+        """Partially format the prompt.
+
+        Args:
+            **kwargs: Partial template variables
+
+        Returns:
+            New chat prompt template with partially filled values
+        """
+        # Handle output parser deepcopy issue
+        output_parser = self.output_parser
+        self.output_parser = None
+
+        # Create a deep copy
+        new_template = deepcopy(self)
+        new_template.output_parser = output_parser
+        new_template.partial_dict = {**self.partial_dict, **kwargs}
+
+        # Restore original output parser
+        self.output_parser = output_parser
+
+        return new_template
+
+
+class SelectorPromptTemplate(BasePromptTemplate):
+    """Conditional prompt template selector.
+
+    Selects different prompts based on LLM type at format time.
+    """
+
+    def __init__(
+        self,
+        default_template: BasePromptTemplate,
+        conditionals: Optional[
+            List[Tuple[Callable[[LLM], bool], BasePromptTemplate]]
+        ] = None,
+        **kwargs: Any,
+    ) -> None:
+        """Initialize the selector prompt template.
+
+        Args:
+            default_template: Default template to use
+            conditionals: List of (condition_func, template) pairs
+            **kwargs: Additional arguments passed to BasePromptTemplate
+        """
+        super().__init__(**kwargs)
+        self.default_template = default_template
+        self.conditionals = conditionals or []
+
+    def _select_template(self, llm: Optional[LLM] = None) -> BasePromptTemplate:
+        """Select the appropriate template based on LLM.
+
+        Args:
+            llm: Optional LLM to check conditions against
+
+        Returns:
+            Selected template
+        """
+        if llm is not None:
+            for condition, template in self.conditionals:
+                if condition(llm):
+                    return template
+        return self.default_template
+
+    def format(self, llm: Optional[LLM] = None, **kwargs: Any) -> str:
+        """Format the prompt into a string.
+
+        Args:
+            llm: Optional LLM for template selection
+            **kwargs: Template variables
+
+        Returns:
+            Formatted prompt string
+        """
+        template = self._select_template(llm)
+        return template.format(llm=llm, **kwargs)
+
+    def format_messages(
+        self, llm: Optional[LLM] = None, **kwargs: Any
+    ) -> List[ChatMessage]:
+        """Format the prompt into a list of chat messages.
+
+        Args:
+            llm: Optional LLM for template selection
+            **kwargs: Template variables
+
+        Returns:
+            List of chat messages
+        """
+        template = self._select_template(llm)
+        return template.format_messages(llm=llm, **kwargs)
+
+    def get_template_vars(self) -> List[str]:
+        """Get the template variables from the default template.
+
+        Returns:
+            List of template variable names
+        """
+        return self.default_template.get_template_vars()
+
+    def partial_format(self, **kwargs: Any) -> "SelectorPromptTemplate":
+        """Partially format all templates in the selector.
+
+        Args:
+            **kwargs: Partial template variables
+
+        Returns:
+            New selector with partially formatted templates
+        """
+        new_default = self.default_template.partial_format(**kwargs)
+        new_conditionals = [
+            (condition, template.partial_format(**kwargs))
+            for condition, template in self.conditionals
+        ]
+
+        return SelectorPromptTemplate(
+            default_template=new_default,
+            conditionals=new_conditionals,
+            metadata=self.metadata,
+            template_var_mappings=self.template_var_mappings,
+            output_parser=self.output_parser,
+        )
+
+
+class LangchainPromptTemplate(BasePromptTemplate):
+    """Compatibility wrapper for LangChain prompts.
+
+    This allows existing LangChain prompts to work with the new interface.
+    """
+
+    def __init__(
+        self,
+        template: Any,  # BaseLangchainPrompt type, but we avoid the import
+        partial_dict: Optional[Dict[str, Any]] = None,
+        **kwargs: Any,
+    ) -> None:
+        """Initialize the LangChain prompt wrapper.
+
+        Args:
+            template: LangChain prompt template object
+            partial_dict: Optional dictionary of partially filled values
+            **kwargs: Additional arguments passed to BasePromptTemplate
+        """
+        super().__init__(**kwargs)
+        self.template = template
+        self.partial_dict = partial_dict or {}
+
+    def format(self, llm: Optional[LLM] = None, **kwargs: Any) -> str:
+        """Format the prompt into a string.
+
+        Args:
+            llm: Optional LLM (unused)
+            **kwargs: Template variables
+
+        Returns:
+            Formatted prompt string
+        """
+        all_kwargs = {**self.partial_dict, **kwargs}
+        return self.template.format(**all_kwargs)
+
+    def format_messages(
+        self, llm: Optional[LLM] = None, **kwargs: Any
+    ) -> List[ChatMessage]:
+        """Format the prompt into a list of chat messages.
+
+        Args:
+            llm: Optional LLM (unused)
+            **kwargs: Template variables
+
+        Returns:
+            List of chat messages
+        """
+        from llama_index.llms.langchain_utils import from_lc_messages
+
+        all_kwargs = {**self.partial_dict, **kwargs}
+        lc_value = self.template.format_prompt(**all_kwargs)
+        lc_messages = lc_value.to_messages()
+        return from_lc_messages(lc_messages)
+
+    def get_template_vars(self) -> List[str]:
+        """Get the template variables.
+
+        Returns:
+            List of template variable names
+        """
+        vars_list = self.template.input_variables
+        return [var for var in vars_list if var not in self.partial_dict]
+
+    def partial_format(self, **kwargs: Any) -> "LangchainPromptTemplate":
+        """Partially format the prompt.
+
+        Args:
+            **kwargs: Partial template variables
+
+        Returns:
+            New wrapped template with partially filled values
+        """
+        # Handle output parser deepcopy issue
+        output_parser = self.output_parser
+        self.output_parser = None
+
+        # Create a deep copy
+        new_template = deepcopy(self)
+        new_template.output_parser = output_parser
+        new_template.partial_dict = {**self.partial_dict, **kwargs}
+
+        # Restore original output parser
+        self.output_parser = output_parser
+
+        return new_template
