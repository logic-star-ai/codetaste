+#!/usr/bin/env python
+"""
+Verification script for prompt template refactoring.
+
+This script verifies that:
+1. New prompt template classes work correctly
+2. Backward compatibility is maintained
+3. All imports work as expected
+4. LangChain dependency can be avoided for new code
+"""
+
+import sys
+
+
+def test_new_imports():
+    """Test that new classes can be imported."""
+    print("Testing new imports...")
+    try:
+        from llama_index.prompts import (
+            BasePromptTemplate,
+            ChatMessageTemplateInfo,
+            ChatPromptTemplate,
+            LangchainPromptTemplate,
+            Prompt,
+            PromptSelector,
+            PromptTemplate,
+            SelectorPromptTemplate,
+            is_chat_model,
+        )
+        print("  ✓ All new classes can be imported")
+        return True
+    except Exception as e:
+        print(f"  ✗ Import failed: {e}")
+        return False
+
+
+def test_backward_compatible_imports():
+    """Test that old imports still work."""
+    print("\nTesting backward compatible imports...")
+    try:
+        from llama_index.prompts.base import Prompt
+        from llama_index.prompts.prompts import (
+            KeywordExtractPrompt,
+            QuestionAnswerPrompt,
+            RefinePrompt,
+            SummaryPrompt,
+        )
+        print("  ✓ Backward compatible imports work")
+        return True
+    except Exception as e:
+        print(f"  ✗ Import failed: {e}")
+        return False
+
+
+def test_basic_functionality():
+    """Test basic prompt template functionality."""
+    print("\nTesting basic functionality...")
+    try:
+        from llama_index.prompts import Prompt, PromptTemplate
+
+        # Test 1: Basic string template
+        prompt = Prompt("Hello {name}")
+        result = prompt.format(name="World")
+        assert result == "Hello World", f"Expected 'Hello World', got '{result}'"
+        print("  ✓ Basic string template works")
+
+        # Test 2: PromptTemplate
+        template = PromptTemplate(template="Hello {name}")
+        result = template.format(name="World")
+        assert result == "Hello World", f"Expected 'Hello World', got '{result}'"
+        print("  ✓ PromptTemplate works")
+
+        # Test 3: Partial formatting
+        prompt = Prompt("Hello {name}, you are {age}")
+        partial = prompt.partial_format(name="Alice")
+        result = partial.format(age=30)
+        assert (
+            result == "Hello Alice, you are 30"
+        ), f"Expected 'Hello Alice, you are 30', got '{result}'"
+        print("  ✓ Partial formatting works")
+
+        return True
+    except Exception as e:
+        print(f"  ✗ Functionality test failed: {e}")
+        import traceback
+
+        traceback.print_exc()
+        return False
+
+
+def test_chat_templates():
