+"""Test new prompt template architecture."""
+
+from llama_index.prompts import (
+    BasePromptTemplate,
+    ChatMessageTemplateInfo,
+    ChatPromptTemplate,
+    LangchainPromptTemplate,
+    Prompt,
+    PromptTemplate,
+    SelectorPromptTemplate,
+)
+from llama_index.llms.base import LLM, LLMMetadata, MessageRole
+from llama_index.llms.openai import OpenAI
+from llama_index.bridge.langchain import PromptTemplate as LCPromptTemplate
+
+
+def test_basic_prompt_template():
+    """Test basic PromptTemplate functionality."""
+    template = PromptTemplate(template="Hello {name}, you are {age} years old")
+
+    # Test format
+    result = template.format(name="Alice", age=30)
+    assert result == "Hello Alice, you are 30 years old"
+
+    # Test get_template_vars
+    vars = template.get_template_vars()
+    assert set(vars) == {"name", "age"}
+
+    # Test partial_format
+    partial = template.partial_format(name="Bob")
+    result = partial.format(age=25)
+    assert result == "Hello Bob, you are 25 years old"
+
+    # Verify original is unchanged
+    vars = template.get_template_vars()
+    assert set(vars) == {"name", "age"}
+
+
+def test_chat_prompt_template():
+    """Test ChatPromptTemplate functionality."""
+    template = ChatPromptTemplate(
+        message_templates=[
+            ChatMessageTemplateInfo(
+                role=MessageRole.SYSTEM,
+                content="You are a helpful assistant.",
+            ),
+            ChatMessageTemplateInfo(
+                role=MessageRole.USER,
+                content="My name is {name}. Can you help me with {task}?",
+            ),
+        ]
+    )
+
+    # Test format_messages
+    messages = template.format_messages(name="Alice", task="coding")
+    assert len(messages) == 2
+    assert messages[0].role == MessageRole.SYSTEM
+    assert messages[0].content == "You are a helpful assistant."
+    assert messages[1].role == MessageRole.USER
+    assert messages[1].content == "My name is Alice. Can you help me with coding?"
+
+    # Test get_template_vars
+    vars = template.get_template_vars()
+    assert set(vars) == {"name", "task"}
+
+    # Test partial_format
+    partial = template.partial_format(name="Bob")
+    messages = partial.format_messages(task="writing")
+    assert messages[1].content == "My name is Bob. Can you help me with writing?"
+
+
+def test_selector_prompt_template():
+    """Test SelectorPromptTemplate functionality."""
+
+    def is_openai(llm: LLM) -> bool:
+        return isinstance(llm, OpenAI)
+
+    default_template = PromptTemplate(template="Default: {text}")
+    openai_template = PromptTemplate(template="OpenAI: {text}")
+
+    selector = SelectorPromptTemplate(
+        default_template=default_template,
+        conditionals=[(is_openai, openai_template)],
+    )
+
+    # Test without LLM (should use default)
+    result = selector.format(text="hello")
+    assert result == "Default: hello"
+
+    # Test with OpenAI LLM (should use conditional)
+    llm = OpenAI(api_key="fake-key", model="gpt-3.5-turbo")
+    result = selector.format(llm=llm, text="hello")
+    assert result == "OpenAI: hello"
+
+
+def test_langchain_prompt_template_wrapper():
+    """Test LangchainPromptTemplate wrapper."""
+    lc_template = LCPromptTemplate.from_template("Hello {name}")
+
+    wrapper = LangchainPromptTemplate(template=lc_template)
+
+    # Test format
+    result = wrapper.format(name="Alice")
+    assert result == "Hello Alice"
+
+    # Test get_template_vars
+    vars = wrapper.get_template_vars()
+    assert vars == ["name"]
+
+    # Test partial_format
+    partial = wrapper.partial_format(name="Bob")
+    result = partial.format()
+    assert result == "Hello Bob"
+
+
+def test_prompt_backward_compatibility():
+    """Test that Prompt class maintains backward compatibility."""
+    # Test basic string template
+    prompt = Prompt("Hello {name}")
+    result = prompt.format(name="Alice")
+    assert result == "Hello Alice"
+
+    # Test from_langchain_prompt (deprecated but should work)
+    lc_template = LCPromptTemplate.from_template("Hello {name}")
+    prompt = Prompt.from_langchain_prompt(lc_template)
+    result = prompt.format(name="Bob")
+    assert result == "Hello Bob"
+
+    # Test that Prompt now extends BasePromptTemplate
+    assert isinstance(prompt, BasePromptTemplate)
+
+    # Test partial_format
+    prompt = Prompt("Hello {name}, {greeting}")
+    partial = prompt.partial_format(greeting="how are you?")
+    result = partial.format(name="Alice")
+    assert result == "Hello Alice, how are you?"
+
+
+def test_prompt_with_new_template_types():
+    """Test that Prompt can accept new template types."""
+    # Test with PromptTemplate
+    base_template = PromptTemplate(template="Hello {name}")
+    prompt = Prompt(template=base_template)
+    result = prompt.format(name="Alice")
+    assert result == "Hello Alice"
+
+    # Test with ChatPromptTemplate
+    chat_template = ChatPromptTemplate(
+        message_templates=[
+            ChatMessageTemplateInfo(
+                role=MessageRole.USER,
+                content="Hello {name}",
+            ),
+        ]
+    )
+    prompt = Prompt(template=chat_template)
+    messages = prompt.format_messages(name="Bob")
+    assert len(messages) == 1
+    assert messages[0].content == "Hello Bob"
+
+
+def test_template_auto_var_extraction():
+    """Test automatic template variable extraction."""
+    template = PromptTemplate(template="Hello {name}, you are {age} years old. {greeting}")
+
+    vars = template.get_template_vars()
+    assert set(vars) == {"name", "age", "greeting"}
+
+
+if __name__ == "__main__":
+    print("Running tests...")
+
+    test_basic_prompt_template()
+    print("✓ test_basic_prompt_template")
+
+    test_chat_prompt_template()
+    print("✓ test_chat_prompt_template")
+
+    test_selector_prompt_template()
+    print("✓ test_selector_prompt_template")
+
+    test_langchain_prompt_template_wrapper()
+    print("✓ test_langchain_prompt_template_wrapper")
+
+    test_prompt_backward_compatibility()
+    print("✓ test_prompt_backward_compatibility")
+
+    test_prompt_with_new_template_types()
+    print("✓ test_prompt_with_new_template_types")
+
+    test_template_auto_var_extraction()
+    print("✓ test_template_auto_var_extraction")
+
+    print("\nAll tests passed! ✓")
