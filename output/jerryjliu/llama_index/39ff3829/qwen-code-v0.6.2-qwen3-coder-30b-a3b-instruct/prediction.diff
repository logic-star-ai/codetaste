+"""
+Unit tests for the new prompt refactored system.
+"""
+
+import pytest
+from unittest.mock import MagicMock
+
+# Import our components directly 
+from llama_index.prompts.base import PromptTemplate, ChatPromptTemplate, SelectorPromptTemplate, LangchainPromptTemplate
+
+def test_prompt_template_basic():
+    """Test basic PromptTemplate functionality."""
+    # Create a template
+    template = PromptTemplate(
+        template="Hello {name}, I'm {age} years old",
+        prompt_type="test_prompt"
+    )
+    
+    # Test formatting
+    result = template.format(name="Alice", age=30)
+    assert result == "Hello Alice, I'm 30 years old"
+    
+    # Test partial formatting
+    partial = template.partial_format(age=25)
+    result = partial.format(name="Bob")
+    assert result == "Hello Bob, I'm 25 years old"
+
+
+def test_chat_prompt_template_basic():
+    """Test basic ChatPromptTemplate functionality."""
+    # Create a template with a list of messages
+    messages = [
+        {"role": "system", "content": "You are a helpful assistant."},
+        {"role": "user", "content": "Hello {name}"}
+    ]
+    
+    template = ChatPromptTemplate(messages=messages)
+    result = template.format(name="Alice")
+    assert "Alice" in result
+    
+    # Create a template with a single template string
+    template2 = ChatPromptTemplate(template="Hello {name}!")
+    result2 = template2.format(name="Bob")
+    assert result2 == "Hello Bob!"
+
+
+def test_selector_prompt_template():
+    """Test SelectorPromptTemplate basic functionality."""
+    # Create a mock selector-like object
+    class MockPromptSelector:
+        def select(self, llm):
+            return PromptTemplate(template="Selected: {text}")
+    
+    mock_selector = MockPromptSelector()
+    selector_prompt = SelectorPromptTemplate(prompt_selector=mock_selector)
+    
+    # Test formatting
+    result = selector_prompt.format(text="test")
+    assert "test" in result
+
+
+def test_langchain_wrapper():
+    """Test LangchainPromptTemplate basic functionality."""
+    # Mock LangChain prompt
+    class MockLangchainPrompt:
+        template = "LangChain: {text}"
+    
+    mock_lcp = MockLangchainPrompt()
+    prompt = LangchainPromptTemplate(langchain_prompt=mock_lcp)
+    
+    result = prompt.format(text="Hello")
+    # Should work without direct LangChain imports
+    assert "Hello" in result
+
+
+def test_basic_prompt_creation():
+    """Test creation of basic prompt templates."""
+    # Test that we can create instances
+    prompt = PromptTemplate(template="Test template {var}")
+    assert prompt.template == "Test template {var}"
+    
+    chat_prompt = ChatPromptTemplate(template="Chat template {var}")
+    assert chat_prompt.template == "Chat template {var}"
+
+
+if __name__ == "__main__":
+    # Run all tests
+    test_prompt_template_basic()
+    test_chat_prompt_template_basic()
+    test_selector_prompt_template()
+    test_langchain_wrapper()
+    test_basic_prompt_creation()
+    print("All tests passed!")
