+
+# Load base.py directly without going through the full system
+spec = importlib.util.spec_from_file_location("base", "llama_index/prompts/base.py")
+base_module = importlib.util.module_from_spec(spec)
+spec.loader.exec_module(base_module)
+
+def test_prompt_template_basic():
+    """Test basic PromptTemplate functionality."""
+    # Create a template
+    PromptTemplate = base_module.PromptTemplate
+    template = PromptTemplate(
+        template="Hello {name}, I'm {age} years old",
+        prompt_type="test_prompt"
+    )
+    
+    # Test formatting
+    result = template.format(name="Alice", age=30)
+    assert result == "Hello Alice, I'm 30 years old"
+    
