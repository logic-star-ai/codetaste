+            output_parser=self.output_parser,
+            prompt_type=self.prompt_type,
+            metadata=deepcopy(self.metadata),
+            template_kwargs=deepcopy(self.template_kwargs),
+            partial_dict=partial_dict,
+        )
+
+    def partial_format(self, **kwargs: Any) -> "SelectorPromptTemplate":
+        new_default = self.default_template.partial_format(**kwargs)
+        new_conditionals = [(cond, tmpl.partial_format(**kwargs)) for cond, tmpl in self.conditionals]
+        new_partial = dict(self.partial_dict)
+        new_partial.update(kwargs)
+        # Keep partials in the selector too, for get_full_format_args behavior.
+        return SelectorPromptTemplate(
+            default_template=new_default,
+            conditionals=new_conditionals,
+            output_parser=self.output_parser,
+            prompt_type=self.prompt_type,
+            metadata=deepcopy(self.metadata),
+            template_kwargs=deepcopy(self.template_kwargs),
+            partial_dict=new_partial,
+        )
+
+    def format(self, llm: Optional[LLM] = None, **kwargs: Any) -> str:
+        tmpl = self.select(llm=llm)
+        merged = self.get_full_format_args(kwargs)
+        return tmpl.format(llm=llm, **merged)
+
+    def format_messages(
+        self, llm: Optional[LLM] = None, **kwargs: Any
+    ) -> List[ChatMessage]:
+        tmpl = self.select(llm=llm)
+        merged = self.get_full_format_args(kwargs)
