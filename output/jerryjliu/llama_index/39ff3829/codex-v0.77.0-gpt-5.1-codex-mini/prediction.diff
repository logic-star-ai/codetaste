+class SelectorPromptTemplate(BasePromptTemplate):
+    """Select a template based on the provided LLM at format time."""
+
+    def __init__(
+        self,
+        default_template: BasePromptTemplate,
+        conditionals: Optional[
+            Sequence[Tuple[Callable[[LLM], bool], BasePromptTemplate]]
+        ] = None,
+        *,
+        output_parser: Optional[BaseOutputParser] = None,
+        prompt_type: str = PromptType.CUSTOM,
+        metadata: Optional[Dict[str, Any]] = None,
+        template_kwargs: Optional[Dict[str, Any]] = None,
+        partial_dict: Optional[Dict[str, Any]] = None,
+    ) -> None:
+        super().__init__(
+            output_parser=output_parser,
+            prompt_type=prompt_type,
+            metadata=metadata,
+            template_kwargs=template_kwargs,
+            partial_dict=partial_dict,
+        )
+        self.default_template = default_template
+        self.conditionals = list(conditionals or [])
+
+    @property
+    def template_vars(self) -> List[str]:
+        vars_: List[str] = []
+        for tmpl in [self.default_template, *[t for _, t in self.conditionals]]:
+            for v in tmpl.template_vars:
+                if v not in vars_:
+                    vars_.append(v)
+        return vars_
+
+    def select(self, llm: Optional[LLM] = None) -> BasePromptTemplate:
+        if llm is None:
+            return self.default_template
+        for condition, tmpl in self.conditionals:
+            if condition(llm):
