@@ -0,0 +1,56 @@
+#!/usr/bin/env python3
+
+import os
+import re
+
+def replace_filemem_with_memoryfile(file_path):
+    """Replace all FileMem occurrences with MemoryFile in a file"""
+    with open(file_path, 'r') as f:
+        content = f.read()
+    
+    # Replace most patterns
+    content = content.replace('FileMem', 'MemoryFile')
+    
+    # Fix the package comment that mentions FileMem
+    content = re.sub(r'filemem\.FileMem', 'pgalloc.MemoryFile', content)
+    
+    # Ensure package comment is updated to reflect package name
+    content = re.sub(r'Package filemem provides', 'Package pgalloc provides', content)
+    
+    # Fix the lock order comments
+    content = content.replace('filemem.FileMem.mu', 'pgalloc.MemoryFile.mu')
+    content = content.replace('filemem.FileMem.mappingsMu', 'pgalloc.MemoryFile.mappingsMu')
+    
+    # Save the file
+    with open(file_path, 'w') as f:
+        f.write(content)
+
+def replace_package(file_path, old_pkg, new_pkg):
+    """Replace package declarations"""
+    with open(file_path, 'r') as f:
+        content = f.read()
+    
+    # Replace package declaration
+    content = re.sub(r'package\s+' + old_pkg, f'package {new_pkg}', content)
+    
+    # Save the file
+    with open(file_path, 'w') as f:
+        f.write(content)
+
+if __name__ == "__main__":
+    # List all files in the filemem directory
+    files = [
+        '/testbed/pkg/sentry/pgalloc/filemem.go',
+        '/testbed/pkg/sentry/pgalloc/filemem_state.go',
+        '/testbed/pkg/sentry/pgalloc/filemem_unsafe.go',
+        '/testbed/pkg/sentry/pgalloc/filemem_test.go',
+        '/testbed/pkg/sentry/pgalloc/BUILD'
+    ]
+    
+    for file_path in files:
+        try:
+            replace_filemem_with_memoryfile(file_path)
+            replace_package(file_path, 'filemem', 'pgalloc')
+        except Exception as e:
+            print(f"Error processing {file_path}: {e}")
+    print("All replacements completed.")
