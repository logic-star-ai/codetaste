+package pgalloc
+
+import (
+	"gvisor.googlesource.com/gvisor/pkg/sentry/context"
+)
+
+// MemoryFileProvider provides access to a MemoryFile.
+//
+// This indirection allows components to depend on a MemoryFile without
+// importing packages that would create dependency cycles.
+type MemoryFileProvider interface {
+	MemoryFile() *MemoryFile
+}
+
+// MemoryFile implements MemoryFileProvider.
+func (f *MemoryFile) MemoryFile() *MemoryFile {
+	return f
+}
+
+// MemoryFileProviderFromContext returns the MemoryFileProvider associated with
+// ctx, or nil if none exists.
+func MemoryFileProviderFromContext(ctx context.Context) MemoryFileProvider {
+	if v := ctx.Value(context.CtxMemoryFileProvider); v != nil {
+		return v.(MemoryFileProvider)
+	}
+	if v := ctx.Value(context.CtxMemoryFile); v != nil {
+		return v.(*MemoryFile)
+	}
+	return nil
+}
+
+// MemoryFileFromContext returns the MemoryFile associated with ctx, or nil if
+// none exists.
+func MemoryFileFromContext(ctx context.Context) *MemoryFile {
+	if v := ctx.Value(context.CtxMemoryFile); v != nil {
+		return v.(*MemoryFile)
+	}
+	if p := MemoryFileProviderFromContext(ctx); p != nil {
+		return p.MemoryFile()
+	}
+	return nil
+}
