+"""Source space routines."""
+
+from . import _source_space as _source_space
+
+# Keep the public and private API surface identical to the historical
+# `mne.source_space` module, including private helpers (leading underscore).
+__all__ = [name for name in dir(_source_space) if not name.startswith("__")]
+
+
+def __getattr__(name):  # noqa: D401
+    """Proxy attribute access to `mne.source_space._source_space`."""
+    try:
+        return getattr(_source_space, name)
+    except AttributeError as err:
+        raise AttributeError(f"module {__name__!r} has no attribute {name!r}") from err
+
+
+def __dir__():
+    return sorted(set(globals()) | set(__all__))
+
