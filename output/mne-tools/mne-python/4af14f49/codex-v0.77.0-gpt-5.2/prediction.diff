+def _iter_non_relative_mne_imports(tree):
+    """Yield (imported_root, lineno, pretty) for non-relative mne.* imports."""
+    for node in tree.body:  # module-level only
+        if isinstance(node, ast.Import):
+            for alias in node.names:
+                name = alias.name
+                if not name.startswith("mne."):
+                    continue
+                imported_root = name.split(".", 2)[1]
+                yield imported_root, node.lineno, f"import {name}"
+        elif isinstance(node, ast.ImportFrom) and node.level == 0:
+            module = node.module
+            if module is None:
+                continue
+            if module == "mne":
+                for alias in node.names:
+                    imported_root = alias.name.split(".", 1)[0]
+                    yield imported_root, node.lineno, f"from mne import {alias.name}"
+            elif module.startswith("mne."):
+                imported_root = module.split(".", 2)[1]
+                yield imported_root, node.lineno, f"from {module} import ..."
+
+
+def _module_root_from_path(py_path, mne_root):
+    rel = py_path.relative_to(mne_root)
+    parts = rel.parts
+    if parts[-1] == "__init__.py":
+        return parts[0] if len(parts) > 1 else None
+    if len(parts) == 1:
+        if parts[0] in ("__init__.py", "__main__.py", "conftest.py"):
+            return None
+        return parts[0].removesuffix(".py")
+    return parts[0]
+
+
+def test_import_nesting_hierarchy():
+    """AST-based check for mne import nesting hierarchy."""
+    order = {name: idx for idx, name in enumerate(IMPORT_NESTING_ORDER)}
+    mne_root = Path(__file__).resolve().parents[1]
+
+    violations = []
+    for py_path in mne_root.rglob("*.py"):
+        parts = py_path.relative_to(mne_root).parts
+        if "tests" in parts:
+            continue
+        if parts[0] == "commands":
+            continue
+        if py_path.name == "conftest.py":
+            continue
+
+        module_root = _module_root_from_path(py_path, mne_root)
+        if module_root is None or module_root not in order:
+            continue
+
+        with tokenize.open(py_path) as f:
+            tree = ast.parse(f.read(), filename=str(py_path))
+        for imported_root, lineno, pretty in _iter_non_relative_mne_imports(tree):
+            if imported_root not in order or imported_root == module_root:
+                continue
+            if order[imported_root] > order[module_root]:
+                violations.append(
+                    f"{py_path}:{lineno} imports {imported_root} ({pretty}) from {module_root}"
+                )
+
+    assert not violations, (
+        "Import nesting hierarchy violations:\n" + "\n".join(sorted(violations))
+    )
