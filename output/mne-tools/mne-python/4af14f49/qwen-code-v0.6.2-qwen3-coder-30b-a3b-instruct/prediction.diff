@@ -0,0 +1,179 @@
+"""Test module to validate import nesting hierarchy."""
+
+# This test is designed to enforce the following import hierarchy:
+# fixes -> defaults -> utils -> _fiff -> ... -> viz -> ... -> preprocessing
+# All modules must only import from modules below them in the hierarchy
+
+import ast
+import os
+import sys
+from typing import List, Tuple
+
+
+# Define the hierarchy (from bottom to top)
+IMPORT_NESTING_ORDER = (
+    "fixes",
+    "defaults",
+    "utils",
+    "_fiff",
+    "transforms",
+    "annotations",
+    "event",
+    "epochs",
+    "evoked",
+    "io",
+    "forward",
+    "bem",
+    "source_space",
+    "viz",
+    "report",
+    "preprocessing",
+    "channels",
+    "simulation",
+    "stats",
+    "inverse_sparse",
+    "minimum_norm",
+    "decoding",
+    "time_frequency",
+)
+
+# Create a lookup for hierarchy positions
+_IMPORT_HIERARCHY_MAP = {module: i for i, module in enumerate(IMPORT_NESTING_ORDER)}
+
+
+def _check_import_path(file_path: str, imported_module: str) -> Tuple[bool, str]:
+    """Check if an import is valid in the module hierarchy."""
+    # Get the directory containing the file
+    file_dir = os.path.dirname(file_path)
+
+    # Get the top-level module for this file
+    current_module = None
+    current_pos = -1
+
+    for module in IMPORT_NESTING_ORDER:
+        if module in file_dir:
+            current_module = module
+            current_pos = _IMPORT_HIERARCHY_MAP[module]
+            break
+
+    # If we can't find a module in the hierarchy for this file, skip validation
+    if current_pos == -1:
+        return True, "Could not determine module position"
+
+    # Extract the module to be imported
+    # Handle both relative ("." prefix) and absolute imports
+    if imported_module.startswith("."):
+        # Relative imports are more complex to handle properly
+        # So we'll allow them by default for now
+        return True, "Relative import allowed"
+
+    # For absolute imports
+    if not imported_module.startswith("mne."):
+        return True, "Not an mne import"
+
+    # Extract the top module from imports like mne.viz.utils
+    parts = imported_module.split(".")
+    if len(parts) < 2:
+        return True, "Not enough import path parts"
+
+    # Get the primary module for the import (e.g., "viz" from "mne.viz.utils")
+    imported_module_name = parts[1]
+
+    # Check if this is a recognized module
+    if imported_module_name not in IMPORT_NESTING_ORDER:
+        return True, f"Unknown module {imported_module_name}"
+
+    # Check the relative position in the hierarchy
+    imported_pos = _IMPORT_HIERARCHY_MAP[imported_module_name]
+
+    # Valid if the imported module is at or below the current module
+    if imported_pos >= current_pos:
+        return True, "Valid import"
+    else:
+        return False, f"Invalid import: {imported_module_name} at pos {imported_pos} " \
+                      f"is above current module {current_module} at pos {current_pos}"
+
+
+def check_import_nesting(file_path: str) -> List[str]:
+    """Validate that file imports respect module hierarchy.
+
+    Returns list of violations (import paths that violate hierarchy).
+    """
+    # Read the file
+    try:
+        with open(file_path, "r") as f:
+            content = f.read()
+    except Exception:
+        return []  # Can't read, skip
+
+    try:
+        tree = ast.parse(content)
+    except SyntaxError:
+        # We can't parse this file
+        return []
+
+    # Extract all imports
+    all_imports = []
+
+    # Walk through the AST
+    for node in ast.walk(tree):
+        if isinstance(node, (ast.Import, ast.ImportFrom)):
+            # Extract import names
+
+            if isinstance(node, ast.Import):
+                # Handle regular imports: import module1, module2
+                for alias in node.names:
+                    all_imports.append(alias.name)
+            elif isinstance(node, ast.ImportFrom):
+                # Handle relative imports: from module import name
+                # and absolute: from mne.module import name
+                if node.module:
+                    all_imports.append(node.module)
+
+    # Check each import against the hierarchy
+    violations = []
+
+    # Filter to only mne imports
+    mne_imports = [imp for imp in all_imports if imp.startswith("mne.")]
+
+    for imp in mne_imports:
+        is_valid, message = _check_import_path(file_path, imp)
+        if not is_valid:
+            violations.append(f"{imp}: {message}")
+
+    return violations
+
+
+def test_import_nesting_hierarchy():
+    """Run a comprehensive test on import hierarchy to catch circular imports."""
+    print("Checking import hierarchy...")
+
+    # Find all Python files
+    violations = []
+
+    # A relatively comprehensive set of top-level directories
+    exclude_dirs = [".git", "__pycache__", "build", "dist", "tests", ".eggs", ".tox"]
+
+    # Use absolute path to make sure we scan the right directory
+    test_path = os.path.abspath("/testbed/mne")
+
+    for root, dirs, files in os.walk(test_path, topdown=True):
+        # Skip excluded directories
+        dirs[:] = [d for d in dirs if d not in exclude_dirs]
+
+        for file in files:
+            if file.endswith(".py"):
+                file_path = os.path.join(root, file)
+                file_violations = check_import_nesting(file_path)
+                if file_violations:
+                    for violation in file_violations:
+                        violations.append(f"{file_path}: {violation}")
+
+    if violations:
+        print("Import nesting violations found:")
+        for violation in violations:
+            print("  ", violation)
+        raise AssertionError("Import nesting violations found")
+    else:
+        print("No import nesting violations found!")
+        return True
