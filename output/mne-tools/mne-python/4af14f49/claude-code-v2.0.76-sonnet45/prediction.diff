diff --git a/mne/tests/test_import_nesting.py b/mne/tests/test_import_nesting.py
index 645817f..65dfb78 100644
--- a/mne/tests/test_import_nesting.py
+++ b/mne/tests/test_import_nesting.py
@@ -2,7 +2,9 @@
 #
 # License: BSD-3-Clause
 
+import ast
 import os
+from pathlib import Path
 import sys
 import pytest
 
@@ -53,3 +55,127 @@ def test_lazy_loading():
         [sys.executable, "-c", run_script], return_code=True
     )
     assert code == 0, stdout + stderr
+
+
+# Module import nesting hierarchy
+# Modules must nest imports from modules below them in this hierarchy
+IMPORT_NESTING_ORDER = (
+    "fixes",
+    "defaults",
+    "utils",
+    "_fiff",
+    "io",
+    "channels",
+    "transforms",
+    "annotations",
+    "event",
+    "epochs",
+    "evoked",
+    "forward",
+    "bem",
+    "source_space",
+    "surface",
+    "parallel",
+    "_freesurfer",
+    "report",
+    "time_frequency",
+    "stats",
+    "inverse_sparse",
+    "beamformer",
+    "minimum_norm",
+    "decoding",
+    "simulation",
+    "viz",
+    "preprocessing",
+)
+
+
+def test_import_nesting_hierarchy():
+    """Test that imports follow the defined nesting hierarchy."""
+    mne_root = Path(__file__).parent.parent
+    violations = []
+
+    # Create a mapping from module name to its position in hierarchy
+    hierarchy_pos = {name: i for i, name in enumerate(IMPORT_NESTING_ORDER)}
+
+    # Find all Python files in the mne package
+    for py_file in mne_root.rglob("*.py"):
+        if "tests" in py_file.parts or "__pycache__" in str(py_file):
+            continue
+
+        # Determine the module name for this file
+        rel_path = py_file.relative_to(mne_root)
+        parts = list(rel_path.parts[:-1])  # Remove filename
+        if rel_path.name != "__init__.py":
+            parts.append(rel_path.stem)
+
+        # Only check files in the hierarchy
+        if not parts:
+            module_name = None
+        else:
+            module_name = parts[0]
+            # For submodules like source_space._source_space, use parent
+            if module_name not in hierarchy_pos:
+                continue
+
+        if module_name is None or module_name not in hierarchy_pos:
+            continue
+
+        module_pos = hierarchy_pos[module_name]
+
+        # Parse the file to find imports
+        try:
+            with open(py_file, "r", encoding="utf-8") as f:
+                tree = ast.parse(f.read(), filename=str(py_file))
+        except (SyntaxError, UnicodeDecodeError):
+            continue
+
+        # Check module-level imports (not nested in functions/classes)
+        for node in ast.walk(tree):
+            if isinstance(node, (ast.Import, ast.ImportFrom)):
+                # Check if this is a top-level import
+                parent_is_module = all(
+                    not isinstance(p, (ast.FunctionDef, ast.AsyncFunctionDef,
+                                      ast.ClassDef))
+                    for p in ast.walk(tree)
+                    if any(node in ast.walk(child) for child in ast.iter_child_nodes(p))
+                )
+
+                # Only check module-level imports
+                if not parent_is_module:
+                    continue
+
+                # Get the imported module name
+                if isinstance(node, ast.ImportFrom):
+                    if node.level > 0:  # Relative import
+                        # Skip relative imports for now
+                        continue
+                    import_module = node.module
+                else:  # ast.Import
+                    import_module = node.names[0].name if node.names else None
+
+                if not import_module or not import_module.startswith("mne."):
+                    continue
+
+                # Extract the top-level mne module being imported
+                import_parts = import_module.split(".")
+                if len(import_parts) < 2:
+                    continue
+
+                imported_module = import_parts[1]  # e.g., "viz" from "mne.viz"
+
+                # Check if it violates the hierarchy
+                if imported_module in hierarchy_pos:
+                    imported_pos = hierarchy_pos[imported_module]
+                    # Module can only import from modules earlier in the hierarchy
+                    if imported_pos >= module_pos:
+                        violation_msg = (
+                            f"{rel_path}: module '{module_name}' (pos {module_pos}) "
+                            f"imports from '{imported_module}' (pos {imported_pos}) "
+                            f"at line {node.lineno}"
+                        )
+                        violations.append(violation_msg)
+
+    if violations:
+        msg = "\n".join(["Import hierarchy violations found:"] + violations)
+        pytest.fail(msg)
