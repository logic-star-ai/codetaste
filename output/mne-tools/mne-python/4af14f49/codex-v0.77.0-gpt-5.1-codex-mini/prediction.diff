+class _ModuleLevelImportCollector(ast.NodeVisitor):
+    def __init__(self):
+        super().__init__()
+        self.imports = []
+        self._depth = 0
+
+    def visit_FunctionDef(self, node):
+        self._depth += 1
+        self.generic_visit(node)
+        self._depth -= 1
+
+    def visit_AsyncFunctionDef(self, node):
+        self.visit_FunctionDef(node)
+
+    def visit_ClassDef(self, node):
+        self._depth += 1
+        self.generic_visit(node)
+        self._depth -= 1
+
+    def visit_Import(self, node):
+        if self._depth == 0:
+            self.imports.append(node)
+        self.generic_visit(node)
+
+    def visit_ImportFrom(self, node):
+        if self._depth == 0:
+            self.imports.append(node)
+        self.generic_visit(node)
+
+
+def _module_name_from_path(path, root):
+    rel = path.relative_to(root)
+    if rel.name == "__init__.py":
+        rel = rel.parent
+    if not rel.parts:
+        return "mne"
+    module = ".".join(rel.with_suffix("").parts)
+    return f"mne.{module}"
+
+
+def _module_base(module_name):
+    parts = module_name.split(".")
+    return parts[1] if len(parts) > 1 else module_name
+
+
+def _resolve_import_from(current_module, module, level):
+    if level == 0:
+        return module
+    parts = current_module.split(".")
+    if level > len(parts):
+        return None
+    parent = parts[: -level]
+    if not parent:
+        return None
+    if module:
+        parent = parent + module.split(".")
+    return ".".join(parent)
+
+
+def _import_targets(node, current_module):
+    if isinstance(node, ast.Import):
+        targets = [
+            alias.name
+            for alias in node.names
+            if alias.name.startswith("mne.")
+        ]
+        return targets
+
+    absolute_module = _resolve_import_from(current_module, node.module, node.level)
+    if not absolute_module:
+        return []
+    if absolute_module == "mne":
+        targets = [
+            f"mne.{alias.name}" for alias in node.names if alias.name != "*"
+        ]
+        return targets
+    if absolute_module.startswith("mne."):
+        return [absolute_module]
+
+    return []
+
+
+def test_import_nesting_hierarchy():
+    repo_root = Path(__file__).resolve().parents[2]
+    mne_root = repo_root / "mne"
+    violations = []
+    for path in sorted(mne_root.rglob("*.py")):
+        if "tests" in path.parts:
+            continue
+        module_name = _module_name_from_path(path, mne_root)
+        current_base = _module_base(module_name)
+        if current_base not in MODULE_ORDER:
+            continue
+        try:
+            source = path.read_text(encoding="utf-8")
+        except (UnicodeDecodeError, OSError):
+            continue
+        tree = ast.parse(source)
+        visitor = _ModuleLevelImportCollector()
+        visitor.visit(tree)
+        for node in visitor.imports:
+            for target in _import_targets(node, module_name):
+                target_base = _module_base(target)
+                if target_base not in MODULE_ORDER:
+                    continue
+                if MODULE_ORDER[target_base] > MODULE_ORDER[current_base]:
+                    violations.append(
+                        f"{path.relative_to(repo_root)} imports {target} "
+                        f"(base {target_base}) from {current_base}"
+                    )
+    assert not violations, "import nesting violations:\n" + "\n".join(violations)
