FROM ubuntu:24.04
ENV DEBIAN_FRONTEND=noninteractive

# 1. Install System Tools + Sudo
RUN apt-get update && apt-get install -y \
    curl git wget jq unzip sudo \
    build-essential gcc g++ clang \
    python3 python3-pip python3-venv python3-dev python3-xlib \
    libssl-dev zlib1g-dev \
    libmysqlclient-dev libpq-dev libldap2-dev libsasl2-dev \
    && rm -rf /var/lib/apt/lists/*

# 2. Install Miniconda
ENV CONDA_PLUGINS_AUTO_ACCEPT_TOS=true
ENV CONDA_DIR=/opt/conda
RUN wget --quiet https://repo.anaconda.com/miniconda/Miniconda3-latest-Linux-x86_64.sh -O ~/miniconda.sh && \
    /bin/bash ~/miniconda.sh -b -p $CONDA_DIR && \
    rm ~/miniconda.sh && \
    $CONDA_DIR/bin/conda clean -a -y

# Add Conda to PATH for all users
ENV PATH=$CONDA_DIR/bin:$PATH

# Install Opengrep
RUN curl -fsSL https://raw.githubusercontent.com/opengrep/opengrep/v1.8.2/install.sh | bash

# 3. Agent Tooling
# Note: Ubuntu 24.04 creates a "conflict" with standard nodejs/npm packages sometimes. 
# Ensuring we get a clean install.
RUN apt-get update && apt-get install -y nodejs npm
RUN npm install -g @anthropic-ai/claude-code

# 4. Create User and Grant Passwordless Sudo
RUN useradd -m -s /bin/bash benchmarker && \
    echo "benchmarker ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers

# 5. Fix Permissions
# Critical: Give the user ownership of conda so they can create envs without sudo
RUN chown -R benchmarker:benchmarker $CONDA_DIR

# CREATE DIRECTORY /SCRIPTS FOR BENCHMARK SCRIPTS
RUN mkdir /scripts
RUN chown benchmarker:benchmarker /scripts

RUN mkdir /rules
RUN chown benchmarker:benchmarker /rules

WORKDIR /testbed
RUN chown benchmarker:benchmarker /testbed

# 6. Switch to User
USER benchmarker

# 7. Initialize and Configure Conda (The Fixes)
RUN conda init bash
RUN conda config --add channels conda-forge && \
    conda config --set channel_priority strict && \
    conda config --set always_yes true && \
    conda install pytest tox cython && \
    conda clean -afy

RUN pip install --no-cache-dir --upgrade pip setuptools && \
    pip install --no-cache-dir tox cython pytest

ENV ANTHROPIC_API_KEY="" 
CMD ["sleep", "infinity"]