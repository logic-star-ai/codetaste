# Using Ubuntu 24.04 (Noble Numbat)
FROM ubuntu:24.04

# Avoid prompts during package installation
ENV DEBIAN_FRONTEND=noninteractive

# 1. Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl git wget jq unzip sudo locales ca-certificates \
    build-essential gcc g++ clang cmake pkg-config gdb \
    python3 python3-pip python3-venv python3-dev python-is-python3 \
    libssl-dev zlib1g-dev libffi-dev libsqlite3-dev \
    libjpeg-dev libpng-dev libtiff-dev libfreetype6-dev \
    libnss3 libatk1.0-0 libatk-bridge2.0-0 libcups2 libdrm2 \
    libxkbcommon0 libxcomposite1 libxdamage1 libxext6 libxfixes3 \
    vim default-jdk \
    libxrandr2 libgbm1 && locale-gen en_US.UTF-8 \
    && rm -rf /var/lib/apt/lists/*

# 1a. Install .NET SDK 8.0 (LTS) for C# support
RUN wget https://dot.net/v1/dotnet-install.sh -O /tmp/dotnet-install.sh && \
    chmod +x /tmp/dotnet-install.sh && \
    /tmp/dotnet-install.sh --channel 8.0 --install-dir /opt/dotnet && \
    rm /tmp/dotnet-install.sh

# 2. Add 'uv' binary from official image and define environment
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

ENV NVM_DIR=/opt/nvm \
    NODE_VERSION=v22.12.0 \
    RUSTUP_HOME=/opt/rust \
    CARGO_HOME=/opt/rust \
    UV_PYTHON_INSTALL_DIR=/opt/uv-python \
    UV_LINK_MODE=copy \
    DOTNET_ROOT=/opt/dotnet \
    DOTNET_CLI_TELEMETRY_OPTOUT=1

# 3. Create directories and install toolchains
RUN mkdir -p $NVM_DIR $RUSTUP_HOME $UV_PYTHON_INSTALL_DIR && \
    curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.1/install.sh | bash && \
    curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --no-modify-path && \
    uv python install 3.8 3.9 3.10 3.11

# 4. Install Node and NPM
RUN . $NVM_DIR/nvm.sh && nvm install $NODE_VERSION && nvm alias default $NODE_VERSION

# 5. Set up global environment for ALL users
RUN echo "export NVM_DIR=$NVM_DIR" >> /etc/bash.bashrc && \
    echo '[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"' >> /etc/bash.bashrc && \
    echo "export PATH=$RUSTUP_HOME/bin:\$PATH" >> /etc/bash.bashrc && \
    echo "export DOTNET_ROOT=$DOTNET_ROOT" >> /etc/bash.bashrc && \
    echo "export PATH=$DOTNET_ROOT:\$PATH" >> /etc/bash.bashrc && \
    echo 'export PATH="$HOME/.local/bin:$PATH"' >> /etc/bash.bashrc

RUN chmod -R 777 /opt

# 7. Update PATH for Node, Rust, .NET, uv-managed Pythons, and Python executables
ENV PATH="/root/.local/bin:/opt/dotnet:/opt/rust/bin:$NVM_DIR/versions/node/$NODE_VERSION/bin:$PATH"

# 8. Install global packages (removed vitest to avoid Node version conflicts)
RUN npm install -g @anthropic-ai/claude-code typescript ts-node eslint prettier vercel && \
    npx playwright install chromium --with-deps

# Create non-root user
RUN echo "benchmarker ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers && \
    mkdir -p /scripts /rules /testbed && useradd -m -s /bin/bash benchmarker && \
    chown -R benchmarker:benchmarker /scripts /rules /testbed

RUN chmod -R 700 /rules && chmod -R 777 /home/benchmarker 
USER benchmarker

RUN curl -fsSL https://raw.githubusercontent.com/opengrep/opengrep/v1.8.2/install.sh | bash
ENV PATH="/home/benchmarker/.opengrep/cli/latest:$PATH"

WORKDIR /testbed
ENV ANTHROPIC_API_KEY=""
CMD ["sleep", "infinity"]