+ * License for the specific language governing permissions and limitations
+ * under the License.
+ */
+package io.netty.handler.codec.dns;
+
+import io.netty.buffer.ByteBuf;
+import io.netty.channel.ChannelHandler;
+import io.netty.channel.ChannelHandlerContext;
+import io.netty.channel.socket.DatagramPacket;
+import io.netty.handler.codec.CorruptedFrameException;
+import io.netty.handler.codec.MessageToMessageDecoder;
+
+import java.net.InetSocketAddress;
+import java.util.List;
+
+/**
+ * UDP (datagram) decoder for {@link DatagramDnsResponse}.
+ */
+@ChannelHandler.Sharable
+public class DatagramDnsResponseDecoder extends MessageToMessageDecoder<DatagramPacket> {
+    @Override
+    protected void decode(ChannelHandlerContext ctx, DatagramPacket packet, List<Object> out) throws Exception {
+        final InetSocketAddress sender = packet.sender();
+        final InetSocketAddress recipient = packet.recipient();
+        final ByteBuf in = packet.content();
+        if (!in.isReadable(12)) {
+            throw new CorruptedFrameException("truncated DNS response header");
+        }
+
+        DnsMessageFactory factory = new DnsMessageFactory() {
+            @Override
+            public DnsQuery newQuery(int id) {
+                return new DatagramDnsQuery(id, sender, recipient);
+            }
+
+            @Override
+            public DnsResponse newResponse(int id) {
+                return new DatagramDnsResponse(id, sender, recipient);
+            }
+        };
+
+        out.add(DnsMessageCodec.decodeResponse(in, factory, DefaultDnsRecordFactory.INSTANCE));
+    }
+}
+
