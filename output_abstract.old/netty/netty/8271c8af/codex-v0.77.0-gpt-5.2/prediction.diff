+package io.netty.handler.codec.dns;
+
+import io.netty.buffer.ByteBuf;
+import io.netty.channel.ChannelHandlerContext;
+import io.netty.handler.codec.ByteToMessageDecoder;
+
+import java.util.List;
+
+/**
+ * TCP decoder for DNS responses (RFC 1035 section 4.2.2).
+ *
+ * <p>Expects a 2-byte length field followed by a DNS message of that length.
+ */
+public class TcpDnsResponseDecoder extends ByteToMessageDecoder {
+    @Override
+    protected void decode(ChannelHandlerContext ctx, ByteBuf in, List<Object> out) throws Exception {
+        if (in.readableBytes() < 2) {
+            return;
+        }
+
+        in.markReaderIndex();
+        int length = in.readUnsignedShort();
+        if (in.readableBytes() < length) {
+            in.resetReaderIndex();
+            return;
+        }
+
+        ByteBuf frame = in.readSlice(length);
+        out.add(DnsMessageCodec.decodeResponse(frame, DefaultDnsMessageFactory.INSTANCE,
+                                              DefaultDnsRecordFactory.INSTANCE));
+    }
+}
