+ * License for the specific language governing permissions and limitations
+ * under the License.
+ */
+package io.netty.handler.codec.dns;
+
+import io.netty.buffer.ByteBuf;
+import io.netty.handler.codec.CorruptedFrameException;
+import io.netty.util.CharsetUtil;
+import io.netty.util.internal.StringUtil;
+
+import java.nio.charset.Charset;
+
+final class DnsMessageCodec {
+    private static final Charset NAME_CHARSET = CharsetUtil.US_ASCII;
+
+    private DnsMessageCodec() { }
+
+    static void encodeMessage(DnsMessage message, ByteBuf out) {
+        if (message == null) {
+            throw new NullPointerException("message");
+        }
+        if (message.header().type() == DnsHeader.TYPE_QUERY) {
+            encodeQuery((DnsQuery) message, out);
+        } else {
+            encodeResponse((DnsResponse) message, out);
+        }
+    }
+
+    static void encodeQuery(DnsQuery query, ByteBuf out) {
+        encodeHeader(query.header(), out, 0, 0, query.header().additionalResourceCount());
+        for (DnsRecord question : query.questions()) {
+            encodeQuestion(question, out);
+        }
+        for (DnsRawRecord record : query.additionalResources()) {
+            encodeRecord(record, out);
+        }
+    }
+
+    static void encodeResponse(DnsResponse response, ByteBuf out) {
+        encodeHeader(
+                response.header(), out,
+                response.header().answerCount(),
+                response.header().authorityResourceCount(),
+                response.header().additionalResourceCount());
+
+        for (DnsRecord question : response.questions()) {
+            encodeQuestion(question, out);
+        }
+        for (DnsRawRecord record : response.answers()) {
+            encodeRecord(record, out);
+        }
+        for (DnsRawRecord record : response.authorityResources()) {
+            encodeRecord(record, out);
+        }
+        for (DnsRawRecord record : response.additionalResources()) {
+            encodeRecord(record, out);
+        }
+    }
+
+    private static void encodeHeader(DnsHeader header, ByteBuf out, int anCount, int nsCount, int arCount) {
+        out.writeShort(header.id());
+
+        int flags = 0;
+        flags |= (header.type() & 0x1) << 15;
+        flags |= (header.opcode() & 0xf) << 11;
+        flags |= header.isRecursionDesired() ? 1 << 8 : 0;
+
+        if (header instanceof DnsResponseHeader) {
+            DnsResponseHeader r = (DnsResponseHeader) header;
+            flags |= r.isAuthoritativeAnswer() ? 1 << 10 : 0;
+            flags |= r.isTruncated() ? 1 << 9 : 0;
+            flags |= r.isRecursionAvailable() ? 1 << 7 : 0;
+            flags |= (r.z() & 0x7) << 4;
+            flags |= r.responseCode().code() & 0xf;
+        } else {
+            flags |= (header.z() & 0x7) << 4;
+        }
+
+        out.writeShort(flags);
+        out.writeShort(header.questionCount());
+        out.writeShort(anCount);
+        out.writeShort(nsCount);
+        out.writeShort(arCount);
+    }
+
+    private static void encodeQuestion(DnsRecord question, ByteBuf out) {
+        encodeDomainName(question.name(), out);
+        out.writeShort(question.type().intValue());
+        out.writeShort(question.dnsClass().intValue());
+    }
+
+    private static void encodeRecord(DnsRawRecord record, ByteBuf out) {
+        encodeDomainName(record.name(), out);
+        out.writeShort(record.type().intValue());
+        out.writeShort(record.dnsClass().intValue());
+        out.writeInt((int) record.timeToLive());
+
+        ByteBuf content = record.content();
+        int contentLen = content.readableBytes();
+        out.writeShort(contentLen);
+        out.writeBytes(content, content.readerIndex(), contentLen);
+    }
+
+    static DnsMessage decodeMessage(ByteBuf in, DnsMessageFactory messageFactory, DnsRecordFactory recordFactory) {
+        int id = in.readUnsignedShort();
+        int flags = in.readUnsignedShort();
+
+        int qr = flags >>> 15;
+        int opcode = flags >>> 11 & 0xf;
+        boolean rd = (flags >>> 8 & 0x1) == 1;
+        int z = flags >>> 4 & 0x7;
+
+        int qdCount = in.readUnsignedShort();
+        int anCount = in.readUnsignedShort();
+        int nsCount = in.readUnsignedShort();
+        int arCount = in.readUnsignedShort();
+
+        DnsMessage message;
+        if (qr == DnsHeader.TYPE_RESPONSE) {
+            DnsResponse response = messageFactory.newResponse(id);
+            DnsResponseHeader header = response.header();
+            header.setType(qr);
+            header.setOpcode(opcode);
+            header.setRecursionDesired(rd);
+            header.setAuthoritativeAnswer((flags >>> 10 & 0x1) == 1);
+            header.setTruncated((flags >>> 9 & 0x1) == 1);
+            header.setRecursionAvailable((flags >>> 7 & 0x1) == 1);
+            header.setZ(z);
+            header.setResponseCode(DnsResponseCode.valueOf(flags & 0xf));
+            message = response;
+        } else {
+            DnsQuery query = messageFactory.newQuery(id);
+            DnsQueryHeader header = query.header();
+            header.setType(qr);
+            header.setOpcode(opcode);
+            header.setRecursionDesired(rd);
+            header.setZ(z);
+            message = query;
+        }
+
+        boolean release = true;
+        try {
+            for (int i = 0; i < qdCount; i++) {
+                message.addQuestion(decodeQuestion(in, recordFactory));
+            }
+            for (int i = 0; i < anCount; i++) {
+                message.addAnswer(decodeRecord(in, recordFactory));
+            }
+            for (int i = 0; i < nsCount; i++) {
+                message.addAuthorityResource(decodeRecord(in, recordFactory));
+            }
+            for (int i = 0; i < arCount; i++) {
+                message.addAdditionalResource(decodeRecord(in, recordFactory));
+            }
+            release = false;
+            return message;
+        } finally {
+            if (release) {
+                message.release();
+            }
+        }
+    }
+
+    static DnsResponse decodeResponse(ByteBuf in, DnsMessageFactory messageFactory, DnsRecordFactory recordFactory) {
+        DnsMessage message = decodeMessage(in, messageFactory, recordFactory);
+        if (!(message instanceof DnsResponse)) {
+            message.release();
+            throw new CorruptedFrameException("not a DNS response");
+        }
+        return (DnsResponse) message;
+    }
+
+    private static DnsRecord decodeQuestion(ByteBuf in, DnsRecordFactory recordFactory) {
+        String qname = decodeDomainName(in);
+        DnsType qtype = DnsType.valueOf(in.readUnsignedShort());
+        DnsClass qclass = DnsClass.valueOf(in.readUnsignedShort());
+        return recordFactory.newQuestion(qname, qtype, qclass);
+    }
+
+    private static DnsRawRecord decodeRecord(ByteBuf in, DnsRecordFactory recordFactory) {
+        String name = decodeDomainName(in);
+        DnsType type = DnsType.valueOf(in.readUnsignedShort());
+        DnsClass dnsClass = DnsClass.valueOf(in.readUnsignedShort());
+        long ttl = in.readUnsignedInt();
+        int rdLength = in.readUnsignedShort();
+
+        int readerIndex = in.readerIndex();
+        ByteBuf rdata = in.duplicate().setIndex(readerIndex, readerIndex + rdLength).retain();
+        in.readerIndex(readerIndex + rdLength);
+        return recordFactory.newRecord(name, type, dnsClass, ttl, rdata);
+    }
+
+    private static String decodeDomainName(ByteBuf in) {
+        int position = -1;
+        int checked = 0;
+        int length = in.writerIndex();
+        StringBuilder name = new StringBuilder(64);
+        for (int len = in.readUnsignedByte(); in.isReadable() && len != 0; len = in.readUnsignedByte()) {
+            boolean pointer = (len & 0xc0) == 0xc0;
+            if (pointer) {
+                if (position == -1) {
+                    position = in.readerIndex() + 1;
+                }
+                in.readerIndex((len & 0x3f) << 8 | in.readUnsignedByte());
+                checked += 2;
+                if (checked >= length) {
+                    throw new CorruptedFrameException("name contains a loop.");
+                }
+            } else {
+                name.append(in.toString(in.readerIndex(), len, NAME_CHARSET)).append('.');
+                in.skipBytes(len);
+            }
+        }
+        if (position != -1) {
+            in.readerIndex(position);
+        }
+        if (name.length() == 0) {
+            return "";
+        }
+        return name.substring(0, name.length() - 1);
+    }
+
+    private static void encodeDomainName(String name, ByteBuf out) {
+        String[] parts = StringUtil.split(name, '.');
+        for (String part : parts) {
+            int partLen = part.length();
+            if (partLen == 0) {
+                continue;
+            }
+            if (partLen > 63) {
+                throw new IllegalArgumentException("label too long: " + partLen);
+            }
+            out.writeByte(partLen);
+            out.writeBytes(part.getBytes(NAME_CHARSET));
+        }
+        out.writeByte(0);
+    }
+}
