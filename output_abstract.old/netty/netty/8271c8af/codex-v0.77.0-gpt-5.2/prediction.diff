+ */
+package io.netty.handler.codec.dns;
+
+import io.netty.buffer.ByteBuf;
+import io.netty.channel.ChannelHandlerContext;
+import io.netty.handler.codec.MessageToByteEncoder;
+
+/**
+ * TCP encoder for DNS queries (RFC 1035 section 4.2.2).
+ *
+ * <p>Prepends a 2-byte length field to the DNS message.
+ */
+public class TcpDnsQueryEncoder extends MessageToByteEncoder<DnsQuery> {
+    @Override
+    protected void encode(ChannelHandlerContext ctx, DnsQuery msg, ByteBuf out) throws Exception {
+        ByteBuf buf = ctx.alloc().buffer(512);
+        try {
+            DnsMessageCodec.encodeQuery(msg, buf);
+            int len = buf.readableBytes();
+            out.writeShort(len);
+            out.writeBytes(buf, buf.readerIndex(), len);
+        } finally {
+            buf.release();
+        }
+    }
+}
