+package io.netty.handler.codec.dns;
+
+/**
+ * A DNS record as defined in RFC 1035.
+ *
+ * <p>In the QUESTION section, the record uses {@code QNAME}, {@code QTYPE}, and {@code QCLASS}.
+ * In other sections (ANSWER, AUTHORITY, ADDITIONAL), the record uses {@code NAME}, {@code TYPE}, and {@code CLASS}.
+ */
+public interface DnsRecord {
+    /**
+     * Returns {@code QNAME} (for QUESTION section) or {@code NAME} (for other sections).
+     */
+    String name();
+
+    /**
+     * Returns {@code QTYPE} (for QUESTION section) or {@code TYPE} (for other sections).
+     */
+    DnsType type();
+
+    /**
+     * Returns {@code QCLASS} (for QUESTION section) or {@code CLASS} (for other sections).
+     */
+    DnsClass dnsClass();
+}
+
