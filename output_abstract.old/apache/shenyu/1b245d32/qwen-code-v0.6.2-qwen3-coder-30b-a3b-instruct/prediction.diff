+    <artifactId>shenyu-infra-client</artifactId>
+    <packaging>pom</packaging>
+
+    <modules>
+        <module>shenyu-infra-client-zookeeper</module>
+        <module>shenyu-infra-client-nacos</module>
+        <module>shenyu-infra-client-consul</module>
+        <module>shenyu-infra-client-etcd</module>
+        <module>shenyu-infra-client-apollo</module>
