+package org.apache.shenyu.infra.http;
+
+import okhttp3.OkHttpClient;
+
+import java.time.Duration;
+import java.util.Objects;
+
+/**
+ * OkHttp client factory utilities.
+ */
+public final class OkHttpClientFactory {
+
+    private OkHttpClientFactory() {
+    }
+
+    /**
+     * Create {@link OkHttpClient.Builder} with connect/read/write timeouts.
+     *
+     * @param connectTimeout connect timeout
+     * @param readTimeout read timeout
+     * @param writeTimeout write timeout
+     * @return OkHttpClient.Builder
+     */
+    public static OkHttpClient.Builder newBuilder(final Duration connectTimeout, final Duration readTimeout, final Duration writeTimeout) {
+        OkHttpClient.Builder builder = new OkHttpClient.Builder();
+        if (Objects.nonNull(connectTimeout)) {
+            builder.connectTimeout(connectTimeout);
+        }
+        if (Objects.nonNull(readTimeout)) {
+            builder.readTimeout(readTimeout);
+        }
+        if (Objects.nonNull(writeTimeout)) {
+            builder.writeTimeout(writeTimeout);
+        }
+        return builder;
+    }
+}
