new file mode 100644
index 0000000..ec73eb9
--- /dev/null
+++ b/src/lib/attributes-to-props.ts
@@ -0,0 +1,101 @@
+import * as reactProperty from 'react-property';
+
+import { PRESERVE_CUSTOM_ATTRIBUTES, setStyleProp } from './utilities';
+
+// https://reactjs.org/docs/uncontrolled-components.html
+// https://developer.mozilla.org/docs/Web/HTML/Attributes
+const UNCONTROLLED_COMPONENT_ATTRIBUTES = ['checked', 'value'] as const;
+const UNCONTROLLED_COMPONENT_NAMES = ['input', 'select', 'textarea'] as const;
+
+const VALUE_ONLY_INPUTS: Record<string, true> = {
+  reset: true,
+  submit: true
+};
+
+export type Attributes = Record<string, string>;
+
+export type Props = Record<string, string> & {
+  style: Record<string, string>;
+};
+
+/**
+ * Converts HTML/SVG DOM attributes to React props.
+ *
+ * @param attributes - HTML/SVG DOM attributes.
+ * @param nodeName - DOM node name.
+ * @returns - React props.
+ */
+export default function attributesToProps(
+  attributes: Attributes,
+  nodeName?: string
+): Props {
+  const resolvedAttributes = attributes || {};
+
+  const props: Record<string, any> = {};
+  const inputIsValueOnly =
+    (resolvedAttributes as any).type &&
+    VALUE_ONLY_INPUTS[(resolvedAttributes as any).type];
+
+  for (const attributeName in resolvedAttributes) {
+    const attributeValue = (resolvedAttributes as any)[attributeName];
+
+    if (reactProperty.isCustomAttribute(attributeName)) {
+      props[attributeName] = attributeValue;
+      continue;
+    }
+
+    const attributeNameLowerCased = attributeName.toLowerCase();
+    let propName = getPropName(attributeNameLowerCased);
+
+    if (propName) {
+      const propertyInfo = reactProperty.getPropertyInfo(propName);
+
+      if (
+        (UNCONTROLLED_COMPONENT_ATTRIBUTES as readonly string[]).indexOf(propName) !==
+          -1 &&
+        (UNCONTROLLED_COMPONENT_NAMES as readonly string[]).indexOf(nodeName || '') !==
+          -1 &&
+        !inputIsValueOnly
+      ) {
+        propName = getPropName('default' + attributeNameLowerCased);
+      }
+
+      props[propName] = attributeValue;
+
+      switch (propertyInfo && propertyInfo.type) {
+        case reactProperty.BOOLEAN:
+          props[propName] = true;
+          break;
+        case reactProperty.OVERLOADED_BOOLEAN:
+          if (attributeValue === '') {
+            props[propName] = true;
+          }
+          break;
+      }
+      continue;
+    }
+
+    if (PRESERVE_CUSTOM_ATTRIBUTES) {
+      props[attributeName] = attributeValue;
+    }
+  }
+
+  setStyleProp((resolvedAttributes as any).style, props);
+
+  return props as Props;
+}
+
+// support CommonJS and ES Modules
+module.exports = attributesToProps;
+(attributesToProps as any).default = attributesToProps;
+
+/**
+ * Gets prop name from lowercased attribute name.
+ *
+ * @param attributeName - Lowercased attribute name.
+ * @returns - Prop name.
+ */
+function getPropName(attributeName: string): string {
+  return reactProperty.possibleStandardNames[attributeName];
+}
+
diff --git a/src/lib/dom-to-react.ts b/src/lib/dom-to-react.ts
new file mode 100644
index 0000000..e2dbe7c
--- /dev/null
+++ b/src/lib/dom-to-react.ts
@@ -0,0 +1,130 @@
+import React from 'react';
+import type { DOMNode, HTMLReactParserOptions } from '..';
+
+import attributesToProps from './attributes-to-props';
+import {
+  canTextBeChildOfNode,
+  isCustomComponent,
+  PRESERVE_CUSTOM_ATTRIBUTES,
+  returnFirstArg,
+  setStyleProp
+} from './utilities';
+
+/**
+ * Converts DOM nodes to JSX element(s).
+ *
+ * @param nodes - DOM nodes.
+ * @param options - Options.
+ * @returns - String or JSX element(s).
+ */
+export default function domToReact(
+  nodes: DOMNode[],
+  options?: HTMLReactParserOptions
+): string | JSX.Element | JSX.Element[] {
+  const resolvedOptions = options || {};
+
+  const library: any = resolvedOptions.library || React;
+  const cloneElement = library.cloneElement;
+  const createElement = library.createElement;
+  const isValidElement = library.isValidElement;
+
+  const result: any[] = [];
+  const hasReplace = typeof resolvedOptions.replace === 'function';
+  const transform = resolvedOptions.transform || returnFirstArg;
+  const trim = resolvedOptions.trim;
+
+  for (let i = 0, len = nodes.length; i < len; i++) {
+    const node: any = nodes[i];
+
+    // replace with custom React element (if present)
+    if (hasReplace) {
+      let replaceElement = (resolvedOptions.replace as any)(node);
+
+      if (isValidElement(replaceElement)) {
+        if (len > 1) {
+          replaceElement = cloneElement(replaceElement, {
+            key: replaceElement.key || i
+          });
+        }
+        result.push(transform(replaceElement, node, i) as any);
+        continue;
+      }
+    }
+
+    if (node.type === 'text') {
+      const isWhitespace = !node.data.trim().length;
+
+      if (isWhitespace && node.parent && !canTextBeChildOfNode(node.parent)) {
+        continue;
+      }
+
+      if (trim && isWhitespace) {
+        continue;
+      }
+
+      result.push(transform(node.data, node, i) as any);
+      continue;
+    }
+
+    let props: any = node.attribs;
+    if (skipAttributesToProps(node)) {
+      setStyleProp(props?.style, props);
+    } else if (props) {
+      props = attributesToProps(props, node.name);
+    }
+
+    let children: any = null;
+
+    switch (node.type) {
+      case 'script':
+      case 'style':
+        if (node.children?.[0]) {
+          props.dangerouslySetInnerHTML = {
+            __html: node.children[0].data
+          };
+        }
+        break;
+
+      case 'tag':
+        if (node.name === 'textarea' && node.children?.[0]) {
+          props.defaultValue = node.children[0].data;
+        } else if (node.children?.length) {
+          children = domToReact(node.children, resolvedOptions);
+        }
+        break;
+
+      default:
+        continue;
+    }
+
+    if (len > 1) {
+      props.key = i;
+    }
+
+    result.push(
+      transform(createElement(node.name, props, children), node, i) as any
+    );
+  }
+
+  return (result.length === 1 ? result[0] : result) as any;
+}
+
+// support CommonJS and ES Modules
+module.exports = domToReact;
+(domToReact as any).default = domToReact;
+
+/**
+ * Determines whether DOM element attributes should be transformed to props.
+ * Web Components should not have their attributes transformed except for `style`.
+ *
+ * @param node
+ * @returns - Whether node attributes should be converted to props.
+ */
+function skipAttributesToProps(node: any): boolean {
+  return (
+    PRESERVE_CUSTOM_ATTRIBUTES &&
+    node.type === 'tag' &&
+    isCustomComponent(node.name, node.attribs)
+  );
+}
+
diff --git a/src/lib/utilities.ts b/src/lib/utilities.ts
new file mode 100644
index 0000000..76c7dcf
--- /dev/null
+++ b/src/lib/utilities.ts
@@ -0,0 +1,99 @@
+import React from 'react';
+import styleToJS from 'style-to-js';
+
+const RESERVED_SVG_MATHML_ELEMENTS = new Set([
+  'annotation-xml',
+  'color-profile',
+  'font-face',
+  'font-face-src',
+  'font-face-uri',
+  'font-face-format',
+  'font-face-name',
+  'missing-glyph'
+]);
+
+/**
+ * Check if a given tag is a custom component.
+ *
+ * @see {@link https://github.com/facebook/react/blob/v16.6.3/packages/react-dom/src/shared/isCustomComponent.js}
+ *
+ * @param tagName - The name of the html tag.
+ * @param props - The props being passed to the element.
+ * @returns - Whether tag is custom component.
+ */
+export function isCustomComponent(
+  tagName: string,
+  props?: Record<string, unknown>
+): boolean {
+  if (tagName.indexOf('-') === -1) {
+    return !!(props && typeof (props as any).is === 'string');
+  }
+  if (RESERVED_SVG_MATHML_ELEMENTS.has(tagName)) {
+    return false;
+  }
+  return true;
+}
+
+const STYLE_TO_JS_OPTIONS = { reactCompat: true } as const;
+
+/**
+ * Sets style prop.
+ *
+ * @param style
+ * @param props
+ */
+export function setStyleProp(
+  style: null | undefined | string,
+  props: any
+): void {
+  if (style === null || style === undefined) {
+    return;
+  }
+  try {
+    props.style = styleToJS(style, STYLE_TO_JS_OPTIONS);
+  } catch {
+    props.style = {};
+  }
+}
+
+/**
+ * @constant {boolean}
+ * @see {@link https://reactjs.org/blog/2017/09/08/dom-attributes-in-react-16.html}
+ */
+export const PRESERVE_CUSTOM_ATTRIBUTES =
+  Number(React.version.split('.')[0]) >= 16;
+
+// Taken from
+// https://github.com/facebook/react/blob/cae635054e17a6f107a39d328649137b83f25972/packages/react-dom/src/client/validateDOMNesting.js#L213
+export const ELEMENTS_WITH_NO_TEXT_CHILDREN = new Set([
+  'tr',
+  'tbody',
+  'thead',
+  'tfoot',
+  'colgroup',
+  'table',
+  'head',
+  'html',
+  'frameset'
+]);
+
+/**
+ * Checks if the given node can contain text nodes
+ *
+ * @param node - Node.
+ * @returns - Whether node can contain text nodes.
+ */
+export function canTextBeChildOfNode(node: { name: string }): boolean {
+  return !ELEMENTS_WITH_NO_TEXT_CHILDREN.has(node.name);
+}
+
+/**
+ * Returns the first argument as is.
+ *
+ * @param arg - The argument to be returned.
+ * @returns The input argument `arg`.
+ */
+export function returnFirstArg<T>(arg: T): T {
+  return arg;
+}
+
