@@ -0,0 +1,99 @@
+import {
+  Comment,
+  Element,
+  Node,
+  ProcessingInstruction,
+  Text
+} from 'domhandler';
+import type { DomHandlerOptions } from 'domhandler';
+import htmlToDOMModule from 'html-dom-parser';
+import type HTMLDOMParser from 'html-dom-parser';
+import type { ParserOptions } from 'htmlparser2';
+
+import attributesToProps from './lib/attributes-to-props';
+import domToReact from './lib/dom-to-react';
+
+export { attributesToProps, domToReact };
+
+export type HTMLParser2Options = ParserOptions & DomHandlerOptions;
+
+export { Comment, Element, ProcessingInstruction, Text };
+
+export type DOMNode = Comment | Element | Node | ProcessingInstruction | Text;
+
+export interface HTMLReactParserOptions {
+  htmlparser2?: HTMLParser2Options;
+
+  library?: {
+    cloneElement: (
+      element: JSX.Element,
+      props?: object,
+      ...children: any
+    ) => JSX.Element;
+    createElement: (type: any, props?: object, ...children: any) => JSX.Element;
+    isValidElement: (element: any) => boolean;
+    [key: string]: any;
+  };
+
+  replace?: (
+    domNode: DOMNode
+  ) => JSX.Element | object | void | undefined | null | false;
+
+  transform?: (
+    reactNode: JSX.Element | string,
+    domNode: DOMNode,
+    index: number
+  ) => JSX.Element | string | null;
+
+  trim?: boolean;
+}
+
+const htmlToDOM: typeof HTMLDOMParser =
+  typeof (htmlToDOMModule as any).default === 'function'
+    ? (htmlToDOMModule as any).default
+    : (htmlToDOMModule as unknown as typeof HTMLDOMParser);
+
+export { htmlToDOM };
+
+const domParserOptions: ParserOptions = { lowerCaseAttributeNames: false };
+
+/**
+ * Converts HTML string to React elements.
+ *
+ * @param html - HTML string.
+ * @param options - Parser options.
+ * @returns - React element(s), empty array, or string.
+ */
+export default function HTMLReactParser(
+  html: string,
+  options?: HTMLReactParserOptions
+): ReturnType<typeof domToReact> {
+  if (typeof html !== 'string') {
+    throw new TypeError('First argument must be a string');
+  }
+  if (html === '') {
+    return [];
+  }
+
+  const resolvedOptions = options || {};
+
+  return domToReact(
+    htmlToDOM(html, resolvedOptions.htmlparser2 || domParserOptions),
+    resolvedOptions
+  );
+}
+
+(HTMLReactParser as any).domToReact = domToReact;
+(HTMLReactParser as any).htmlToDOM = htmlToDOM;
+(HTMLReactParser as any).attributesToProps = attributesToProps;
+
+// domhandler
+(HTMLReactParser as any).Comment = Comment;
+(HTMLReactParser as any).Element = Element;
+(HTMLReactParser as any).ProcessingInstruction = ProcessingInstruction;
+(HTMLReactParser as any).Text = Text;
+
+// support CommonJS and ES Modules
+module.exports = HTMLReactParser;
+(HTMLReactParser as any).default = HTMLReactParser;
+
