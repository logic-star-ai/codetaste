+import domToReact from '../lib/dom-to-react';
+import { Element, Text } from 'domhandler';
+
+describe('domToReact', () => {
+  it('should convert text node to string', () => {
+    const nodes = [{ type: 'text', data: 'Hello World' }];
+    const result = domToReact(nodes);
+    
+    expect(result).toBe('Hello World');
+  });
+
+  it('should convert element node to React element', () => {
+    const nodes = [{
+      type: 'tag',
+      name: 'p',
+      attribs: {},
+      children: []
+    }];
+    const result = domToReact(nodes);
+    
+    expect(result).toBeDefined();
+  });
+
+  it('should handle nested elements', () => {
+    const nodes = [{
+      type: 'tag',
+      name: 'div',
+      attribs: {},
+      children: [{
+        type: 'tag',
+        name: 'p',
+        attribs: {},
+        children: [{
+          type: 'text',
+          data: 'Hello'
+        }]
+      }]
+    }];
+    const result = domToReact(nodes);
+    
+    expect(result).toBeDefined();
+  });
+});
