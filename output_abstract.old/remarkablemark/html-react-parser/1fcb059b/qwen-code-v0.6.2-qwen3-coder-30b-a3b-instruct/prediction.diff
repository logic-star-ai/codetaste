+import HTMLReactParser from '../index';
+import { Element } from 'domhandler';
+
+describe('HTMLReactParser', () => {
+  it('should parse simple HTML string', () => {
+    const html = '<p>Hello World</p>';
+    const result = HTMLReactParser(html);
+    
+    expect(result).toBeDefined();
+  });
+
+  it('should throw TypeError for non-string input', () => {
+    expect(() => HTMLReactParser(123)).toThrow(TypeError);
+  });
+
+  it('should return empty array for empty string', () => {
+    const result = HTMLReactParser('');
+    
+    expect(result).toEqual([]);
+  });
+
+  it('should handle replace option', () => {
+    const html = '<p>Hello World</p>';
+    const options = {
+      replace: (domNode) => {
+        if (domNode instanceof Element && domNode.name === 'p') {
+          return <span>Hello World</span>;
+        }
+      }
+    };
+    const result = HTMLReactParser(html, options);
+    
+    expect(result).toBeDefined();
+  });
+});
