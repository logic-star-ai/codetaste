+import domhandler from 'domhandler';
+import htmlToDOM from 'html-dom-parser';
+
+import attributesToProps from './lib/attributes-to-props';
+import domToReact from './lib/dom-to-react';
+
+// support backwards compatibility for ES Module
+const htmlToDOMDefault = typeof (htmlToDOM as any).default === 'function' ? (htmlToDOM as any).default : htmlToDOM;
+
+const domParserOptions = { lowerCaseAttributeNames: false };
+
+/**
+ * Converts HTML string to React elements.
+ *
+ * @param {string} html - HTML string.
+ * @param {object} [options] - Parser options.
+ * @param {object} [options.htmlparser2] - htmlparser2 options.
+ * @param {object} [options.library] - Library for React, Preact, etc.
+ * @param {Function} [options.replace] - Replace method.
+ * @returns {JSX.Element|JSX.Element[]|string} - React element(s), empty array, or string.
+ */
+function HTMLReactParser(html: string, options?: any): any {
+  if (typeof html !== 'string') {
+    throw new TypeError('First argument must be a string');
+  }
+  if (html === '') {
+    return [];
+  }
+  options = options || {};
+  return domToReact(
+    htmlToDOMDefault(html, options.htmlparser2 || domParserOptions),
+    options
+  );
+}
+
+HTMLReactParser.domToReact = domToReact;
+HTMLReactParser.htmlToDOM = htmlToDOMDefault;
+HTMLReactParser.attributesToProps = attributesToProps;
+
+// domhandler
+HTMLReactParser.Comment = (domhandler as any).Comment;
+HTMLReactParser.Element = (domhandler as any).Element;
+HTMLReactParser.ProcessingInstruction = (domhandler as any).ProcessingInstruction;
+HTMLReactParser.Text = (domhandler as any).Text;
+
+// support CommonJS and ES Modules
+export default HTMLReactParser;
+HTMLReactParser.default = HTMLReactParser;
