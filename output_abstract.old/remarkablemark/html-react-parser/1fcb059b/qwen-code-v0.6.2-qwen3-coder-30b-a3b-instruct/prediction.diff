+import attributesToProps from '../lib/attributes-to-props';
+
+describe('attributesToProps', () => {
+  it('should convert attributes to props', () => {
+    const attributes = { class: 'btn', id: 'btn1' };
+    const props = attributesToProps(attributes);
+    
+    expect(props).toEqual({
+      className: 'btn',
+      id: 'btn1'
+    });
+  });
+
+  it('should convert style attribute to style object', () => {
+    const attributes = { style: 'color: red; font-size: 16px;' };
+    const props = attributesToProps(attributes);
+    
+    expect(props).toEqual({
+      style: {
+        color: 'red',
+        fontSize: '16px'
+      }
+    });
+  });
+
+  it('should handle custom attributes', () => {
+    const attributes = { 'data-testid': 'my-button' };
+    const props = attributesToProps(attributes);
+    
+    expect(props).toEqual({
+      'data-testid': 'my-button'
+    });
+  });
+});
