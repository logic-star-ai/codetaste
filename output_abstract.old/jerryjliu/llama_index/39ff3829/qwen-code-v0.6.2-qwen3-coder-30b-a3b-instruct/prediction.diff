+from unittest.mock import MagicMock
+from llama_index.prompts.base import Prompt
+from llama_index.prompts.prompt_selector import PromptSelector, is_chat_model
+from llama_index.prompts.generic_prompt import GenericPromptTemplate
+from llama_index.llms.base import LLM
+from llama_index.llms.openai import OpenAI
+
+# Test the exact scenario from the failing test
+def is_openai(llm: LLM) -> bool:
+    """Test condition."""
+    return isinstance(llm, OpenAI)
+
+# Create test prompts
+prompt_txt = "hello {text} {foo}"
+prompt_txt_2 = "world {text} {foo}"
+prompt = GenericPromptTemplate(input_variables=["text", "foo"], template=prompt_txt)
+prompt_2 = GenericPromptTemplate(input_variables=["text", "foo"], template=prompt_txt_2)
+
+print("Creating prompt selector...")
+test_prompt_selector = PromptSelector(
+    default_prompt=prompt, conditionals=[(is_openai, prompt_2)]
+)
+
+print("Creating prompt with selector...")
+prompt_new = Prompt(langchain_prompt_selector=test_prompt_selector)
+print("Prompt's prompt:", prompt_new.prompt.template)
+
+# Test get_langchain_prompt with None
+lc_prompt_none = prompt_new.get_langchain_prompt(None)
+print("get_langchain_prompt(None):", lc_prompt_none.template)
+
+# Test get_langchain_prompt with LLM
+test_llm = MagicMock(spec=OpenAI)
+lc_prompt_with_llm = prompt_new.get_langchain_prompt(test_llm)
+print("get_langchain_prompt(test_llm):", lc_prompt_with_llm.template)
+
+# Test format with LLM
+result = prompt_new.format(llm=test_llm, text="world2", foo="bar")
+print("format with llm:", result)
+print("Expected:", "world world2 bar")
