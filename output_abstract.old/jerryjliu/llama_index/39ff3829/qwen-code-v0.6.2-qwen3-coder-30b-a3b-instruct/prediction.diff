--- /dev/null
+++ b/llama_index/prompts/generic_prompt.py
@@ -0,0 +1,45 @@
+"""Generic prompt template without LangChain dependency."""
+
+from typing import Any, Dict, List, Optional
+import re
+
+
+class GenericPromptTemplate:
+    """Generic prompt template that handles formatting without LangChain dependency."""
+
+    def __init__(self, template: str, input_variables: Optional[List[str]] = None):
+        """Initialize with template string and input variables."""
+        self.template = template
+        self.input_variables = input_variables or []
+
+        # Extract variables from template if not provided
+        if not self.input_variables:
+            # Simple regex-like extraction of variables in braces
+            matches = re.findall(r'\{([^}]+)\}', template)
+            self.input_variables = list(set(matches))  # Remove duplicates
+
+    def format(self, **kwargs: Any) -> str:
+        """Format the template with provided values."""
+        # Use simple string replacement for {} style placeholders
+        formatted = self.template
+        for key, value in kwargs.items():
+            formatted = formatted.replace(f"{{{key}}}", str(value))
+        return formatted
+
+    @property
+    def input_variables(self) -> List[str]:
+        """Get the input variables for this template."""
+        return self._input_variables
+
+    @input_variables.setter
+    def input_variables(self, value: List[str]) -> None:
+        """Set the input variables for this template."""
+        self._input_variables = value
+
+    def __str__(self) -> str:
+        """String representation of the template."""
+        return self.template
+
+    def __repr__(self) -> str:
+        """Detailed representation of the template."""
+        return f"GenericPromptTemplate(template='{self.template}', input_variables={self.input_variables})"
