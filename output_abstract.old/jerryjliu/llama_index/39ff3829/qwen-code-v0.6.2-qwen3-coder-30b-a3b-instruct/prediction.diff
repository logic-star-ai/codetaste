+from unittest.mock import MagicMock
+from llama_index.prompts.prompt_selector import PromptSelector, is_chat_model
+from llama_index.prompts.generic_prompt import GenericPromptTemplate
+from llama_index.llms.base import LLM
+from llama_index.llms.openai import OpenAI
+
+# Test the selector logic directly
+def is_openai(llm: LLM) -> bool:
+    """Test condition."""
+    return isinstance(llm, OpenAI)
+
+# Create test prompts
+prompt_txt = "hello {text} {foo}"
+prompt_txt_2 = "world {text} {foo}"
+prompt = GenericPromptTemplate(input_variables=["text", "foo"], template=prompt_txt)
+prompt_2 = GenericPromptTemplate(input_variables=["text", "foo"], template=prompt_txt_2)
+
+print("Testing condition function...")
+test_llm = MagicMock(spec=OpenAI)
+print("Is instance of OpenAI?", isinstance(test_llm, OpenAI))
+
+# Create selector
+test_prompt_selector = PromptSelector(
+    default_prompt=prompt, conditionals=[(is_openai, prompt_2)]
+)
+
+print("Testing select method...")
+selected_prompt = test_prompt_selector.select(test_llm)
+print("Selected prompt:", selected_prompt.template)
+
+# Test with None
+selected_prompt_none = test_prompt_selector.select(None)
+print("Selected prompt (None):", selected_prompt_none.template)
+
+# Test with non-openai llm
+fake_llm = MagicMock()
+print("Is instance of OpenAI (fake)?", isinstance(fake_llm, OpenAI))
+selected_prompt_fake = test_prompt_selector.select(fake_llm)
+print("Selected prompt (fake):", selected_prompt_fake.template)
