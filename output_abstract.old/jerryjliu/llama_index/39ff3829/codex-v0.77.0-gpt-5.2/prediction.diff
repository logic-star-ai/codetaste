+++ b/llama_index/prompts/templates.py
@@ -0,0 +1,178 @@
+"""Prompt template primitives used by LlamaIndex.
+
+This module is intentionally LangChain-free. If a LangChain prompt template is
+provided by a caller, it can be wrapped via `LangChainPromptTemplateAdapter`
+without importing LangChain at module import time.
+"""
+
+from __future__ import annotations
+
+from dataclasses import dataclass, field
+from string import Formatter
+from typing import Any, Dict, Iterable, List, Optional, Sequence, Set, Union
+
+from llama_index.llms.base import ChatMessage, MessageRole
+
+
+def _extract_template_vars(template: str) -> List[str]:
+    """Extract format variables from a python format string."""
+    vars_: Set[str] = set()
+    for _, field_name, _, _ in Formatter().parse(template):
+        if not field_name:
+            continue
+        # strip format specifiers / attribute / item access (best-effort)
+        base = field_name.split("!")[0].split(":")[0]
+        base = base.split(".", 1)[0].split("[", 1)[0]
+        if base:
+            vars_.add(base)
+    return sorted(vars_)
+
+
+class BasePromptTemplate:
+    """Minimal prompt template interface used throughout the prompts package."""
+
+    @property
+    def input_variables(self) -> List[str]:
+        raise NotImplementedError
+
+    def format(self, **kwargs: Any) -> str:
+        raise NotImplementedError
+
+    def format_messages(self, **kwargs: Any) -> List[ChatMessage]:
+        raise NotImplementedError
+
+
+@dataclass(frozen=True)
+class TextPromptTemplate(BasePromptTemplate):
+    template: str
+    _input_variables: List[str] = field(default_factory=list)
+
+    @classmethod
+    def from_template(
+        cls, template: str, input_variables: Optional[Sequence[str]] = None, **_: Any
+    ) -> "TextPromptTemplate":
+        return cls(
+            template=template,
+            _input_variables=list(input_variables) if input_variables else _extract_template_vars(template),
+        )
+
+    @property
+    def input_variables(self) -> List[str]:
+        return list(self._input_variables)
+
+    def format(self, **kwargs: Any) -> str:
+        return self.template.format(**kwargs)
+
+    def format_messages(self, **kwargs: Any) -> List[ChatMessage]:
+        return [ChatMessage(role=MessageRole.USER, content=self.format(**kwargs))]
+
+
+@dataclass(frozen=True)
+class ChatMessageTemplate:
+    role: MessageRole
+    template: str
+    name: Optional[str] = None
+    additional_kwargs: Dict[str, Any] = field(default_factory=dict)
+    _input_variables: List[str] = field(default_factory=list)
+
+    @classmethod
+    def from_template(
+        cls,
+        template: str,
+        role: MessageRole,
+        *,
+        name: Optional[str] = None,
+        additional_kwargs: Optional[Dict[str, Any]] = None,
+    ) -> "ChatMessageTemplate":
+        return cls(
+            role=role,
+            template=template,
+            name=name,
+            additional_kwargs=dict(additional_kwargs or {}),
+            _input_variables=_extract_template_vars(template),
+        )
+
+    @property
+    def input_variables(self) -> List[str]:
+        return list(self._input_variables)
+
+    def format(self, **kwargs: Any) -> ChatMessage:
+        return ChatMessage(
+            role=self.role,
+            content=self.template.format(**kwargs),
+            name=self.name,
+            additional_kwargs=dict(self.additional_kwargs),
+        )
+
+
+@dataclass(frozen=True)
+class ChatPromptTemplate(BasePromptTemplate):
+    message_templates: List[ChatMessageTemplate]
+
+    @classmethod
+    def from_messages(
+        cls, message_templates: Sequence[ChatMessageTemplate]
+    ) -> "ChatPromptTemplate":
+        return cls(message_templates=list(message_templates))
+
+    @property
+    def input_variables(self) -> List[str]:
+        vars_: Set[str] = set()
+        for msg in self.message_templates:
+            vars_.update(msg.input_variables)
+        return sorted(vars_)
+
+    def format(self, **kwargs: Any) -> str:
+        # Best-effort string representation (useful for token counting/debugging).
+        return "\n".join(m.format(**kwargs).content for m in self.message_templates)
+
+    def format_messages(self, **kwargs: Any) -> List[ChatMessage]:
+        return [m.format(**kwargs) for m in self.message_templates]
+
+
+def _lc_message_to_chat_message(lc_message: Any) -> ChatMessage:
+    """Convert a LangChain BaseMessage-like object into a LlamaIndex ChatMessage.
+
+    This is duck-typed to avoid importing LangChain.
+    """
+    msg_type = getattr(lc_message, "type", None)
+    content = getattr(lc_message, "content", "")
+    additional_kwargs = dict(getattr(lc_message, "additional_kwargs", {}) or {})
+
+    if msg_type in ("human", "user"):
+        return ChatMessage(role=MessageRole.USER, content=content, additional_kwargs=additional_kwargs)
+    if msg_type in ("ai", "assistant"):
+        return ChatMessage(role=MessageRole.ASSISTANT, content=content, additional_kwargs=additional_kwargs)
+    if msg_type == "system":
+        return ChatMessage(role=MessageRole.SYSTEM, content=content, additional_kwargs=additional_kwargs)
+    if msg_type == "function":
+        name = getattr(lc_message, "name", None)
+        if name is not None:
+            additional_kwargs = dict(additional_kwargs)
+            additional_kwargs.setdefault("name", name)
+        return ChatMessage(role=MessageRole.FUNCTION, content=content, additional_kwargs=additional_kwargs)
+
+    raise ValueError(f"Unsupported message type: {msg_type!r} ({type(lc_message)})")
+
+
+class LangChainPromptTemplateAdapter(BasePromptTemplate):
+    """Wrap a LangChain prompt template without a hard dependency on LangChain."""
+
+    def __init__(self, lc_prompt: Any) -> None:
+        self._lc_prompt = lc_prompt
+
+    @property
+    def input_variables(self) -> List[str]:
+        return list(getattr(self._lc_prompt, "input_variables", []) or [])
+
+    def format(self, **kwargs: Any) -> str:
+        return self._lc_prompt.format(**kwargs)
+
+    def format_messages(self, **kwargs: Any) -> List[ChatMessage]:
+        prompt_value = self._lc_prompt.format_prompt(**kwargs)
+        lc_messages = prompt_value.to_messages()
+        return [_lc_message_to_chat_message(m) for m in lc_messages]
