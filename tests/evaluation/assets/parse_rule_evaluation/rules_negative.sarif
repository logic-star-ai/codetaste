                                },
                                "region": {
                                    "endColumn": 207,
                                    "endLine": 2187,
                                    "snippet": {
                                        "text": "\t\t\t\tDescription: \"Provenance contains some key authenticated metadata about how a software artifact was built (what sources, what inputs/outputs, etc.). For now, it only contains the subfield `ConfigSource` that identifies the source where a build config file came from. In future, it can be expanded as needed to include more metadata about the build. This field aims to be used to carry minimum amount of the authenticated metadata in *Run status so that Tekton Chains can pick it up and record in the provenance it generates.\","
                                    },
                                    "startColumn": 193,
                                    "startLine": 2187
                                }
                            }
                        }
                    ],
                    "message": {
                        "text": "ConfigSource in backticks should be changed to RefSource"
                    },
                    "properties": {},
                    "ruleId": "rules.configsource-backticks-in-comment"
                },
