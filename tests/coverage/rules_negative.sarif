\n            for (Object path : paths) {\n                addItem(owner, resolver, patternSetFactory, taskDependencyFactory, propertyHost, path, oldItems);\n            }\n            return this;\n        }"},"startColumn":9,"startLine":662}}}],"message":{"text":"Public method parameter should use PatternSetFactory instead of Factory<PatternSet>"},"properties":{},"ruleId":"rules.factory-patternset-public-method-param"},{"fingerprints":{"matchBasedId/v1":"6a188d2c27171679bac093253703dc248d465629592448fd600d0575000c95275869313ac60c2215c18715dbcc8891e2ae0510833bd433892b246537499bd14d_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"platforms/core-configuration/file-collections/src/main/java/org/gradle/api/internal/file/collections/DefaultConfigurableFileCollection.java","uriBaseId":"%SRCROOT%"},"region":{"endColumn":10,"endLine":685,"snippet":{"text":"        private void addItem(DefaultConfigurableFileCollection owner, PathToFileResolver resolver, Factory<PatternSet> patternSetFactory, TaskDependencyFactory taskDependencyFactory, PropertyHost propertyHost, Object path, ImmutableList<Object> oldItems) {\n            // Unpack to deal with DSL syntax: collection += someFiles\n            if (path instanceof FileCollectionInternal) {\n                path = ((FileCollectionInternal) path).replace(owner, () -> {\n                    // Should use FileCollectionFactory here, and it can take care of simplifying the tree. For example, ths returned collection does not need to be mutable\n                    if (oldItems.size() == 1 && oldItems.get(0) instanceof FileCollectionInternal) {\n                        return (FileCollectionInternal) oldItems.get(0);\n                    }\n                    DefaultConfigurableFileCollection oldFiles = new DefaultConfigurableFileCollection(null, resolver, taskDependencyFactory, patternSetFactory, propertyHost);\n                    oldFiles.from(oldItems);\n                    return oldFiles;\n                });\n            }\n            items.add(path);\n        }"},"startColumn":9,"startLine":671}}}],"message":{"text":"Method parameter should use PatternSetFactory instead of Factory<PatternSet>"},"properties":{},"ruleId":"rules.factory-patternset-method-param"},{"fingerprints":{"matchBasedId/v1":"846fb6819926fef0bc59c53a366cf50d9fe02a8b0f72a64837c011e9c5e217753474717bc155bc125943d3a406b44dd5b388014a1106c82d21662db31da45655_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"platforms/core-configuration/file-collections/src/main/java/org/gradle/api/internal/file/collections/DefaultConfigurableFileCollection.java","uriBaseId":"%SRCROOT%"},"region":{"endColumn":10,"endLine":685,"snippet":{"text":"        private void addItem(DefaultConfigurableFileCollection owner, PathToFileResolver resolver, Factory<PatternSet> patternSetFactory, TaskDependencyFactory taskDependencyFactory, PropertyHost propertyHost, Object path, ImmutableList<Object> oldItems) {\n            // Unpack to deal with DSL syntax: collection += someFiles\n            if (path instanceof FileCollectionInternal) {\n                path = ((FileCollectionInternal) path).replace(owner, () -> {\n                    // Should use FileCollectionFactory here, and it can take care of simplifying the tree. For example, ths returned collection does not need to be mutable\n                    if (oldItems.size() == 1 && oldItems.get(0) instanceof FileCollectionInternal) {\n                        return (FileCollectionInternal) oldItems.get(0);\n                    }\n                    DefaultConfigurableFileCollection oldFiles = new DefaultConfigurableFileCollection(null, resolver, taskDependencyFactory, patternSetFactory, propertyHost);\n                    oldFiles.from(oldItems);\n                    return oldFiles;\n                });\n            }\n            items.add(path);\n        }"},"startColumn":9,"startLine":671}}}],"message":{"text":"Parameter named patternSetFactory should use PatternSetFactory type instead of Factory<PatternSet>"},"properties":{},"ruleId":"rules.factory-patternset-named-param"},{"fingerprints":{"matchBasedId/v1":"cef1cd8d3e93545cb29f09d68c227fa780890c753643bb57d737d87348935ddbbd21a3289b25328679d9b461490ccd3e021887fb00910ac3005d9aaeda2cfb52_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"platforms/core-configuration/file-collections/src/main/java/org/gradle/api/internal/file/collections/DefaultConfigurableFileCollection.java","uriBaseId":"%SRCROOT%"},"region":{"endColumn":10,"endLine":685,"snippet":{"text":"        private void addItem(DefaultConfigurableFileCollection owner, PathToFileResolver resolver, Factory<PatternSet> patternSetFactory, TaskDependencyFactory taskDependencyFactory, PropertyHost propertyHost, Object path, ImmutableList<Object> oldItems) {\n            // Unpack to deal with DSL syntax: collection += someFiles\n            if (path instanceof FileCollectionInternal) {\n                path = ((FileCollectionInternal) path).replace(owner, () -> {\n                    // Should use FileCollectionFactory here, and it can take care of simplifying the tree. For example, ths returned collection does not need to be mutable\n                    if (oldItems.size() == 1 && oldItems.get(0) instanceof FileCollectionInternal) {\n                        return (FileCollectionInternal) oldItems.get(0);\n                    }\n                    DefaultConfigurableFileCollection oldFiles = new DefaultConfigurableFileCollection(null, resolver, taskDependencyFactory, patternSetFactory, propertyHost);\n                    oldFiles.from(oldItems);\n                    return oldFiles;\n                });\n            }\n            items.add(path);\n        }"},"startColumn":9,"startLine":671}}}],"message":{"text":"Private method parameter should use PatternSetFactory instead of Factory<PatternSet>"},"properties":{},"ruleId":"rules.factory-patternset-private-method-param"},{"fingerprints":{"matchBasedId/v1":"