r with dedicated factory parameter"},"properties":{},"ruleId":"rules.patternset-factory-constructor-param-positive"},{"fingerprints":{"matchBasedId/v1":"b936e8af0d8d016008a325723244293497032bd0f05ee32c141a62e0b57be478779d4c4e99021dcfd6368f26aba269a775835ae3fd3fa6c7699fb294112fd91f_2"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"platforms/core-configuration/file-collections/src/main/java/org/gradle/api/internal/file/collections/DefaultConfigurableFileCollection.java","uriBaseId":"%SRCROOT%"},"region":{"endColumn":10,"endLine":650,"snippet":{"text":"        @Override\n        public ValueCollector setFrom(DefaultConfigurableFileCollection owner, PathToFileResolver resolver, PatternSetFactory patternSetFactory, TaskDependencyFactory taskDependencyFactory, PropertyHost propertyHost, Iterable<?> path) {\n            ImmutableList<Object> oldItems = ImmutableList.copyOf(items);\n            items.clear();\n            addItem(owner, resolver, patternSetFactory, taskDependencyFactory, propertyHost, path, oldItems);\n            return this;\n        }"},"startColumn":9,"startLine":644}}}],"message":{"text":"Detected constructor with dedicated factory parameter"},"properties":{},"ruleId":"rules.patternset-factory-constructor-param-positive"},{"fingerprints":{"matchBasedId/v1":"b936e8af0d8d016008a325723244293497032bd0f05ee32c141a62e0b57be478779d4c4e99021dcfd6368f26aba269a775835ae3fd3fa6c7699fb294112fd91f_3"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"platforms/core-configuration/file-collections/src/main/java/org/gradle/api/internal/file/collections/DefaultConfigurableFileCollection.java","uriBaseId":"%SRCROOT%"},"region":{"endColumn":10,"endLine":660,"snippet":{"text":"        @Override\n        public ValueCollector setFrom(DefaultConfigurableFileCollection owner, PathToFileResolver resolver, PatternSetFactory patternSetFactory, TaskDependencyFactory taskDependencyFactory, PropertyHost propertyHost, Object[] paths) {\n            ImmutableList<Object> oldItems = ImmutableList.copyOf(items);\n            items.clear();\n            for (Object path : paths) {\n                addItem(owner, resolver, patternSetFactory, taskDependencyFactory, propertyHost, path, oldItems);\n            }\n            return this;\n        }"},"startColumn":9,"startLine":652}}}],"message":{"text":"Detected constructor with dedicated factory parameter"},"properties":{},"ruleId":"rules.patternset-factory-constructor-param-positive"},{"fingerprints":{"matchBasedId/v1":"3923f548084c1c8fd42738579a049ccbdb1eadb72a6feb50be40001c26b4e581e29f6689f0e39de32dce44e16a98428ae2b60d30808ae96041c20398b0d7f67e_1"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"platforms/core-configuration/file-collections/src/main/java/org/gradle/api/internal/file/collections/DefaultConfigurableFileCollection.java","uriBaseId":"%SRCROOT%"},"region":{"endColumn":10,"endLine":669,"snippet":{"text":"        @Override\n        public ValueCollector plus(DefaultConfigurableFileCollection owner, PathToFileResolver resolver, PatternSetFactory patternSetFactory, TaskDependencyFactory taskDependencyFactory, PropertyHost propertyHost, Object... paths) {\n            ImmutableList<Object> oldItems = ImmutableList.copyOf(items);\n            for (Object path : paths) {\n                addItem(owner, resolver, patternSetFactory, taskDependencyFactory, propertyHost, path, oldItems);\n            }\n            return this;\n        }"},"startColumn":9,"startLine":662}}}],"message":{"text":"Detected constructor with dedicated factory parameter"},"properties":{},"ruleId":"rules.patternset-factory-constructor-param-positive"},{"fingerprints":{"matchBasedId/v1":"c5a17c7f7070facdaf32e1048ae16b5856ec64ff930b7f50294e3ff1fca71c727060885e45e8884a4c7b19ff839d7be3ab7beaafad606e6d931b062051239355_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"platforms/core-configuration/file-collections/src/main/java/org/gradle/api/internal/file/collections/DefaultConfigurableFileCollection.java","uriBaseId":"%SRCROOT%"},"region":{"endColumn":10,"endLine":685,"snippet":{"text":"        private void addItem(DefaultConfigurableFileCollection owner, PathToFileResolver resolver, PatternSetFactory patternSetFactory, TaskDependencyFactory taskDependencyFactory, PropertyHost propertyHost, Object path, ImmutableList<Object> oldItems) {\n            // Unpack to deal with DSL syntax: collection += someFiles\n            if (path instanceof FileCollectionInternal) {\n                path = ((FileCollectionInternal) path).replace(owner, () -> {\n                    // Should use FileCollectionFactory here, and it can take care of simplifying the tree. For example, ths returned collection does not need to be mutable\n                    if (oldItems.size() == 1 && oldItems.get(0) instanceof FileCollectionInternal) {\n                        return (FileCollectionInternal) oldItems.get(0);\n                    }\n                    DefaultConfigurableFileCollection oldFiles = new DefaultConfigurableFileCollection(null, resolver, taskDependencyFactory, patternSetFactory, propertyHost);\n                    oldFiles.from(oldItems);\n                    return oldFiles;\n                });\n            }\n            items.add(path);\n        }"},"startColumn":9,"startLine":671}}}],"message":{"text":"Detected constructor with dedicated factory parameter"},"properties":{},"ruleId":"rules.patternset-factory-constructor-param-positive"},{"fingerprints":{"matchBasedId/v1":"b936e8af0d8d016008a325723244293497032bd0f05ee32c141a62e0b57be478779d4c4e99021dcfd6368f26aba269a775835ae3fd3fa6c7699fb294112fd91f_4"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"platforms/core-configuration/file-collections/src/main/java/org/gradle/api/internal/file/collections/DefaultConfigurableFileCollection.java","uriBaseId":"%SRCROOT%"},"region":{"endColumn":10,"endLine":739,"snippet":{"text":"        @Override\n        public ValueCollector setFrom(D