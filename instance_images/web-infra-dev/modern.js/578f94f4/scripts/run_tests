#!/bin/bash
# Test runner script - executes representative test suite
# Run after: source /scripts/setup_shell.sh

set -e

cd /testbed

# Initialize counters
PASSED=0
FAILED=0
SKIPPED=0
TOTAL=0

# Create a temporary file for test output
TEMP_OUTPUT=$(mktemp)

echo "Running Jest unit tests (subset)..."
cd /testbed/tests

# Run Jest with a filter to only test a subset
# This helps keep tests under 15 minutes
if pnpm run test:ut 2>&1 | tee "$TEMP_OUTPUT"; then
    JEST_EXIT=0
else
    JEST_EXIT=$?
fi

# Parse Jest output to extract test counts
if grep -q "Tests:" "$TEMP_OUTPUT"; then
    JEST_LINE=$(grep "Tests:" "$TEMP_OUTPUT" | tail -1)

    # Extract total (last number with "total")
    if echo "$JEST_LINE" | grep -oP '\d+(?= total)' > /dev/null 2>&1; then
        JEST_TOTAL=$(echo "$JEST_LINE" | grep -oP '\d+(?= total)' | head -1)
        TOTAL=$((TOTAL + JEST_TOTAL))
    fi

    # Extract passed
    if echo "$JEST_LINE" | grep -oP '\d+(?= passed)' > /dev/null 2>&1; then
        JEST_PASSED=$(echo "$JEST_LINE" | grep -oP '\d+(?= passed)' | head -1)
        PASSED=$((PASSED + JEST_PASSED))
    fi

    # Extract failed
    if echo "$JEST_LINE" | grep -oP '\d+(?= failed)' > /dev/null 2>&1; then
        JEST_FAILED=$(echo "$JEST_LINE" | grep -oP '\d+(?= failed)' | head -1)
        FAILED=$((FAILED + JEST_FAILED))
    fi

    # Extract skipped
    if echo "$JEST_LINE" | grep -oP '\d+(?= skipped)' > /dev/null 2>&1; then
        JEST_SKIPPED=$(echo "$JEST_LINE" | grep -oP '\d+(?= skipped)' | head -1)
        SKIPPED=$((SKIPPED + JEST_SKIPPED))
    fi

    echo "Jest Results: Passed=$JEST_PASSED, Failed=$JEST_FAILED, Skipped=$JEST_SKIPPED, Total=$JEST_TOTAL"
fi

# Clean up temp file
rm -f "$TEMP_OUTPUT"

# Output final JSON result
echo ""
echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $SKIPPED, \"total\": $TOTAL}"
