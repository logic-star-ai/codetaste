#!/bin/bash
# Test runner script for NumPy
# This script runs a representative subset of tests and outputs JSON results

set -e

# Change to /tmp to avoid import issues with source numpy in /testbed
cd /tmp

# Run actual tests with detailed output
# Use a subset of tests that completes in reasonable time
python -m pytest --pyargs numpy \
    -m "not slow" \
    -v \
    -n auto \
    2>&1 | tee /tmp/pytest_output.txt || true

# Parse the pytest output to extract test results
# Pytest output format: "X passed, Y failed, Z skipped in Xs"
# or variations like "X passed in Xs"

PASSED=0
FAILED=0
SKIPPED=0
TOTAL=0

# Parse the last few lines for the summary
if [ -f /tmp/pytest_output.txt ]; then
    # Look for patterns like "123 passed", "5 failed", "10 skipped"
    SUMMARY=$(tail -30 /tmp/pytest_output.txt | grep -E "passed|failed|skipped|error" | tail -1 || echo "")

    if [ -n "$SUMMARY" ]; then
        # Extract passed count
        if echo "$SUMMARY" | grep -q "passed"; then
            PASSED=$(echo "$SUMMARY" | grep -oE '[0-9]+ passed' | grep -oE '[0-9]+' || echo "0")
        fi

        # Extract failed count
        if echo "$SUMMARY" | grep -q "failed"; then
            FAILED=$(echo "$SUMMARY" | grep -oE '[0-9]+ failed' | grep -oE '[0-9]+' || echo "0")
        fi

        # Extract skipped count
        if echo "$SUMMARY" | grep -q "skipped"; then
            SKIPPED=$(echo "$SUMMARY" | grep -oE '[0-9]+ skipped' | grep -oE '[0-9]+' || echo "0")
        fi

        # Extract error count and add to failed
        if echo "$SUMMARY" | grep -q "error"; then
            ERROR=$(echo "$SUMMARY" | grep -oE '[0-9]+ error' | grep -oE '[0-9]+' || echo "0")
            FAILED=$((FAILED + ERROR))
        fi
    fi
fi

# Calculate total
TOTAL=$((PASSED + FAILED + SKIPPED))

# Ensure we have valid numbers
PASSED=${PASSED:-0}
FAILED=${FAILED:-0}
SKIPPED=${SKIPPED:-0}
TOTAL=${TOTAL:-0}

# Output JSON result
echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $SKIPPED, \"total\": $TOTAL}"
