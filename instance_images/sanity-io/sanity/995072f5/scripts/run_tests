#!/bin/bash
# run_tests - Execute the test suite and output JSON results
# This script assumes setup_shell.sh has already been sourced
# It runs vitest tests and outputs results in JSON format

set -e

cd /testbed

# Create a temporary file for storing test output
TEMP_OUTPUT=$(mktemp)
TEMP_JSON=$(mktemp)

# Run vitest tests with JSON reporter
# We run the workspace tests which should complete in a reasonable time
# Using a timeout to prevent hanging (15 minutes max)
timeout 900 pnpm vitest run --reporter=json --reporter=default --outputFile.json="$TEMP_JSON" 2>&1 | tee "$TEMP_OUTPUT" || EXIT_CODE=$?

# If timeout or other error, try to parse what we have
EXIT_CODE=${EXIT_CODE:-0}

# Check if JSON file was created and has content
if [ -s "$TEMP_JSON" ]; then
    # Parse the vitest JSON output and extract test counts
    # Use node to parse the JSON and extract the relevant fields
    node -e "
    const fs = require('fs');
    let data;
    try {
        const content = fs.readFileSync('$TEMP_JSON', 'utf8');
        data = JSON.parse(content);
    } catch (e) {
        // Fallback to 0
        console.log(JSON.stringify({passed: 0, failed: 0, skipped: 0, total: 0}));
        process.exit(0);
    }

    let passed = 0;
    let failed = 0;
    let skipped = 0;
    let total = 0;

    // Vitest JSON reporter format
    if (data.numTotalTests !== undefined) {
        total = data.numTotalTests || 0;
        passed = data.numPassedTests || 0;
        failed = data.numFailedTests || 0;
        skipped = data.numPendingTests || 0;
    } else if (data.testResults && Array.isArray(data.testResults)) {
        // Alternative format - iterate through test results
        data.testResults.forEach(fileResult => {
            if (fileResult.assertionResults && Array.isArray(fileResult.assertionResults)) {
                fileResult.assertionResults.forEach(assertion => {
                    total++;
                    if (assertion.status === 'passed') passed++;
                    else if (assertion.status === 'failed') failed++;
                    else if (assertion.status === 'pending' || assertion.status === 'skipped' || assertion.status === 'todo') skipped++;
                });
            }
        });
    }

    console.log(JSON.stringify({passed, failed, skipped, total}));
    " 2>/dev/null
else
    # Fallback: parse from verbose output if JSON file wasn't created
    # Look for the summary line which has format:
    # Test Files  X passed | Y failed | Z skipped (N)
    #      Tests  X passed | Y failed | Z skipped (N)

    if grep -q "Test Files" "$TEMP_OUTPUT"; then
        # Extract the Tests line (not Test Files)
        TESTS_LINE=$(grep "^[ ]*Tests[ ]" "$TEMP_OUTPUT" | tail -1)

        if [ -n "$TESTS_LINE" ]; then
            # Parse the numbers from the line
            PASSED=$(echo "$TESTS_LINE" | grep -oP '\d+(?= passed)' | head -1 || echo 0)
            FAILED=$(echo "$TESTS_LINE" | grep -oP '\d+(?= failed)' | head -1 || echo 0)
            SKIPPED=$(echo "$TESTS_LINE" | grep -oP '\d+(?= skipped)' | head -1 || echo 0)

            # Get total from the parenthesis at the end
            TOTAL=$(echo "$TESTS_LINE" | grep -oP '\(\K\d+(?=\))' | head -1 || echo 0)

            # If we didn't find total in parenthesis, calculate it
            if [ "$TOTAL" = "0" ] || [ -z "$TOTAL" ]; then
                TOTAL=$((PASSED + FAILED + SKIPPED))
            fi
        else
            # No summary line found, try counting individual results
            PASSED=$(grep -c " ✓ " "$TEMP_OUTPUT" 2>/dev/null || echo 0)
            FAILED=$(grep -c " ✗ " "$TEMP_OUTPUT" 2>/dev/null || echo 0)
            SKIPPED=$(grep -c " ○ " "$TEMP_OUTPUT" 2>/dev/null || echo 0)
            TOTAL=$((PASSED + FAILED + SKIPPED))
        fi
    else
        # No summary found at all
        PASSED=0
        FAILED=0
        SKIPPED=0
        TOTAL=0
    fi

    echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $SKIPPED, \"total\": $TOTAL}"
fi

# Cleanup
rm -f "$TEMP_OUTPUT" "$TEMP_JSON"

# Exit with appropriate code
exit $EXIT_CODE
