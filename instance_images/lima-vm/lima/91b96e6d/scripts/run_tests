#!/bin/bash
# SPDX-FileCopyrightText: Copyright The Lima Authors
# SPDX-License-Identifier: Apache-2.0

# Test execution script for Lima project
# Runs the Go unit test suite and outputs results in JSON format
# Prerequisites: setup_shell.sh must have been sourced before running this script

set -euo pipefail

cd /testbed

# Create a temporary file for test output
TEST_JSON=$(mktemp)

# Function to clean up temporary files
cleanup() {
    rm -f "${TEST_JSON}"
}
trap cleanup EXIT

# Run tests with JSON output to get accurate counts
echo "Running Go unit tests..." >&2

# Run go test with JSON output, capturing both stdout and stderr
if go test -json ./... 2>&1 | tee "${TEST_JSON}"; then
    TEST_EXIT_CODE=0
else
    TEST_EXIT_CODE=$?
fi

# Parse JSON output to count test results
# Count individual test results (not package results)
# We need to count lines where both "Test" and "Action" keys are present (not just "Package")

PASSED=0
FAILED=0
SKIPPED=0

# Read line by line and parse JSON properly
while IFS= read -r line; do
    # Check if this is a test result (has "Test" field and is not just a package result)
    if echo "$line" | grep -q '"Test":' && echo "$line" | grep -q '"Action":"pass"'; then
        PASSED=$((PASSED + 1))
    elif echo "$line" | grep -q '"Test":' && echo "$line" | grep -q '"Action":"fail"'; then
        FAILED=$((FAILED + 1))
    elif echo "$line" | grep -q '"Test":' && echo "$line" | grep -q '"Action":"skip"'; then
        SKIPPED=$((SKIPPED + 1))
    fi
done < "${TEST_JSON}"

# Calculate total
TOTAL=$((PASSED + FAILED + SKIPPED))

# Output JSON result
echo "{\"passed\": ${PASSED}, \"failed\": ${FAILED}, \"skipped\": ${SKIPPED}, \"total\": ${TOTAL}}"

# Exit with appropriate code
exit ${TEST_EXIT_CODE}
