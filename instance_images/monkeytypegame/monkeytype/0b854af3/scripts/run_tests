#!/bin/bash
set -e

# This script runs the test suite and outputs results in JSON format
# It should be run after sourcing setup_shell.sh

cd /testbed

# Create temporary files
TEMP_OUTPUT=$(mktemp)

echo "Running tests..."

# Initialize counters
TOTAL=0
PASSED=0
FAILED=0
SKIPPED=0

# List of packages to test
PACKAGES=(
    "packages/util"
    "packages/contracts"
    "backend"
    "frontend"
)

# Run tests for each package sequentially
for pkg in "${PACKAGES[@]}"; do
    if [ -d "$pkg" ] && [ -f "$pkg/package.json" ]; then
        echo "Testing $pkg..."

        # Check if package has a test script
        if grep -q '"test"' "$pkg/package.json"; then
            cd "/testbed/$pkg"

            # Run vitest with single thread to avoid resource issues
            npx vitest run --pool.threads.singleThread=true --reporter=verbose 2>&1 | tee -a "$TEMP_OUTPUT" || true

            cd /testbed
        fi
    fi
done

# Parse accumulated test results
# Look for vitest summary lines like " Tests  25 passed (25)"
# Sum up all test results from all packages

# Count each type of result from all "Tests " summary lines
while IFS= read -r line; do
    # Only process lines that start with " Tests "
    if [[ $line =~ ^[[:space:]]+Tests[[:space:]]+ ]]; then
        # Extract passed count
        if [[ $line =~ ([0-9]+)[[:space:]]+passed ]]; then
            P="${BASH_REMATCH[1]}"
            PASSED=$((PASSED + P))
        fi
        # Extract failed count
        if [[ $line =~ ([0-9]+)[[:space:]]+failed ]]; then
            F="${BASH_REMATCH[1]}"
            FAILED=$((FAILED + F))
        fi
        # Extract skipped count
        if [[ $line =~ ([0-9]+)[[:space:]]+skipped ]]; then
            S="${BASH_REMATCH[1]}"
            SKIPPED=$((SKIPPED + S))
        fi
        # Extract total from parentheses at end
        if [[ $line =~ \(([0-9]+)\)[[:space:]]*$ ]]; then
            T="${BASH_REMATCH[1]}"
            TOTAL=$((TOTAL + T))
        fi
    fi
done < "$TEMP_OUTPUT"

# If we still don't have a total, calculate it
if [ "$TOTAL" = "0" ]; then
    TOTAL=$((PASSED + FAILED + SKIPPED))
fi

# Ensure we have numeric values
TOTAL=${TOTAL:-0}
PASSED=${PASSED:-0}
FAILED=${FAILED:-0}
SKIPPED=${SKIPPED:-0}

# Clean up temp file
rm -f "$TEMP_OUTPUT"

# Output the required JSON format as the last line
echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $SKIPPED, \"total\": $TOTAL}"
