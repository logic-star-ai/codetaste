#!/bin/bash
# Run TanStack Router test suite
# This script runs the unit tests for the project

set -e

cd /testbed

# Run unit tests with vitest in single-thread mode to avoid resource issues
# We run tests from the root directory which will pick up all packages with tests
echo "Running unit tests..." >&2

# Run vitest with JSON reporter and capture output
# The JSON output is a single line, potentially with warnings before it
JSON_OUTPUT=$(pnpm exec vitest run --pool=threads --poolOptions.threads.singleThread --reporter=json 2>&1 | grep '^{"numTotalTestSuites"' || echo '{"numTotalTests":0,"numPassedTests":0,"numFailedTests":0,"numPendingTests":0}')

# Parse the JSON output and format it
PASSED=$(echo "$JSON_OUTPUT" | jq -r '.numPassedTests // 0')
FAILED=$(echo "$JSON_OUTPUT" | jq -r '.numFailedTests // 0')
SKIPPED=$(echo "$JSON_OUTPUT" | jq -r '.numPendingTests // 0')
TOTAL=$(echo "$JSON_OUTPUT" | jq -r '.numTotalTests // 0')

# Output the final JSON result to stdout
echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $SKIPPED, \"total\": $TOTAL}"
