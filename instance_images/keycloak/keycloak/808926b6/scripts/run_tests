#!/bin/bash
# Test runner script for Keycloak
# This script runs a representative subset of the unit tests

set -e

cd /testbed

# Run unit tests from the services module
# These tests don't use Arquillian and run much faster
echo "Running Keycloak unit tests..."

# Create a temporary file for test output
TEST_OUTPUT=$(mktemp)

# Run the tests from the services module which contains unit tests
# for authentication, OAuth, SAML, and other core functionality
./mvnw -f services/pom.xml \
    test \
    -q \
    2>&1 | tee "$TEST_OUTPUT"

# Parse the test results from Maven surefire-reports directory
# Sum up all test results from individual test report files
REPORT_DIR="/testbed/services/target/surefire-reports"

if [ -d "$REPORT_DIR" ] && [ "$(ls -A $REPORT_DIR/*.txt 2>/dev/null)" ]; then
    # Use awk to sum up all test results
    RESULT=$(grep "Tests run:" "$REPORT_DIR"/*.txt | awk '{
        sum1+=$3; sum2+=$5; sum3+=$7; sum4+=$9
    } END {
        print sum1 "," sum2 "," sum3 "," sum4
    }')

    # Split the result
    TOTAL=$(echo "$RESULT" | cut -d',' -f1)
    FAILURES=$(echo "$RESULT" | cut -d',' -f2)
    ERRORS=$(echo "$RESULT" | cut -d',' -f3)
    SKIPPED=$(echo "$RESULT" | cut -d',' -f4)

    # Calculate passed tests
    FAILED_TOTAL=$((FAILURES + ERRORS))
    PASSED=$((TOTAL - FAILED_TOTAL - SKIPPED))

    # Output JSON result
    echo "{\"passed\": $PASSED, \"failed\": $FAILED_TOTAL, \"skipped\": $SKIPPED, \"total\": $TOTAL}"
else
    # If no tests were run or parsing failed, output zero results
    echo "{\"passed\": 0, \"failed\": 0, \"skipped\": 0, \"total\": 0}"
fi

# Clean up
rm -f "$TEST_OUTPUT"
