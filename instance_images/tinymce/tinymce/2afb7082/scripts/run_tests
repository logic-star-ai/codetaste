#!/bin/bash
# Test runner script for TinyMCE monorepo
# This script runs a representative subset of tests that complete within 15 minutes
# Output format: {"passed": int, "failed": int, "skipped": int, "total": int}

set -e

# Ensure we're using Node 16
export NVM_DIR="/opt/nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
nvm use 16 > /dev/null 2>&1
corepack enable > /dev/null 2>&1

cd /testbed

# Run tests for a representative subset of modules that can complete in <15 minutes
# These modules cover different types of functionality:
# - katamari: data structures and utilities
# - boss: DOM operations
# - boulder: data validation
# - dragster: drag and drop
# - jax: AJAX utilities
# - polaris: search functionality
# - robin: text operations
# - echo: data structures

OUTPUT_FILE="/tmp/test_output_$$.txt"
ERROR_FILE="/tmp/test_errors_$$.txt"

# Run bedrock-auto tests for selected modules
npx bedrock-auto -b chrome-headless \
  -d modules/katamari/src/test/ts \
  -d modules/boss/src/test/ts \
  -d modules/boulder/src/test/ts \
  -d modules/dragster/src/test/ts \
  -d modules/jax/src/test/ts \
  -d modules/polaris/src/test/ts \
  -d modules/robin/src/test/ts \
  -d modules/echo/src/test/ts \
  > "$OUTPUT_FILE" 2> "$ERROR_FILE" || true

# Parse the test results
# Count dots (each dot represents a passing test)
PASSED=$(grep -o '\.' "$OUTPUT_FILE" | wc -l || echo 0)

# Check for failures
FAILED=0
if grep -q "failed" "$OUTPUT_FILE" 2>/dev/null; then
    # Try to extract failure count if bedrock provides it
    FAILED=$(grep -oP '\d+(?= failed)' "$OUTPUT_FILE" | head -1 || echo 0)
fi

# If tests didn't pass, count failures from error output
if ! grep -q "All tests passed" "$OUTPUT_FILE" 2>/dev/null; then
    # If we see timeout or error, mark all tests as failed
    if grep -q -E "(timed out|Fatal error|Unexpected.*Error)" "$OUTPUT_FILE" 2>/dev/null; then
        # Count total tests that were supposed to run
        TOTAL_TESTS=$(grep -oP 'Compiling \K\d+' "$OUTPUT_FILE" | head -1 || echo 0)
        if [ "$TOTAL_TESTS" -gt 0 ]; then
            FAILED=$((TOTAL_TESTS - PASSED))
        fi
    fi
fi

# Bedrock doesn't skip tests by default
SKIPPED=0

# Calculate total
TOTAL=$((PASSED + FAILED + SKIPPED))

# Clean up temp files
rm -f "$OUTPUT_FILE" "$ERROR_FILE"

# Output JSON result (this must be the last line of stdout)
echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $SKIPPED, \"total\": $TOTAL}"
