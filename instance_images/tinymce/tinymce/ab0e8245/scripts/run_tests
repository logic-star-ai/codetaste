#!/bin/bash
# Test execution script
# This script runs the test suite and outputs results in JSON format.
# Environment must be set up by setup_shell.sh before running this script.

set -e

cd /testbed

# Create a temporary file for test output
TEST_OUTPUT=$(mktemp)
trap "rm -f $TEST_OUTPUT" EXIT

# Run headless tests (these are fast and comprehensive)
# We'll run with --ignore-lerna-changed to test all modules
echo "Running headless automated tests..."

# Run the grunt headless tests and capture output
yarn grunt headless-auto --ignore-lerna-changed 2>&1 | tee "$TEST_OUTPUT" || true

# Parse bedrock output to extract test results
# Bedrock outputs progress like: "Progress: 737/737, Failed: 12, Skipped: 9"
PASSED=0
FAILED=0
SKIPPED=0
TOTAL=0

# Look for the final status line with counts
if grep -q "Status: COMPLETE" "$TEST_OUTPUT" 2>/dev/null; then
    # Extract from the COMPLETE status line
    STATUS_LINE=$(grep "Status: COMPLETE" "$TEST_OUTPUT" | tail -1)

    # Extract Progress: X/Y
    if echo "$STATUS_LINE" | grep -q "Progress:"; then
        TOTAL=$(echo "$STATUS_LINE" | grep -oP "Progress: \d+/\K\d+" | head -1)
    fi

    # Extract Failed: X
    if echo "$STATUS_LINE" | grep -q "Failed:"; then
        FAILED=$(echo "$STATUS_LINE" | grep -oP "Failed: \K\d+" | head -1)
    fi

    # Extract Skipped: X
    if echo "$STATUS_LINE" | grep -q "Skipped:"; then
        SKIPPED=$(echo "$STATUS_LINE" | grep -oP "Skipped: \K\d+" | head -1)
    fi

    # Calculate passed
    PASSED=$((TOTAL - FAILED - SKIPPED))
fi

# Ensure they are integers
PASSED=${PASSED:-0}
FAILED=${FAILED:-0}
SKIPPED=${SKIPPED:-0}
TOTAL=${TOTAL:-0}

# If we still don't have results, try other patterns
if [ "$TOTAL" -eq 0 ]; then
    # Count passed tests (lines with checkmark)
    PASSED=$(grep -c "^✓" "$TEST_OUTPUT" 2>/dev/null || echo "0")

    # Count failed tests (lines with X)
    FAILED=$(grep -c "^✗" "$TEST_OUTPUT" 2>/dev/null || echo "0")

    # Count skipped tests (lines with -)
    SKIPPED=$(grep -c "^-" "$TEST_OUTPUT" 2>/dev/null || echo "0")

    # Calculate total
    TOTAL=$((PASSED + FAILED + SKIPPED))
fi

# Output JSON result
echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $SKIPPED, \"total\": $TOTAL}"
