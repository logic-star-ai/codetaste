#!/bin/bash
set -e

cd /testbed

# Function to run yarn commands (same as in setup_shell.sh)
run_yarn() {
    node /testbed/.yarn/releases/yarn-3.4.1.cjs "$@"
}

# Create a temporary file for test output
TEMP_OUTPUT=$(mktemp)

echo "Running Vitest tests..."

# Run vitest with increased memory and capture output
# Using --reporter=verbose to get detailed output
NODE_OPTIONS="--max_old_space_size=8192" run_yarn vitest run --reporter=verbose --passWithNoTests 2>&1 | tee "$TEMP_OUTPUT" || true

# Parse the output to extract test results
# Vitest outputs something like "Test Files  X passed | Y failed (Z)"
# and "Tests  X passed | Y failed | Z skipped (Total)"

# Initialize counters
PASSED=0
FAILED=0
SKIPPED=0
TOTAL=0

# Try to parse the summary line from vitest output
# Look for patterns like:
# "Tests  X passed (Y)" or "Test Files  X passed (Y)" or variations with failed/skipped

# Extract test results from the summary
if grep -q " Tests " "$TEMP_OUTPUT"; then
    # Try to extract from "Tests  X passed | Y failed | Z skipped (Total)" format
    SUMMARY_LINE=$(grep " Tests " "$TEMP_OUTPUT" | tail -1)

    # Extract passed count
    if echo "$SUMMARY_LINE" | grep -oP '\d+(?= passed)' > /dev/null 2>&1; then
        PASSED=$(echo "$SUMMARY_LINE" | grep -oP '\d+(?= passed)' | head -1)
    fi

    # Extract failed count
    if echo "$SUMMARY_LINE" | grep -oP '\d+(?= failed)' > /dev/null 2>&1; then
        FAILED=$(echo "$SUMMARY_LINE" | grep -oP '\d+(?= failed)' | head -1)
    fi

    # Extract skipped count
    if echo "$SUMMARY_LINE" | grep -oP '\d+(?= skipped)' > /dev/null 2>&1; then
        SKIPPED=$(echo "$SUMMARY_LINE" | grep -oP '\d+(?= skipped)' | head -1)
    fi

    # Extract total from parentheses
    if echo "$SUMMARY_LINE" | grep -oP '\(\K\d+(?=\))' > /dev/null 2>&1; then
        TOTAL=$(echo "$SUMMARY_LINE" | grep -oP '\(\K\d+(?=\))' | tail -1)
    fi
fi

# If we couldn't extract from Tests line, try Test Files line
if [ "$TOTAL" -eq 0 ] && grep -q " Test Files " "$TEMP_OUTPUT"; then
    SUMMARY_LINE=$(grep " Test Files " "$TEMP_OUTPUT" | tail -1)

    # Extract passed count
    if echo "$SUMMARY_LINE" | grep -oP '\d+(?= passed)' > /dev/null 2>&1; then
        PASSED=$(echo "$SUMMARY_LINE" | grep -oP '\d+(?= passed)' | head -1)
    fi

    # Extract failed count
    if echo "$SUMMARY_LINE" | grep -oP '\d+(?= failed)' > /dev/null 2>&1; then
        FAILED=$(echo "$SUMMARY_LINE" | grep -oP '\d+(?= failed)' | head -1)
    fi

    # Extract total from parentheses
    if echo "$SUMMARY_LINE" | grep -oP '\(\K\d+(?=\))' > /dev/null 2>&1; then
        TOTAL=$(echo "$SUMMARY_LINE" | grep -oP '\(\K\d+(?=\))' | tail -1)
    fi
fi

# Fallback: If still zero, try counting individual test results
if [ "$TOTAL" -eq 0 ]; then
    # Count checkmarks and crosses in output
    PASSED=$(grep -c "✓" "$TEMP_OUTPUT" 2>/dev/null || echo "0")
    FAILED=$(grep -c "✗" "$TEMP_OUTPUT" 2>/dev/null || echo "0")
    SKIPPED=$(grep -c "↓" "$TEMP_OUTPUT" 2>/dev/null || echo "0")
fi

# Ensure all variables are valid numbers
PASSED=${PASSED:-0}
FAILED=${FAILED:-0}
SKIPPED=${SKIPPED:-0}
TOTAL=${TOTAL:-0}

# Calculate total if not extracted
if [ "$TOTAL" -eq 0 ]; then
    TOTAL=$((PASSED + FAILED + SKIPPED))
fi

# Clean up temp file
rm -f "$TEMP_OUTPUT"

# Output the required JSON format
echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $SKIPPED, \"total\": $TOTAL}"
