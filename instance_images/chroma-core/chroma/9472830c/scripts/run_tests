#!/bin/bash
# Run ChromaDB test suite and output results in JSON format

set -e

cd /testbed

# Run a representative subset of tests that can complete within 15 minutes
# Focus on fast unit tests that don't require external services

# Run pytest and capture output - store exit code separately
set +e
PYTEST_OUTPUT=$(python -m pytest \
    chromadb/test/api/ \
    chromadb/test/client/ \
    chromadb/test/configurations/ \
    chromadb/test/data_loader/ \
    chromadb/test/ef/ \
    chromadb/test/quota/ \
    chromadb/test/rate_limiting/ \
    chromadb/test/segment/test_metadata.py \
    chromadb/test/segment/test_vector.py \
    chromadb/test/test_multithreaded.py \
    -v \
    --tb=short \
    2>&1)
PYTEST_EXIT_CODE=$?
set -e

# Save output for debugging
echo "$PYTEST_OUTPUT" >&2

# Parse the pytest summary line
# Looking for patterns like: "10 passed, 2 failed, 3 skipped in 10.00s"
SUMMARY=$(echo "$PYTEST_OUTPUT" | grep -E "^=+ .* (passed|failed|skipped|error|xfailed)" | tail -1)

# Extract numbers with more robust parsing
PASSED=0
FAILED=0
SKIPPED=0

if echo "$PYTEST_OUTPUT" | grep -q "no tests ran"; then
    PASSED=0
    FAILED=0
    SKIPPED=0
    TOTAL=0
else
    # Extract passed
    if echo "$SUMMARY" | grep -qE "[0-9]+ passed"; then
        PASSED=$(echo "$SUMMARY" | grep -oE "[0-9]+ passed" | grep -oE "[0-9]+" | head -1)
    fi

    # Extract failed
    if echo "$SUMMARY" | grep -qE "[0-9]+ failed"; then
        FAILED=$(echo "$SUMMARY" | grep -oE "[0-9]+ failed" | grep -oE "[0-9]+" | head -1)
    fi

    # Extract skipped
    if echo "$SUMMARY" | grep -qE "[0-9]+ skipped"; then
        SKIPPED=$(echo "$SUMMARY" | grep -oE "[0-9]+ skipped" | grep -oE "[0-9]+" | head -1)
    fi

    # Extract xfailed (expected failures - don't count as failures)
    # Already handled in skipped count

    # Extract errors (treat as failures)
    if echo "$SUMMARY" | grep -qE "[0-9]+ error"; then
        ERRORS=$(echo "$SUMMARY" | grep -oE "[0-9]+ error" | grep -oE "[0-9]+" | head -1)
        FAILED=$((FAILED + ERRORS))
    fi

    # Calculate total
    TOTAL=$((PASSED + FAILED + SKIPPED))
fi

# Output JSON result
echo "{\"passed\": ${PASSED}, \"failed\": ${FAILED}, \"skipped\": ${SKIPPED}, \"total\": ${TOTAL}}"
