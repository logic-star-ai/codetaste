#!/usr/bin/env bash
# Test runner script for etcd
# This script runs the test suite and outputs results in JSON format
# Usage: /scripts/run_tests

# Don't exit on error - we want to collect all test results
set -o pipefail

cd /testbed

# Create a temporary file for test results
TEMP_RESULTS=$(mktemp)
trap "rm -f $TEMP_RESULTS" EXIT

# Run unit tests for key modules with JSON output
# We'll run tests for the most important modules to stay within time budget
# These represent a good cross-section of the codebase

# Modules to test (subset for 15-minute constraint)
# Focus on core modules that are representative of the codebase
MODULES=(
    "raft"
    "pkg/adt"
    "pkg/fileutil"
    "pkg/idutil"
    "pkg/netutil"
    "pkg/transport"
    "pkg/wait"
    "pkg/pbutil"
    "pkg/types"
)

echo "Running unit tests for etcd modules..." >&2

# Initialize counters
total_passed=0
total_failed=0
total_skipped=0

# Function to run tests for a module
run_module_tests() {
    local module=$1
    local module_dir="/testbed/${module}"

    if [ ! -d "$module_dir" ]; then
        return
    fi

    echo "Testing module: $module" >&2

    # Run tests with JSON output, capturing both stdout and stderr
    cd "$module_dir"

    # Run go test with JSON output and short mode for faster tests
    # We use short mode (-short) to skip long-running tests to fit in 15 minute window
    # Note: We skip -race flag as it significantly slows down tests
    # Use timeout to prevent any single module from hanging
    timeout 120s go test -json -short -timeout=90s ./... 2>&1 || true
}

# Collect all test results
{
    for module in "${MODULES[@]}"; do
        run_module_tests "$module"
    done
} > "$TEMP_RESULTS"

# Parse JSON results and count outcomes
# Each test event in JSON has an "Action" field: "pass", "fail", "skip", or "run"
# We need to count test-level actions, not package-level ones
passed=$(grep '"Action":"pass"' "$TEMP_RESULTS" | grep '"Test":' | wc -l | tr -d ' ')
failed=$(grep '"Action":"fail"' "$TEMP_RESULTS" | grep '"Test":' | wc -l | tr -d ' ')
skipped=$(grep '"Action":"skip"' "$TEMP_RESULTS" | grep '"Test":' | wc -l | tr -d ' ')

# Ensure we have valid numbers (default to 0 if empty)
passed=${passed:-0}
failed=${failed:-0}
skipped=${skipped:-0}

# Calculate total
total=$((passed + failed + skipped))

# Output final JSON result to stdout
echo "{\"passed\": $passed, \"failed\": $failed, \"skipped\": $skipped, \"total\": $total}"
