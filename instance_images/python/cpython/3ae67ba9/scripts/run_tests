#!/bin/bash
# Run CPython test suite and output JSON results

set -e

cd /testbed

# Ensure python is built
if [ ! -f "/testbed/python" ]; then
    echo "Error: Python executable not found. Run setup_shell.sh first" >&2
    exit 1
fi

echo "Running CPython test suite..." >&2

# Run a representative subset of tests that completes in reasonable time
# Using --fast-ci which is the CI mode that runs a good representative set
# Excluding GUI tests with -u-gui
OUTPUT=$(/testbed/python -m test --fast-ci -u-gui -j 4 --timeout 900 2>&1) || true

# Print output to stderr for debugging
echo "$OUTPUT" >&2

# Parse the output to extract test statistics
# Look for line: "Total tests: run=XXX failures=YYY skipped=ZZZ"
TOTAL_TESTS_LINE=$(echo "$OUTPUT" | grep "^Total tests:" | head -1)

if [ -n "$TOTAL_TESTS_LINE" ]; then
    # Extract run count
    TOTAL=$(echo "$TOTAL_TESTS_LINE" | grep -oP 'run=\K[0-9,]+' | tr -d ',')

    # Default values if not found
    TOTAL=${TOTAL:-0}

    # Extract failures (may not be present if 0)
    FAILED=$(echo "$TOTAL_TESTS_LINE" | grep -oP 'failures=\K[0-9,]+' | tr -d ',' 2>/dev/null)
    FAILED=${FAILED:-0}

    # Extract skipped (may not be present if 0)
    SKIPPED=$(echo "$TOTAL_TESTS_LINE" | grep -oP 'skipped=\K[0-9,]+' | tr -d ',' 2>/dev/null)
    SKIPPED=${SKIPPED:-0}

    # Calculate passed
    PASSED=$((TOTAL - FAILED - SKIPPED))
else
    # Fallback: set all to 0
    TOTAL=0
    FAILED=0
    SKIPPED=0
    PASSED=0
fi

# Output JSON result
echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $SKIPPED, \"total\": $TOTAL}"
