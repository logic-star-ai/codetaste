#!/bin/bash
# Test execution script for llama_index project
# This script runs the test suite and outputs results in JSON format
# It assumes setup_shell.sh has already been sourced

set -e

cd /testbed

# Run pytest with json report
# Run all tests without stopping on first failure
PYTEST_OUTPUT=$(pytest tests/ -v --tb=short --maxfail=1000 2>&1 || true)

# Save output to file for debugging
echo "$PYTEST_OUTPUT" > /tmp/pytest_output.txt

# Extract the summary line from the output
# Pytest outputs like: "138 passed, 14 skipped, 11 warnings, 1 error in 1.17s"
SUMMARY=$(echo "$PYTEST_OUTPUT" | grep -E "^(=+ )?[0-9]+ (passed|failed|skipped|error)" | tail -1 || echo "")

# Initialize counters
PASSED=0
FAILED=0
SKIPPED=0

# If no summary found, try alternative parsing
if [ -z "$SUMMARY" ]; then
    # Count individual test results
    PASSED=$(echo "$PYTEST_OUTPUT" | grep -c "PASSED" || echo "0")
    FAILED=$(echo "$PYTEST_OUTPUT" | grep -c "FAILED" || echo "0")
    SKIPPED=$(echo "$PYTEST_OUTPUT" | grep -c "SKIPPED" || echo "0")
else
    # Parse passed count
    if echo "$SUMMARY" | grep -q "passed"; then
        PASSED=$(echo "$SUMMARY" | grep -oE "[0-9]+ passed" | grep -oE "[0-9]+" | head -1 || echo "0")
    fi

    # Parse failed count (includes errors)
    if echo "$SUMMARY" | grep -q "failed"; then
        FAILED=$(echo "$SUMMARY" | grep -oE "[0-9]+ failed" | grep -oE "[0-9]+" | head -1 || echo "0")
    fi

    # Also check for errors and add to failed count
    if echo "$SUMMARY" | grep -q "error"; then
        ERRORS=$(echo "$SUMMARY" | grep -oE "[0-9]+ error" | grep -oE "[0-9]+" | head -1 || echo "0")
        FAILED=$((FAILED + ERRORS))
    fi

    # Parse skipped count
    if echo "$SUMMARY" | grep -q "skipped"; then
        SKIPPED=$(echo "$SUMMARY" | grep -oE "[0-9]+ skipped" | grep -oE "[0-9]+" | head -1 || echo "0")
    fi
fi

# Calculate total
TOTAL=$((PASSED + FAILED + SKIPPED))

# Output JSON result (this should be the last line of stdout)
echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $SKIPPED, \"total\": $TOTAL}"
