#!/bin/bash
# Test runner script for fabric.js
# This script runs the unit tests and outputs JSON results

cd /testbed

# Create a temporary file for test output
TEMP_OUTPUT=$(mktemp)

# Run QUnit tests and capture output
# Disable exit on error to capture test results even if some fail
set +e
npx qunit test/node_test_setup.js test/lib test/unit 2>&1 | tee "$TEMP_OUTPUT"
TEST_EXIT_CODE=$?
set -e

# Count individual test results from the output
# QUnit outputs lines like "ok 1 test name" or "not ok 2 test name"
PASSED=$(grep -c "^ok " "$TEMP_OUTPUT" || echo 0)
FAILED=$(grep -c "^not ok " "$TEMP_OUTPUT" || echo 0)

# Try to extract skipped count if available
# QUnit may output "# skip" in test output
SKIPPED=$(grep -c "# skip" "$TEMP_OUTPUT" 2>/dev/null || echo 0)

# Calculate total
TOTAL=$((PASSED + FAILED + SKIPPED))

# Clean up
rm -f "$TEMP_OUTPUT"

# Output JSON format
echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $SKIPPED, \"total\": $TOTAL}"

# Exit with success to allow JSON to be captured
exit 0
