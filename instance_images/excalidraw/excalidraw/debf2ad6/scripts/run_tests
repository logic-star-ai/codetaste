#!/bin/bash
# Test execution script for Excalidraw
# This script runs the test suite and outputs results in JSON format
# Must be run after setup_shell.sh

set -e

cd /testbed

# Run vitest with JSON reporter
echo "Running tests..."

# Create a temporary file for test output
TEMP_JSON=$(mktemp)

# Run vitest with json reporter, capture exit code but don't fail the script
yarn test:app --run --reporter=json --outputFile="$TEMP_JSON" 2>&1 > /dev/null || true

# Parse the JSON output
if [ -f "$TEMP_JSON" ] && [ -s "$TEMP_JSON" ]; then
    # Extract test counts from vitest JSON output
    PASSED=$(jq -r '.numPassedTests // 0' "$TEMP_JSON" 2>/dev/null || echo "0")
    FAILED=$(jq -r '.numFailedTests // 0' "$TEMP_JSON" 2>/dev/null || echo "0")
    # Vitest uses numPendingTests for skipped tests
    SKIPPED=$(jq -r '.numPendingTests // 0' "$TEMP_JSON" 2>/dev/null || echo "0")
    TOTAL=$(jq -r '.numTotalTests // 0' "$TEMP_JSON" 2>/dev/null || echo "0")
else
    # If JSON file doesn't exist or is empty, set all to 0
    PASSED=0
    FAILED=0
    SKIPPED=0
    TOTAL=0
fi

# Ensure we have numeric values
PASSED=${PASSED:-0}
FAILED=${FAILED:-0}
SKIPPED=${SKIPPED:-0}
TOTAL=${TOTAL:-0}

# Clean up temporary file
rm -f "$TEMP_JSON"

# Output final JSON result
echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $SKIPPED, \"total\": $TOTAL}"
