#!/bin/bash
# Test runner script for llama.cpp
# Runs CTest and outputs results in JSON format
# Usage: /scripts/run_tests

set -e

cd /testbed/build

# Run ctest with the 'main' label (excludes slow tests)
# Capture output to parse results
ctest_output=$(ctest -L main --output-on-failure 2>&1 || true)

# Display the output for debugging
echo "$ctest_output" >&2

# Parse the ctest output to extract test results
# CTest output format typically includes a summary line like:
# "100% tests passed, 0 tests failed out of 25"
# or "X% tests passed, Y tests failed out of Z"

# Extract test statistics using grep and awk
if echo "$ctest_output" | grep -q "tests passed"; then
    # Parse the summary line
    summary=$(echo "$ctest_output" | grep "tests passed" | tail -1)

    # Extract numbers using regex
    total=$(echo "$summary" | grep -oP 'out of \K\d+' || echo "0")
    failed=$(echo "$summary" | grep -oP '\d+(?= tests failed)' || echo "0")

    # Calculate passed tests
    passed=$((total - failed))

    # CTest doesn't report skipped tests separately in the summary, so we set it to 0
    skipped=0
else
    # If no summary found, check if there were any tests run
    if echo "$ctest_output" | grep -q "No tests were found"; then
        total=0
        passed=0
        failed=0
        skipped=0
    else
        # Try to count from test results
        total=$(echo "$ctest_output" | grep -c "Test #" || echo "0")
        passed=$(echo "$ctest_output" | grep -c "Passed" || echo "0")
        failed=$(echo "$ctest_output" | grep -c "Failed" || echo "0")
        skipped=0
    fi
fi

# Output JSON result as the final line
echo "{\"passed\": $passed, \"failed\": $failed, \"skipped\": $skipped, \"total\": $total}"
