#!/bin/bash
# Test runner script
# Runs the test suite and outputs JSON test results
# Must be run after setup_shell.sh has been sourced

set -e

cd /testbed

# Run golangci-lint on itself first (as per the Makefile test target)
echo "Running golangci-lint on the project..." >&2
./golangci-lint run -v > /dev/null 2>&1 || true

# Run tests with JSON output and capture results
# Use parallel=1 to avoid resource exhaustion issues
echo "Running Go tests..." >&2

# Create a temporary file for the test output
TEMP_FILE=$(mktemp)

# Run tests with timeout and capture output
# The -timeout flag ensures tests don't hang
# Use -p=1 to limit package parallelism and avoid fork/exec issues
go test -json -p=1 -parallel 1 -timeout 15m ./... 2>&1 > "$TEMP_FILE" || true

# Parse JSON output to count test results
PASSED=$(grep '"Action":"pass"' "$TEMP_FILE" | grep '"Test":' | wc -l)
FAILED=$(grep '"Action":"fail"' "$TEMP_FILE" | grep '"Test":' | wc -l)
SKIPPED=$(grep '"Action":"skip"' "$TEMP_FILE" | grep '"Test":' | wc -l)

# Clean up
rm -f "$TEMP_FILE"

TOTAL=$((PASSED + FAILED + SKIPPED))

# Output the final JSON result
echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $SKIPPED, \"total\": $TOTAL}"
