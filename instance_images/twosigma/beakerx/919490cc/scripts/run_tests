#!/bin/bash
# Test runner for BeakerX
# This script runs the Java/Gradle test suite and outputs JSON results

set -e

# Ensure Java 8 is set (should be set by setup_shell.sh)
export JAVA_HOME=${JAVA_HOME:-/usr/lib/jvm/java-1.8.0-openjdk-amd64}
export PATH=$JAVA_HOME/bin:$PATH

# Initialize test counters
total_tests=0
total_successes=0
total_failures=0
total_skipped=0

# Temporary file to store test output
TEMP_OUTPUT=$(mktemp)

# Run Gradle tests and capture output
cd /testbed/kernel
echo "Running Gradle tests..." >&2

# Run tests and capture output (exclude sql module due to dependency download issues)
./gradlew test --no-daemon -x :sql:test 2>&1 | tee "$TEMP_OUTPUT" >&2 || true

# Parse the test results from Gradle output
# Look for lines like: "Tests run: 1576, Successes: 1564, Failures: 7, Skipped: 5, Total time: ..."
while IFS= read -r line; do
    if [[ "$line" =~ Tests\ run:\ ([0-9]+),\ Successes:\ ([0-9]+),\ Failures:\ ([0-9]+),\ Skipped:\ ([0-9]+) ]]; then
        tests="${BASH_REMATCH[1]}"
        successes="${BASH_REMATCH[2]}"
        failures="${BASH_REMATCH[3]}"
        skipped="${BASH_REMATCH[4]}"

        total_tests=$((total_tests + tests))
        total_successes=$((total_successes + successes))
        total_failures=$((total_failures + failures))
        total_skipped=$((total_skipped + skipped))
    fi
done < "$TEMP_OUTPUT"

# Clean up temp file
rm -f "$TEMP_OUTPUT"

# Output JSON result (must be the last stdout line)
echo "{\"passed\": $total_successes, \"failed\": $total_failures, \"skipped\": $total_skipped, \"total\": $total_tests}"
