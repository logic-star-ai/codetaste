#!/bin/bash
set -e

cd /testbed

# Run tests with pytest and parse output
python -m pytest -v 2>&1 | tee /tmp/test_output.txt || true

# Parse the output and produce JSON
python <<'PARSE_EOF'
import re
import json

try:
    with open('/tmp/test_output.txt', 'r') as f:
        output = f.read()

    # Look for the summary line like "= 123 passed, 4 failed, 5 skipped in 10.23s ="
    match = re.search(r'=+\s*([\d]+\s+\w+(?:,\s*[\d]+\s+\w+)*)\s+in\s+[\d.]+s?\s*=+', output)

    passed = failed = skipped = 0

    if match:
        summary = match.group(1)

        # Extract counts
        passed_match = re.search(r'(\d+)\s+passed', summary)
        if passed_match:
            passed = int(passed_match.group(1))

        failed_match = re.search(r'(\d+)\s+failed', summary)
        if failed_match:
            failed = int(failed_match.group(1))

        skipped_match = re.search(r'(\d+)\s+skipped', summary)
        if skipped_match:
            skipped = int(skipped_match.group(1))

    # If no matches found, check for error counts
    if passed == 0 and failed == 0 and skipped == 0:
        error_match = re.search(r'=+\s*(\d+)\s+error', output)
        if error_match:
            # Treat errors as failed tests
            failed = int(error_match.group(1))

    total = passed + failed + skipped

    print json.dumps({'passed': passed, 'failed': failed, 'skipped': skipped, 'total': total})
except Exception as e:
    print json.dumps({'passed': 0, 'failed': 0, 'skipped': 0, 'total': 0})
PARSE_EOF
