#!/bin/bash
# Test execution script for Strapi
# This script runs the test suite and outputs JSON results

set -e

cd /testbed

# Function to run tests with JSON output
run_jest_tests() {
    # Run unit tests with JSON reporter
    # We use --json --testLocationInResults to get detailed JSON output
    yarn test:unit --json --testLocationInResults --no-coverage --silent 2>&1 | tee /tmp/jest_output.txt || true

    # Parse the Jest JSON output
    # The last line should be the JSON summary
    tail -1 /tmp/jest_output.txt > /tmp/jest_result.json 2>/dev/null || echo '{}' > /tmp/jest_result.json
}

# Run the tests
run_jest_tests

# Parse Jest JSON output and extract test counts
python3 - <<'PYTHON_SCRIPT'
import json
import sys

try:
    with open('/tmp/jest_result.json', 'r') as f:
        content = f.read().strip()
        if not content:
            print('{"passed": 0, "failed": 0, "skipped": 0, "total": 0}')
            sys.exit(0)

        data = json.loads(content)

        # Jest JSON output structure
        if 'numPassedTests' in data:
            passed = data.get('numPassedTests', 0)
            failed = data.get('numFailedTests', 0)
            skipped = data.get('numPendingTests', 0) + data.get('numTodoTests', 0)
            total = data.get('numTotalTests', 0)
        else:
            passed = 0
            failed = 0
            skipped = 0
            total = 0

        print(json.dumps({
            "passed": passed,
            "failed": failed,
            "skipped": skipped,
            "total": total
        }))
except Exception as e:
    print('{"passed": 0, "failed": 0, "skipped": 0, "total": 0}')
    sys.exit(0)
PYTHON_SCRIPT
