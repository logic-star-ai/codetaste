#!/usr/bin/env python3
"""
Test runner script for AWS CLI
Runs a representative subset of tests and outputs results in JSON format
"""
import json
import os
import sys
import subprocess
import re
from pathlib import Path


def run_tests():
    """Run pytest and capture results"""
    testbed = Path("/testbed")
    tests_dir = testbed / "tests"

    # Change to tests directory (pytest expects to be run from here)
    os.chdir(tests_dir)

    # Set environment variable to remove repo root from path
    env = os.environ.copy()
    env['TESTS_REMOVE_REPO_ROOT_FROM_PATH'] = 'true'

    # Run a representative subset of tests
    # Run only unit tests as they are faster and more stable
    # Functional tests can take a very long time to run
    # We limit to the most important unit test directories for a reasonable runtime
    pytest_args = [
        sys.executable,  # Use current Python interpreter
        '-m', 'pytest',
        '-v',  # verbose
        '--tb=short',  # shorter traceback format
        '--numprocesses=auto',  # parallel execution
        '--dist=loadfile',  # distribute tests by file
        '--maxprocesses=4',  # limit to 4 processes
        '-q',  # quiet mode to reduce output
        '--tb=no',  # no traceback for cleaner output
        # Run core unit tests - representative sample
        'unit/test_utils.py',
        'unit/test_argparser.py',
        'unit/test_argprocess.py',
        'unit/test_clidriver.py',
        'unit/test_alias.py',
        'unit/test_compat.py',
        'unit/test_formatter.py',
        'unit/test_help.py',
        'unit/test_paramfile.py',
        'unit/test_shorthand.py',
        'unit/test_table.py',
        'unit/test_text.py',
        'unit/customizations/',
    ]

    try:
        result = subprocess.run(
            pytest_args,
            env=env,
            capture_output=True,
            text=True,
            timeout=900  # 15 minute timeout
        )
        stdout = result.stdout
        stderr = result.stderr
        returncode = result.returncode

    except subprocess.TimeoutExpired:
        print(json.dumps({
            "passed": 0,
            "failed": 0,
            "skipped": 0,
            "total": 0,
            "error": "Tests timed out after 15 minutes"
        }))
        sys.exit(1)

    # Parse pytest output to extract test counts
    # Look for the summary line like: "1234 passed, 56 failed, 78 skipped in 123.45s"
    passed = 0
    failed = 0
    skipped = 0

    # Try to find the summary in the last lines of output
    output_lines = (stdout + stderr).split('\n')

    # Look for patterns like "X passed", "X failed", "X skipped"
    for line in output_lines[-50:]:  # Check last 50 lines
        # Match patterns like "1234 passed" or "56 failed"
        passed_match = re.search(r'(\d+)\s+passed', line)
        if passed_match:
            passed = int(passed_match.group(1))

        failed_match = re.search(r'(\d+)\s+failed', line)
        if failed_match:
            failed = int(failed_match.group(1))

        skipped_match = re.search(r'(\d+)\s+skipped', line)
        if skipped_match:
            skipped = int(skipped_match.group(1))

    total = passed + failed + skipped

    # If we couldn't parse anything, try an alternative approach
    if total == 0:
        # Look for individual test results
        passed = len(re.findall(r' PASSED', stdout + stderr))
        failed = len(re.findall(r' FAILED', stdout + stderr))
        skipped = len(re.findall(r' SKIPPED', stdout + stderr))
        total = passed + failed + skipped

    # Output the results in JSON format
    result_json = {
        "passed": passed,
        "failed": failed,
        "skipped": skipped,
        "total": total
    }

    print(json.dumps(result_json))

    # Exit with error code if tests failed
    if failed > 0:
        sys.exit(1)

    return 0


if __name__ == "__main__":
    sys.exit(run_tests())
