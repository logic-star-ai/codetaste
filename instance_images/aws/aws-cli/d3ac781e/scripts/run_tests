#!/bin/bash
# Test runner for AWS CLI that outputs JSON test results
# This script runs the test suite and outputs results in JSON format
# Assumes that setup_shell.sh has already been sourced

set -e

# Change to test directory
cd /testbed/tests

# Run pytest on unit and functional tests (most representative tests)
# Skip integration tests as they may require AWS credentials
# Capture output
OUTPUT=$(python -m pytest --tb=line -q unit/ functional/ 2>&1 || true)

# Extract test counts from summary line
# Example: "1234 passed, 5 failed, 10 skipped in 123.45s"
PASSED=$(echo "$OUTPUT" | grep -oP '\d+(?= passed)' | tail -1 || echo "0")
FAILED=$(echo "$OUTPUT" | grep -oP '\d+(?= failed)' | tail -1 || echo "0")
SKIPPED=$(echo "$OUTPUT" | grep -oP '\d+(?= skipped)' | tail -1 || echo "0")

# Default to 0 if empty
PASSED=${PASSED:-0}
FAILED=${FAILED:-0}
SKIPPED=${SKIPPED:-0}

# Calculate total
TOTAL=$((PASSED + FAILED + SKIPPED))

# Output JSON
echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $SKIPPED, \"total\": $TOTAL}"
