#!/bin/bash
# Test execution script
# This script runs the test suite and outputs results in JSON format
# Assumes shell environment is already set up by setup_shell.sh

set -e

cd /testbed

# Run tests with mysql tag and capture output
# Due to dependency issues with private Bytebase parser modules
# (tidb-parser, tsql-parser), we focus on tests that don't require them
# These are primarily utility and common packages
echo "Running backend tests..."

# Create a temporary file for test output
TEMP_OUTPUT=$(mktemp)

# Run tests with verbose output
# Use timeout to prevent hanging tests
# Run with parallel execution for speed
# Focus on backend/common which contains utility functions and doesn't
# depend on the problematic parser modules
go test -tags mysql -v -timeout 15m -p 4 \
    ./backend/common/... \
    2>&1 | tee "$TEMP_OUTPUT"

# Store exit code
TEST_EXIT_CODE=$?

# Count test results from verbose output
# Use wc -l to count lines instead of grep -c to avoid trailing newlines
PASSED=$(grep "^--- PASS:" "$TEMP_OUTPUT" 2>/dev/null | wc -l | tr -d ' ')
FAILED=$(grep "^--- FAIL:" "$TEMP_OUTPUT" 2>/dev/null | wc -l | tr -d ' ')
SKIPPED=$(grep "^--- SKIP:" "$TEMP_OUTPUT" 2>/dev/null | wc -l | tr -d ' ')

# Set defaults if empty
PASSED=${PASSED:-0}
FAILED=${FAILED:-0}
SKIPPED=${SKIPPED:-0}

TOTAL=$((PASSED + FAILED + SKIPPED))

# Clean up temp files
rm -f "$TEMP_OUTPUT"

# Output JSON result (always output this line regardless of test results)
echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $SKIPPED, \"total\": $TOTAL}"

# Exit with the test exit code
exit $TEST_EXIT_CODE
