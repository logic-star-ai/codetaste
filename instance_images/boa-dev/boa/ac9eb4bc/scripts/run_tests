#!/bin/bash
# Test execution script for Boa JavaScript Engine
# Must be run after setup_shell.sh has been sourced

set -e

cd /testbed

# Run cargo nextest and capture output
echo "Running tests with cargo-nextest..." >&2

# Run tests and capture the output
cargo nextest run \
    --profile ci \
    --cargo-profile ci \
    --features annex-b,intl_bundled,experimental,embedded_lz4 \
    2>&1 | tee /tmp/test_output.txt || true

# Parse the summary line from nextest output
# Example summary: "     Summary [  43.123s] 1225 tests run: 1225 passed, 2 skipped"
SUMMARY=$(grep -E "^\s+Summary" /tmp/test_output.txt | tail -1 || echo "")

if [ -z "$SUMMARY" ]; then
    echo "Error: Could not find test summary" >&2
    echo '{"passed": 0, "failed": 0, "skipped": 0, "total": 0}'
    exit 1
fi

# Extract test counts using grep -oP (Perl regex)
# Looking for patterns like "1225 passed", "2 failed", "2 skipped"
TOTAL=$(echo "$SUMMARY" | grep -oP '\d+(?= tests run)' || echo "0")
PASSED=$(echo "$SUMMARY" | grep -oP '\d+(?= passed)' || echo "0")
FAILED=$(echo "$SUMMARY" | grep -oP '\d+(?= failed)' || echo "0")

# Skipped appears as "X skipped" at the end
SKIPPED=$(echo "$SUMMARY" | grep -oP '\d+(?= skipped)' || echo "0")

# Output the required JSON format
echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $SKIPPED, \"total\": $TOTAL}"

# Clean up
rm -f /tmp/test_output.txt
