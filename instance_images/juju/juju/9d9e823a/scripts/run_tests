#!/bin/bash
# Test runner - must be run after sourcing setup_shell.sh
set -e
cd /testbed

if [ -z "$CGO_ENABLED" ]; then
    echo "ERROR: Source /scripts/setup_shell.sh first!" >&2
    echo '{"passed": 0, "failed": 0, "skipped": 0, "total": 0}'
    exit 1
fi

TMP=$(mktemp -d)
trap "rm -rf $TMP" EXIT

# Get 10 core test packages 
PKGS=$(go list -f '{{if .TestGoFiles}}{{.ImportPath}}{{end}}' ./... | \
    grep 'github.com/juju/juju/api' | head -10)

# Run tests
go test -v -mod=readonly -tags="$TEST_BUILD_TAGS" -timeout=300s $PKGS > $TMP/out.txt 2>&1 || true

cat $TMP/out.txt

# Count results - look for OK: lines from gocheck
PASSED=$(grep "^OK:" $TMP/out.txt | sed 's/^OK: \([0-9]*\) passed.*/\1/' | awk '{s+=$1} END {print s+0}')
FAILED=$(grep "^FAIL:" $TMP/out.txt | wc -l)
TOTAL=$((PASSED + FAILED))

echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": 0, \"total\": $TOTAL}"
