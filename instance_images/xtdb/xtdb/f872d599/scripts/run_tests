#!/bin/bash
# Test execution script for XTDB
# This script runs the test suite and outputs results in JSON format

set -e

cd /testbed

# Run the test suite
# We exclude integration, jdbc, timescale, s3, minio, slt, docker, azure, google-cloud tests
# as per the build.gradle.kts configuration (line 95)
echo "Running XTDB test suite..." >&2

# Run tests and capture results
./gradlew test --continue 2>&1 | tee /tmp/test_output.log >&2 || true

# Parse XML test results to generate JSON output
python3 - << 'EOF'
import os
import sys
import xml.etree.ElementTree as ET
import glob
import json

def parse_test_results():
    passed = 0
    failed = 0
    skipped = 0
    errors = 0

    # Find all test result XML files
    test_result_dirs = []
    for root, dirs, files in os.walk('/testbed'):
        if 'test-results' in root and 'test' in root:
            test_result_dirs.append(root)

    # Parse each XML file
    for result_dir in test_result_dirs:
        xml_files = glob.glob(os.path.join(result_dir, '*.xml'))
        for xml_file in xml_files:
            try:
                tree = ET.parse(xml_file)
                root = tree.getroot()

                # Parse testsuite element
                if root.tag == 'testsuite':
                    tests = int(root.get('tests', 0))
                    skipped_count = int(root.get('skipped', 0))
                    failures = int(root.get('failures', 0))
                    errors_count = int(root.get('errors', 0))

                    # Calculate passed tests
                    passed_count = tests - skipped_count - failures - errors_count

                    passed += passed_count
                    failed += failures + errors_count
                    skipped += skipped_count
            except Exception as e:
                print(f"Error parsing {xml_file}: {e}", file=sys.stderr)
                continue

    total = passed + failed + skipped

    # Output JSON result
    result = {
        "passed": passed,
        "failed": failed,
        "skipped": skipped,
        "total": total
    }

    print(json.dumps(result))

if __name__ == "__main__":
    parse_test_results()
EOF
