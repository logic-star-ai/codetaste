#!/bin/bash
# Run tests script - execute Jest test suite
# This script runs the test suite and outputs JSON results

set -e

cd /testbed

# Create temporary files to store outputs
TEMP_OUTPUT=$(mktemp)
TEMP_STDERR=$(mktemp)

echo "Running Jest tests..." >&2

# Run Jest tests directly
# The test script runs: test-client test-packages test-server test-build-tools
# We'll run a representative subset to complete within 15 minutes

EXIT_CODE=0

# Run Jest test suites with NO_COLOR to make parsing easier
# Run packages and server tests (faster than client tests)
TZ=UTC NO_COLOR=1 node .yarn/releases/yarn-4.0.2.cjs run-s -s test-packages test-server test-build-tools \
    2>"$TEMP_STDERR" | tee "$TEMP_OUTPUT" || EXIT_CODE=$?

# Filter stderr and show it
if [ -s "$TEMP_STDERR" ]; then
    grep -v "YN0013" "$TEMP_STDERR" | grep -v "Browserslist" >&2 2>/dev/null || true
fi
rm -f "$TEMP_STDERR"

# Parse the Jest output from stdout
# Extract the summary lines and compute totals
if [ -f "$TEMP_OUTPUT" ] && [ -s "$TEMP_OUTPUT" ]; then
    # Look for "Tests:" summary lines from Jest output
    # Format: "Tests:       X failed, Y passed, Z total" or "Tests:       X passed, Y total"
    # Remove ANSI color codes first (in case NO_COLOR didn't work everywhere)
    sed 's/\x1b\[[0-9;]*m//g' "$TEMP_OUTPUT" > "$TEMP_OUTPUT.clean"

    # Extract numbers for each metric - look for lines containing "Tests:"
    PASSED=$(grep "Tests:" "$TEMP_OUTPUT.clean" | grep -oE "[0-9]+ passed" | grep -oE "[0-9]+" | awk '{sum+=$1} END {print sum}')
    FAILED=$(grep "Tests:" "$TEMP_OUTPUT.clean" | grep -oE "[0-9]+ failed" | grep -oE "[0-9]+" | awk '{sum+=$1} END {print sum}')
    SKIPPED=$(grep "Tests:" "$TEMP_OUTPUT.clean" | grep -oE "[0-9]+ skipped" | grep -oE "[0-9]+" | awk '{sum+=$1} END {print sum}')

    # Calculate total from the individual suite totals
    TOTAL=$(grep "Tests:" "$TEMP_OUTPUT.clean" | grep -oE "[0-9]+ total" | grep -oE "[0-9]+" | awk '{sum+=$1} END {print sum}')

    # Clean up
    rm -f "$TEMP_OUTPUT" "$TEMP_OUTPUT.clean"

    # Ensure we have valid numbers
    PASSED=${PASSED:-0}
    FAILED=${FAILED:-0}
    SKIPPED=${SKIPPED:-0}
    TOTAL=${TOTAL:-0}

    # Output the final JSON result
    echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $SKIPPED, \"total\": $TOTAL}"
else
    # If output file doesn't exist or is empty
    rm -f "$TEMP_OUTPUT"

    if [ $EXIT_CODE -eq 0 ]; then
        # Tests passed but no output - output zeros
        echo "{\"passed\": 0, \"failed\": 0, \"skipped\": 0, \"total\": 0}"
    else
        # Tests failed - output failure
        echo "{\"passed\": 0, \"failed\": 1, \"skipped\": 0, \"total\": 1}"
    fi
fi

exit $EXIT_CODE
