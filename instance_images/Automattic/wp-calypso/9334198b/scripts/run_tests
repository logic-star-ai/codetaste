#!/bin/bash
# Test runner script for wp-calypso
# Runs Jest tests and outputs JSON results

set -e

cd /testbed

# Run all Jest tests with JSON output
# According to package.json, the main test command is:
# "test": "run-s -s test-client test-packages test-server test-build-tools"

# Create a temporary file for collecting results
TEMP_RESULTS=$(mktemp)

# Set timezone for tests
export TZ=UTC

# Run each test suite sequentially and capture results
./node_modules/.bin/jest -c=test/client/jest.config.js --json --testLocationInResults --no-coverage > "$TEMP_RESULTS.client.json" 2>&1 || true
./node_modules/.bin/jest -c=test/packages/jest.config.js --json --testLocationInResults --no-coverage > "$TEMP_RESULTS.packages.json" 2>&1 || true
./node_modules/.bin/jest -c=test/server/jest.config.js --json --testLocationInResults --no-coverage > "$TEMP_RESULTS.server.json" 2>&1 || true
./node_modules/.bin/jest -c=test/build-tools/jest.config.js --json --testLocationInResults --no-coverage > "$TEMP_RESULTS.build-tools.json" 2>&1 || true

# Parse and aggregate results using grep
PASSED=0
FAILED=0
SKIPPED=0
TOTAL=0

for suite in client packages server build-tools; do
    FILE="$TEMP_RESULTS.$suite.json"
    if [ -f "$FILE" ]; then
        P=$(grep -o '"numPassedTests":[0-9]*' "$FILE" 2>/dev/null | cut -d: -f2 || echo 0)
        F=$(grep -o '"numFailedTests":[0-9]*' "$FILE" 2>/dev/null | cut -d: -f2 || echo 0)
        S=$(grep -o '"numPendingTests":[0-9]*' "$FILE" 2>/dev/null | cut -d: -f2 || echo 0)
        T=$(grep -o '"numTotalTests":[0-9]*' "$FILE" 2>/dev/null | cut -d: -f2 || echo 0)

        PASSED=$((PASSED + P))
        FAILED=$((FAILED + F))
        SKIPPED=$((SKIPPED + S))
        TOTAL=$((TOTAL + T))
    fi
done

# Output the final JSON result
echo "{\"passed\":$PASSED,\"failed\":$FAILED,\"skipped\":$SKIPPED,\"total\":$TOTAL}"

# Clean up temporary files
rm -f "$TEMP_RESULTS".*
