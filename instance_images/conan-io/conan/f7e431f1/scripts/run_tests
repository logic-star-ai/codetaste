#!/bin/bash
# run_tests - Execute Conan test suite and output JSON results
# This script assumes setup_shell.sh has already been sourced

set -e

cd /testbed

# Run a representative subset of tests with JSON output
# We'll run unittests (fast) and a subset of functional tests
# Exclude docker tests and artifactory tests as they require special setup
# Use pytest-json-report for structured output

# First, install pytest-json-report if not already installed
pip install --quiet pytest-json-report 2>/dev/null || true

# Run tests with JSON reporter
# - Exclude docker_runner and artifactory_ready markers
# - Run unittests (comprehensive and fast)
# - Run a sample of functional tests for broader coverage
# - Limit to ~15 minutes runtime
python -m pytest \
    test/unittests \
    test/functional/command \
    test/functional/toolchains \
    test/functional/tools \
    -v \
    -m "not docker_runner and not artifactory_ready" \
    --json-report --json-report-file=/tmp/test_report.json \
    --tb=short \
    2>&1 | tee /tmp/pytest_output.txt || true

# Parse the JSON report to extract test results
if [ -f /tmp/test_report.json ]; then
    python3 << 'EOF'
import json
import sys

try:
    with open('/tmp/test_report.json', 'r') as f:
        report = json.load(f)

    summary = report.get('summary', {})
    passed = summary.get('passed', 0)
    failed = summary.get('failed', 0)
    skipped = summary.get('skipped', 0)
    # Total might be 'collected' in some versions
    total = summary.get('total', summary.get('collected', 0))

    # Output the required JSON format
    result = {
        "passed": passed,
        "failed": failed,
        "skipped": skipped,
        "total": total
    }
    print(json.dumps(result))
except Exception as e:
    # Fallback: try to parse from pytest output
    import re
    try:
        with open('/tmp/pytest_output.txt', 'r') as f:
            output = f.read()

        # Look for pytest summary line like "1234 passed, 56 failed, 78 skipped in 123.45s"
        match = re.search(r'(\d+) passed(?:, (\d+) failed)?(?:, (\d+) skipped)?', output)
        if match:
            passed = int(match.group(1))
            failed = int(match.group(2)) if match.group(2) else 0
            skipped = int(match.group(3)) if match.group(3) else 0
            total = passed + failed + skipped
            print(json.dumps({"passed": passed, "failed": failed, "skipped": skipped, "total": total}))
        else:
            # Default fallback
            print(json.dumps({"passed": 0, "failed": 0, "skipped": 0, "total": 0}))
    except:
        print(json.dumps({"passed": 0, "failed": 0, "skipped": 0, "total": 0}))
EOF
else
    # If JSON report doesn't exist, parse from output
    python3 << 'EOF'
import re
import json

try:
    with open('/tmp/pytest_output.txt', 'r') as f:
        output = f.read()

    # Look for pytest summary line
    match = re.search(r'(\d+) passed(?:, (\d+) failed)?(?:, (\d+) skipped)?', output)
    if match:
        passed = int(match.group(1))
        failed = int(match.group(2)) if match.group(2) else 0
        skipped = int(match.group(3)) if match.group(3) else 0
        total = passed + failed + skipped
        print(json.dumps({"passed": passed, "failed": failed, "skipped": skipped, "total": total}))
    else:
        print(json.dumps({"passed": 0, "failed": 0, "skipped": 0, "total": 0}))
except:
    print(json.dumps({"passed": 0, "failed": 0, "skipped": 0, "total": 0}))
EOF
fi
