#!/bin/bash
# Run Conan test suite and output JSON results
# This script runs pytest tests and formats the output as JSON

set -e

# Change to testbed directory
cd "${TESTBED_DIR:-/testbed}"

# Run pytest with JSON output
# We'll run the unittests which are faster and more deterministic
# Using pytest-json-report plugin if available, otherwise parse pytest output

# Create a temporary file for pytest output
PYTEST_OUTPUT=$(mktemp)

# Run pytest and capture the output
# Run unittests only (faster and more representative)
# Use -v for verbose output and --tb=short for shorter tracebacks
python -m pytest test/unittests/ -v --tb=short --color=no > "$PYTEST_OUTPUT" 2>&1 || true

# Parse the pytest output to extract test results
# The last line usually contains the summary like "X passed, Y failed, Z skipped in Xs"

# Extract test counts from pytest output
passed=$(grep -oP '\d+(?= passed)' "$PYTEST_OUTPUT" | tail -1 || echo "0")
failed=$(grep -oP '\d+(?= failed)' "$PYTEST_OUTPUT" | tail -1 || echo "0")
skipped=$(grep -oP '\d+(?= skipped)' "$PYTEST_OUTPUT" | tail -1 || echo "0")
errors=$(grep -oP '\d+(?= error)' "$PYTEST_OUTPUT" | tail -1 || echo "0")

# If we couldn't parse, try alternative parsing
if [ "$passed" = "0" ] && [ "$failed" = "0" ] && [ "$skipped" = "0" ]; then
    # Try parsing from the summary line
    summary_line=$(grep -E "^=+.*in [0-9.]+s" "$PYTEST_OUTPUT" | tail -1 || echo "")
    if [ -n "$summary_line" ]; then
        passed=$(echo "$summary_line" | grep -oP '\d+(?= passed)' || echo "0")
        failed=$(echo "$summary_line" | grep -oP '\d+(?= failed)' || echo "0")
        skipped=$(echo "$summary_line" | grep -oP '\d+(?= skipped)' || echo "0")
        errors=$(echo "$summary_line" | grep -oP '\d+(?= error)' || echo "0")
    fi
fi

# Add errors to failed count
failed=$((failed + errors))

# Calculate total
total=$((passed + failed + skipped))

# Output the JSON result
echo "{\"passed\": $passed, \"failed\": $failed, \"skipped\": $skipped, \"total\": $total}"

# Clean up
rm -f "$PYTEST_OUTPUT"
