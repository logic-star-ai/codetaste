#!/bin/bash
# Test runner script for Gitea
# This script runs a representative subset of tests that complete within 15 minutes

set -e

cd /testbed

# Run unit tests (excluding integration tests, migrations, and packages with build issues)
# Using sqlite tags since that's the fastest database for testing
echo "Running unit tests..."

# Define test output file
TEST_OUTPUT="/tmp/test_output.txt"

# Packages to exclude:
# - integrations: separate integration test suite requiring full binary
# - models/migrations: migration tests requiring special setup
# - cmd: main command package with syscall compatibility issues
# - services/migrations: has timeout issues with external service tests
EXCLUDE_PKGS="code.gitea.io/gitea/integrations|code.gitea.io/gitea/models/migrations|code.gitea.io/gitea/cmd|code.gitea.io/gitea/services/migrations"

# Run tests with JSON output and a timeout
go test -v -tags='sqlite sqlite_unlock_notify' -timeout=15m -json \
    $(go list ./... | grep -vE "$EXCLUDE_PKGS") \
    2>&1 | tee "$TEST_OUTPUT"

# Parse test results from JSON output
# Count passed, failed, skipped tests
PASSED=$(grep '"Action":"pass"' "$TEST_OUTPUT" | grep -c '"Test":' || echo "0")
FAILED=$(grep '"Action":"fail"' "$TEST_OUTPUT" | grep -c '"Test":' || echo "0")
SKIPPED=$(grep '"Action":"skip"' "$TEST_OUTPUT" | grep -c '"Test":' || echo "0")

# If no test results found in JSON, try parsing from regular output
if [ "$PASSED" -eq 0 ] && [ "$FAILED" -eq 0 ] && [ "$SKIPPED" -eq 0 ]; then
    # Parse from text output
    PASSED=$(grep -E '^--- PASS:' "$TEST_OUTPUT" | wc -l || echo "0")
    FAILED=$(grep -E '^--- FAIL:' "$TEST_OUTPUT" | wc -l || echo "0")
    SKIPPED=$(grep -E '^--- SKIP:' "$TEST_OUTPUT" | wc -l || echo "0")
fi

TOTAL=$((PASSED + FAILED + SKIPPED))

# Output JSON result
echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $SKIPPED, \"total\": $TOTAL}"

# Clean up temp files
rm -f "$TEST_OUTPUT"

# Exit with error if any tests failed
if [ "$FAILED" -gt 0 ]; then
    exit 1
fi

exit 0
