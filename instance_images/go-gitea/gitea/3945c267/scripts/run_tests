#!/bin/bash
set -e

cd /testbed

# Run backend unit tests with verbose output and JSON format
echo "Running backend unit tests..."

# Get the list of test packages
GO_TEST_PACKAGES=$(go list ./... | grep -v /vendor/ | \
  grep -v 'code.gitea.io/gitea/models/migrations' | \
  grep -v 'code.gitea.io/gitea/tests/integration/migration-test' | \
  grep -v 'code.gitea.io/gitea/tests$' | \
  grep -v 'code.gitea.io/gitea/tests/integration' | \
  grep -v 'code.gitea.io/gitea/tests/e2e')

# Run tests with JSON output
go test -tags='sqlite sqlite_unlock_notify' -json -timeout=15m ${GO_TEST_PACKAGES} > /tmp/test_output.json 2>&1 || true

# Parse the JSON output to count tests
python3 << 'EOF'
import json
import sys

passed = 0
failed = 0
skipped = 0
total = 0

try:
    with open('/tmp/test_output.json', 'r') as f:
        for line in f:
            try:
                obj = json.loads(line.strip())
                if obj.get('Action') == 'pass' and 'Test' in obj:
                    passed += 1
                    total += 1
                elif obj.get('Action') == 'fail' and 'Test' in obj:
                    failed += 1
                    total += 1
                elif obj.get('Action') == 'skip' and 'Test' in obj:
                    skipped += 1
                    total += 1
            except json.JSONDecodeError:
                continue
except FileNotFoundError:
    print("Error: test output file not found", file=sys.stderr)
    sys.exit(1)

# Print the final JSON result to stdout
print(json.dumps({"passed": passed, "failed": failed, "skipped": skipped, "total": total}))
EOF
