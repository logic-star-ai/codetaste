#!/bin/bash
# Run Gitea test suite and output results in JSON format
# This script must be run after sourcing setup_shell.sh

set -e

cd /testbed

# Run Go unit tests with JSON output
# We focus on backend tests as they are the core of Gitea
# Excluding integration and e2e tests to finish within 15 minutes
echo "Running Gitea backend unit tests..." >&2

# Run tests with timeout and capture output to a temp file
TEMP_OUTPUT=$(mktemp)
TEMP_PACKAGES=$(mktemp)

# Get list of packages to test, excluding integration/e2e/migrations
go list ./... | \
  grep -v /vendor/ | \
  grep -v 'code.gitea.io/gitea/tests/integration' | \
  grep -v 'code.gitea.io/gitea/tests/e2e' | \
  grep -v 'code.gitea.io/gitea/tests$' | \
  grep -v 'code.gitea.io/gitea/models/migrations' > "$TEMP_PACKAGES"

# Run tests
cat "$TEMP_PACKAGES" | xargs go test -timeout 14m -tags="sqlite sqlite_unlock_notify" \
  -json \
  2>&1 > "$TEMP_OUTPUT" || true

TEST_OUTPUT=$(cat "$TEMP_OUTPUT")
rm -f "$TEMP_OUTPUT" "$TEMP_PACKAGES"

# Parse the JSON test output
PASSED=0
FAILED=0
SKIPPED=0
TOTAL=0

# Process each JSON line
while IFS= read -r line; do
    # Check if line contains test result
    if echo "$line" | grep -q '"Action":"pass"' && echo "$line" | grep -q '"Test":"Test'; then
        PASSED=$((PASSED + 1))
        TOTAL=$((TOTAL + 1))
    elif echo "$line" | grep -q '"Action":"fail"' && echo "$line" | grep -q '"Test":"Test'; then
        FAILED=$((FAILED + 1))
        TOTAL=$((TOTAL + 1))
    elif echo "$line" | grep -q '"Action":"skip"' && echo "$line" | grep -q '"Test":"Test'; then
        SKIPPED=$((SKIPPED + 1))
        TOTAL=$((TOTAL + 1))
    fi
done <<< "$TEST_OUTPUT"

# Output final JSON result
echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $SKIPPED, \"total\": $TOTAL}"
