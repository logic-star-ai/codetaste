#!/bin/bash
# Test execution script for MNE-Python
# This script runs a representative subset of tests and outputs JSON results
# Assumes environment is already set up via setup_shell.sh

set -e

cd /testbed

# Run pytest with JSON output
# We'll run a subset of tests that are representative but finish within 15 minutes
# Focus on core functionality tests

# Use pytest-json-report or parse pytest output
# Install pytest-json-report if not available
if ! python -c "import pytest_jsonreport" 2>/dev/null; then
    pip install --quiet pytest-json-report
fi

# Create a temporary file for test results
export RESULTS_FILE=$(mktemp)

# Run a subset of core tests
# These are representative tests that cover main functionality
pytest \
    --json-report --json-report-file="$RESULTS_FILE" --json-report-indent=2 \
    -v --tb=short --color=no \
    --timeout=120 \
    --ignore=doc --ignore=logo --ignore=examples --ignore=tutorials \
    --ignore=mne/gui --ignore=mne/icons --ignore=tools \
    --ignore=mne/report/js_and_css \
    -k "not (ultraslowtest or pgtest)" \
    mne/tests/test_annotations.py \
    mne/tests/test_bem.py \
    mne/tests/test_cov.py \
    mne/tests/test_defaults.py \
    mne/tests/test_dipole.py \
    mne/tests/test_event.py \
    mne/tests/test_evoked.py \
    mne/tests/test_filter.py \
    mne/tests/test_source_estimate.py \
    mne/_fiff/tests/test_meas_info.py \
    mne/_fiff/tests/test_pick.py \
    mne/_fiff/tests/test_reference.py \
    mne/channels/tests/test_channels.py \
    mne/channels/tests/test_layout.py \
    mne/io/tests/test_raw.py \
    mne/preprocessing/tests/test_artifact_detection.py \
    mne/stats/tests/test_parametric.py \
    mne/time_frequency/tests/test_spectrum.py \
    mne/utils/tests/test_bunch.py \
    mne/utils/tests/test_check.py \
    || true  # Don't fail on test failures, we need to parse results

# Parse JSON output and create final JSON line
python3 << 'PYEOF'
import json
import sys
import os

results_file = os.environ.get('RESULTS_FILE')
if not results_file:
    print(json.dumps({"passed": 0, "failed": 0, "skipped": 0, "total": 0}))
    sys.exit(1)

try:
    with open(results_file, 'r') as f:
        data = json.load(f)

    summary = data.get('summary', {})
    passed = summary.get('passed', 0)
    failed = summary.get('failed', 0)
    skipped = summary.get('skipped', 0)
    total = summary.get('total', 0)

    result = {
        'passed': passed,
        'failed': failed,
        'skipped': skipped,
        'total': total
    }

    print(json.dumps(result))
except Exception as e:
    # Fallback if JSON parsing fails
    print(json.dumps({"passed": 0, "failed": 0, "skipped": 0, "total": 0}))
    sys.exit(1)
PYEOF

# Clean up
rm -f "$RESULTS_FILE"
