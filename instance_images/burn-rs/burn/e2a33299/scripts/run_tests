#!/bin/bash
# Test runner script for Burn project
# This script runs tests and outputs results in JSON format
# Assumes setup_shell.sh has been sourced

set -e

cd /testbed

# Create a temporary file to capture test output
TEMP_OUTPUT=$(mktemp)

# Run cargo test with workspace
# We'll run the main workspace tests (excluding xtask which is just tooling)
# Using --no-fail-fast to continue running all tests even if some fail
echo "Running Burn test suite..." >&2

# Run tests and capture output
# We test core libraries that compile successfully
# Focus on the fundamental tensor and compute libraries
cargo test \
    --package burn-common \
    --package burn-derive \
    --package burn-tensor-testgen \
    --package burn-ndarray \
    --package burn-tensor \
    --package burn-compute \
    --package burn-autodiff \
    --lib --bins \
    --no-fail-fast 2>&1 | tee "$TEMP_OUTPUT" || true

# Parse the test output to count results
# Cargo runs multiple test binaries, each with its own summary
# We need to aggregate all test results

# Initialize counters
PASSED=0
FAILED=0
IGNORED=0

# Find all test result lines and sum them up
# Format: "test result: ok. X passed; Y failed; Z ignored; ..."
while IFS= read -r line; do
    # Extract passed count from this line
    if [[ "$line" =~ ([0-9]+)\ passed ]]; then
        PASSED=$((PASSED + ${BASH_REMATCH[1]}))
    fi

    # Extract failed count
    if [[ "$line" =~ ([0-9]+)\ failed ]]; then
        FAILED=$((FAILED + ${BASH_REMATCH[1]}))
    fi

    # Extract ignored count
    if [[ "$line" =~ ([0-9]+)\ ignored ]]; then
        IGNORED=$((IGNORED + ${BASH_REMATCH[1]}))
    fi
done < <(grep "^test result:" "$TEMP_OUTPUT")

# Calculate total
TOTAL=$((PASSED + FAILED + IGNORED))

# If we didn't find any summaries, try counting individual test lines
if [ $TOTAL -eq 0 ]; then
    echo "Warning: Could not parse test summaries, attempting fallback parsing" >&2
    PASSED_COUNT=$(grep -c "test .* \.\.\. ok$" "$TEMP_OUTPUT" 2>/dev/null || echo "0")
    FAILED_COUNT=$(grep -c "test .* \.\.\. FAILED$" "$TEMP_OUTPUT" 2>/dev/null || echo "0")
    IGNORED_COUNT=$(grep -c "test .* \.\.\. ignored$" "$TEMP_OUTPUT" 2>/dev/null || echo "0")
    # Ensure we have valid single numbers
    PASSED=$(echo "$PASSED_COUNT" | tr -d '\n' | grep -o '[0-9]*' | head -1)
    FAILED=$(echo "$FAILED_COUNT" | tr -d '\n' | grep -o '[0-9]*' | head -1)
    IGNORED=$(echo "$IGNORED_COUNT" | tr -d '\n' | grep -o '[0-9]*' | head -1)
    PASSED=${PASSED:-0}
    FAILED=${FAILED:-0}
    IGNORED=${IGNORED:-0}
    TOTAL=$((PASSED + FAILED + IGNORED))
fi

# Clean up
rm -f "$TEMP_OUTPUT"

# Output JSON result to stdout
echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $IGNORED, \"total\": $TOTAL}"
