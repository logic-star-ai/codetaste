#!/bin/bash
# Test execution script for GraphHopper
# This script runs the test suite and outputs results in JSON format

set -e

cd /testbed

# Run Maven tests and capture output
# We run with -B for batch mode
TEST_OUTPUT=$(mktemp)

# Run tests and store exit code
set +e
mvn test -B 2>&1 | tee "$TEST_OUTPUT"
EXIT_CODE=$?
set -e

# Extract test results from Maven output
# Maven Surefire reports test results in the format:
# Tests run: X, Failures: Y, Errors: Z, Skipped: W
# Can appear as [INFO] or [WARNING] depending on whether there are skipped tests

# Parse all "Results:" sections and aggregate them (one per module)
TOTAL=0
FAILED=0
SKIPPED=0

IN_RESULTS_SECTION=0
while IFS= read -r line; do
    # Check if we're entering a Results section
    if echo "$line" | grep -q "^\[INFO\] Results:"; then
        IN_RESULTS_SECTION=1
        continue
    fi

    # If we're in results section and find the summary line, extract it
    # Handle both [INFO] and [WARNING] prefixes
    if [ "$IN_RESULTS_SECTION" -eq 1 ] && echo "$line" | grep -qE "^\[(INFO|WARNING)\] Tests run:"; then
        # Extract numbers using grep and sed
        RUN=$(echo "$line" | grep -oP 'Tests run: \K[0-9]+' || echo "0")
        FAIL=$(echo "$line" | grep -oP 'Failures: \K[0-9]+' || echo "0")
        ERR=$(echo "$line" | grep -oP 'Errors: \K[0-9]+' || echo "0")
        SKIP=$(echo "$line" | grep -oP 'Skipped: \K[0-9]+' || echo "0")

        # Aggregate the results from this module
        TOTAL=$((TOTAL + RUN))
        FAILED=$((FAILED + FAIL + ERR))
        SKIPPED=$((SKIPPED + SKIP))

        # Reset flag to look for next Results section
        IN_RESULTS_SECTION=0
    fi
done < "$TEST_OUTPUT"

# Calculate passed tests
PASSED=$((TOTAL - FAILED - SKIPPED))

# Clean up
rm -f "$TEST_OUTPUT"

# Output JSON result (this must be the last line of stdout)
echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $SKIPPED, \"total\": $TOTAL}"

# Return the maven exit code
exit $EXIT_CODE
