#!/bin/bash
# Test runner script - executes tests and outputs JSON summary
# Must be run after sourcing setup_shell.sh

set -e

cd /testbed

# Run jest tests (excluding integration tests as per package.json)
# Use --json to get machine-readable output
# --testPathIgnorePatterns is already set in package.json script

echo "Running tests..." >&2

# Capture jest output with JSON reporter and separate stdout from stderr
JEST_OUTPUT=$(npx jest --testPathIgnorePatterns test/integration --json --ci --colors 2>/dev/null)
EXIT_CODE=$?

# Extract test results from Jest JSON output
# Jest's --json flag outputs a JSON object with test results
# Use -c for compact output (single line)
echo "$JEST_OUTPUT" | jq -c '{
  passed: (.numPassedTests // 0),
  failed: (.numFailedTests // 0),
  skipped: (.numPendingTests // 0),
  total: (.numTotalTests // 0)
}'

exit $EXIT_CODE
