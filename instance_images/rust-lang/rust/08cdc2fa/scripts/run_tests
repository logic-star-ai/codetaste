#!/bin/bash
# Test runner script for Rust compiler
# This script runs a representative subset of tests that complete within 15 minutes

set -e

cd /testbed

# We'll run the tidy tests which check:
# - Code style and formatting
# - License headers
# - Feature gate tests
# - Error code documentation
# - Other code quality checks
#
# These are fast (< 5 minutes) and are always run in CI

echo "Running Rust compiler tidy tests..."

# Run tidy tests and capture output
TEST_OUTPUT=$(./x.py test tidy --stage 0 2>&1 || true)

# Check if tests passed or failed
if echo "$TEST_OUTPUT" | grep -q "Build completed successfully"; then
    # All tidy tests passed
    PASSED=1
    FAILED=0
    SKIPPED=0
    TOTAL=1
elif echo "$TEST_OUTPUT" | grep -q "some tidy checks failed"; then
    # Some tidy checks failed
    PASSED=0
    FAILED=1
    SKIPPED=0
    TOTAL=1
else
    # Could not determine test status, assume failure
    PASSED=0
    FAILED=1
    SKIPPED=0
    TOTAL=1
fi

# Output the JSON result as required
echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $SKIPPED, \"total\": $TOTAL}"
