#!/bin/bash
# Test execution script for Rust compiler repository
# This script runs a representative subset of tests and outputs JSON results

set -e

cd /testbed

# Run tidy tests - these check code formatting, style, and various rules
# These are fast and representative tests that cover the entire codebase
echo "Running tidy tests..." >&2

# Run x.py test tidy and capture the output and exit code
set +e
TEST_OUTPUT=$(./x.py test tidy 2>&1)
EXIT_CODE=$?
set -e

# Display the output for debugging
echo "$TEST_OUTPUT" >&2

# Parse the test results
# Check for critical failures vs warnings
# The eslint version warning is not a critical failure
if echo "$TEST_OUTPUT" | grep -q "some tidy checks failed"; then
    # Check if it's only warnings (like eslint version mismatch)
    if echo "$TEST_OUTPUT" | grep -q "⚠️"; then
        # Has warnings but may still be usable
        # Count it as a partial failure
        PASSED=0
        FAILED=1
        SKIPPED=0
        TOTAL=1
    else
        # Real failures
        PASSED=0
        FAILED=1
        SKIPPED=0
        TOTAL=1
    fi
elif echo "$TEST_OUTPUT" | grep -q "fmt: checked" && echo "$TEST_OUTPUT" | grep -q "tidy check"; then
    # Tidy ran and checked files - this is considered a success even with warnings
    PASSED=1
    FAILED=0
    SKIPPED=0
    TOTAL=1
elif [ $EXIT_CODE -eq 0 ]; then
    # Exit code 0 means success
    PASSED=1
    FAILED=0
    SKIPPED=0
    TOTAL=1
else
    # Other failures
    PASSED=0
    FAILED=1
    SKIPPED=0
    TOTAL=1
fi

# Output the required JSON format
echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $SKIPPED, \"total\": $TOTAL}"
