#!/usr/bin/env python3
"""
Run Rust compiler tests and output results in JSON format.
This script runs the tidy test suite which is fast and comprehensive.
"""

import json
import subprocess
import sys
import re
import os

def run_tests():
    """Run tidy tests and parse the output."""

    os.chdir('/testbed')

    # Run tidy tests - these are fast self-tests that don't require building the full compiler
    # tidy checks code style, file organization, and other linting rules
    sys.stderr.write("Running tidy tests...\n")
    sys.stderr.flush()

    try:
        # Run the tidy self-test suite - fast tests that don't require building the full compiler
        result = subprocess.run(
            ['python3', 'x.py', 'test', 'tidyselftest', '--stage', '0'],
            capture_output=True,
            text=True,
            timeout=900  # 15 minutes max
        )

        output = result.stdout + result.stderr

        # Parse test results from cargo test output
        # Looking for patterns like:
        # "test result: ok. 15 passed; 0 failed; 0 ignored; 0 measured; 0 filtered out"

        passed = 0
        failed = 0
        ignored = 0

        # Find ALL test result summary lines (there can be multiple test suites)
        summary_pattern = r'test result:.*?(\d+) passed.*?(\d+) failed.*?(\d+) (?:ignored|skipped)'
        summary_matches = re.findall(summary_pattern, output)

        if summary_matches:
            # Sum up results from all test suites
            for match in summary_matches:
                passed += int(match[0])
                failed += int(match[1])
                ignored += int(match[2])
        else:
            # Fallback: count individual test results
            # Count "test ... ok" lines
            passed = len(re.findall(r'test .+? \.\.\. ok', output))
            # Count "test ... FAILED" lines
            failed = len(re.findall(r'test .+? \.\.\. FAILED', output))
            # Count "test ... ignored" lines
            ignored = len(re.findall(r'test .+? \.\.\. ignored', output))

        # If we couldn't parse anything, check if tidy itself ran
        if passed == 0 and failed == 0 and ignored == 0:
            # Check if tidy binary was tested successfully
            if 'running 0 tests' in output.lower():
                # No tests to run but compilation succeeded
                passed = 1
                failed = 0
                ignored = 0
            elif result.returncode == 0:
                # Command succeeded but we couldn't parse output
                # This might mean tidy ran but in a different mode
                # Check for "tidy check" output
                if 'tidy error' in output.lower():
                    failed = 1
                else:
                    passed = 1

        total = passed + failed + ignored

        # If return code is non-zero and we didn't find failures, mark as 1 failure
        if result.returncode != 0 and failed == 0:
            failed = 1
            total = max(total, 1)

        # Ensure we report at least something
        if total == 0:
            if result.returncode == 0:
                passed = 1
                total = 1
            else:
                failed = 1
                total = 1

        # Output the JSON result to stdout (must be last line)
        result_json = {
            "passed": passed,
            "failed": failed,
            "skipped": ignored,
            "total": total
        }

        sys.stdout.write(json.dumps(result_json) + "\n")
        sys.stdout.flush()

        # Exit with appropriate code
        sys.exit(0 if failed == 0 else 1)

    except subprocess.TimeoutExpired:
        sys.stderr.write("Test execution timed out\n")
        sys.stderr.flush()
        result_json = {
            "passed": 0,
            "failed": 1,
            "skipped": 0,
            "total": 1
        }
        sys.stdout.write(json.dumps(result_json) + "\n")
        sys.stdout.flush()
        sys.exit(1)
    except Exception as e:
        sys.stderr.write(f"Error running tests: {e}\n")
        sys.stderr.flush()
        result_json = {
            "passed": 0,
            "failed": 1,
            "skipped": 0,
            "total": 1
        }
        sys.stdout.write(json.dumps(result_json) + "\n")
        sys.stdout.flush()
        sys.exit(1)

if __name__ == '__main__':
    run_tests()
