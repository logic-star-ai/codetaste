#!/bin/bash
# Test runner script for Rust compiler
# This script runs a representative subset of the test suite

set -e

cd /testbed

# We'll run tidy tests which are fast and don't require building the compiler
# Tidy checks source code style, consistency, and various lint rules

# Run tidy tests using x.py
echo "Running tidy tests..."
TEST_OUTPUT=$(python3 ./x.py test tidy 2>&1)

# Save exit code
TEST_EXIT_CODE=$?

# Output the results for debugging (but not to final JSON)
echo "$TEST_OUTPUT" >&2

# Parse test results
# Look for success indicators
PASSED=0
FAILED=0
IGNORED=0

# Check if tidy tests passed
if [ $TEST_EXIT_CODE -eq 0 ]; then
    # Tidy tests passed - count as 1 passed test
    PASSED=1
    FAILED=0
    IGNORED=0
else
    # Tidy tests failed
    PASSED=0
    FAILED=1
    IGNORED=0
fi

# Try to extract more detailed results if available
if echo "$TEST_OUTPUT" | grep -q "test result:"; then
    RESULT_LINE=$(echo "$TEST_OUTPUT" | grep "test result:" | tail -1)

    # Extract numbers using grep and sed
    EXTRACTED_PASSED=$(echo "$RESULT_LINE" | grep -o '[0-9]\+ passed' | grep -o '[0-9]\+' || echo "")
    EXTRACTED_FAILED=$(echo "$RESULT_LINE" | grep -o '[0-9]\+ failed' | grep -o '[0-9]\+' || echo "")
    EXTRACTED_IGNORED=$(echo "$RESULT_LINE" | grep -o '[0-9]\+ ignored' | grep -o '[0-9]\+' || echo "")

    if [ -n "$EXTRACTED_PASSED" ]; then
        PASSED=$EXTRACTED_PASSED
    fi
    if [ -n "$EXTRACTED_FAILED" ]; then
        FAILED=$EXTRACTED_FAILED
    fi
    if [ -n "$EXTRACTED_IGNORED" ]; then
        IGNORED=$EXTRACTED_IGNORED
    fi
fi

# Calculate total
TOTAL=$((PASSED + FAILED + IGNORED))

# Output JSON result
echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $IGNORED, \"total\": $TOTAL}"
