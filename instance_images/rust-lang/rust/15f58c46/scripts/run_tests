#!/bin/bash
# Test runner script for Rust compiler
# This script runs a representative subset of tests and outputs results in JSON format

set -e

cd /testbed

# We'll run a subset of tests that are representative and complete in reasonable time
# Options:
# 1. Library tests (library/std, library/core) - fast and comprehensive
# 2. A small subset of UI tests

# Create a temporary file to capture test output
TEMP_OUTPUT=$(mktemp)

# Function to parse test output and generate JSON
parse_test_output() {
    local output_file=$1

    # Parse the test output for lines like:
    # "test result: ok. 123 passed; 0 failed; 10 ignored; 0 measured; 0 filtered out"
    # Multiple test runs will have multiple such lines

    local total_passed=0
    local total_failed=0
    local total_ignored=0

    # Look for test result summary lines
    while IFS= read -r line; do
        if [[ "$line" =~ test[[:space:]]result:.* ]]; then
            # Extract numbers using grep -oP for proper matching
            local passed=$(echo "$line" | grep -oP '\d+(?= passed)' || echo "0")
            local failed=$(echo "$line" | grep -oP '\d+(?= failed)' || echo "0")
            local ignored=$(echo "$line" | grep -oP '\d+(?= ignored)' || echo "0")

            if [[ -n "$passed" && "$passed" != "0" ]]; then
                total_passed=$((total_passed + passed))
            fi
            if [[ -n "$failed" && "$failed" != "0" ]]; then
                total_failed=$((total_failed + failed))
            fi
            if [[ -n "$ignored" && "$ignored" != "0" ]]; then
                total_ignored=$((total_ignored + ignored))
            fi
        fi
    done < "$output_file"

    # If we didn't find any standard test output, try to parse compiletest output
    if [ $total_passed -eq 0 ] && [ $total_failed -eq 0 ]; then
        # compiletest outputs: "test result: FAILED. X passed; Y failed; Z ignored; ..."
        # or multiple lines like ".... ok" or ".... FAILED"
        local test_passed=$(grep -c "^\.\.\.\. ok" "$output_file" 2>/dev/null || echo 0)
        local test_failed=$(grep -c "^\.\.\. FAILED" "$output_file" 2>/dev/null || echo 0)

        if [ $test_passed -gt 0 ] || [ $test_failed -gt 0 ]; then
            total_passed=$test_passed
            total_failed=$test_failed
        fi
    fi

    local total=$((total_passed + total_failed + total_ignored))

    echo "{\"passed\": $total_passed, \"failed\": $total_failed, \"skipped\": $total_ignored, \"total\": $total}"
}

# Run library tests - these are comprehensive and relatively fast
echo "Running library tests..." >&2

# Test library/core - fundamental data structures
# Use stage 0 to avoid needing to build stage1 compiler
./x.py test --stage 0 --no-fail-fast library/core 2>&1 | tee "$TEMP_OUTPUT" >&2 || true

# Parse and output JSON result
parse_test_output "$TEMP_OUTPUT"

# Cleanup
rm -f "$TEMP_OUTPUT"
