#!/bin/bash
# Test runner script for Mockito
# Runs tests and outputs results in JSON format

set -e

cd /testbed

# Create target directory if it doesn't exist (for clean builds)
mkdir -p target

# Create reports directory
mkdir -p target/reports/junit

# Run tests - compile and test in one go
# Remove haltonfailure to get full test results
ant compile compile.test 2>&1 > /dev/null

# Run tests with detailed output
cat > /tmp/run_junit.xml << 'EOF'
<?xml version="1.0"?>
<project name="mockito-test" basedir="/testbed" default="test">
    <property name="src.classes.dir" value="target/classes" />
    <property name="test.classes.dir" value="target/test-classes" />
    <property name="lib.dir" value="lib" />
    <property name="test.reports.dir" value="target/reports/junit" />

    <path id="compile.classpath">
        <fileset dir="${lib.dir}" includes="*.jar" />
    </path>

    <path id="test.compile.classpath">
        <path refid="compile.classpath" />
        <pathelement location="${src.classes.dir}" />
    </path>

    <path id="test.classpath">
        <path refid="test.compile.classpath" />
        <pathelement location="${test.classes.dir}" />
    </path>

    <target name="test">
        <mkdir dir="${test.reports.dir}" />
        <junit fork="true" forkmode="once" printsummary="true" haltonfailure="false" haltonerror="false">
            <formatter type="xml" />
            <formatter type="brief" usefile="false" />
            <classpath refid="test.classpath" />
            <batchtest todir="${test.reports.dir}">
                <fileset dir="${test.classes.dir}" includes="**/*Test.class" />
            </batchtest>
        </junit>
    </target>
</project>
EOF

# Run the tests
ant -f /tmp/run_junit.xml test 2>&1 | tee /tmp/test_output.txt || true

# Parse XML results if they exist
PASSED=0
FAILED=0
SKIPPED=0
TOTAL=0
ERRORS=0

if [ -d "target/reports/junit" ] && [ "$(ls -A target/reports/junit/*.xml 2>/dev/null)" ]; then
    # Parse all XML files
    for xml_file in target/reports/junit/*.xml; do
        if [ -f "$xml_file" ]; then
            # Extract test counts from XML
            tests=$(grep -oP 'tests="\K[0-9]+' "$xml_file" | head -1)
            failures=$(grep -oP 'failures="\K[0-9]+' "$xml_file" | head -1)
            errors=$(grep -oP 'errors="\K[0-9]+' "$xml_file" | head -1)
            skipped=$(grep -oP 'skipped="\K[0-9]+' "$xml_file" | head -1)

            TOTAL=$((TOTAL + ${tests:-0}))
            FAILED=$((FAILED + ${failures:-0}))
            ERRORS=$((ERRORS + ${errors:-0}))
            SKIPPED=$((SKIPPED + ${skipped:-0}))
        fi
    done

    # Combine errors into failed
    FAILED=$((FAILED + ERRORS))
    # Calculate passed
    PASSED=$((TOTAL - FAILED - SKIPPED))
else
    # Fallback: Parse text output
    if grep -q "Tests run:" /tmp/test_output.txt; then
        SUMMARY=$(grep "Tests run:" /tmp/test_output.txt | tail -1)

        TOTAL=$(echo "$SUMMARY" | sed -n 's/.*Tests run: \([0-9]*\).*/\1/p')
        FAILED=$(echo "$SUMMARY" | sed -n 's/.*Failures: \([0-9]*\).*/\1/p')
        ERRORS=$(echo "$SUMMARY" | sed -n 's/.*Errors: \([0-9]*\).*/\1/p')
        SKIPPED=$(echo "$SUMMARY" | sed -n 's/.*Skipped: \([0-9]*\).*/\1/p')

        TOTAL=${TOTAL:-0}
        FAILED=${FAILED:-0}
        ERRORS=${ERRORS:-0}
        SKIPPED=${SKIPPED:-0}

        FAILED=$((FAILED + ERRORS))
        PASSED=$((TOTAL - FAILED - SKIPPED))
    fi
fi

# Ensure all values are valid integers
PASSED=${PASSED:-0}
FAILED=${FAILED:-0}
SKIPPED=${SKIPPED:-0}
TOTAL=${TOTAL:-0}

# Output JSON result
echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $SKIPPED, \"total\": $TOTAL}"
