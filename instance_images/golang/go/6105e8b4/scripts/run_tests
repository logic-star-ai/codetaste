#!/bin/bash
# Test execution script for Go
# Runs the test suite and outputs JSON results
# Must be run after sourcing setup_shell.sh

set -e

# Verify environment is set up
if [ -z "$GOROOT" ] || [ "$GOROOT" != "/testbed" ]; then
    echo "Error: Environment not set up. Run 'source /scripts/setup_shell.sh' first" >&2
    exit 1
fi

# Change to testbed directory
cd /testbed

# Create a temporary file for storing raw test output
TEMP_OUTPUT=$(mktemp)
trap "rm -f $TEMP_OUTPUT" EXIT

# Run a representative subset of tests that complete within 15 minutes
# We run standard library tests which are the most representative of Go functionality
# Excludes slower tests like cmd/go and net/http to stay within time limit
echo "Running Go standard library tests..." >&2

# Use dist test to run standard library tests
# We run most standard library packages - these are fast and comprehensive
# Excluding: cmd/* (slow), net/* (can be slow), runtime (slow), crypto/x509 (slow)
/testbed/pkg/tool/linux_amd64/dist test \
    -run="^go_test:(archive|bufio|bytes|compress|container|context|database|debug|encoding|errors|expvar|flag|fmt|hash|html|image|index|internal/(cpu|fmtsort|oserror|poll|reflectlite|singleflight|trace|xcoff)|io|log|math|mime|os/(signal)?$|path|plugin|reflect|regexp|sort|strconv|strings|sync|syscall|testing|text|time|unicode)" \
    2>&1 | tee $TEMP_OUTPUT >&2

# Parse the output to count passed/failed tests
# dist test shows output like "ok  	bytes	0.078s" for passed tests
# and "FAIL	package	0.123s" for failed tests

PASSED=0
FAILED=0
SKIPPED=0

# Count passed tests (lines starting with "ok  ")
PASSED=$(cat $TEMP_OUTPUT | grep -c "^ok  " || true)

# Count failed tests (lines starting with "FAIL")
FAILED=$(cat $TEMP_OUTPUT | grep -c "^FAIL" || true)

# For Go dist test, skipped is harder to count, we'll compute from banners
# Each test group that runs is one test for our purposes
TOTAL=$((PASSED + FAILED))

# Output the JSON result
echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $SKIPPED, \"total\": $TOTAL}"
