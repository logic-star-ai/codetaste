#!/usr/bin/env bash
#
# Test runner script for Apache DataFusion
# This script runs the test suite and outputs results in JSON format
#
set -e

# Ensure we're in the testbed directory
cd /testbed

# Ensure protoc is in PATH (should be set by setup_shell.sh)
if [ -d "$HOME/.protoc/bin" ]; then
    export PATH="$HOME/.protoc/bin:$PATH"
fi

# Use the local CARGO_HOME if it exists (set by setup_shell.sh)
if [ -d "/testbed/.cargo-local" ]; then
    export CARGO_HOME="/testbed/.cargo-local"
fi

# Initialize git submodules if needed
if [ -f .gitmodules ]; then
    git submodule update --init --recursive 2>/dev/null || true
fi

# Run tests with standard output format
# We run the main workspace tests (excluding doctests for speed)
# Using --lib --tests --bins to test library code, integration tests, and binaries
# Features: avro,json,backtrace as per CI configuration
echo "Running DataFusion test suite..." >&2

# Capture test output to a temporary file
TMPFILE=$(mktemp)
cargo test --lib --tests --bins --features avro,json,backtrace 2>&1 | tee "$TMPFILE" >&2 || true

# Parse the output with Python (which should be available)
python3 << 'EOF' 2>/dev/null || python << 'EOF' 2>/dev/null || {
    # Fallback if Python is not available - output zeros
    echo '{"passed": 0, "failed": 0, "skipped": 0, "total": 0}'
    exit 0
}
import sys
import re

try:
    with open('$TMPFILE', 'r') as f:
        content = f.read()

    # Look for the test result summary line
    # Format: "test result: ok. 123 passed; 0 failed; 5 ignored; 0 measured; 0 filtered out"
    match = re.search(r'test result:.*?(\d+) passed.*?(\d+) failed.*?(\d+) ignored', content)

    if match:
        passed = int(match.group(1))
        failed = int(match.group(2))
        skipped = int(match.group(3))
        total = passed + failed + skipped
        print(f'{{"passed": {passed}, "failed": {failed}, "skipped": {skipped}, "total": {total}}}')
    else:
        print('{"passed": 0, "failed": 0, "skipped": 0, "total": 0}')
except Exception as e:
    print('{"passed": 0, "failed": 0, "skipped": 0, "total": 0}', file=sys.stderr)
    sys.exit(1)
EOF

# Clean up
rm -f "$TMPFILE"
