#!/bin/bash
#
# Test execution script for Apache Pulsar
# Runs a representative subset of tests
#

set -e

cd /testbed

# Maven test options
MVN_TEST_OPTIONS="-B -ntp -DskipSourceReleaseAssembly=true -DskipBuildDistribution=true -Dspotbugs.skip=true -Dlicense.skip=true -Dcheckstyle.skip=true -Drat.skip=true"

# Disable output redirection to see results
MAVEN_OPTS="-Xmx2048m"

# Create a temporary file for collecting test results
RESULTS_FILE=$(mktemp)

# Function to parse surefire reports and collect stats
parse_test_results() {
    local module_dir=$1
    local passed=0
    local failed=0
    local skipped=0
    local total=0

    # Look for surefire reports
    if [ -d "${module_dir}/target/surefire-reports" ]; then
        # Parse TEST-*.xml files
        for xml_file in "${module_dir}"/target/surefire-reports/TEST-*.xml; do
            if [ -f "$xml_file" ]; then
                # Extract test statistics from XML
                local file_tests=$(grep -oP '(?<=tests=")[^"]*' "$xml_file" | head -1)
                local file_failures=$(grep -oP '(?<=failures=")[^"]*' "$xml_file" | head -1)
                local file_errors=$(grep -oP '(?<=errors=")[^"]*' "$xml_file" | head -1)
                local file_skipped=$(grep -oP '(?<=skipped=")[^"]*' "$xml_file" | head -1)

                # Add to totals
                total=$((total + ${file_tests:-0}))
                failed=$((failed + ${file_failures:-0} + ${file_errors:-0}))
                skipped=$((skipped + ${file_skipped:-0}))
            fi
        done
    fi

    # Check for testng-results.xml as fallback
    if [ -f "${module_dir}/target/surefire-reports/testng-results.xml" ]; then
        local file_tests=$(grep -oP '(?<=total=")[^"]*' "${module_dir}/target/surefire-reports/testng-results.xml" | head -1)
        local file_failed=$(grep -oP '(?<=failed=")[^"]*' "${module_dir}/target/surefire-reports/testng-results.xml" | head -1)
        local file_skipped=$(grep -oP '(?<=skipped=")[^"]*' "${module_dir}/target/surefire-reports/testng-results.xml" | head -1)

        if [ -n "$file_tests" ]; then
            total=$((total + ${file_tests:-0}))
            failed=$((failed + ${file_failed:-0}))
            skipped=$((skipped + ${file_skipped:-0}))
        fi
    fi

    passed=$((total - failed - skipped))

    # Write to results file
    echo "$passed $failed $skipped $total" >> "$RESULTS_FILE"
}

# Run tests on selected modules (subset that completes in ~15 minutes)
# Focus on core modules with unit tests

echo "Running tests on pulsar-common..."
./mvnw test -pl pulsar-common $MVN_TEST_OPTIONS -DredirectTestOutputToFile=false -DfailIfNoTests=false || true
parse_test_results "pulsar-common"

echo "Running tests on pulsar-client-api..."
./mvnw test -pl pulsar-client-api $MVN_TEST_OPTIONS -DredirectTestOutputToFile=false -DfailIfNoTests=false || true
parse_test_results "pulsar-client-api"

echo "Running tests on pulsar-cli-utils..."
./mvnw test -pl pulsar-cli-utils $MVN_TEST_OPTIONS -DredirectTestOutputToFile=false -DfailIfNoTests=false || true
parse_test_results "pulsar-cli-utils"

echo "Running tests on pulsar-client-tools-test..."
./mvnw test -pl pulsar-client-tools-test $MVN_TEST_OPTIONS -DredirectTestOutputToFile=false -DfailIfNoTests=false || true
parse_test_results "pulsar-client-tools-test"

echo "Running tests on structured-event-log..."
./mvnw test -pl structured-event-log $MVN_TEST_OPTIONS -DredirectTestOutputToFile=false -DfailIfNoTests=false || true
parse_test_results "structured-event-log"

echo "Running tests on pulsar-broker-common..."
./mvnw test -pl pulsar-broker-common $MVN_TEST_OPTIONS -DredirectTestOutputToFile=false -DfailIfNoTests=false || true
parse_test_results "pulsar-broker-common"

echo "Running tests on managed-ledger (subset)..."
./mvnw test -pl managed-ledger $MVN_TEST_OPTIONS -DredirectTestOutputToFile=false -DfailIfNoTests=false -Dtest='!ManagedLedgerTest,!OffloadersCacheTest' || true
parse_test_results "managed-ledger"

# Aggregate results
TOTAL_PASSED=0
TOTAL_FAILED=0
TOTAL_SKIPPED=0
TOTAL_TESTS=0

while read -r passed failed skipped total; do
    TOTAL_PASSED=$((TOTAL_PASSED + passed))
    TOTAL_FAILED=$((TOTAL_FAILED + failed))
    TOTAL_SKIPPED=$((TOTAL_SKIPPED + skipped))
    TOTAL_TESTS=$((TOTAL_TESTS + total))
done < "$RESULTS_FILE"

# Clean up temp file
rm -f "$RESULTS_FILE"

# Output JSON result
echo "{\"passed\": ${TOTAL_PASSED}, \"failed\": ${TOTAL_FAILED}, \"skipped\": ${TOTAL_SKIPPED}, \"total\": ${TOTAL_TESTS}}"
