#!/bin/bash
# Run Hadoop tests and output JSON results
# This script relies on setup_shell.sh having been sourced

# Don't exit on error - we want to collect results even if some tests fail
set +e

cd /testbed

# Run tests on hadoop-common module
# This is the core Hadoop module with comprehensive test coverage
# Run a representative subset of tests to complete within 15 minutes

echo "Running tests on hadoop-common module..."

# Run Maven tests with surefire reporting
# We'll run a subset of quick unit tests that are compatible with Java 21
# Allow test failures so we can still collect results
mvn test -pl hadoop-common-project/hadoop-common \
    -Dmaven.javadoc.skip=true \
    -Dcheckstyle.skip=true \
    -Dmaven.test.failure.ignore=true \
    -Dtest='org.apache.hadoop.util.TestStringUtils,org.apache.hadoop.io.TestText,org.apache.hadoop.io.TestArrayWritable,org.apache.hadoop.io.TestBooleanWritable,org.apache.hadoop.io.TestByteWritable' \
    2>&1 | tee /tmp/test_output.log

# Parse the test results from Maven output
# Maven Surefire generates XML reports in target/surefire-reports/

# Find all TEST-*.xml files in the surefire reports directory
REPORT_DIR="/testbed/hadoop-common-project/hadoop-common/target/surefire-reports"

if [ ! -d "$REPORT_DIR" ]; then
    echo '{"passed": 0, "failed": 0, "skipped": 0, "total": 0}'
    exit 1
fi

# Parse XML reports to count test results
# Using a Python script for more reliable XML parsing
python3 << 'EOF'
import xml.etree.ElementTree as ET
import glob
import json
import os

report_dir = "/testbed/hadoop-common-project/hadoop-common/target/surefire-reports"
passed = 0
failed = 0
skipped = 0
errors = 0

# Find all TEST-*.xml files
xml_files = glob.glob(os.path.join(report_dir, "TEST-*.xml"))

for xml_file in xml_files:
    try:
        tree = ET.parse(xml_file)
        root = tree.getroot()

        # Get test counts from testsuite element
        tests = int(root.get('tests', 0))
        failures = int(root.get('failures', 0))
        test_errors = int(root.get('errors', 0))
        test_skipped = int(root.get('skipped', 0))

        failed += failures + test_errors
        skipped += test_skipped
        passed += tests - failures - test_errors - test_skipped

    except Exception as e:
        # If we can't parse a file, continue with others
        continue

total = passed + failed + skipped

# Output JSON result
result = {
    "passed": passed,
    "failed": failed,
    "skipped": skipped,
    "total": total
}

print(json.dumps(result))
EOF
