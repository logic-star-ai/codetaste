# Test runner script for Apache ShenYu
# Assumes environment is already set up via setup_shell.sh

cd /testbed || exit 1

# Run tests on a representative subset of core modules
# These modules have good test coverage and complete within 15 minutes
# We exclude modules that require external services (etcd, nacos, etc.)
MODULES="shenyu-common,shenyu-spi,shenyu-loadbalancer,shenyu-disruptor,shenyu-web"
MODULES="$MODULES,shenyu-admin-listener/shenyu-admin-listener-api"
MODULES="$MODULES,shenyu-plugin/shenyu-plugin-api,shenyu-plugin/shenyu-plugin-base"
MODULES="$MODULES,shenyu-protocol/shenyu-protocol-tcp,shenyu-protocol/shenyu-protocol-mqtt"
MODULES="$MODULES,shenyu-register-center/shenyu-register-common"
MODULES="$MODULES,shenyu-sync-data-center/shenyu-sync-data-api"

echo "Running Apache ShenYu tests on core modules..."

# Run Maven tests with surefire plugin
# Use -fn (fail-never) to continue even if some tests fail
./mvnw -B -fn test \
    -pl "$MODULES" \
    -Drat.skip=true \
    -Dmaven.javadoc.skip=true \
    -Djacoco.skip=true \
    -Dcheckstyle.skip=true \
    -DfailIfNoTests=false 2>&1 | tee /tmp/test_output.log

# Parse the test results from Maven output
# Look for lines like: "[INFO] Tests run: X, Failures: Y, Errors: Z, Skipped: W"
# These appear after each test class completes, and as a summary after each module

passed=0
failed=0
skipped=0
total=0

# Extract the summary line from each module (the line without "Time elapsed")
# to avoid double counting individual test results
while IFS= read -r line; do
    if [[ "$line" =~ Tests\ run:\ ([0-9]+),\ Failures:\ ([0-9]+),\ Errors:\ ([0-9]+),\ Skipped:\ ([0-9]+)$ ]]; then
        run="${BASH_REMATCH[1]}"
        failures="${BASH_REMATCH[2]}"
        errors="${BASH_REMATCH[3]}"
        skip="${BASH_REMATCH[4]}"

        total=$((total + run))
        skipped=$((skipped + skip))
        failed=$((failed + failures + errors))
    fi
done < <(grep -E "^\[INFO\] Tests run: [0-9]+, Failures: [0-9]+, Errors: [0-9]+, Skipped: [0-9]+$|^\[ERROR\] Tests run: [0-9]+, Failures: [0-9]+, Errors: [0-9]+, Skipped: [0-9]+$" /tmp/test_output.log)

passed=$((total - failed - skipped))

# Output the final JSON result
echo "{\"passed\": $passed, \"failed\": $failed, \"skipped\": $skipped, \"total\": $total}"
