#!/bin/bash
################################################################################
# Test execution script for Apache Flink
# Runs a representative subset of tests and outputs JSON results
# Must be run after sourcing setup_shell.sh
################################################################################

set -e

cd /testbed

# Set Java 8
export JAVA_HOME=/usr/lib/jvm/java-8-openjdk-amd64
export PATH=$JAVA_HOME/bin:$PATH
export MAVEN_OPTS="-Xmx2g -XX:MaxPermSize=512m"

# Run tests on flink-core module which is core functionality
# Skip checkstyle and other quality checks to focus on actual tests
# Use surefire report plugin to generate test results
mvn test -pl flink-core \
    -Dcheckstyle.skip=true \
    -Djapicmp.skip=true \
    -Drat.skip=true \
    -Dmaven.javadoc.skip=true \
    -Dflink.forkCount=2 \
    -Dflink.reuseForks=true \
    -B

# Parse the surefire reports to get test counts
# Surefire generates XML reports in target/surefire-reports/
REPORTS_DIR="/testbed/flink-core/target/surefire-reports"

if [ ! -d "$REPORTS_DIR" ]; then
    echo '{"passed": 0, "failed": 0, "skipped": 0, "total": 0}'
    exit 1
fi

# Parse XML reports to count test results
# Use grep and basic text processing to extract counts
PASSED=0
FAILED=0
SKIPPED=0
ERRORS=0

# Look for TEST-*.xml files
for xml_file in "$REPORTS_DIR"/TEST-*.xml; do
    if [ -f "$xml_file" ]; then
        # Extract attributes from testsuite tag
        # Format: <testsuite ... tests="N" failures="F" errors="E" skipped="S" ...>
        line=$(grep '<testsuite' "$xml_file" | head -1)

        # Extract numbers using sed
        tests=$(echo "$line" | sed -n 's/.*tests="\([0-9]*\)".*/\1/p')
        failures=$(echo "$line" | sed -n 's/.*failures="\([0-9]*\)".*/\1/p')
        errors=$(echo "$line" | sed -n 's/.*errors="\([0-9]*\)".*/\1/p')
        skipped=$(echo "$line" | sed -n 's/.*skipped="\([0-9]*\)".*/\1/p')

        # Add to totals (default to 0 if empty)
        FAILED=$((FAILED + ${failures:-0}))
        ERRORS=$((ERRORS + ${errors:-0}))
        SKIPPED=$((SKIPPED + ${skipped:-0}))
    fi
done

# Also check for summary files
if [ -f "$REPORTS_DIR/failsafe-summary.xml" ] || [ -f "$REPORTS_DIR/surefire-summary.xml" ]; then
    for summary in "$REPORTS_DIR"/*-summary.xml; do
        if [ -f "$summary" ]; then
            result=$(grep '<result>' "$summary" | head -1)
            if [ -n "$result" ]; then
                FAILED=$((FAILED + $(echo "$result" | sed -n 's/.*<failures>\([0-9]*\)<\/failures>.*/\1/p' || echo 0)))
                ERRORS=$((ERRORS + $(echo "$result" | sed -n 's/.*<errors>\([0-9]*\)<\/errors>.*/\1/p' || echo 0)))
                SKIPPED=$((SKIPPED + $(echo "$result" | sed -n 's/.*<skipped>\([0-9]*\)<\/skipped>.*/\1/p' || echo 0)))
            fi
        fi
    done
fi

# Count all test result XML files to get total tests
TOTAL=$(grep -h '<testsuite' "$REPORTS_DIR"/TEST-*.xml 2>/dev/null | \
        sed -n 's/.*tests="\([0-9]*\)".*/\1/p' | \
        awk '{sum+=$1} END {print sum}')

# Calculate passed tests
TOTAL=${TOTAL:-0}
FAILED=$((FAILED + ERRORS))
PASSED=$((TOTAL - FAILED - SKIPPED))

# Ensure non-negative values
[ $PASSED -lt 0 ] && PASSED=0
[ $FAILED -lt 0 ] && FAILED=0
[ $SKIPPED -lt 0 ] && SKIPPED=0
[ $TOTAL -lt 0 ] && TOTAL=0

# Output JSON result
echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $SKIPPED, \"total\": $TOTAL}"
