#!/bin/bash
#
# Test execution script for Apache Pinot
# Executes the test suite and outputs results in JSON format
# This script assumes setup_shell.sh has been sourced

set -e

cd /testbed

# Run unit tests for a representative subset of modules
# We'll run tests from key modules that finish within 15 minutes
echo "Running Apache Pinot unit tests (representative subset)..."
./mvnw test -T 4 \
    -pl 'pinot-spi' \
    -pl 'pinot-segment-spi' \
    -pl 'pinot-common' \
    -P github-actions,no-integration-tests 2>&1 | tee /tmp/test_output.log

# Parse Maven output to extract test results
# Maven Surefire reports test results like:
# Tests run: X, Failures: Y, Errors: Z, Skipped: W

# Extract test counts from the surefire summary
PASSED=0
FAILED=0
SKIPPED=0
TOTAL=0

# Parse all test results from the log
while IFS= read -r line; do
    if [[ "$line" =~ Tests\ run:\ ([0-9]+),\ Failures:\ ([0-9]+),\ Errors:\ ([0-9]+),\ Skipped:\ ([0-9]+) ]]; then
        TESTS_RUN=${BASH_REMATCH[1]}
        FAILURES=${BASH_REMATCH[2]}
        ERRORS=${BASH_REMATCH[3]}
        SKIPPED_CURRENT=${BASH_REMATCH[4]}

        # Accumulate totals
        TOTAL=$((TOTAL + TESTS_RUN))
        FAILED=$((FAILED + FAILURES + ERRORS))
        SKIPPED=$((SKIPPED + SKIPPED_CURRENT))
    fi
done < /tmp/test_output.log

# Calculate passed tests
PASSED=$((TOTAL - FAILED - SKIPPED))

# Ensure we have valid numbers
if [ $TOTAL -eq 0 ]; then
    echo "Warning: No tests found in output. Checking Maven summary..." >&2

    # Try to find the final summary line
    SUMMARY=$(grep -A 5 "^\[INFO\] Results:$" /tmp/test_output.log | tail -10)

    if echo "$SUMMARY" | grep -q "Tests run:"; then
        TOTAL=$(echo "$SUMMARY" | grep -oP "Tests run: \K[0-9]+" | tail -1)
        FAILURES=$(echo "$SUMMARY" | grep -oP "Failures: \K[0-9]+" | tail -1)
        ERRORS=$(echo "$SUMMARY" | grep -oP "Errors: \K[0-9]+" | tail -1)
        SKIPPED=$(echo "$SUMMARY" | grep -oP "Skipped: \K[0-9]+" | tail -1)

        # Default to 0 if not found
        TOTAL=${TOTAL:-0}
        FAILURES=${FAILURES:-0}
        ERRORS=${ERRORS:-0}
        SKIPPED=${SKIPPED:-0}

        FAILED=$((FAILURES + ERRORS))
        PASSED=$((TOTAL - FAILED - SKIPPED))
    fi
fi

# Output JSON result (this is the required final output)
echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $SKIPPED, \"total\": $TOTAL}"
