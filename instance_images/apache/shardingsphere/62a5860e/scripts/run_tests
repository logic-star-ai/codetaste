#!/bin/bash

# This script runs a representative subset of tests from Apache ShardingSphere
# It focuses on core modules that can complete within 15 minutes
# Output format: JSON with test statistics

set -e

cd /testbed

# List of modules to test - these are core modules with good test coverage
# that represent the main functionality of the project
TEST_MODULES=(
    "infra/util"
    "infra/common"
    "infra/binder"
    "infra/context"
    "infra/executor"
    "infra/expr/core"
    "infra/rewrite"
    "infra/route"
    "kernel/authority/core"
    "kernel/single/core"
    "kernel/sql-parser/core"
    "kernel/transaction/core"
    "parser/sql/statement"
    "db-protocol/core"
)

# Run tests and capture output
echo "Running tests on representative modules..." >&2
TEST_OUTPUT=$(./mvnw test -pl $(IFS=,; echo "${TEST_MODULES[*]}") 2>&1)

# Extract test statistics from Maven output
# Maven surefire plugin outputs: "Tests run: X, Failures: Y, Errors: Z, Skipped: W"
PASSED=0
FAILED=0
SKIPPED=0
TOTAL=0

# Parse each module's test results
while IFS= read -r line; do
    if [[ $line =~ Tests\ run:\ ([0-9]+),\ Failures:\ ([0-9]+),\ Errors:\ ([0-9]+),\ Skipped:\ ([0-9]+) ]]; then
        run=${BASH_REMATCH[1]}
        failures=${BASH_REMATCH[2]}
        errors=${BASH_REMATCH[3]}
        skipped=${BASH_REMATCH[4]}

        # Calculate passed tests for this run
        passed=$((run - failures - errors - skipped))

        PASSED=$((PASSED + passed))
        FAILED=$((FAILED + failures + errors))
        SKIPPED=$((SKIPPED + skipped))
        TOTAL=$((TOTAL + run))
    fi
done <<< "$TEST_OUTPUT"

# Output JSON result
echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $SKIPPED, \"total\": $TOTAL}"
