#!/bin/bash
# run_tests - Execute Apache ShardingSphere test suite
# This script runs a representative subset of tests that completes within 15 minutes
# Output: JSON with test results in format: {"passed": int, "failed": int, "skipped": int, "total": int}

set -e

# Navigate to testbed directory
cd /testbed

# Define the modules to test - these are core modules that provide good coverage
# and run relatively quickly
TEST_MODULES=(
    "infra/common"
    "infra/util"
    "infra/spi"
    "infra/database/core"
    "parser/sql/statement"
    "parser/sql/engine"
    "kernel/metadata/core"
    "kernel/data-pipeline/core"
    "kernel/transaction/core"
    "mode/core"
)

# Create a temporary file to collect test results
TEMP_RESULTS=$(mktemp)
trap "rm -f $TEMP_RESULTS" EXIT

# Run tests for selected modules
echo "Running tests for selected core modules..."

# Use Maven Surefire plugin to run tests
# -pl specifies project list (modules to test)
# -am also makes (builds) the dependencies
# -B batch mode (non-interactive)
# -ntp no transfer progress
# -fae fail at end (continue testing all modules even if some fail)

MODULE_LIST=$(IFS=,; echo "${TEST_MODULES[*]}")

./mvnw test -pl "$MODULE_LIST" -am -B -ntp -fae 2>&1 | tee $TEMP_RESULTS

# Parse the test results from Maven output
# Maven Surefire reports results as: "Tests run: X, Failures: Y, Errors: Z, Skipped: W"

# Initialize counters
TOTAL_TESTS=0
TOTAL_FAILURES=0
TOTAL_ERRORS=0
TOTAL_SKIPPED=0

# Extract test statistics from the output
# Look for lines like: "Tests run: 224, Failures: 0, Errors: 0, Skipped: 0"
while IFS= read -r line; do
    if [[ $line =~ Tests\ run:\ ([0-9]+),\ Failures:\ ([0-9]+),\ Errors:\ ([0-9]+),\ Skipped:\ ([0-9]+) ]]; then
        TESTS="${BASH_REMATCH[1]}"
        FAILURES="${BASH_REMATCH[2]}"
        ERRORS="${BASH_REMATCH[3]}"
        SKIPPED="${BASH_REMATCH[4]}"

        # Only count the final summary (which appears after "Results:" line)
        # or individual test class results
        TOTAL_TESTS=$((TOTAL_TESTS + TESTS))
        TOTAL_FAILURES=$((TOTAL_FAILURES + FAILURES))
        TOTAL_ERRORS=$((TOTAL_ERRORS + ERRORS))
        TOTAL_SKIPPED=$((TOTAL_SKIPPED + SKIPPED))
    fi
done < $TEMP_RESULTS

# Calculate passed tests (total - failures - errors - skipped)
# Note: In Maven/JUnit, failures and errors are both test failures
TOTAL_FAILED=$((TOTAL_FAILURES + TOTAL_ERRORS))
TOTAL_PASSED=$((TOTAL_TESTS - TOTAL_FAILED - TOTAL_SKIPPED))

# If we didn't find any test results, check if tests actually ran
if [ $TOTAL_TESTS -eq 0 ]; then
    # Try to get results from the final reactor summary
    if grep -q "BUILD SUCCESS" $TEMP_RESULTS; then
        # Even with success, we should have test counts
        # This might mean no tests were found or results parsing failed
        echo "Warning: No test results found in output" >&2
        # Check for the final Results line
        FINAL_RESULTS=$(grep -A 1 "^\\[INFO\\] Results:" $TEMP_RESULTS | tail -1 || echo "")
        if [[ $FINAL_RESULTS =~ Tests\ run:\ ([0-9]+),\ Failures:\ ([0-9]+),\ Errors:\ ([0-9]+),\ Skipped:\ ([0-9]+) ]]; then
            TOTAL_TESTS="${BASH_REMATCH[1]}"
            TOTAL_FAILURES="${BASH_REMATCH[2]}"
            TOTAL_ERRORS="${BASH_REMATCH[3]}"
            TOTAL_SKIPPED="${BASH_REMATCH[4]}"
            TOTAL_FAILED=$((TOTAL_FAILURES + TOTAL_ERRORS))
            TOTAL_PASSED=$((TOTAL_TESTS - TOTAL_FAILED - TOTAL_SKIPPED))
        fi
    elif grep -q "BUILD FAILURE" $TEMP_RESULTS; then
        # Build failed, but we might still have partial results
        echo "Warning: Build failed, reporting partial results" >&2
    fi
fi

# Output the JSON result as the final line
echo "{\"passed\": $TOTAL_PASSED, \"failed\": $TOTAL_FAILED, \"skipped\": $TOTAL_SKIPPED, \"total\": $TOTAL_TESTS}"
