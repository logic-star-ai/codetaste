#!/bin/bash
# HBase test runner script
# This script runs the test suite and outputs results in JSON format

set -e

# Ensure Java 17 and Maven are in PATH (setup_shell.sh should have installed them)
if [ -d "/usr/lib/jvm/java-17-openjdk-amd64" ]; then
    export JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64
    export PATH=$JAVA_HOME/bin:$PATH
fi

if [ -d "/opt/maven" ]; then
    export MAVEN_HOME=/opt/maven
    export PATH=$MAVEN_HOME/bin:$PATH
fi

export MAVEN_OPTS="-Xmx3g -Xms1g"

cd /testbed

# Run SmallTests only (fast, representative subset that completes in ~15 minutes)
# Run tests in a single module to keep it under 15 minutes
# hbase-common is a good representative module with a reasonable number of tests
echo "Running HBase SmallTests in hbase-common module..."

# Use surefire to run tests and capture results
mvn surefire:test \
    -pl hbase-common \
    -Dtest.groups=org.apache.hadoop.hbase.testclassification.SmallTests \
    -Dsurefire.rerunFailingTestsCount=0 \
    -Dcheckstyle.skip=true \
    -Dspotbugs.skip=true \
    -Denforcer.skip=true \
    2>&1 | tee /tmp/test_output.log

# Parse test results from surefire-reports
REPORT_DIR="/testbed/hbase-common/target/surefire-reports"

if [ -d "$REPORT_DIR" ]; then
    # Count tests from XML reports
    TOTAL=0
    PASSED=0
    FAILED=0
    SKIPPED=0
    ERRORS=0

    # Parse all TEST-*.xml files
    for xml_file in "$REPORT_DIR"/TEST-*.xml; do
        if [ -f "$xml_file" ]; then
            # Extract test counts from testsuite element
            tests=$(grep -oP 'tests="\K[0-9]+' "$xml_file" | head -1 || echo "0")
            failures=$(grep -oP 'failures="\K[0-9]+' "$xml_file" | head -1 || echo "0")
            errors=$(grep -oP 'errors="\K[0-9]+' "$xml_file" | head -1 || echo "0")
            skipped=$(grep -oP 'skipped="\K[0-9]+' "$xml_file" | head -1 || echo "0")

            TOTAL=$((TOTAL + tests))
            FAILED=$((FAILED + failures))
            ERRORS=$((ERRORS + errors))
            SKIPPED=$((SKIPPED + skipped))
        fi
    done

    # Errors count as failures
    FAILED=$((FAILED + ERRORS))
    PASSED=$((TOTAL - FAILED - SKIPPED))

    # Ensure non-negative values
    if [ $PASSED -lt 0 ]; then
        PASSED=0
    fi

    # Output JSON result
    echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $SKIPPED, \"total\": $TOTAL}"
else
    # No test reports found - output zero results
    echo "{\"passed\": 0, \"failed\": 0, \"skipped\": 0, \"total\": 0}"
fi
