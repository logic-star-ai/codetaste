#!/bin/bash
# Test runner script for MMEX
# This script builds the project and reports the result
# The "test" is whether the project compiles successfully

set -e

# Ensure we're in the testbed directory
cd /testbed

# Prepare the database headers (required step before build)
echo "==> Preparing database headers..."
cd /testbed/src/db

# Generate database headers using Python scripts
python3 ../../util/sqlite2cpp.py ../../database/tables.sql
rm -f sql*.sql *.mmdbg 2>/dev/null || true
python3 ../../util/sqliteupgrade2cpp.py ../../database/incremental_upgrade

# Return to testbed root
cd /testbed

# Create build directory if it doesn't exist
if [ ! -d "build" ]; then
    mkdir build
fi

cd build

# Configure with CMake
echo "==> Configuring build with CMake..."
cmake .. \
    -DCMAKE_BUILD_TYPE=Release \
    > /tmp/cmake_output.txt 2>&1

CMAKE_EXIT_CODE=$?

if [ $CMAKE_EXIT_CODE -ne 0 ]; then
    echo "CMake configuration failed!"
    cat /tmp/cmake_output.txt
    echo '{"passed": 0, "failed": 1, "skipped": 0, "total": 1}'
    exit 1
fi

# Build the project
echo "==> Building MMEX..."
cmake --build . --config Release -j$(nproc) > /tmp/build_output.txt 2>&1

BUILD_EXIT_CODE=$?

if [ $BUILD_EXIT_CODE -eq 0 ]; then
    echo "==> Build successful!"
    # Count compiled source files as "tests"
    TOTAL_SOURCES=$(find /testbed/src -name "*.cpp" | wc -l)
    echo '{"passed": '"$TOTAL_SOURCES"', "failed": 0, "skipped": 0, "total": '"$TOTAL_SOURCES"'}'
    exit 0
else
    echo "==> Build failed!"
    # Show last 100 lines of build output for debugging
    tail -100 /tmp/build_output.txt

    # Try to count how many files compiled before failure
    COMPILED=$(grep -c "Building CXX object" /tmp/build_output.txt 2>/dev/null || echo "0")
    TOTAL_SOURCES=$(find /testbed/src -name "*.cpp" | wc -l)
    FAILED=$((TOTAL_SOURCES - COMPILED))

    echo '{"passed": '"$COMPILED"', "failed": '"$FAILED"', "skipped": 0, "total": '"$TOTAL_SOURCES"'}'
    exit 1
fi
