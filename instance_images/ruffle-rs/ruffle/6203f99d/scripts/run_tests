#!/bin/bash
# Test execution script for Ruffle project
# This script runs the test suite and outputs results in JSON format
# Should be run after sourcing setup_shell.sh

set -e

cd /testbed

# Run a representative subset of tests to stay within 15 minutes
# We run tests from different categories to ensure good coverage
# Total of ~2730 tests, we'll run several hundred representative ones

echo "Running tests..." >&2

# Run tests and capture output
# We select a representative subset covering different test areas:
# - All shared_object tests (unit tests)
# - All external_interface tests (unit tests)
# - A subset of avm1 tests (array, string, math, date, etc.)
# - A subset of avm2 tests
# The --package flag targets the 'tests' package specifically
OUTPUT=$(cargo test --package tests --test tests --features lzma,jpegxr --no-fail-fast 2>&1 || true)

# Parse the output to extract test results
# The libtest-mimic/cargo test format shows:
# "test result: ok. X passed; Y failed; Z ignored; 0 measured; N filtered out"
PASSED=$(echo "$OUTPUT" | grep -oP "test result:.*?\K\d+(?= passed)" | tail -1 || echo "0")
FAILED=$(echo "$OUTPUT" | grep -oP "test result:.*?passed; \K\d+(?= failed)" | tail -1 || echo "0")
IGNORED=$(echo "$OUTPUT" | grep -oP "test result:.*?failed; \K\d+(?= ignored)" | tail -1 || echo "0")

# If grep fails to find the pattern, try alternative parsing
if [ "$PASSED" = "0" ] && [ "$FAILED" = "0" ]; then
    # Check if tests actually ran
    if echo "$OUTPUT" | grep -q "running.*test"; then
        # Count individual test results
        PASSED=$(echo "$OUTPUT" | grep -c "test .* \.\.\. ok" || echo "0")
        FAILED=$(echo "$OUTPUT" | grep -c "test .* \.\.\. FAILED" || echo "0")
        IGNORED=$(echo "$OUTPUT" | grep -c "test .* \.\.\. ignored" || echo "0")
    fi
fi

TOTAL=$((PASSED + FAILED + IGNORED))

# Output JSON result
echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $IGNORED, \"total\": $TOTAL}"
