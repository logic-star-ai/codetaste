#!/usr/bin/env bash
set -euo pipefail

# This script runs the Dokku unit tests and outputs JSON results.
# It assumes the environment has been set up by setup_shell.sh

cd /testbed

# Create a temporary directory for test results
TEST_OUTPUT_DIR=$(mktemp -d)
trap "rm -rf $TEST_OUTPUT_DIR" EXIT

# Run BATS unit tests with TAP output
echo "Running Dokku unit tests..."
cd /testbed/tests/unit

# Run a representative subset of tests (to finish within 15 minutes)
# Select tests that work without Docker/SSH/deployment infrastructure
# These are unit tests that test basic dokku commands and configuration
TEST_FILES=(
    "10_version.bats"
    "40_trace.bats"
)

# Run bats on selected test files and capture output
set +e
bats --tap "${TEST_FILES[@]}" > "$TEST_OUTPUT_DIR/tap_output.txt" 2>&1
BATS_EXIT_CODE=$?
set -e

# Parse TAP output to count results
PASSED=0
FAILED=0
SKIPPED=0
TOTAL=0

set +e
while IFS= read -r line || [[ -n "$line" ]]; do
    if [[ "$line" =~ ^ok\ [0-9]+ ]]; then
        if [[ "$line" =~ \#\ skip ]]; then
            ((SKIPPED++))
        else
            ((PASSED++))
        fi
        ((TOTAL++))
    elif [[ "$line" =~ ^not\ ok\ [0-9]+ ]]; then
        ((FAILED++))
        ((TOTAL++))
    fi
done < "$TEST_OUTPUT_DIR/tap_output.txt"
set -e

# Output JSON result to stdout
echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $SKIPPED, \"total\": $TOTAL}"

# Exit with test result code
if [ "$FAILED" -gt 0 ]; then
    exit 1
else
    exit 0
fi
