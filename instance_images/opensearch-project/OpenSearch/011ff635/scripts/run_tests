#!/bin/bash
set -e

# Test execution script for OpenSearch
# This script runs a representative subset of tests and outputs results in JSON format
# It should be run after sourcing setup_shell.sh

# Change to testbed directory
cd /testbed

# Run tests on a subset of the server module
# This is a representative sample that covers core functionality
# We select specific test classes from key packages to complete in reasonable time

echo "Running OpenSearch test suite..." >&2

# Clean previous test results
rm -rf /testbed/server/build/test-results/test/*.xml 2>/dev/null || true

# Define specific test classes to run (representative sample from different areas)
TEST_CLASSES=(
    "org.opensearch.VersionTests"
    "org.opensearch.OpenSearchExceptionTests"
    "org.opensearch.ExceptionsHelperTests"
    "org.opensearch.action.admin.cluster.health.ClusterHealthRequestTests"
    "org.opensearch.action.admin.cluster.health.ClusterHealthResponseTests"
    "org.opensearch.action.admin.indices.create.CreateIndexRequestTests"
    "org.opensearch.cluster.ClusterNameTests"
    "org.opensearch.cluster.ClusterStateTests"
    "org.opensearch.cluster.metadata.IndexMetadataTests"
    "org.opensearch.cluster.metadata.MetadataTests"
    "org.opensearch.cluster.routing.RoutingTableTests"
    "org.opensearch.common.settings.SettingsTests"
    "org.opensearch.common.unit.ByteSizeValueTests"
    "org.opensearch.common.unit.TimeValueTests"
    "org.opensearch.common.xcontent.XContentFactoryTests"
    "org.opensearch.index.IndexSettingsTests"
    "org.opensearch.index.query.QueryStringQueryBuilderTests"
    "org.opensearch.index.query.MatchQueryBuilderTests"
    "org.opensearch.search.SearchModuleTests"
    "org.opensearch.search.builder.SearchSourceBuilderTests"
)

# Build the --tests arguments
TEST_ARGS=""
for test_class in "${TEST_CLASSES[@]}"; do
    TEST_ARGS="$TEST_ARGS --tests $test_class"
done

# Run server tests with the defined test classes
./gradlew :server:test \
    $TEST_ARGS \
    --no-daemon \
    -Dtests.seed=DEADBEEF \
    --max-workers=4 \
    --continue 2>&1 | tee /tmp/test_output.log >&2 || true

# Parse test results from XML files
parse_test_results() {
    local passed=0
    local failed=0
    local skipped=0
    local total=0

    # Find all TEST-*.xml files in test-results directories
    while IFS= read -r xmlfile; do
        if [ -f "$xmlfile" ]; then
            # Extract test counts from XML using grep and sed
            local tests=$(grep '<testsuite' "$xmlfile" | sed -n 's/.*tests="\([0-9]*\)".*/\1/p' | head -1)
            local failures=$(grep '<testsuite' "$xmlfile" | sed -n 's/.*failures="\([0-9]*\)".*/\1/p' | head -1)
            local errors=$(grep '<testsuite' "$xmlfile" | sed -n 's/.*errors="\([0-9]*\)".*/\1/p' | head -1)
            local skip=$(grep '<testsuite' "$xmlfile" | sed -n 's/.*skipped="\([0-9]*\)".*/\1/p' | head -1)

            # Add to totals
            if [ -n "$tests" ]; then
                total=$((total + tests))
                failed=$((failed + failures + errors))
                skipped=$((skipped + skip))
            fi
        fi
    done < <(find /testbed -path "*/test-results/test/TEST-*.xml" 2>/dev/null)

    # Calculate passed tests
    passed=$((total - failed - skipped))

    # Ensure we have valid numbers
    if [ $total -eq 0 ]; then
        echo "Warning: No test results found" >&2
        passed=0
        failed=0
        skipped=0
        total=0
    fi

    # Output JSON result
    echo "{\"passed\": $passed, \"failed\": $failed, \"skipped\": $skipped, \"total\": $total}"
}

# Parse and output results
parse_test_results
