#!/bin/bash
# Test execution script for PyVista
# This script runs the test suite and outputs results as JSON

set -e

cd /testbed

# Create a temporary file for pytest output
PYTEST_OUTPUT=$(mktemp)

# Run a representative subset of tests that completes within 15 minutes
# We exclude plotting tests as they can be flaky, and focus on core functionality
# We exclude tests that require downloads to speed up execution
# We run specific test files to avoid segfaults from running everything at once

python -m pytest \
    tests/test_helpers.py \
    tests/test_datasetattributes.py \
    tests/test_dataset.py \
    tests/test_filters.py \
    tests/test_grid.py \
    tests/test_composite.py \
    tests/test_colors.py \
    tests/test_utilities.py \
    tests/test_geometric_objects.py \
    tests/test_pointset.py \
    tests/test_polydata.py \
    tests/test_camera.py \
    tests/test_cells.py \
    tests/test_dataobject.py \
    tests/test_init.py \
    -v \
    --tb=short \
    -k "not download and not test_download" \
    2>&1 | tee "$PYTEST_OUTPUT" || true

# Parse the output to extract test results
# Look for the summary line like "123 passed, 4 failed, 5 skipped in 10.45s"
PASSED=0
FAILED=0
SKIPPED=0

# Try to extract from the summary line
if grep -q "passed" "$PYTEST_OUTPUT"; then
    PASSED=$(grep -E "=+ .*(passed|failed|skipped)" "$PYTEST_OUTPUT" | tail -1 | grep -oP "(\d+) passed" | grep -oP "\d+" || echo 0)
fi

if grep -q "failed" "$PYTEST_OUTPUT"; then
    FAILED=$(grep -E "=+ .*(passed|failed|skipped)" "$PYTEST_OUTPUT" | tail -1 | grep -oP "(\d+) failed" | grep -oP "\d+" || echo 0)
fi

if grep -q "skipped" "$PYTEST_OUTPUT"; then
    SKIPPED=$(grep -E "=+ .*(passed|failed|skipped)" "$PYTEST_OUTPUT" | tail -1 | grep -oP "(\d+) skipped" | grep -oP "\d+" || echo 0)
fi

# Also check for errors
if grep -q "error" "$PYTEST_OUTPUT"; then
    ERRORS=$(grep -E "=+ .*(passed|failed|skipped)" "$PYTEST_OUTPUT" | tail -1 | grep -oP "(\d+) error" | grep -oP "\d+" || echo 0)
    FAILED=$((FAILED + ERRORS))
fi

# Calculate total
TOTAL=$((PASSED + FAILED + SKIPPED))

# Clean up
rm -f "$PYTEST_OUTPUT"

# Output JSON result
echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $SKIPPED, \"total\": $TOTAL}"
