#!/bin/bash
# Run representative subset of tests for Datadog Agent
# This script runs tests and outputs results in JSON format
# Expects environment to be set up by setup_shell.sh

set -e

cd /testbed

# Create temporary directory for test results
TEMP_DIR=$(mktemp -d)
TEST_OUTPUT="$TEMP_DIR/test_output.txt"
JSON_OUTPUT="$TEMP_DIR/test_results.json"

# Function to parse Go test output and generate JSON
parse_test_results() {
    local output_file="$1"
    local json_file="$2"

    # Use Python to parse the test output
    python3 - "$output_file" "$json_file" << 'PYTHON_SCRIPT'
import json
import re
import sys

output_file = sys.argv[1]
json_file = sys.argv[2]

passed = 0
failed = 0
skipped = 0
total = 0

try:
    with open(output_file, 'r') as f:
        content = f.read()

    # Parse test results from Go test output
    # Look for patterns like:
    # --- PASS: TestName (0.00s)
    # --- FAIL: TestName (0.00s)
    # --- SKIP: TestName (0.00s)
    # ok  	package_name	0.123s
    # FAIL	package_name	0.123s

    # Count individual test results
    pass_matches = re.findall(r'^--- PASS:', content, re.MULTILINE)
    fail_matches = re.findall(r'^--- FAIL:', content, re.MULTILINE)
    skip_matches = re.findall(r'^--- SKIP:', content, re.MULTILINE)

    passed = len(pass_matches)
    failed = len(fail_matches)
    skipped = len(skip_matches)

    # Also look for package-level results as backup
    ok_packages = re.findall(r'^ok\s+github\.com/DataDog/datadog-agent/', content, re.MULTILINE)
    fail_packages = re.findall(r'^FAIL\s+github\.com/DataDog/datadog-agent/', content, re.MULTILINE)

    # If we didn't find individual test results, use package counts
    if passed == 0 and failed == 0 and skipped == 0:
        # Estimate: assume each package has at least 1 test
        passed = len(ok_packages)
        failed = len(fail_packages)

    total = passed + failed + skipped

    # If still no results, check for "no test files" or "build failed"
    if total == 0:
        if 'no test files' in content.lower():
            # No tests found
            total = 0
        elif 'build failed' in content.lower() or 'FAIL' in content:
            # Build or test failure
            failed = 1
            total = 1
        else:
            # Some tests ran but we couldn't parse them
            # Use package-level success as proxy
            if ok_packages:
                passed = len(ok_packages)
                total = passed

except Exception as e:
    print(f"Error parsing test results: {e}", file=sys.stderr)
    passed = 0
    failed = 1
    skipped = 0
    total = 1

result = {
    "passed": passed,
    "failed": failed,
    "skipped": skipped,
    "total": total
}

with open(json_file, 'w') as f:
    json.dump(result, f)

PYTHON_SCRIPT
}

# Run a representative subset of tests
# We'll test a few key packages that should complete within 15 minutes
# Focus on core functionality packages

echo "Running Datadog Agent tests..."

# Run tests with JSON output and capture results
# Use -json flag for structured output, but also keep text for parsing
# Target specific packages that are representative and reasonably fast

# Select packages that have tests and are representative
# Use go list to find packages with test files
# We'll run a curated list of stable packages to ensure tests complete successfully
PACKAGES=$(go list -f '{{if .TestGoFiles}}{{.ImportPath}}{{end}}' ./pkg/... 2>/dev/null | head -100 | tr '\n' ' ')

if [ -z "$PACKAGES" ]; then
    echo "No test packages found" >&2
    echo '{"passed": 0, "failed": 1, "skipped": 0, "total": 1}'
    exit 1
fi

# Run go test with verbose output for better parsing
# Use -short to skip long-running tests
# Capture both stdout and stderr
go test -timeout 10m -short -v $PACKAGES 2>&1 | tee "$TEST_OUTPUT" || true

# Parse the results and output JSON
parse_test_results "$TEST_OUTPUT" "$JSON_OUTPUT"

# Output the JSON result to stdout (last line)
cat "$JSON_OUTPUT"

# Cleanup
rm -rf "$TEMP_DIR"
