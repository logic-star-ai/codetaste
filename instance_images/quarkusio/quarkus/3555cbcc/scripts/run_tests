#!/bin/bash
# Test runner script for Quarkus project
# Runs a representative subset of tests and outputs JSON results

set -e

cd /testbed

# Run tests on core modules (representative subset that completes in reasonable time)
# Using -Dno-format to skip formatting checks, -DskipDocs to skip documentation
# Focus on core functionality modules

echo "Running Quarkus core tests..."

# Run tests and capture output
TEST_OUTPUT=$(mktemp)

# Run surefire tests on core modules
# -pl: project list (select specific modules)
# -Dno-test-modules: skip test-only modules in other parts
# We'll test a few core modules that are fast and representative
./mvnw test \
  -pl core/deployment,core/runtime,core/builder \
  -Dno-format \
  -DskipDocs \
  -Dquarkus.analytics.disabled=true \
  -Dmaven.javadoc.skip=true \
  2>&1 | tee "$TEST_OUTPUT"

# Parse test results from Maven output
# Look for the final "Tests run:" summary line that appears after "[INFO] Results:"

# Extract the final summary line (appears after "[INFO] Results:")
SUMMARY_LINE=$(grep -A 5 "\[INFO\] Results:" "$TEST_OUTPUT" | grep "\[ERROR\] Tests run:" || grep -A 5 "\[INFO\] Results:" "$TEST_OUTPUT" | grep "\[INFO\] Tests run:" || echo "Tests run: 0, Failures: 0, Errors: 0, Skipped: 0")

# Extract numbers from the summary line
TOTAL_TESTS=$(echo "$SUMMARY_LINE" | sed -n 's/.*Tests run: \([0-9]*\).*/\1/p')
TOTAL_FAILURES=$(echo "$SUMMARY_LINE" | sed -n 's/.*Failures: \([0-9]*\).*/\1/p')
TOTAL_ERRORS=$(echo "$SUMMARY_LINE" | sed -n 's/.*Errors: \([0-9]*\).*/\1/p')
TOTAL_SKIPPED=$(echo "$SUMMARY_LINE" | sed -n 's/.*Skipped: \([0-9]*\).*/\1/p')

# Default to 0 if parsing failed
[ -z "$TOTAL_TESTS" ] && TOTAL_TESTS=0
[ -z "$TOTAL_FAILURES" ] && TOTAL_FAILURES=0
[ -z "$TOTAL_ERRORS" ] && TOTAL_ERRORS=0
[ -z "$TOTAL_SKIPPED" ] && TOTAL_SKIPPED=0

# Calculate passed tests
TOTAL_FAILED=$((TOTAL_FAILURES + TOTAL_ERRORS))
TOTAL_PASSED=$((TOTAL_TESTS - TOTAL_FAILED - TOTAL_SKIPPED))

# Clean up temp file
rm -f "$TEST_OUTPUT"

# Output JSON result (must be the last line of stdout)
echo "{\"passed\": $TOTAL_PASSED, \"failed\": $TOTAL_FAILED, \"skipped\": $TOTAL_SKIPPED, \"total\": $TOTAL_TESTS}"
