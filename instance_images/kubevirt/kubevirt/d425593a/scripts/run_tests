#!/bin/bash
# Test execution script for KubeVirt
# This script runs a representative subset of unit tests and outputs results in JSON format

set -e

cd /testbed

# Test packages to run - representative subset covering different areas
TEST_PACKAGES=(
    # Core functionality tests
    "./pkg/instancetype"
    "./pkg/container-disk"
    "./pkg/emptydisk"
    "./pkg/executor"
    "./pkg/config"
    "./pkg/virt-config"
    "./pkg/watchdog"
    "./pkg/ignition"

    # Storage tests
    "./pkg/storage/types"
    "./pkg/storage/snapshot"
    "./pkg/storage/export/export"

    # Operator tests
    "./pkg/virt-operator/util"
    "./pkg/virt-operator/resource/generate/rbac"
    "./pkg/virt-operator/resource/generate/components"
    "./pkg/virt-operator/resource/apply"

    # Network tests
    "./pkg/network/cache"
    "./pkg/network/namescheme"
    "./pkg/network/link"
    "./pkg/network/vmispec"

    # Other important packages
    "./pkg/certificates"
    "./pkg/certificates/bootstrap"
    "./pkg/controller"
    "./pkg/ephemeral-disk"
    "./pkg/host-disk"
    "./pkg/hooks"
    "./pkg/hotplug-disk"

    # Client-go tests (from staging)
    "./staging/src/kubevirt.io/client-go/kubecli"
    "./staging/src/kubevirt.io/client-go/log"
)

# Additional packages with tests
TEST_PACKAGES+=(
    "./pkg/virt-launcher/virtwrap/api"
    "./pkg/virt-launcher/virtwrap/converter"
    "./pkg/virt-launcher/virtwrap/device"
    "./pkg/util"
    "./pkg/monitoring/metrics/virt-handler/domainstats"
)

# Counters
total=0
passed=0
failed=0
skipped=0

# Temporary file for test output
TEMP_OUTPUT=$(mktemp)
trap "rm -f ${TEMP_OUTPUT}" EXIT

# Run tests for each package
for pkg in "${TEST_PACKAGES[@]}"; do
    # Check if package exists and has tests
    if [ ! -d "$pkg" ]; then
        continue
    fi

    # Check if package has test files
    if ! ls ${pkg}/*_test.go >/dev/null 2>&1; then
        continue
    fi

    echo "Running tests in $pkg..." >&2

    # Run tests and capture output
    if go test -v "$pkg" -timeout 3m 2>&1 | tee -a "${TEMP_OUTPUT}"; then
        : # Success, continue
    else
        echo "Package $pkg had test failures" >&2
    fi
done

# Parse Ginkgo output to extract test counts
# Look for lines like: "SUCCESS! -- 131 Passed | 0 Failed | 0 Pending | 0 Skipped"
# or "FAIL! -- 5 Passed | 2 Failed | 0 Pending | 0 Skipped"
while IFS= read -r line; do
    if echo "$line" | grep -q "SUCCESS!\|FAIL!"; then
        # Extract numbers from summary line
        pass_count=$(echo "$line" | grep -oE "[0-9]+ Passed" | grep -oE "[0-9]+" | head -1)
        fail_count=$(echo "$line" | grep -oE "[0-9]+ Failed" | grep -oE "[0-9]+" | head -1)
        skip_count=$(echo "$line" | grep -oE "[0-9]+ Skipped" | grep -oE "[0-9]+" | head -1)

        if [ ! -z "$pass_count" ]; then
            passed=$((passed + pass_count))
        fi
        if [ ! -z "$fail_count" ]; then
            failed=$((failed + fail_count))
        fi
        if [ ! -z "$skip_count" ]; then
            skipped=$((skipped + skip_count))
        fi
    fi
done < "${TEMP_OUTPUT}"

total=$((passed + failed + skipped))

# Output final summary to stderr
echo "================== Test Summary ==================" >&2
echo "Total:   $total" >&2
echo "Passed:  $passed" >&2
echo "Failed:  $failed" >&2
echo "Skipped: $skipped" >&2
echo "==================================================" >&2

# Output JSON result to stdout (this is the required format)
echo "{\"passed\": ${passed}, \"failed\": ${failed}, \"skipped\": ${skipped}, \"total\": ${total}}"
