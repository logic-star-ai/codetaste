#!/bin/bash
# This script runs the test suite and outputs JSON results
# It must be run after sourcing setup_shell.sh

set -e

cd /testbed

# Create a temporary file for test results
TEST_OUTPUT_FILE=$(mktemp)

# Get list of packages to test (exclude internal/promqltests which has special go.mod)
PACKAGES=$(go list ./... | grep -v internal/promqltests)

echo "Running tests for $(echo "$PACKAGES" | wc -l) packages..." >&2

# Run tests with JSON output
# Use -count=1 to disable test caching for accurate results
# Redirect stderr to suppress warnings but keep test output
go test -json -count=1 $PACKAGES 2>/dev/null > "$TEST_OUTPUT_FILE" || true

# Parse the JSON output to count test results
python3 -c "
import json
import sys

passed = 0
failed = 0
skipped = 0
total_tests = set()

try:
    with open('$TEST_OUTPUT_FILE', 'r') as f:
        for line in f:
            try:
                data = json.loads(line.strip())
                action = data.get('Action', '')
                test_name = data.get('Test', '')

                # Only count top-level tests (not subtests) to avoid double counting
                # A top-level test doesn't have '/' in its name
                if test_name and '/' not in test_name:
                    test_id = data.get('Package', '') + '::' + test_name

                    if action == 'pass':
                        if test_id not in total_tests:
                            total_tests.add(test_id)
                            passed += 1
                    elif action == 'fail':
                        if test_id not in total_tests:
                            total_tests.add(test_id)
                            failed += 1
                    elif action == 'skip':
                        if test_id not in total_tests:
                            total_tests.add(test_id)
                            skipped += 1
            except json.JSONDecodeError:
                continue

    total = passed + failed + skipped
    print('{\"passed\": %d, \"failed\": %d, \"skipped\": %d, \"total\": %d}' % (passed, failed, skipped, total))
except Exception as e:
    # If parsing fails, output zeros
    print('{\"passed\": 0, \"failed\": 0, \"skipped\": 0, \"total\": 0}')
    sys.exit(0)
"

# Clean up temporary file
rm -f "$TEST_OUTPUT_FILE"
