#!/bin/bash
# Test execution script
# This script runs the test suite and outputs results in JSON format

set -e

cd /testbed

# Run Mocha tests with JSON reporter using make test command
# We need to extract the test command from the Makefile and modify it
# The Makefile's test target uses specific test paths that differ between versions

# Extract the TESTS variable from Makefile
TESTS_VAR=$(grep -A5 "^TESTS = " Makefile | sed 's/TESTS = //' | tr -d '\t' | tr '\\' ' ' | xargs)

# Run Mocha tests with JSON reporter
# Redirect stderr to suppress warnings, keep stdout
NODE_ENV=test node ./node_modules/.bin/_mocha \
    --require should \
    --require should-http \
    $TESTS_VAR \
    --bail \
    --reporter json 2>/tmp/test_stderr.log > /tmp/test_output.json || true

# Parse the JSON output and extract test statistics
if [ -f /tmp/test_output.json ]; then
    # Use node to parse the JSON and extract counts
    # Read the file and find the first '{' to skip any leading warnings
    node -e "
    try {
        const fs = require('fs');
        let content = fs.readFileSync('/tmp/test_output.json', 'utf8');
        // Find the first '{' character to skip any leading warnings
        const jsonStart = content.indexOf('{');
        if (jsonStart > 0) {
            content = content.substring(jsonStart);
        }
        const data = JSON.parse(content);
        const stats = data.stats || {};
        const passed = stats.passes || 0;
        const failed = stats.failures || 0;
        const skipped = stats.pending || 0;
        const total = stats.tests || 0;
        console.log(JSON.stringify({passed: passed, failed: failed, skipped: skipped, total: total}));
    } catch(e) {
        console.error('Error parsing test output:', e.message);
        console.log(JSON.stringify({passed: 0, failed: 0, skipped: 0, total: 0}));
    }
    "
else
    echo '{"passed": 0, "failed": 0, "skipped": 0, "total": 0}'
fi
