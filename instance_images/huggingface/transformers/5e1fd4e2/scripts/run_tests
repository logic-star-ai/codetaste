#!/bin/bash
# Test execution script for transformers
# This script runs a representative subset of tests and outputs results in JSON format

set -e

cd /testbed

# Use the Python from the virtual environment (set by setup_shell.sh)
export PYTHON_BIN="${PYTHON_BIN:-/testbed/.venv/bin/python}"

# Run a representative subset of tests that cover various aspects
# Focus on: utils, repo_utils, and some core functionality tests
# These tests are faster and don't require downloading large models

# Create a temporary file for pytest JSON output
TEMP_JSON=$(mktemp)

# Run pytest with JSON report
# Select a good representative subset:
# - tests/utils: Core utility tests (excluding those requiring special dependencies)
# - tests/repo_utils: Repository utility tests
# These tests represent the core framework functionality without requiring models

$PYTHON_BIN -m pytest \
    tests/utils/test_generic.py \
    tests/utils/test_configuration_utils.py \
    tests/utils/test_hub_utils.py \
    tests/utils/test_logging.py \
    tests/utils/test_deprecation.py \
    tests/utils/test_hf_argparser.py \
    tests/utils/test_feature_extraction_utils.py \
    tests/repo_utils/test_check_copies.py \
    tests/repo_utils/test_check_dummies.py \
    -v \
    --tb=short \
    --no-header \
    --disable-warnings \
    -q \
    2>&1 | tee /tmp/pytest_output.txt

# Parse the output to extract test results
# pytest outputs a summary line like: "10 passed, 2 failed, 1 skipped in 5.23s"
SUMMARY=$(tail -20 /tmp/pytest_output.txt | grep -E "passed|failed|skipped" | tail -1)

# Initialize counters
PASSED=0
FAILED=0
SKIPPED=0
TOTAL=0

# Parse the summary line
if echo "$SUMMARY" | grep -q "passed"; then
    PASSED=$(echo "$SUMMARY" | grep -oP '\d+(?= passed)' || echo "0")
fi

if echo "$SUMMARY" | grep -q "failed"; then
    FAILED=$(echo "$SUMMARY" | grep -oP '\d+(?= failed)' || echo "0")
fi

if echo "$SUMMARY" | grep -q "skipped"; then
    SKIPPED=$(echo "$SUMMARY" | grep -oP '\d+(?= skipped)' || echo "0")
fi

# Calculate total
TOTAL=$((PASSED + FAILED + SKIPPED))

# If parsing failed, try alternative parsing
if [ "$TOTAL" -eq 0 ]; then
    # Try to count from verbose output
    PASSED=$(grep -c "PASSED" /tmp/pytest_output.txt 2>/dev/null || echo "0")
    FAILED=$(grep -c "FAILED" /tmp/pytest_output.txt 2>/dev/null || echo "0")
    SKIPPED=$(grep -c "SKIPPED" /tmp/pytest_output.txt 2>/dev/null || echo "0")
    TOTAL=$((PASSED + FAILED + SKIPPED))
fi

# Output JSON result
echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $SKIPPED, \"total\": $TOTAL}"

# Clean up
rm -f /tmp/pytest_output.txt "$TEMP_JSON"

# Exit with appropriate code
if [ "$FAILED" -gt 0 ]; then
    exit 1
else
    exit 0
fi
