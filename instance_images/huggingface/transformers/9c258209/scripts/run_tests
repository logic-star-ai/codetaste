#!/bin/bash
# Test runner script for transformers
# This script runs a representative subset of tests and outputs JSON results

# Exit on error for commands, but handle test failures gracefully
set -e

cd /testbed

# Run a representative subset of tests
# We'll run tests from utils that don't require heavy dependencies
# These are fast, deterministic, and cover important functionality

echo "Running transformers test suite..."
echo "Test subset: core utils and configuration tests"
echo ""

# Create a temporary file for pytest output
PYTEST_OUTPUT=$(mktemp)

# Run pytest and capture output - don't exit on test failure
set +e
python -m pytest \
    tests/utils/test_generic.py \
    tests/utils/test_deprecation.py \
    tests/utils/test_configuration_utils.py \
    tests/utils/test_model_output.py \
    tests/utils/test_chat_template_utils.py \
    tests/utils/test_backbone_utils.py \
    tests/utils/test_doc_samples.py \
    tests/utils/test_hub_utils.py \
    tests/repo_utils/test_check_copies.py \
    tests/repo_utils/test_check_docstrings.py \
    tests/test_configuration_common.py \
    -v \
    --tb=short \
    --timeout=60 \
    --continue-on-collection-errors \
    2>&1 | tee "$PYTEST_OUTPUT"

PYTEST_EXIT=$?
set -e

# Parse the pytest output to extract test counts
# Look for the summary line like "17 passed in 2.31s" or "passed, X failed, Y skipped"
SUMMARY=$(grep -E "^=+.*(passed|failed|skipped).*in [0-9]+\.[0-9]+s.*=+$" "$PYTEST_OUTPUT" | tail -1)

# Initialize counters
PASSED=0
FAILED=0
SKIPPED=0
ERRORS=0

# Parse the summary line for different formats
if [ -n "$SUMMARY" ]; then
    # Extract passed count
    if echo "$SUMMARY" | grep -qE "[0-9]+ passed"; then
        PASSED=$(echo "$SUMMARY" | grep -oP '\d+(?= passed)' || echo "0")
    fi

    # Extract failed count
    if echo "$SUMMARY" | grep -qE "[0-9]+ failed"; then
        FAILED=$(echo "$SUMMARY" | grep -oP '\d+(?= failed)' || echo "0")
    fi

    # Extract skipped count
    if echo "$SUMMARY" | grep -qE "[0-9]+ skipped"; then
        SKIPPED=$(echo "$SUMMARY" | grep -oP '\d+(?= skipped)' || echo "0")
    fi

    # Extract error count
    if echo "$SUMMARY" | grep -qE "[0-9]+ error"; then
        ERRORS=$(echo "$SUMMARY" | grep -oP '\d+(?= error)' || echo "0")
    fi
fi

# Count errors as failures
FAILED=$((FAILED + ERRORS))

# Calculate total
TOTAL=$((PASSED + FAILED + SKIPPED))

# If we couldn't parse anything, try counting from verbose output
if [ "$TOTAL" -eq 0 ]; then
    PASSED=$(grep -c " PASSED" "$PYTEST_OUTPUT" || echo "0")
    FAILED=$(grep -c " FAILED" "$PYTEST_OUTPUT" || echo "0")
    SKIPPED=$(grep -c " SKIPPED" "$PYTEST_OUTPUT" || echo "0")
    TOTAL=$((PASSED + FAILED + SKIPPED))
fi

# Output JSON result to stdout
echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $SKIPPED, \"total\": $TOTAL}"

# Clean up
rm -f "$PYTEST_OUTPUT"

# Exit with the pytest exit code
exit $PYTEST_EXIT
