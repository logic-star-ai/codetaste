#!/bin/bash
# Run the representative test suite and output results as JSON

# This script should be run after setup_shell.sh has been sourced

set -e

cd /testbed

# Temporary file for capturing test output
TEMP_OUTPUT=$(mktemp)

# Run the core test suite that covers a representative subset of the project
# We'll run: test:core, test:package, test:entrypoint, test:frontend
# These represent the main functionality without integration tests which can be flaky

run_tests() {
    local exit_code=0

    # Run tests and capture output, allow failures
    set +e

    # Run core tests
    npm run test:core > "$TEMP_OUTPUT" 2>&1
    local core_exit=$?

    # Run package tests
    npm run test:package >> "$TEMP_OUTPUT" 2>&1
    local package_exit=$?

    # Run entrypoint tests
    npm run test:entrypoint >> "$TEMP_OUTPUT" 2>&1
    local entrypoint_exit=$?

    # Run frontend tests
    npm run test:frontend >> "$TEMP_OUTPUT" 2>&1
    local frontend_exit=$?

    set -e

    # Parse mocha output for test counts
    # Mocha outputs lines like: "  1234 passing (5s)"
    # We need to extract the test counts

    local passed=0
    local failed=0
    local skipped=0

    # Sum up passing tests across all test runs
    passed=$(grep -oP '^\s+\K\d+(?=\s+passing)' "$TEMP_OUTPUT" | awk '{s+=$1} END {print s+0}')

    # Sum up failing tests
    failed=$(grep -oP '^\s+\K\d+(?=\s+failing)' "$TEMP_OUTPUT" | awk '{s+=$1} END {print s+0}')

    # Sum up pending tests (skipped)
    skipped=$(grep -oP '^\s+\K\d+(?=\s+pending)' "$TEMP_OUTPUT" | awk '{s+=$1} END {print s+0}')

    # Calculate total
    local total=$((passed + failed + skipped))

    # Output JSON result
    echo "{\"passed\": $passed, \"failed\": $failed, \"skipped\": $skipped, \"total\": $total}"

    # Clean up
    rm -f "$TEMP_OUTPUT"

    # Return appropriate exit code
    if [ $failed -gt 0 ] || [ $core_exit -ne 0 ] || [ $package_exit -ne 0 ] || [ $entrypoint_exit -ne 0 ] || [ $frontend_exit -ne 0 ]; then
        return 1
    fi
    return 0
}

run_tests
