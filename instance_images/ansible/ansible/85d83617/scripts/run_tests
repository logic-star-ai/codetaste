#!/bin/bash
# Test runner script for Ansible test environment
# This script runs a representative subset of unit tests

set -e

cd /testbed

# Ensure virtual environment is activated
if [ -z "$VIRTUAL_ENV" ]; then
    echo "Error: Virtual environment not activated. Run 'source /scripts/setup_shell.sh' first."
    exit 1
fi

# Create test results directory if it doesn't exist
mkdir -p test/results/junit

# List of problematic test files to exclude (collection errors or require Python 3.9+)
EXCLUDE_ARGS=(
    "--ignore=test/units/module_utils/test_vmware.py"
    "--ignore=test/units/modules/cloud/vmware/test_vmware_guest.py"
    "--ignore=test/units/plugins/filter/test_mathstuff.py"
    "--ignore=test/units/utils/test_encrypt.py"
)

# Run pytest on unit tests with JSON output
# Using -q for quiet output, --tb=no to suppress tracebacks
# Using --junit-xml to generate a JUnit XML report for parsing
python -m pytest test/units/ \
    "${EXCLUDE_ARGS[@]}" \
    --junit-xml=test/results/junit/results.xml \
    -q \
    --tb=no \
    --maxfail=1000 \
    2>&1 | tee /tmp/test_output.txt

# Parse the JUnit XML file to extract test counts
if [ -f test/results/junit/results.xml ]; then
    # Use Python to parse the XML and extract counts
    python3 << 'EOF'
import xml.etree.ElementTree as ET
import sys

try:
    tree = ET.parse('test/results/junit/results.xml')
    root = tree.getroot()

    # Get test statistics from testsuite element
    testsuite = root.find('.//testsuite')
    if testsuite is not None:
        tests = int(testsuite.get('tests', 0))
        errors = int(testsuite.get('errors', 0))
        failures = int(testsuite.get('failures', 0))
        skipped = int(testsuite.get('skipped', 0))

        passed = tests - errors - failures - skipped
        failed = errors + failures

        print(f'{{"passed": {passed}, "failed": {failed}, "skipped": {skipped}, "total": {tests}}}')
    else:
        # Fallback: count testcase elements
        testcases = root.findall('.//testcase')
        total = len(testcases)
        errors = len(root.findall('.//error'))
        failures = len(root.findall('.//failure'))
        skipped = len(root.findall('.//skipped'))

        passed = total - errors - failures - skipped
        failed = errors + failures

        print(f'{{"passed": {passed}, "failed": {failed}, "skipped": {skipped}, "total": {total}}}')

except Exception as e:
    print(f'{{"passed": 0, "failed": 0, "skipped": 0, "total": 0}}')
    sys.exit(1)
EOF
else
    # If JUnit XML is not available, try to parse from pytest output
    python3 << 'EOF'
import re
import sys

try:
    with open('/tmp/test_output.txt', 'r') as f:
        output = f.read()

    # Look for the pytest summary line like "484 failed, 5915 passed, 107 skipped"
    # Pattern: (N failed, )?(N passed)(, N skipped)?(, N warnings)?(, N errors)?
    match = re.search(r'(\d+)\s+failed,\s+(\d+)\s+passed(?:,\s+(\d+)\s+skipped)?', output)
    if match:
        failed = int(match.group(1))
        passed = int(match.group(2))
        skipped = int(match.group(3)) if match.group(3) else 0
        total = passed + failed + skipped
        print(f'{{"passed": {passed}, "failed": {failed}, "skipped": {skipped}, "total": {total}}}')
    else:
        # Try alternative pattern for when tests pass
        match = re.search(r'(\d+)\s+passed(?:,\s+(\d+)\s+skipped)?', output)
        if match:
            passed = int(match.group(1))
            skipped = int(match.group(2)) if match.group(2) else 0
            total = passed + skipped
            print(f'{{"passed": {passed}, "failed": 0, "skipped": {skipped}, "total": {total}}}')
        else:
            print(f'{{"passed": 0, "failed": 0, "skipped": 0, "total": 0}}')
except Exception as e:
    print(f'{{"passed": 0, "failed": 0, "skipped": 0, "total": 0}}')
    sys.exit(1)
EOF
fi
