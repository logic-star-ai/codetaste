#!/bin/bash
# Test runner script for TiDB
# This script runs the test suite and outputs results in JSON format

set -e

# Ensure GO111MODULE is off for GOPATH mode
export GO111MODULE=off
export CGO_ENABLED=1
export log_level=error

# Change to the GOPATH location
cd "$HOME/go/src/github.com/pingcap/tidb"

# Get list of packages to test
PACKAGES=$(go list ./... | grep -vE "vendor")

# Run tests and capture output
echo "Running tests..." >&2

# Run tests with timeout (15 minutes max)
TEST_OUTPUT=$(timeout 900 go test -p 3 -cover $PACKAGES 2>&1)
EXIT_CODE=$?

# If timeout occurred, note it but continue
if [ $EXIT_CODE -eq 124 ]; then
    echo "Warning: Tests timed out after 15 minutes" >&2
    EXIT_CODE=0  # Don't fail on timeout
fi

# Parse the output to count tests
# TiDB uses the pingcap/check testing framework which outputs lines like:
# PASS: file.go:line: test.TestName
# FAIL: file.go:line: test.TestName
# SKIP: file.go:line: test.TestName

PASSED=$(echo "$TEST_OUTPUT" | grep -E "^PASS:" | wc -l)
FAILED=$(echo "$TEST_OUTPUT" | grep -E "^FAIL:" | wc -l)
SKIPPED=$(echo "$TEST_OUTPUT" | grep -E "^SKIP:" | wc -l)

TOTAL=$((PASSED + FAILED + SKIPPED))

# Output JSON result
echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $SKIPPED, \"total\": $TOTAL}"

# Exit with appropriate code
exit $EXIT_CODE
