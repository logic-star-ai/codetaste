#!/bin/bash
# Test execution script
# This script runs a representative subset of tests and outputs JSON results.

set -o pipefail

# Change to repository root
REPO_ROOT="${REPO_ROOT:-/testbed}"
cd "${REPO_ROOT}"

# Temporary file for test output
TEST_OUTPUT=$(mktemp)
trap "rm -f ${TEST_OUTPUT}" EXIT

# Function to run tests and capture output
run_go_tests() {
    # Run a representative subset of unit tests
    # Focus on core packages that are fast to test

    # Collect test packages
    TEST_PACKAGES=(
        "./pkg/config/..."
        "./pkg/bootstrap/..."
        "./pkg/kube/..."
        "./pkg/util/..."
        "./galley/pkg/config/..."
        "./istioctl/pkg/..."
    )

    echo "Running Go unit tests..." >&2

    # Run tests with JSON output, but don't fail on test failures
    # Save to file only, don't output to console
    go test -json "${TEST_PACKAGES[@]}" > "${TEST_OUTPUT}" 2>&1 || true
}

# Function to parse test results from go test -json output
parse_test_results() {
    local output_file="$1"

    # Parse JSON output to count test results
    # Go test -json outputs one JSON object per line
    # We only count test-level results (not package-level)

    local passed=0
    local failed=0
    local skipped=0

    while IFS= read -r line; do
        # Only count if it has a Test field (not package-level results)
        if echo "$line" | grep -q '"Test":"' && echo "$line" | grep -q '"Action":"'; then
            if echo "$line" | grep -q '"Action":"pass"'; then
                ((passed++))
            elif echo "$line" | grep -q '"Action":"fail"'; then
                ((failed++))
            elif echo "$line" | grep -q '"Action":"skip"'; then
                ((skipped++))
            fi
        fi
    done < "$output_file"

    local total=$((passed + failed + skipped))

    # Output JSON result
    echo "{\"passed\": ${passed}, \"failed\": ${failed}, \"skipped\": ${skipped}, \"total\": ${total}}"
}

# Run tests
run_go_tests

# Parse and output results
parse_test_results "${TEST_OUTPUT}"
