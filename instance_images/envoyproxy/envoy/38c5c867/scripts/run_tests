#!/bin/bash
# Test execution script for Envoy
# This script runs a representative subset of Envoy tests and outputs results in JSON format
# Must be run after sourcing setup_shell.sh

set -e

cd /testbed

# Run a representative subset of tests from //test/common/...
# These are core unit tests that cover fundamental functionality
# We limit to a subset for time constraints (~15 minutes)

# Define test targets - using a focused subset of common tests
TEST_TARGETS=(
    "//test/common/buffer/..."
    "//test/common/common/..."
    "//test/common/http/..."
    "//test/common/network/..."
    "//test/common/stats/..."
)

# Create a temporary file for test output
TEMP_OUTPUT=$(mktemp)
TEMP_XML=$(mktemp)

# Run bazel test with config from environment
bazel test \
    "${BAZEL_BUILD_OPTIONS[@]}" \
    -c fastbuild \
    --test_summary=detailed \
    --build_tests_only \
    "${TEST_TARGETS[@]}" 2>&1 | tee "$TEMP_OUTPUT"

# Parse the output to extract test results
# Bazel outputs a summary at the end with format like:
# Executed X out of Y tests: Z tests pass and A fail locally.

# Extract test counts from bazel output
EXECUTED=$(grep -oP "Executed \K[0-9]+" "$TEMP_OUTPUT" | head -1 || echo "0")
TOTAL=$(grep -oP "Executed [0-9]+ out of \K[0-9]+" "$TEMP_OUTPUT" | head -1 || echo "0")
PASSED=$(grep -oP "\K[0-9]+(?= test[s]? pass)" "$TEMP_OUTPUT" | head -1 || echo "0")

# Try to extract failures
FAILED_LINE=$(grep -oP "[0-9]+ fail" "$TEMP_OUTPUT" | head -1 || echo "0 fail")
FAILED=$(echo "$FAILED_LINE" | grep -oP "^[0-9]+" || echo "0")

# Calculate skipped (if total > executed)
if [ "$TOTAL" -gt "$EXECUTED" ]; then
    SKIPPED=$((TOTAL - EXECUTED))
else
    SKIPPED=0
fi

# If we couldn't parse passed, calculate it
if [ "$PASSED" -eq "0" ] && [ "$EXECUTED" -gt "0" ]; then
    PASSED=$((EXECUTED - FAILED))
fi

# If total is 0, use executed as total
if [ "$TOTAL" -eq "0" ]; then
    TOTAL=$EXECUTED
fi

# Ensure we have valid numbers
PASSED=${PASSED:-0}
FAILED=${FAILED:-0}
SKIPPED=${SKIPPED:-0}
TOTAL=${TOTAL:-0}

# Output JSON result
echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $SKIPPED, \"total\": $TOTAL}"

# Clean up
rm -f "$TEMP_OUTPUT" "$TEMP_XML"

# Exit with appropriate code
if [ "$FAILED" -gt "0" ]; then
    exit 1
fi

exit 0
