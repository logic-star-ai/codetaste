#!/bin/bash
# Test runner script
# This script runs the test suite and outputs JSON results
# It assumes setup_shell.sh has already been sourced

set -e

cd /testbed

# Activate virtual environment if it exists
if [ -d ".venv" ]; then
    source .venv/bin/activate
fi

# Create a temporary file for pytest output
TEMP_OUTPUT=$(mktemp)

# Run pytest with JSON reporting
# We run unit tests from key directories that represent core functionality
# Using -m "unit" to only run unit tests
# --tb=short for shorter tracebacks
# -v for verbose output
# --document_store_type=memory to use only in-memory document store (no external services)
# Excluding problematic test files that have import issues

pytest \
    -m "unit" \
    --document_store_type=memory \
    -v \
    --tb=short \
    test/agents \
    test/cli \
    test/utils \
    test/pipelines \
    test/others \
    --ignore=test/pipelines/test_pipeline_yaml.py \
    --ignore=test/others/test_squad_data.py \
    2>&1 | tee "$TEMP_OUTPUT"

# Capture pytest exit code
PYTEST_EXIT=$?

# Parse the pytest output to extract test counts
# Look for the summary line like "100 passed, 2 failed, 5 skipped in 10.00s"
SUMMARY_LINE=$(grep -E "^=.*passed.*=|^=.*failed.*=|^=.*error.*=" "$TEMP_OUTPUT" | tail -1 || echo "")

# Initialize counters
PASSED=0
FAILED=0
SKIPPED=0
ERRORS=0

# Parse the summary line
if [[ -n "$SUMMARY_LINE" ]]; then
    # Extract passed count
    if [[ "$SUMMARY_LINE" =~ ([0-9]+)\ passed ]]; then
        PASSED=${BASH_REMATCH[1]}
    fi

    # Extract failed count
    if [[ "$SUMMARY_LINE" =~ ([0-9]+)\ failed ]]; then
        FAILED=${BASH_REMATCH[1]}
    fi

    # Extract skipped count
    if [[ "$SUMMARY_LINE" =~ ([0-9]+)\ skipped ]]; then
        SKIPPED=${BASH_REMATCH[1]}
    fi

    # Extract error count
    if [[ "$SUMMARY_LINE" =~ ([0-9]+)\ error ]]; then
        ERRORS=${BASH_REMATCH[1]}
    fi
fi

# If no tests were found or parsing failed, try alternative parsing
if [[ $PASSED -eq 0 && $FAILED -eq 0 && $SKIPPED -eq 0 ]]; then
    # Check for "no tests ran" message
    if grep -q "no tests ran" "$TEMP_OUTPUT"; then
        PASSED=0
        FAILED=0
        SKIPPED=0
    fi
fi

# Add errors to failed count
FAILED=$((FAILED + ERRORS))

# Calculate total
TOTAL=$((PASSED + FAILED + SKIPPED))

# Clean up
rm -f "$TEMP_OUTPUT"

# Output JSON result (this MUST be the last line of stdout)
echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $SKIPPED, \"total\": $TOTAL}"

# Exit with pytest's exit code
exit $PYTEST_EXIT
