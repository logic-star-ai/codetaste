#!/bin/bash
# This script runs the Saleor test suite and outputs results in JSON format
# It should be run after setup_shell.sh has been sourced

set -e

cd /testbed

# Activate virtual environment if not already active
if [ -z "$VIRTUAL_ENV" ]; then
    source .venv/bin/activate
fi

# Create a temporary file for pytest JSON output
PYTEST_JSON_OUTPUT=$(mktemp)

# Run pytest with JSON output
# We run a subset of tests to complete within 15 minutes
# Excluding e2e tests and slow tests, running unit and integration tests
# Using -n auto for parallel execution with xdist
python -m pytest \
    saleor/discount/tests/ \
    saleor/account/tests/ \
    saleor/app/tests/ \
    saleor/shipping/tests/ \
    saleor/warehouse/tests/ \
    --ignore=saleor/tests/e2e/ \
    -v \
    --tb=short \
    2>&1 | tee /tmp/pytest_output.txt

# Parse the output to extract test results
# The last line typically contains the summary like: "123 passed, 45 failed, 67 skipped in X.XXs"
SUMMARY=$(grep -E "^=.*passed|failed|skipped" /tmp/pytest_output.txt | tail -1 || echo "")

# Extract numbers from the summary
PASSED=0
FAILED=0
SKIPPED=0
TOTAL=0

if [ -n "$SUMMARY" ]; then
    # Extract passed
    if echo "$SUMMARY" | grep -q "passed"; then
        PASSED=$(echo "$SUMMARY" | grep -oP '\d+(?= passed)' || echo "0")
    fi

    # Extract failed
    if echo "$SUMMARY" | grep -q "failed"; then
        FAILED=$(echo "$SUMMARY" | grep -oP '\d+(?= failed)' || echo "0")
    fi

    # Extract skipped
    if echo "$SUMMARY" | grep -q "skipped"; then
        SKIPPED=$(echo "$SUMMARY" | grep -oP '\d+(?= skipped)' || echo "0")
    fi

    # Calculate total
    TOTAL=$((PASSED + FAILED + SKIPPED))
fi

# Output JSON result
echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $SKIPPED, \"total\": $TOTAL}"

# Clean up
rm -f "$PYTEST_JSON_OUTPUT" /tmp/pytest_output.txt

# Exit with appropriate code
if [ "$FAILED" -gt 0 ]; then
    exit 1
else
    exit 0
fi
