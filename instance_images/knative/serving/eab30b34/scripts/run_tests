#!/bin/bash
# Test execution script
# This script runs the test suite and outputs results in JSON format

set -e

# Change to the project directory via GOPATH
cd "${GOPATH}/src/github.com/knative/serving"

# Ensure artifacts directory exists
mkdir -p "${ARTIFACTS}"

# Create a temporary file for test output
TEST_OUTPUT=$(mktemp)
TEST_RESULTS=$(mktemp)

# Function to run tests and capture output
run_tests() {
    # Run all unit tests (excluding e2e tests which require a running k8s cluster)
    # The -short flag is used to skip long-running tests
    # We exclude the test/e2e and test/conformance directories as they need k8s

    # Find all packages except those requiring k8s cluster
    PACKAGES=$(go list ./... | grep -v -e '/test/e2e' -e '/test/conformance' -e '/test/performance' -e '/test/upgrade')

    # Run tests with race detector disabled for faster execution
    # and capture both stdout and stderr
    set +e
    go test -v -short ${PACKAGES} 2>&1 | tee "${TEST_OUTPUT}"
    TEST_EXIT_CODE=${PIPESTATUS[0]}
    set -e

    return ${TEST_EXIT_CODE}
}

# Parse test output and generate JSON
parse_test_results() {
    local output_file="$1"
    local passed=0
    local failed=0
    local skipped=0
    local total=0

    # Parse the go test output
    # Lines like "--- PASS: TestName" indicate passed tests
    # Lines like "--- FAIL: TestName" indicate failed tests
    # Lines like "--- SKIP: TestName" indicate skipped tests

    # Use grep to count lines, handling the case where no matches are found
    passed=$(grep "^--- PASS:" "${output_file}" 2>/dev/null | wc -l || echo 0)
    failed=$(grep "^--- FAIL:" "${output_file}" 2>/dev/null | wc -l || echo 0)
    skipped=$(grep "^--- SKIP:" "${output_file}" 2>/dev/null | wc -l || echo 0)

    # Ensure all values are numeric (default to 0 if empty)
    passed=${passed:-0}
    failed=${failed:-0}
    skipped=${skipped:-0}

    total=$((passed + failed + skipped))

    # Output JSON format
    echo "{\"passed\": ${passed}, \"failed\": ${failed}, \"skipped\": ${skipped}, \"total\": ${total}}"
}

# Run the tests
echo "Running unit tests..." >&2
if run_tests; then
    echo "Tests completed successfully" >&2
    TEST_RESULT=0
else
    echo "Some tests failed" >&2
    TEST_RESULT=1
fi

# Parse and output results
parse_test_results "${TEST_OUTPUT}"

# Clean up
rm -f "${TEST_OUTPUT}" "${TEST_RESULTS}"

exit ${TEST_RESULT}
