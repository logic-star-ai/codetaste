#!/bin/bash
# Test execution script for TensorFlow
# This script runs a representative subset of TensorFlow tests
# Usage: /scripts/run_tests

set -e

cd /testbed

# Note: This TensorFlow snapshot has compilation compatibility issues with
# the available compilers (GCC 11/14) and Python versions (3.11/3.12).
# Multiple dependencies (LLVM, protobuf, absl) have missing #include statements
# required by newer C++ standards.
#
# The tests below attempt to run a small subset of Bazel test targets.
# If builds fail, we report the build failures as part of the test results.

# Define test targets - focusing on data utility tests
TEST_TARGETS=(
    "//tensorflow/python/data/util:options_test"
    "//tensorflow/python/data/util:random_seed_test"
)

# Initialize counters
TOTAL_TESTS=0
PASSED_TESTS=0
FAILED_TESTS=0
SKIPPED_TESTS=0

# Create a temporary file to store test output
TEMP_OUTPUT=$(mktemp)

# Try to run each test target
for target in "${TEST_TARGETS[@]}"; do
    echo "Attempting to build and run test: $target" >&2

    # Run test with a reasonable timeout
    if timeout 600 bazel test \
        --test_output=errors \
        --test_timeout=300 \
        --keep_going \
        --build_tests_only \
        --test_summary=detailed \
        --verbose_failures \
        "$target" > "$TEMP_OUTPUT" 2>&1; then

        # Test passed
        echo "  Test PASSED: $target" >&2
        ((PASSED_TESTS++)) || true
    else
        # Test failed or had build errors
        EXIT_CODE=$?
        if grep -q "FAILED TO BUILD" "$TEMP_OUTPUT" 2>/dev/null; then
            echo "  Test FAILED TO BUILD: $target" >&2
        elif grep -q "FAILED" "$TEMP_OUTPUT" 2>/dev/null; then
            echo "  Test FAILED: $target" >&2
        elif [ $EXIT_CODE -eq 124 ]; then
            echo "  Test TIMEOUT: $target" >&2
        else
            echo "  Test ERROR: $target (exit code: $EXIT_CODE)" >&2
        fi
        ((FAILED_TESTS++)) || true
    fi
    ((TOTAL_TESTS++)) || true
done

# Clean up temp file
rm -f "$TEMP_OUTPUT"

# Ensure we have at least attempted some tests
if [ $TOTAL_TESTS -eq 0 ]; then
    TOTAL_TESTS=${#TEST_TARGETS[@]}
    FAILED_TESTS=$TOTAL_TESTS
fi

# Output results in JSON format (final line to stdout)
echo "{\"passed\": $PASSED_TESTS, \"failed\": $FAILED_TESTS, \"skipped\": $SKIPPED_TESTS, \"total\": $TOTAL_TESTS}"
