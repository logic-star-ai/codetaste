#!/bin/bash
# Test execution script for TensorFlow.js models repository
# This script runs the test suite and outputs results in JSON format

set -e

cd /testbed

# Initialize counters
total_passed=0
total_failed=0
total_skipped=0
total_tests=0

# Array of models to test (representative subset that should complete in ~15 minutes)
# Some models have longer build/test times or dependencies that may fail
MODEL_DIRS=(
    "mobilenet"
    "posenet"
    "coco-ssd"
    "knn-classifier"
)

# Function to parse jasmine output
parse_jasmine_output() {
    local output="$1"
    local specs=0
    local failures=0

    # Extract "X specs, Y failures" from jasmine output
    if echo "$output" | grep -q "specs.*failures"; then
        specs=$(echo "$output" | grep -oP '\d+(?= specs)' | tail -1)
        failures=$(echo "$output" | grep -oP '\d+(?= failures)' | tail -1)
    fi

    echo "$specs $failures"
}

# Run tests for each model
for dir in "${MODEL_DIRS[@]}"; do
    if [ -d "/testbed/$dir" ] && [ -f "/testbed/$dir/package.json" ]; then
        # Check if the package has a test script
        if grep -q '"test"' "/testbed/$dir/package.json"; then
            echo "======================================"
            echo "Testing $dir..."
            echo "======================================"

            cd "/testbed/$dir"

            # Run tests and capture output
            set +e
            test_output=$(yarn test 2>&1)
            test_exit_code=$?
            set -e

            # Parse jasmine output
            read specs failures <<< $(parse_jasmine_output "$test_output")

            if [ -n "$specs" ] && [ "$specs" -gt 0 ]; then
                passed=$((specs - failures))
                total_tests=$((total_tests + specs))
                total_passed=$((total_passed + passed))
                total_failed=$((total_failed + failures))

                echo "  -> $specs specs, $failures failures ($passed passed)"
            else
                # Check if test failed completely (e.g., compilation error)
                if [ $test_exit_code -ne 0 ]; then
                    echo "  -> Test execution failed for $dir (exit code: $test_exit_code)"
                    echo "$test_output" | tail -20
                else
                    echo "  -> Could not parse test results for $dir"
                fi
            fi

            cd /testbed
        fi
    fi
done

# Output JSON summary
echo ""
echo "======================================"
echo "Test Summary"
echo "======================================"
echo "{\"passed\": $total_passed, \"failed\": $total_failed, \"skipped\": $total_skipped, \"total\": $total_tests}"
