#!/bin/bash
# Run Ghidra tests and output results in JSON format
# This script assumes the environment has already been set up via setup_shell.sh

set -e

cd /testbed

# Run unit tests with a timeout
# We run a subset of fast unit tests to complete within 15 minutes
# The unitTestReport task runs all unit tests across all subprojects
echo "Running Ghidra unit tests..."
echo "This may take several minutes..."

# Create a temporary directory for test results
TEST_RESULTS_DIR="/tmp/ghidra_test_results"
mkdir -p "$TEST_RESULTS_DIR"

# Run tests with gradle
# We run unit tests from core Framework subprojects to avoid external dependency issues
# These are the foundational modules that have fewer external dependencies
# We use || true to continue even if some tests fail (we want to count failures)
# The --max-workers flag limits parallelism to avoid resource exhaustion
echo "Running tests on core Framework modules..."
timeout 900 gradle \
    :Framework:Generic:test \
    :Framework:Docking:test \
    :Framework:DB:test \
    :Framework:Graph:test \
    :Framework:Help:test \
    :Framework:FileSystem:test \
    -x integrationTest --continue --max-workers=4 2>&1 | tee "$TEST_RESULTS_DIR/test_output.log" || {
    EXIT_CODE=$?
    if [ $EXIT_CODE -eq 124 ]; then
        echo "Warning: Test execution timed out after 15 minutes"
    fi
    # Continue to parse whatever results we have
    true
}

# Parse test results from gradle's test output
# Gradle generates XML test results in build/test-results/test/
echo ""
echo "Parsing test results..."

# Find all TEST-*.xml files generated by gradle
PASSED=0
FAILED=0
SKIPPED=0
TOTAL=0

# Look for XML test results across all subprojects
for xml_file in $(find /testbed -path "*/build/test-results/test/TEST-*.xml" 2>/dev/null); do
    if [ -f "$xml_file" ]; then
        # Extract test counts from XML using grep and sed
        # XML format: <testsuite name="..." tests="X" skipped="Y" failures="Z" errors="W" ...>
        TESTS=$(grep -o 'tests="[0-9]*"' "$xml_file" | head -1 | grep -o '[0-9]*' || echo "0")
        FAILS=$(grep -o 'failures="[0-9]*"' "$xml_file" | head -1 | grep -o '[0-9]*' || echo "0")
        ERRS=$(grep -o 'errors="[0-9]*"' "$xml_file" | head -1 | grep -o '[0-9]*' || echo "0")
        SKIPS=$(grep -o 'skipped="[0-9]*"' "$xml_file" | head -1 | grep -o '[0-9]*' || echo "0")

        TOTAL=$((TOTAL + TESTS))
        FAILED=$((FAILED + FAILS + ERRS))
        SKIPPED=$((SKIPPED + SKIPS))
    fi
done

# Calculate passed tests
PASSED=$((TOTAL - FAILED - SKIPPED))

# Ensure non-negative values
if [ $PASSED -lt 0 ]; then
    PASSED=0
fi

echo ""
echo "Test Results Summary:"
echo "  Total:   $TOTAL"
echo "  Passed:  $PASSED"
echo "  Failed:  $FAILED"
echo "  Skipped: $SKIPPED"
echo ""

# Output final JSON result
echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $SKIPPED, \"total\": $TOTAL}"
