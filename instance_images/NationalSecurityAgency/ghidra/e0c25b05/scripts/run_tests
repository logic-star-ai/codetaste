#!/bin/bash
# Test execution script for Ghidra
# This script runs a representative subset of tests and outputs results in JSON format

set -e

# Ensure we're in the testbed directory
cd /testbed

# Set environment variables (should already be set by setup_shell.sh)
export JAVA_HOME=${JAVA_HOME:-/usr/lib/jvm/java-11-openjdk-amd64}
export PATH=$JAVA_HOME/bin:/opt/gradle-5.0/bin:$PATH

# Create a temporary file to store test output
TEST_OUTPUT=$(mktemp)
trap "rm -f $TEST_OUTPUT" EXIT

# List of test modules to run (selecting a representative subset that completes in ~15 minutes)
# We'll run unit tests from a few core modules
TEST_MODULES=(
    ":Utility:test"
    ":Generic:test"
    ":DB:test"
    ":Docking:test"
)

echo "Running Ghidra tests..."
echo "Test modules: ${TEST_MODULES[@]}"

# Run the tests and capture output
gradle ${TEST_MODULES[@]} --continue --console=plain > $TEST_OUTPUT 2>&1 || true

# Display the test output
cat $TEST_OUTPUT

# Parse test results from XML files
parse_test_results() {
    local passed=0
    local failed=0
    local skipped=0
    local total=0

    # Find all test result XML files
    for xml_file in $(find /testbed -path "*/test-results/test/TEST-*.xml" 2>/dev/null); do
        if [ -f "$xml_file" ]; then
            # Parse the testsuite element for counts
            # Format: <testsuite name="..." tests="X" skipped="Y" failures="Z" errors="E" ...>
            local tests=$(grep -oP '<testsuite[^>]+tests="\K[0-9]+' "$xml_file" | head -1)
            local failures=$(grep -oP '<testsuite[^>]+failures="\K[0-9]+' "$xml_file" | head -1)
            local errors=$(grep -oP '<testsuite[^>]+errors="\K[0-9]+' "$xml_file" | head -1)
            local skips=$(grep -oP '<testsuite[^>]+skipped="\K[0-9]+' "$xml_file" | head -1)

            # Default to 0 if not found
            tests=${tests:-0}
            failures=${failures:-0}
            errors=${errors:-0}
            skips=${skips:-0}

            # Add to totals
            total=$((total + tests))
            skipped=$((skipped + skips))
            failed=$((failed + failures + errors))
        fi
    done

    # Calculate passed tests
    passed=$((total - failed - skipped))

    # If no XML files found, try to parse from gradle output
    if [ $total -eq 0 ]; then
        # Look for test summary in gradle output
        if grep -q "BUILD SUCCESSFUL" $TEST_OUTPUT; then
            # Parse test counts from output like "123 tests completed, 5 failed, 2 skipped"
            local completed=$(grep -oP '\K[0-9]+(?= tests? completed)' $TEST_OUTPUT | tail -1)
            local out_failed=$(grep -oP '\K[0-9]+(?= failed)' $TEST_OUTPUT | tail -1)
            local out_skipped=$(grep -oP '\K[0-9]+(?= skipped)' $TEST_OUTPUT | tail -1)

            completed=${completed:-0}
            out_failed=${out_failed:-0}
            out_skipped=${out_skipped:-0}

            if [ $completed -gt 0 ]; then
                total=$completed
                failed=$out_failed
                skipped=$out_skipped
                passed=$((total - failed - skipped))
            fi
        fi
    fi

    # Output JSON result
    echo "{\"passed\": $passed, \"failed\": $failed, \"skipped\": $skipped, \"total\": $total}"
}

# Parse and output results
parse_test_results
