#!/bin/bash
# Test execution script
# This script runs the test suite and outputs results in JSON format
# It expects the environment to be already set up by setup_shell.sh

set -e

cd /testbed

# Run PHPUnit tests with JSON logging
# We'll run Unit tests only for faster execution (as Integration tests can be very slow)
echo "Running PHPUnit unit tests..." >&2

# Create a temporary file for test results
TEMP_RESULT=$(mktemp)

# Run PHPUnit with tap output which is easier to parse
php -d date.timezone=UTC vendor/phpunit/phpunit/phpunit \
    -c tests/Unit/phpunit.xml \
    --log-junit "$TEMP_RESULT" \
    --no-coverage \
    2>&1 | tee /tmp/phpunit_output.log >&2 || true

# Parse the JUnit XML output to get test counts
if [ -f "$TEMP_RESULT" ]; then
    # Use PHP to parse the XML and extract counts
    PASSED=$(php -r "
        \$xml = simplexml_load_file('$TEMP_RESULT');
        if (\$xml === false) { echo '0'; exit; }
        \$suites = \$xml->xpath('//testsuite');
        \$total = 0;
        \$failures = 0;
        \$errors = 0;
        \$skipped = 0;
        foreach (\$suites as \$suite) {
            if (isset(\$suite['tests'])) {
                \$total += (int)\$suite['tests'];
            }
            if (isset(\$suite['failures'])) {
                \$failures += (int)\$suite['failures'];
            }
            if (isset(\$suite['errors'])) {
                \$errors += (int)\$suite['errors'];
            }
            if (isset(\$suite['skipped'])) {
                \$skipped += (int)\$suite['skipped'];
            }
        }
        \$passed = \$total - \$failures - \$errors - \$skipped;
        echo json_encode([
            'passed' => max(0, \$passed),
            'failed' => \$failures + \$errors,
            'skipped' => \$skipped,
            'total' => \$total
        ]);
    " 2>/dev/null)

    if [ -n "$PASSED" ] && [ "$PASSED" != "null" ]; then
        echo "$PASSED"
        rm -f "$TEMP_RESULT"
        exit 0
    fi
fi

# Fallback: Parse from PHPUnit output if XML parsing failed
if [ -f /tmp/phpunit_output.log ]; then
    # Try to extract from the summary line
    SUMMARY=$(grep -E "Tests: [0-9]+" /tmp/phpunit_output.log | tail -1 || echo "")

    if [ -n "$SUMMARY" ]; then
        # Extract numbers from the summary
        TOTAL=$(echo "$SUMMARY" | grep -oP 'Tests: \K[0-9]+' || echo "0")
        FAILURES=$(echo "$SUMMARY" | grep -oP 'Failures: \K[0-9]+' || echo "0")
        ERRORS=$(echo "$SUMMARY" | grep -oP 'Errors: \K[0-9]+' || echo "0")
        SKIPPED=$(echo "$SUMMARY" | grep -oP 'Skipped: \K[0-9]+' || echo "0")

        FAILED=$((FAILURES + ERRORS))
        PASSED=$((TOTAL - FAILED - SKIPPED))

        echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $SKIPPED, \"total\": $TOTAL}"
        exit 0
    fi
fi

# If all else fails, return zeros
echo '{"passed": 0, "failed": 0, "skipped": 0, "total": 0}'
exit 1
