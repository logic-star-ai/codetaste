#!/bin/bash
# Test runner script for PrestaShop
# This script runs the test suite and outputs JSON results
# Expects environment to be already set up via setup_shell.sh

set -e

cd /testbed

# Create temporary file for XML results
XML_RESULTS="/tmp/phpunit_results_$(date +%s).xml"

echo "Running PrestaShop Unit Tests..." >&2
echo "This may take a few minutes..." >&2

# Run PHPUnit tests with XML logging
# Use date.timezone to avoid warnings
# Suppress most output but show progress
php -d date.timezone=UTC -d memory_limit=-1 \
    vendor/bin/phpunit \
    -c tests/Unit/phpunit.xml \
    --no-coverage \
    --log-junit "$XML_RESULTS" \
    2>&1 | grep -E "^(PHPUnit|Runtime|Configuration|Time:|OK|Tests:|FAILURES!|ERRORS!)" >&2 || true

# Check if tests completed and XML was generated
if [ ! -f "$XML_RESULTS" ]; then
    echo "Error: Test results XML not generated" >&2
    echo '{"passed": 0, "failed": 0, "skipped": 0, "total": 0}'
    exit 1
fi

# Parse XML and output JSON - this is the LAST line of stdout
python3 /scripts/parse_phpunit_xml.py "$XML_RESULTS"

# Clean up
rm -f "$XML_RESULTS"
