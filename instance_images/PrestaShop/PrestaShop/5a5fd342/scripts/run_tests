#!/bin/bash
# Run PrestaShop test suite and output JSON results
# This script runs a representative subset of tests that complete within 15 minutes

set -e

cd /testbed

# Helper function to run PHPUnit and parse results
run_phpunit_tests() {
    local config_file=$1
    local suite_name=$2

    echo "Running $suite_name tests..." >&2

    # Run PHPUnit with JUnit XML output
    local xml_output="/tmp/phpunit_${suite_name}_results.xml"
    php8.1 -d date.timezone=UTC -d memory_limit=-1 \
        ./vendor/phpunit/phpunit/phpunit \
        -c "$config_file" \
        --log-junit "$xml_output" \
        2>&1 | tee /tmp/phpunit_${suite_name}_output.log >&2 || true

    # Parse the XML output if it exists
    if [ -f "$xml_output" ]; then
        python3 - "$xml_output" << 'PYTHON_SCRIPT'
import sys
import xml.etree.ElementTree as ET

xml_file = sys.argv[1]
try:
    tree = ET.parse(xml_file)
    root = tree.getroot()

    # Get test suite statistics
    testsuite = root.find('.//testsuite')
    if testsuite is not None:
        tests = int(testsuite.get('tests', 0))
        failures = int(testsuite.get('failures', 0))
        errors = int(testsuite.get('errors', 0))
        skipped = int(testsuite.get('skipped', 0))

        passed = tests - failures - errors - skipped
        failed = failures + errors

        print(f"{passed},{failed},{skipped},{tests}")
    else:
        print("0,0,0,0")
except Exception as e:
    print(f"0,0,0,0", file=sys.stderr)
    print(f"Error parsing XML: {e}", file=sys.stderr)
PYTHON_SCRIPT
    else
        # Try to parse from log output
        local output_file="/tmp/phpunit_${suite_name}_output.log"
        if [ -f "$output_file" ]; then
            # Look for PHPUnit summary line like "Tests: 123, Assertions: 456, Failures: 2, Skipped: 3"
            local summary=$(grep -E "^(Tests:|OK \()" "$output_file" | tail -1 || echo "")
            if [ -n "$summary" ]; then
                # Parse the summary
                local tests=$(echo "$summary" | grep -oP 'Tests:\s*\K\d+' || echo "0")
                local failures=$(echo "$summary" | grep -oP 'Failures:\s*\K\d+' || echo "0")
                local errors=$(echo "$summary" | grep -oP 'Errors:\s*\K\d+' || echo "0")
                local skipped=$(echo "$summary" | grep -oP 'Skipped:\s*\K\d+' || echo "0")

                # If we got "OK" summary, parse differently
                if echo "$summary" | grep -q "^OK"; then
                    tests=$(echo "$summary" | grep -oP 'OK \(\K\d+' || echo "0")
                    failures=0
                    errors=0
                    skipped=$(echo "$summary" | grep -oP 'skipped:\s*\K\d+' || echo "0")
                fi

                local failed=$((failures + errors))
                local passed=$((tests - failed - skipped))

                echo "$passed,$failed,$skipped,$tests"
            else
                echo "0,0,0,0"
            fi
        else
            echo "0,0,0,0"
        fi
    fi
}

# Initialize counters
total_passed=0
total_failed=0
total_skipped=0
total_tests=0

# Run Unit tests (fast, no database required for most)
echo "==================================="
echo "Running Unit Tests"
echo "==================================="
result=$(run_phpunit_tests "tests/Unit/phpunit.xml" "unit")
IFS=',' read -r passed failed skipped tests <<< "$result"
total_passed=$((total_passed + passed))
total_failed=$((total_failed + failed))
total_skipped=$((total_skipped + skipped))
total_tests=$((total_tests + tests))

echo "Unit tests: $tests total, $passed passed, $failed failed, $skipped skipped"

# Output final JSON result
echo ""
echo "==================================="
echo "Test Summary"
echo "==================================="
echo "Total: $total_tests tests"
echo "Passed: $total_passed"
echo "Failed: $total_failed"
echo "Skipped: $total_skipped"
echo "==================================="

# Output JSON on the last line of stdout
echo "{\"passed\": $total_passed, \"failed\": $total_failed, \"skipped\": $total_skipped, \"total\": $total_tests}"
