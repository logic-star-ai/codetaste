#!/bin/bash
# Test runner script
# Runs PHPUnit tests and outputs JSON summary

set -e

cd /testbed

# Set environment variables for tests
export SYMFONY_DEPRECATIONS_HELPER=disabled
export TZ=UTC

# Run PHPUnit tests and capture output
echo "Running PHPUnit unit tests..."

# Create a temporary file for the test output
TEMP_OUTPUT=$(mktemp)
TEMP_JSON=$(mktemp)

# Run PHPUnit with JUnit XML format for parsing
php -d date.timezone=UTC ./vendor/phpunit/phpunit/phpunit \
    -c tests/Unit/phpunit.xml \
    --log-junit "$TEMP_JSON" \
    2>&1 | tee "$TEMP_OUTPUT" || true

# Parse the JUnit XML output to get test counts
if [ -f "$TEMP_JSON" ] && [ -s "$TEMP_JSON" ]; then
    # Use PHP to parse XML and extract counts
    TEMP_JSON="$TEMP_JSON" TEMP_OUTPUT="$TEMP_OUTPUT" php <<'PHP_SCRIPT'
<?php
$xmlFile = getenv('TEMP_JSON');
$outputFile = getenv('TEMP_OUTPUT');

if (!empty($xmlFile) && file_exists($xmlFile)) {
    $xml = simplexml_load_file($xmlFile);
    if ($xml !== false) {
        $testsuites = $xml->testsuite ?? $xml;
        $tests = (int)($testsuites['tests'] ?? 0);
        $failures = (int)($testsuites['failures'] ?? 0);
        $errors = (int)($testsuites['errors'] ?? 0);
        $skipped = (int)($testsuites['skipped'] ?? 0);

        $failed = $failures + $errors;
        $passed = $tests - $failed - $skipped;

        echo json_encode([
            'passed' => $passed,
            'failed' => $failed,
            'skipped' => $skipped,
            'total' => $tests
        ]);
        exit(0);
    }
}

// Fallback: try to parse from text output
if (!empty($outputFile) && file_exists($outputFile)) {
    $output = file_get_contents($outputFile);
    if (preg_match('/Tests: (\d+), Assertions: (\d+)(?:, Failures: (\d+))?(?:, Errors: (\d+))?(?:, Skipped: (\d+))?/', $output, $matches)) {
        $tests = (int)$matches[1];
        $failures = isset($matches[3]) ? (int)$matches[3] : 0;
        $errors = isset($matches[4]) ? (int)$matches[4] : 0;
        $skipped = isset($matches[5]) ? (int)$matches[5] : 0;

        $failed = $failures + $errors;
        $passed = $tests - $failed - $skipped;

        echo json_encode([
            'passed' => $passed,
            'failed' => $failed,
            'skipped' => $skipped,
            'total' => $tests
        ]);
        exit(0);
    }
}

// Ultimate fallback
echo json_encode(['passed' => 0, 'failed' => 0, 'skipped' => 0, 'total' => 0]);
?>
PHP_SCRIPT

elif [ -f "$TEMP_OUTPUT" ] && [ -s "$TEMP_OUTPUT" ]; then
    # Parse from text output
    if grep -q "Tests: " "$TEMP_OUTPUT" 2>/dev/null; then
        # Parse from summary line
        TEMP_OUTPUT="$TEMP_OUTPUT" php <<'PHP_SCRIPT'
<?php
$outputFile = getenv('TEMP_OUTPUT');
if (!empty($outputFile) && file_exists($outputFile)) {
    $output = file_get_contents($outputFile);
    if (preg_match('/Tests: (\d+), Assertions: (\d+)(?:, Failures: (\d+))?(?:, Errors: (\d+))?(?:, Skipped: (\d+))?/', $output, $matches)) {
        $tests = (int)$matches[1];
        $failures = isset($matches[3]) ? (int)$matches[3] : 0;
        $errors = isset($matches[4]) ? (int)$matches[4] : 0;
        $skipped = isset($matches[5]) ? (int)$matches[5] : 0;
        $failed = $failures + $errors;
        $passed = $tests - $failed - $skipped;
        echo json_encode(['passed' => $passed, 'failed' => $failed, 'skipped' => $skipped, 'total' => $tests]);
    } else {
        echo json_encode(['passed' => 0, 'failed' => 0, 'skipped' => 0, 'total' => 0]);
    }
} else {
    echo json_encode(['passed' => 0, 'failed' => 0, 'skipped' => 0, 'total' => 0]);
}
?>
PHP_SCRIPT
    elif grep -q "OK (" "$TEMP_OUTPUT" 2>/dev/null; then
        # Extract test counts from OK line
        TESTS=$(grep -oP 'OK \(\K\d+(?= test)' "$TEMP_OUTPUT" || echo "0")
        echo "{\"passed\": $TESTS, \"failed\": 0, \"skipped\": 0, \"total\": $TESTS}"
    else
        # No tests found
        echo '{"passed": 0, "failed": 0, "skipped": 0, "total": 0}'
    fi
fi

# Clean up temporary files
rm -f "$TEMP_OUTPUT" "$TEMP_JSON"
