#!/bin/bash
# Test runner script for Zulip
# Runs backend tests and outputs results in JSON format

set -e

cd /testbed

# Activate virtualenv
source /tmp/zulip-py3-venv/bin/activate

# Run a subset of backend tests for speed
echo "Running Zulip backend tests..."

# Create a temporary file to store test results
TEMP_OUTPUT=$(mktemp)

# Check if we can run tests
if ! python -c "import django" 2>/dev/null; then
    echo "ERROR: Django not installed. Run setup_shell.sh first." >&2
    echo '{"passed": 0, "failed": 1, "skipped": 0, "total": 1}'
    exit 1
fi

# Run tests with a subset of modules for speed
# These are representative tests that cover different aspects
TEST_MODULES=(
    "zerver.tests.test_alert_words"
    "zerver.tests.test_auth_backends"
)

# Try to run the tests
if python3 tools/test-backend \
    --nonfatal-errors \
    --processes=1 \
    "${TEST_MODULES[@]}" \
    2>&1 | tee "$TEMP_OUTPUT"; then
    TEST_SUCCESS=true
else
    TEST_SUCCESS=false
fi

# Extract test results from output
# Django test output format typically shows:
# Ran X tests in Y.ZZZs
# OK or FAILED (failures=N, errors=M, skipped=S)

# Parse the output
TOTAL=$(grep -oP "Ran \K\d+" "$TEMP_OUTPUT" 2>/dev/null || echo "0")
FAILED=$(grep -oP "failures=\K\d+" "$TEMP_OUTPUT" 2>/dev/null || echo "0")
ERRORS=$(grep -oP "errors=\K\d+" "$TEMP_OUTPUT" 2>/dev/null || echo "0")
SKIPPED=$(grep -oP "skipped=\K\d+" "$TEMP_OUTPUT" 2>/dev/null || echo "0")

# Calculate passed tests
FAILED_TOTAL=$((FAILED + ERRORS))
PASSED=$((TOTAL - FAILED_TOTAL - SKIPPED))

# If parsing failed but tests succeeded, check for "OK" in output
if [ "$TOTAL" -eq 0 ] && [ "$TEST_SUCCESS" = true ]; then
    if grep -q "Ran [0-9]* test" "$TEMP_OUTPUT"; then
        TOTAL=$(grep -oP "Ran \K\d+" "$TEMP_OUTPUT" 2>/dev/null || echo "0")
        if grep -q "^OK" "$TEMP_OUTPUT"; then
            PASSED=$TOTAL
            FAILED_TOTAL=0
            SKIPPED=0
        fi
    fi
fi

# Handle case where test framework couldn't run at all
if [ "$TOTAL" -eq 0 ] && [ "$TEST_SUCCESS" = false ]; then
    TOTAL=1
    FAILED_TOTAL=1
    PASSED=0
    SKIPPED=0
fi

# Clean up
rm -f "$TEMP_OUTPUT"

# Output JSON result
echo "{\"passed\": $PASSED, \"failed\": $FAILED_TOTAL, \"skipped\": $SKIPPED, \"total\": $TOTAL}"
