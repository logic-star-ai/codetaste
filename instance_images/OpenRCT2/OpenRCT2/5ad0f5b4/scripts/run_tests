#!/bin/bash
# Test execution script for OpenRCT2
# Runs tests and outputs results in JSON format

set -e

cd /testbed/bin

# Check if test binary exists
if [ ! -f "OpenRCT2Tests" ]; then
    echo "Error: OpenRCT2Tests binary not found. Please run setup_shell.sh first." >&2
    exit 1
fi

# Run tests with GTest XML output
TEMP_OUTPUT=$(mktemp)
TEST_XML="/tmp/test_results.xml"

# Run the tests and capture the exit code
set +e
./OpenRCT2Tests --gtest_output=xml:${TEST_XML} 2>&1 | tee "$TEMP_OUTPUT"
TEST_EXIT_CODE=$?
set -e

# Parse the XML output to get test statistics
if [ -f "${TEST_XML}" ]; then
    # Extract test counts from XML using grep and sed
    TOTAL=$(grep -o 'tests="[0-9]*"' "${TEST_XML}" | head -1 | sed 's/tests="\([0-9]*\)"/\1/')
    FAILURES=$(grep -o 'failures="[0-9]*"' "${TEST_XML}" | head -1 | sed 's/failures="\([0-9]*\)"/\1/')
    SKIPPED=$(grep -o 'disabled="[0-9]*"' "${TEST_XML}" | head -1 | sed 's/disabled="\([0-9]*\)"/\1/')

    # Default values if extraction fails
    TOTAL=${TOTAL:-0}
    FAILURES=${FAILURES:-0}
    SKIPPED=${SKIPPED:-0}

    # Calculate passed tests
    PASSED=$((TOTAL - FAILURES - SKIPPED))

    # Ensure non-negative values
    if [ $PASSED -lt 0 ]; then
        PASSED=0
    fi
else
    # Fallback: parse from stdout if XML parsing fails
    PASSED=$(grep -o '\[  PASSED  \] [0-9]* test' "$TEMP_OUTPUT" | sed 's/\[  PASSED  \] \([0-9]*\) test.*/\1/' | tail -1)
    FAILURES=$(grep -o '\[  FAILED  \] [0-9]* test' "$TEMP_OUTPUT" | sed 's/\[  FAILED  \] \([0-9]*\) test.*/\1/' | tail -1)
    TOTAL=$(grep -o '\[==========\] [0-9]* test' "$TEMP_OUTPUT" | sed 's/\[==========\] \([0-9]*\) test.*/\1/' | head -1)

    # Default values if extraction fails
    PASSED=${PASSED:-0}
    FAILURES=${FAILURES:-0}
    TOTAL=${TOTAL:-0}
    SKIPPED=0
fi

# Clean up temp file
rm -f "$TEMP_OUTPUT"

# Output JSON result
echo "{\"passed\": $PASSED, \"failed\": $FAILURES, \"skipped\": $SKIPPED, \"total\": $TOTAL}"

# Exit with the test exit code
exit $TEST_EXIT_CODE
