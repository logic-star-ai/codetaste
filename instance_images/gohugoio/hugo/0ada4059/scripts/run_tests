#!/bin/bash
# run_tests - Execute Hugo test suite
# This script runs tests and outputs results in JSON format.
# Note: This Hugo repository is from 2017 and has dependency incompatibilities
# with modern Go versions. Tests cannot run without modifying source code.

set -e

cd /testbed

echo "Error: This Hugo version (from 2017) has incompatible dependencies with Go 1.23" >&2
echo "The code uses github.com/pelletier/go-toml API that changed in newer versions." >&2
echo "Tests cannot run without source code modifications, which violates the integrity constraint." >&2

# Output zero test results in required JSON format
echo '{"passed": 0, "failed": 0, "skipped": 0, "total": 0}'
exit 1
