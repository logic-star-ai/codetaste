#!/bin/bash
# Run tests for Hugo and output JSON results
# This script expects the environment to be set up by setup_shell.sh

cd /testbed

# List of packages that can be tested (excluding those with build failures)
PACKAGES=(
    "./bufferpool"
    "./parser"
    "./transform"
    "./helpers"
    "./source"
    "./target"
    "./hugofs"
    "./i18n"
    "./tpl"
)

# Run tests with JSON output and parse directly
go test -json "${PACKAGES[@]}" 2>&1 | python3 -c '
import json
import sys

passed = 0
failed = 0
skipped = 0

for line in sys.stdin:
    try:
        data = json.loads(line.strip())
        action = data.get("Action")

        if action == "pass" and "Test" in data:
            passed += 1
        elif action == "fail" and "Test" in data:
            failed += 1
        elif action == "skip" and "Test" in data:
            skipped += 1
    except:
        pass

total = passed + failed + skipped
print(json.dumps({"passed": passed, "failed": failed, "skipped": skipped, "total": total}))
'
