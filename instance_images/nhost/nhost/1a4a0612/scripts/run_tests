#!/bin/bash
# run_tests - Execute test suite and output JSON results
# This script must be run after sourcing setup_shell.sh

set -e

# Change to testbed directory
cd /testbed

# Run tests with turbo, using vitest with --threads=false to avoid memory issues
# and --reporter=json for machine-readable output
# Filter out dashboard, docs, and examples as per package.json test script
pnpm run test -- --reporter=json --threads=false 2>&1 > /tmp/test_output.txt || true

# Parse the test results using Node.js script
node /scripts/parse_test_results.js
