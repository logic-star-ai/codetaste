#!/bin/bash
# Test runner script for go-ethereum
# This script runs the test suite and outputs results in JSON format
# Must be run after setup_shell.sh has been sourced

set -e

cd /testbed

# Select a representative subset of packages to test within 15 minutes
# We'll test core packages that are essential to the project
PACKAGES=(
    "./common/..."
    "./crypto/..."
    "./core/types/..."
    "./core/rawdb/..."
    "./core/state/..."
    "./rlp/..."
    "./trie/..."
    "./ethdb/..."
    "./accounts/abi/..."
    "./params/..."
    "./node/..."
    "./rpc/..."
    "./eth/protocols/eth/..."
    "./p2p/..."
)

# Run tests with verbose output and JSON format
# Use -short flag to skip long-running tests
# Use -timeout to prevent hanging
echo "Running go-ethereum test suite..." >&2

# Create a temporary file to store test output
TMPFILE=$(mktemp)
trap "rm -f $TMPFILE" EXIT

# Run tests and capture output in JSON format
# -json flag outputs test results in JSON format (one JSON object per line)
# -short flag skips long-running tests
# -timeout sets maximum time for tests
# -p 1 runs one package at a time to avoid resource conflicts
go test -json -short -timeout=15m -p 1 ${PACKAGES[@]} > "$TMPFILE" 2>&1 || true

# Parse JSON output and count results
PASSED=0
FAILED=0
SKIPPED=0
TOTAL=0

while IFS= read -r line; do
    # Each line is a JSON object
    # Check if it's a test result line
    if echo "$line" | grep -q '"Action":"pass"' && echo "$line" | grep -q '"Test":"Test'; then
        PASSED=$((PASSED + 1))
        TOTAL=$((TOTAL + 1))
    elif echo "$line" | grep -q '"Action":"fail"' && echo "$line" | grep -q '"Test":"Test'; then
        FAILED=$((FAILED + 1))
        TOTAL=$((TOTAL + 1))
    elif echo "$line" | grep -q '"Action":"skip"' && echo "$line" | grep -q '"Test":"Test'; then
        SKIPPED=$((SKIPPED + 1))
        TOTAL=$((TOTAL + 1))
    fi
done < "$TMPFILE"

# Output the summary in the required JSON format
echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $SKIPPED, \"total\": $TOTAL}"
