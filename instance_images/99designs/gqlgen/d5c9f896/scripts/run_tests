#!/bin/bash
# Test runner script for gqlgen
# Runs the test suite and outputs results in JSON format

set -e

cd /testbed

# Run tests with JSON output
# We'll use go test with -json flag and parse the results
echo "Running tests..." >&2

# Run tests excluding _examples directory and capture JSON output
TEST_OUTPUT=$(go test -json ./... 2>&1 | grep -v "^#" || true)

# Parse the JSON output to count results
PASSED=0
FAILED=0
SKIPPED=0
TOTAL=0

# Process each line of JSON output
while IFS= read -r line; do
    if echo "$line" | grep -q '"Action":"pass"' && echo "$line" | grep -q '"Test":"'; then
        PASSED=$((PASSED + 1))
        TOTAL=$((TOTAL + 1))
    elif echo "$line" | grep -q '"Action":"fail"' && echo "$line" | grep -q '"Test":"'; then
        FAILED=$((FAILED + 1))
        TOTAL=$((TOTAL + 1))
    elif echo "$line" | grep -q '"Action":"skip"' && echo "$line" | grep -q '"Test":"'; then
        SKIPPED=$((SKIPPED + 1))
        TOTAL=$((TOTAL + 1))
    fi
done <<< "$TEST_OUTPUT"

# Output the final JSON line
echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $SKIPPED, \"total\": $TOTAL}"
