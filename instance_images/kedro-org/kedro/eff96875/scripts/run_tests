#!/bin/bash
# Test execution script
# This script runs the test suite and outputs JSON results

set -e

cd /testbed

# Run pytest with json report
# Use --numprocesses 4 --dist loadfile as specified in Makefile
# We'll capture output and parse it
# Using pytest-json-report for structured output would be ideal, but we'll parse the native output

# Install pytest-json-report if not already installed
if ! python -c "import pytest_jsonreport" 2>/dev/null; then
    uv pip install pytest-json-report >/dev/null 2>&1 || true
fi

# Run tests with JSON report
# Note: Running without xdist (parallel) due to serialization issues
# The Makefile uses --numprocesses 4 --dist loadfile but this causes
# issues with KedroContext serialization in some tests
pytest tests/ \
    --json-report \
    --json-report-file=/tmp/test_report.json \
    --json-report-indent=2 \
    --tb=short \
    -q 2>&1 | tee /tmp/pytest_output.txt || true

# Parse the JSON report
if [ -f /tmp/test_report.json ]; then
    python3 << 'EOF'
import json
import sys

try:
    with open('/tmp/test_report.json', 'r') as f:
        report = json.load(f)

    summary = report.get('summary', {})
    passed = summary.get('passed', 0)
    failed = summary.get('failed', 0)
    skipped = summary.get('skipped', 0)
    # Calculate total from collected or as sum
    total = summary.get('total', 0)
    if total == 0:
        total = summary.get('collected', passed + failed + skipped)

    result = {
        "passed": passed,
        "failed": failed,
        "skipped": skipped,
        "total": total
    }

    print(json.dumps(result))
except Exception as e:
    # Fallback: parse pytest output
    print(json.dumps({"passed": 0, "failed": 0, "skipped": 0, "total": 0}), file=sys.stderr)
    print(f"Error parsing test report: {e}", file=sys.stderr)
    sys.exit(1)
EOF
else
    # Fallback: try to parse from pytest output
    python3 << 'EOF'
import re
import json
import sys

try:
    with open('/tmp/pytest_output.txt', 'r') as f:
        output = f.read()

    # Look for pytest summary line like "123 passed, 4 failed, 5 skipped in 10.5s"
    pattern = r'(\d+)\s+passed|(\d+)\s+failed|(\d+)\s+skipped'

    passed = 0
    failed = 0
    skipped = 0

    # Find all matches
    for match in re.finditer(r'(\d+)\s+(passed|failed|skipped)', output):
        count = int(match.group(1))
        status = match.group(2)
        if status == 'passed':
            passed = count
        elif status == 'failed':
            failed = count
        elif status == 'skipped':
            skipped = count

    total = passed + failed + skipped

    result = {
        "passed": passed,
        "failed": failed,
        "skipped": skipped,
        "total": total
    }

    print(json.dumps(result))
except Exception as e:
    print(json.dumps({"passed": 0, "failed": 0, "skipped": 0, "total": 0}))
    print(f"Error: {e}", file=sys.stderr)
EOF
fi
