#!/bin/bash
# Test runner for gVisor
# Runs a representative subset of tests and outputs JSON results

set -e

# Change to testbed directory
cd /testbed

# Define test targets - select a representative subset of tests
# We focus on pkg/ tests that don't require kernel/sentry to avoid build complexity
# This gives us a good cross-section of the codebase
TEST_TARGETS=(
    "//pkg/bits:bits_test"
    "//pkg/gate:gate_test"
    "//pkg/fd:fd_test"
    "//pkg/ilist:list_test"
    "//pkg/log:log_test"
    "//pkg/metric:metric_test"
    "//pkg/linewriter:linewriter_test"
    "//pkg/refs:refs_test"
    "//pkg/secio:secio_test"
    "//pkg/sleep:sleep_test"
    "//pkg/syserror:syserror_test"
    "//pkg/waiter:waiter_test"
    "//pkg/unet:unet_test"
    "//pkg/urpc:urpc_test"
    "//pkg/tmutex:tmutex_test"
    "//pkg/compressio:compressio_test"
    "//pkg/bpf:bpf_test"
    "//pkg/cpuid:cpuid_test"
    "//pkg/segment/test:segment_test"
    "//pkg/seccomp:seccomp_test"
    "//pkg/tcpip:tcpip_test"
    "//pkg/tcpip/buffer:buffer_test"
    "//pkg/tcpip/header:header_test"
    "//pkg/tcpip/hash/jenkins:jenkins_test"
    "//pkg/tcpip/link/fdbased:fdbased_test"
    "//pkg/tcpip/link/muxed:muxed_test"
    "//pkg/tcpip/link/waitable:waitable_test"
    "//pkg/tcpip/network:ip_test"
    "//pkg/tcpip/network/arp:arp_test"
    "//pkg/tcpip/network/ipv4:ipv4_test"
    "//pkg/tcpip/network/ipv6:ipv6_test"
    "//pkg/tcpip/network/fragmentation:fragmentation_test"
    "//pkg/tcpip/ports:ports_test"
    "//pkg/tcpip/stack:stack_test"
    "//pkg/tcpip/stack:stack_x_test"
    "//pkg/tcpip/transport/tcp:tcp_test"
    "//pkg/tcpip/transport/tcpconntrack:tcpconntrack_test"
    "//pkg/tcpip/transport/udp:udp_x_test"
    "//third_party/gvsync:gvsync_test"
    "//third_party/gvsync/atomicptrtest:atomicptr_test"
    "//third_party/gvsync/seqatomictest:seqatomic_test"
    "//tools/go_generics:go_generics_test"
)

# Run tests and capture output
echo "Running gVisor tests..." >&2
OUTPUT=$(USE_BAZEL_VERSION=${USE_BAZEL_VERSION:-0.26.1} bazelisk test "${TEST_TARGETS[@]}" \
    $BAZEL_FLAGS \
    --test_output=errors \
    --test_summary=short \
    2>&1) || true

echo "$OUTPUT" >&2

# Parse the test results
# Bazel outputs lines like:
# "Executed X out of Y tests: Z tests pass."
# "FAILED: Build did NOT complete successfully"
# or individual test results like:
# "//pkg/gate:gate_test                                            PASSED in 4.2s"

PASSED=0
FAILED=0
SKIPPED=0
TOTAL=0

# Extract summary line
if echo "$OUTPUT" | grep -q "Executed.*out of.*test"; then
    # Parse "Executed X out of Y tests: Z tests pass"
    EXECUTED=$(echo "$OUTPUT" | grep "Executed.*out of.*test" | tail -1 | sed -n 's/.*Executed \([0-9]*\) out of \([0-9]*\) test.*/\1/p')
    TOTAL_TARGETS=$(echo "$OUTPUT" | grep "Executed.*out of.*test" | tail -1 | sed -n 's/.*Executed \([0-9]*\) out of \([0-9]*\) test.*/\2/p')

    # Count passed and failed tests from individual results
    PASSED=$(echo "$OUTPUT" | grep -c "PASSED in" || true)
    FAILED=$(echo "$OUTPUT" | grep -c "FAILED in" || true)
    FLAKY=$(echo "$OUTPUT" | grep -c "FLAKY" || true)
    PASSED=${PASSED:-0}
    FAILED=${FAILED:-0}
    FLAKY=${FLAKY:-0}

    # If we have failure messages, count those too
    if echo "$OUTPUT" | grep -q "FAILED:.*Build did NOT complete"; then
        # Build failed - count targets that didn't run
        FAILED=$((TOTAL_TARGETS - PASSED))
    fi

    # Total is all targets
    TOTAL=$TOTAL_TARGETS

    # Skipped = total - executed (cached tests count as executed)
    SKIPPED=$((TOTAL - EXECUTED))
else
    # Fallback: count individual test results
    PASSED=$(echo "$OUTPUT" | grep -E "^//" | grep -c "PASSED" || true)
    FAILED=$(echo "$OUTPUT" | grep -E "^//" | grep -c "FAILED" || true)
    SKIPPED=$(echo "$OUTPUT" | grep -E "^//" | grep -c "SKIPPED" || true)
    PASSED=${PASSED:-0}
    FAILED=${FAILED:-0}
    SKIPPED=${SKIPPED:-0}
    TOTAL=$((PASSED + FAILED + SKIPPED))
fi

# If we still have no tests, something went wrong
if [ "$TOTAL" -eq 0 ]; then
    # Count the test targets we tried to run
    TOTAL=${#TEST_TARGETS[@]}
    # Assume all failed if we got no results
    FAILED=$TOTAL
    PASSED=0
    SKIPPED=0
fi

# Output JSON result
echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $SKIPPED, \"total\": $TOTAL}"
