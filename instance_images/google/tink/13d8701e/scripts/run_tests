#!/bin/bash

# Test runner script for Tink Go tests
# This script runs the test suite and outputs JSON results

set -e

cd /testbed

# Run all Go tests and capture output
TEST_OUTPUT=$(bazel test //go/... --test_output=summary 2>&1)

# Extract test results from the output
# Look for lines like "Executed N out of M tests: X tests pass"
EXECUTED_LINE=$(echo "$TEST_OUTPUT" | grep -E "Executed [0-9]+ out of [0-9]+ test" | tail -1)

if [ -z "$EXECUTED_LINE" ]; then
    # If no executed line found, count individual test results
    PASSED=$(echo "$TEST_OUTPUT" | grep -c "PASSED" || echo "0")
    FAILED=$(echo "$TEST_OUTPUT" | grep -c "FAILED" || echo "0")
    SKIPPED=$(echo "$TEST_OUTPUT" | grep -c "SKIPPED" || echo "0")
    TOTAL=$((PASSED + FAILED + SKIPPED))
else
    # Parse the summary line
    # Format: "Executed X out of Y tests: Z tests pass"
    if echo "$EXECUTED_LINE" | grep -q "tests pass"; then
        TOTAL=$(echo "$EXECUTED_LINE" | sed -n 's/.*Executed \([0-9]*\) out of \([0-9]*\) test.*/\2/p')
        PASSED=$(echo "$EXECUTED_LINE" | sed -n 's/.*: \([0-9]*\) test.* pass.*/\1/p')
        FAILED=0
        SKIPPED=0
    elif echo "$EXECUTED_LINE" | grep -q "test fails"; then
        TOTAL=$(echo "$EXECUTED_LINE" | sed -n 's/.*Executed \([0-9]*\) out of \([0-9]*\) test.*/\2/p')
        FAILED=$(echo "$EXECUTED_LINE" | sed -n 's/.*: \([0-9]*\) test.* fail.*/\1/p')
        PASSED=$((TOTAL - FAILED))
        SKIPPED=0
    else
        # Fallback: count from individual results
        PASSED=$(echo "$TEST_OUTPUT" | grep -c "PASSED" || echo "0")
        FAILED=$(echo "$TEST_OUTPUT" | grep -c "FAILED" || echo "0")
        SKIPPED=$(echo "$TEST_OUTPUT" | grep -c "SKIPPED" || echo "0")
        TOTAL=$((PASSED + FAILED + SKIPPED))
    fi
fi

# Ensure we have valid numbers
PASSED=${PASSED:-0}
FAILED=${FAILED:-0}
SKIPPED=${SKIPPED:-0}
TOTAL=${TOTAL:-0}

# Output JSON result
echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $SKIPPED, \"total\": $TOTAL}"
