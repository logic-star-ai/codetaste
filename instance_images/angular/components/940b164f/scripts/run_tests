#!/bin/bash
# Test runner script for Angular Components repository
# This script runs a representative subset of tests

set -e

cd /testbed

# Run schematics tests (Node-based, no browser needed)
# These tests are reliable and representative of the codebase
echo "Running Material schematics tests..."
OUTPUT=$(yarn -s bazel test //src/material/schematics:unit_tests --test_output=errors 2>&1)
MATERIAL_SCHEMATIC_EXIT=$?

echo "Running CDK schematics tests..."
OUTPUT2=$(yarn -s bazel test //src/cdk/schematics:unit_tests --test_output=errors 2>&1)
CDK_SCHEMATIC_EXIT=$?

echo "Running Material core theming tests..."
OUTPUT3=$(yarn -s bazel test //src/material/core/theming/tests:unit_tests --test_output=errors 2>&1)
THEMING_EXIT=$?

# Parse test results from Bazel output
# Bazel outputs "Executed X out of X tests: Y test passes"
# We need to extract the numbers

PASSED=0
FAILED=0
TOTAL=0

# Function to parse Bazel test output
parse_bazel_output() {
    local output="$1"
    # Look for "Executed X out of X tests: Y test passes" or "X fail locally"
    if echo "$output" | grep -q "test passes"; then
        local count=$(echo "$output" | grep "test passes" | sed -n 's/.*Executed \([0-9]*\) out of \([0-9]*\) tests: \([0-9]*\) test passes.*/\3/p' | tail -1)
        echo "$count"
    elif echo "$output" | grep -q "tests pass"; then
        local count=$(echo "$output" | grep "tests pass" | sed -n 's/.*Executed \([0-9]*\) out of \([0-9]*\) tests: \([0-9]*\) tests pass.*/\3/p' | tail -1)
        echo "$count"
    else
        echo "0"
    fi
}

parse_failed_tests() {
    local output="$1"
    # Look for "X fail locally"
    if echo "$output" | grep -q "fail locally"; then
        local count=$(echo "$output" | grep "fail locally" | sed -n 's/.*Executed \([0-9]*\) out of \([0-9]*\) tests: \([0-9]*\) fail locally.*/\3/p' | tail -1)
        echo "$count"
    elif echo "$output" | grep -q "fails locally"; then
        local count=$(echo "$output" | grep "fails locally" | sed -n 's/.*Executed \([0-9]*\) out of \([0-9]*\) tests: \([0-9]*\) fails locally.*/\3/p' | tail -1)
        echo "$count"
    else
        echo "0"
    fi
}

# Parse results for each test suite
if [ $MATERIAL_SCHEMATIC_EXIT -eq 0 ]; then
    MAT_PASSED=1
    MAT_FAILED=0
else
    MAT_PASSED=0
    MAT_FAILED=1
fi

if [ $CDK_SCHEMATIC_EXIT -eq 0 ]; then
    CDK_PASSED=1
    CDK_FAILED=0
else
    CDK_PASSED=0
    CDK_FAILED=1
fi

if [ $THEMING_EXIT -eq 0 ]; then
    THEME_PASSED=1
    THEME_FAILED=0
else
    THEME_PASSED=0
    THEME_FAILED=1
fi

PASSED=$((MAT_PASSED + CDK_PASSED + THEME_PASSED))
FAILED=$((MAT_FAILED + CDK_FAILED + THEME_FAILED))
TOTAL=$((PASSED + FAILED))

# Output JSON result as the last line of stdout
echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": 0, \"total\": $TOTAL}"
