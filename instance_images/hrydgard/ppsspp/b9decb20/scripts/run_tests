#!/bin/bash
# Execute PPSSPP unit tests and output results in JSON format
# This script assumes the environment has been set up via setup_shell.sh

set -e

cd /testbed

# Check if the unittest binary exists
if [ ! -f "build/PPSSPPUnitTest" ]; then
    echo "Error: PPSSPPUnitTest binary not found at build/PPSSPPUnitTest" >&2
    echo "Please run 'source /scripts/setup_shell.sh' first" >&2
    exit 1
fi

# Run all unit tests and capture output
TEST_OUTPUT=$(./build/PPSSPPUnitTest ALL 2>&1)
EXIT_CODE=$?

# Parse the test output to extract pass/fail counts
# The output format is:
# "X tests passed."
# "Y tests failed!"
# If all tests pass, only "X tests passed." appears

PASSED=0
FAILED=0
SKIPPED=0

# Extract passed count
if echo "$TEST_OUTPUT" | grep -q "tests passed"; then
    PASSED=$(echo "$TEST_OUTPUT" | grep "tests passed" | awk '{print $1}')
fi

# Extract failed count
if echo "$TEST_OUTPUT" | grep -q "tests failed"; then
    FAILED=$(echo "$TEST_OUTPUT" | grep "tests failed" | awk '{print $1}')
fi

# Calculate total
TOTAL=$((PASSED + FAILED + SKIPPED))

# Output JSON result as the final line
echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $SKIPPED, \"total\": $TOTAL}"

# Exit with appropriate code
if [ $EXIT_CODE -ne 0 ]; then
    exit 1
fi

exit 0
