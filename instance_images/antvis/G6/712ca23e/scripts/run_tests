#!/bin/bash
# Test execution script for G6 project
# This script runs the test suite and outputs results in JSON format

set -e

cd /testbed/packages/g6

# Run jest tests and capture output
TEST_OUTPUT=$(npm test 2>&1 || true)

# Parse the test summary from the output
# Jest outputs: "Tests: X passed, Y total"
# Extract the numbers using proper regex
TESTS_LINE=$(echo "$TEST_OUTPUT" | grep "Tests:")

# Extract passed count
PASSED=$(echo "$TESTS_LINE" | grep -oP '\d+(?= passed)' || echo "0")

# Extract failed count (may not exist if no failures)
FAILED=$(echo "$TESTS_LINE" | grep -oP '\d+(?= failed)' || echo "0")

# Extract skipped count (may not exist if no skipped)
SKIPPED=$(echo "$TESTS_LINE" | grep -oP '\d+(?= skipped)' || echo "0")

# Extract total count - it's the last number followed by " total"
TOTAL=$(echo "$TESTS_LINE" | grep -oP '\d+(?= total)' || echo "0")

# Set defaults if we couldn't extract numbers
if [ -z "$PASSED" ]; then PASSED=0; fi
if [ -z "$FAILED" ]; then FAILED=0; fi
if [ -z "$SKIPPED" ]; then SKIPPED=0; fi
if [ -z "$TOTAL" ]; then TOTAL=0; fi

echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $SKIPPED, \"total\": $TOTAL}"
