#!/bin/bash
# Run gopass tests and output results in JSON format
# This script should be run AFTER setup_shell.sh has been sourced

set -e

cd /testbed

# Get list of packages to test (exclude /tests, /xcpb, /openpgp as per Makefile)
PKGS=$(go list ./... | grep -v /tests | grep -v /xcpb | grep -v /openpgp)

# Run tests with JSON output
echo "Running gopass tests..." >&2
TEST_OUTPUT=$(mktemp)
go test -json $PKGS 2>&1 | tee "$TEST_OUTPUT" >&2

# Parse the JSON output to count results
PASSED=$(grep '"Action":"pass"' "$TEST_OUTPUT" | grep -c '"Test":' || echo 0)
FAILED=$(grep '"Action":"fail"' "$TEST_OUTPUT" | grep -c '"Test":' || echo 0)
SKIPPED=$(grep '"Action":"skip"' "$TEST_OUTPUT" | grep -c '"Test":' || echo 0)
TOTAL=$((PASSED + FAILED + SKIPPED))

# Clean up
rm -f "$TEST_OUTPUT"

# Output JSON result as the final line
echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $SKIPPED, \"total\": $TOTAL}"
