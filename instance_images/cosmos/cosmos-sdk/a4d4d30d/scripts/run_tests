#!/bin/bash
# Test execution script
# This script runs a representative subset of tests and outputs JSON results

set -e

cd /testbed

# Test tags to use
TEST_TAGS="cgo ledger test_ledger_mock norace"

# Run tests in JSON mode and collect results
echo "Running tests..." >&2

total_passed=0
total_failed=0
total_skipped=0

# Test main module packages (selective subset for speed)
MAIN_PACKAGES=(
    "./version"
    "./codec"
    "./crypto/keys/ed25519"
    "./crypto/keys/secp256k1"
    "./types/address"
)

for pkg in "${MAIN_PACKAGES[@]}"; do
    echo "Testing ${pkg}..." >&2
    TEST_OUTPUT=$(go test -mod=readonly -json -tags="${TEST_TAGS}" -timeout=2m ${pkg} 2>&1 || true)

    pkg_passed=$(echo "${TEST_OUTPUT}" | jq -r 'select(.Action == "pass" and .Test != null) | .Test' 2>/dev/null | wc -l)
    pkg_failed=$(echo "${TEST_OUTPUT}" | jq -r 'select(.Action == "fail" and .Test != null) | .Test' 2>/dev/null | wc -l)
    pkg_skipped=$(echo "${TEST_OUTPUT}" | jq -r 'select(.Action == "skip" and .Test != null) | .Test' 2>/dev/null | wc -l)

    total_passed=$((total_passed + pkg_passed))
    total_failed=$((total_failed + pkg_failed))
    total_skipped=$((total_skipped + pkg_skipped))
done

# Test sub-modules (math, errors, collections)
for module_dir in math errors collections; do
    echo "Testing ${module_dir} module..." >&2
    if [ -f "/testbed/${module_dir}/go.mod" ]; then
        MODULE_OUTPUT=$(cd "/testbed/${module_dir}" && go test -mod=readonly -json -timeout=2m ./... 2>&1 || true)

        module_passed=$(echo "${MODULE_OUTPUT}" | jq -r 'select(.Action == "pass" and .Test != null) | .Test' 2>/dev/null | wc -l)
        module_failed=$(echo "${MODULE_OUTPUT}" | jq -r 'select(.Action == "fail" and .Test != null) | .Test' 2>/dev/null | wc -l)
        module_skipped=$(echo "${MODULE_OUTPUT}" | jq -r 'select(.Action == "skip" and .Test != null) | .Test' 2>/dev/null | wc -l)

        total_passed=$((total_passed + module_passed))
        total_failed=$((total_failed + module_failed))
        total_skipped=$((total_skipped + module_skipped))
    fi
done

total_tests=$((total_passed + total_failed + total_skipped))

# Output final JSON result
echo "{\"passed\": ${total_passed}, \"failed\": ${total_failed}, \"skipped\": ${total_skipped}, \"total\": ${total_tests}}"

# Exit with appropriate code
if [ ${total_failed} -gt 0 ]; then
    exit 1
else
    exit 0
fi
