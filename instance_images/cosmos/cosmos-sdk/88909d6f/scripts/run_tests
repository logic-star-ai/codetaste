#!/bin/bash

# Test execution script for Cosmos SDK
# Runs a representative subset of tests and outputs JSON results
# Must be run after setup_shell.sh has been sourced

set -e

cd /testbed

# Test configuration
TEST_TAGS="cgo ledger test_ledger_mock norace"
TEST_ARGS="-tags=\"${TEST_TAGS}\" -timeout=15m"

# We'll run unit tests for the main module
# The full test suite takes too long, so we run a representative subset
# We'll test core packages that represent the main functionality

CORE_PACKAGES=(
    "github.com/cosmos/cosmos-sdk/baseapp"
    "github.com/cosmos/cosmos-sdk/client"
    "github.com/cosmos/cosmos-sdk/codec"
    "github.com/cosmos/cosmos-sdk/crypto/..."
    "github.com/cosmos/cosmos-sdk/types"
    "github.com/cosmos/cosmos-sdk/types/..."
    "github.com/cosmos/cosmos-sdk/x/auth/..."
    "github.com/cosmos/cosmos-sdk/x/bank/..."
    "github.com/cosmos/cosmos-sdk/server"
)

# Run tests and capture output
TEMP_OUTPUT=$(mktemp)
TEMP_JSON=$(mktemp)

# Run go test with JSON output to capture structured results
echo "Running Cosmos SDK tests..."
go test -mod=readonly -json -tags="${TEST_TAGS}" -timeout=15m "${CORE_PACKAGES[@]}" 2>&1 | tee "$TEMP_OUTPUT"

# Parse JSON output to count test results
PASSED=0
FAILED=0
SKIPPED=0

# Process each line of JSON output
while IFS= read -r line; do
    if echo "$line" | grep -q '"Action":"pass"' && echo "$line" | grep -q '"Test":"'; then
        PASSED=$((PASSED + 1))
    elif echo "$line" | grep -q '"Action":"fail"' && echo "$line" | grep -q '"Test":"'; then
        FAILED=$((FAILED + 1))
    elif echo "$line" | grep -q '"Action":"skip"' && echo "$line" | grep -q '"Test":"'; then
        SKIPPED=$((SKIPPED + 1))
    fi
done < "$TEMP_OUTPUT"

TOTAL=$((PASSED + FAILED + SKIPPED))

# Clean up
rm -f "$TEMP_OUTPUT" "$TEMP_JSON"

# Output the final JSON result
echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $SKIPPED, \"total\": $TOTAL}"
