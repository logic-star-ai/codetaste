#!/bin/bash
# Test execution script for Cosmos SDK
# This script runs the test suite and outputs results in JSON format

set -e

cd /testbed

# Initialize counters
PASSED=0
FAILED=0
SKIPPED=0
TOTAL=0

# Temporary files for test output
TMPDIR=$(mktemp -d)
trap "rm -rf $TMPDIR" EXIT

# Function to parse JSON test output and update counters
parse_test_results() {
    local output_file="$1"

    if [ ! -f "$output_file" ]; then
        return
    fi

    # Parse JSON output to count test results (not package results)
    # We only count lines that have both "Action" and "Test" fields
    local passed=$(grep '"Action":"pass"' "$output_file" 2>/dev/null | grep '"Test":' | wc -l || echo 0)
    local failed=$(grep '"Action":"fail"' "$output_file" 2>/dev/null | grep '"Test":' | wc -l || echo 0)
    local skipped=$(grep '"Action":"skip"' "$output_file" 2>/dev/null | grep '"Test":' | wc -l || echo 0)

    PASSED=$((PASSED + passed))
    FAILED=$((FAILED + failed))
    SKIPPED=$((SKIPPED + skipped))
}

# Function to run tests for a package
run_package_tests() {
    local pkg="$1"
    local tags="$2"
    local output_file="$TMPDIR/test_output_$$.json"

    echo "Testing $pkg..." >&2

    # Run tests with JSON output, capturing both stdout and stderr
    if go test -mod=readonly -json -timeout 10m -tags="$tags" "$pkg" > "$output_file" 2>&1; then
        parse_test_results "$output_file"
        return 0
    else
        # Even if tests fail, parse the results
        parse_test_results "$output_file"
        return 1
    fi
}

# Test tags matching CI configuration
TEST_TAGS="norace ledger test_ledger_mock"

# Run tests for core packages (representative subset)
# These packages provide good coverage and complete within time limit
echo "Running core package tests..." >&2

CORE_PACKAGES=(
    "github.com/cosmos/cosmos-sdk/types"
    "github.com/cosmos/cosmos-sdk/codec"
    "github.com/cosmos/cosmos-sdk/store/types"
    "github.com/cosmos/cosmos-sdk/x/auth/types"
    "github.com/cosmos/cosmos-sdk/x/bank/types"
)

for pkg in "${CORE_PACKAGES[@]}"; do
    run_package_tests "$pkg" "$TEST_TAGS" || true
done

# Run some integration tests
echo "Running integration tests..." >&2
cd /testbed/tests

INTEGRATION_PACKAGES=(
    "github.com/cosmos/cosmos-sdk/tests/integration/bank/keeper"
    "github.com/cosmos/cosmos-sdk/tests/integration/distribution/keeper"
)

for pkg in "${INTEGRATION_PACKAGES[@]}"; do
    run_package_tests "$pkg" "$TEST_TAGS" || true
done

cd /testbed

# Calculate total
TOTAL=$((PASSED + FAILED + SKIPPED))

# Ensure we have some results
if [ $TOTAL -eq 0 ]; then
    echo "Warning: No tests were counted. Running fallback test count..." >&2
    # Fallback: run a simple package and count manually
    if go test -json -timeout 5m ./codec 2>&1 | tee "$TMPDIR/fallback.json" >/dev/null; then
        parse_test_results "$TMPDIR/fallback.json"
        TOTAL=$((PASSED + FAILED + SKIPPED))
    fi
fi

# Output JSON result (this MUST be the last line of stdout)
echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $SKIPPED, \"total\": $TOTAL}"
