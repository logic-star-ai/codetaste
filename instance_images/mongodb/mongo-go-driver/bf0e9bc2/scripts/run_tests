#!/bin/bash
# run_tests - Execute the test suite and output results in JSON format
# This script runs the Go test suite and parses results into the required JSON format.

set -e

cd /testbed

# Run tests with JSON output and short mode (to skip integration tests that require MongoDB)
# The -short flag skips tests that require external dependencies like MongoDB
# Timeout is set to 60 seconds per package
# -p 1 ensures tests run sequentially to avoid resource conflicts

echo "Running Go test suite..." >&2

# Run tests and capture JSON output
# We pipe directly to Python for parsing to avoid storing large temporary files
go test -short -timeout 60s -json ./... 2>&1 | python3 -c "
import json
import sys

passed = 0
failed = 0
skipped = 0

for line in sys.stdin:
    try:
        data = json.loads(line.strip())
        # Only count individual test results (not package-level results)
        if 'Action' in data and 'Test' in data:
            action = data['Action']
            if action == 'pass':
                passed += 1
            elif action == 'fail':
                failed += 1
            elif action == 'skip':
                skipped += 1
    except:
        # Skip lines that aren't valid JSON
        pass

total = passed + failed + skipped
print(json.dumps({'passed': passed, 'failed': failed, 'skipped': skipped, 'total': total}))
"
