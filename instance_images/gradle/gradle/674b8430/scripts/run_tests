#!/bin/bash
# Test runner script for Gradle
# This script runs a representative subset of tests and outputs results in JSON format

set -e

cd /testbed

# Define projects to test (a representative subset that completes within 15 minutes)
# We focus on fast unit tests from core modules
TEST_PROJECTS=(
    ":base-services:test"
    ":logging:test"
)

# Create a temporary file for test results
RESULTS_FILE=$(mktemp)
trap "rm -f $RESULTS_FILE" EXIT

# Run tests with XML reports
echo "Running tests..."
./gradlew ${TEST_PROJECTS[@]} \
    --no-daemon \
    --console=plain \
    --no-parallel \
    --max-workers=2 \
    -Dorg.gradle.jvmargs="-Xmx1536m -XX:MaxMetaspaceSize=512m" \
    --continue \
    2>&1 | tee /tmp/gradle_test_output.log

# Parse test results from XML files
parse_test_results() {
    local passed=0
    local failed=0
    local skipped=0
    local total=0

    # Find all TEST-*.xml files generated by the test runs
    while IFS= read -r -d '' xml_file; do
        if [ -f "$xml_file" ]; then
            # Extract test counts from XML
            local tests=$(grep -oP 'tests="\K[0-9]+' "$xml_file" 2>/dev/null | head -1 || echo "0")
            local failures=$(grep -oP 'failures="\K[0-9]+' "$xml_file" 2>/dev/null | head -1 || echo "0")
            local errors=$(grep -oP 'errors="\K[0-9]+' "$xml_file" 2>/dev/null | head -1 || echo "0")
            local skips=$(grep -oP 'skipped="\K[0-9]+' "$xml_file" 2>/dev/null | head -1 || echo "0")

            total=$((total + tests))
            failed=$((failed + failures + errors))
            skipped=$((skipped + skips))
        fi
    done < <(find /testbed -name "TEST-*.xml" -path "*/test-results/*" -print0 2>/dev/null)

    passed=$((total - failed - skipped))

    # If no XML files found, check the output for summary
    if [ $total -eq 0 ]; then
        # Try to parse from Gradle output
        if [ -f /tmp/gradle_test_output.log ]; then
            # Look for test summary in output (format: "X tests completed, Y failed")
            local test_line=$(grep -oP '\d+ tests? completed' /tmp/gradle_test_output.log | tail -1 || echo "")
            if [ -n "$test_line" ]; then
                total=$(echo "$test_line" | grep -oP '^\d+' || echo "0")
                local fail_line=$(grep -oP '\d+ failed' /tmp/gradle_test_output.log | tail -1 || echo "")
                if [ -n "$fail_line" ]; then
                    failed=$(echo "$fail_line" | grep -oP '^\d+' || echo "0")
                fi
                passed=$((total - failed))
            fi
        fi
    fi

    # If still no results, report 0 (could be build failure)
    if [ $total -eq 0 ]; then
        total=0
        passed=0
        failed=0
        skipped=0
    fi

    echo "{\"passed\": $passed, \"failed\": $failed, \"skipped\": $skipped, \"total\": $total}"
}

# Parse and output results
parse_test_results
