#!/bin/bash
# Test runner script for OOT decompilation project
# This script runs the test suite and outputs results in JSON format
# Usage: /scripts/run_tests

set -e

cd /testbed

# Initialize test counters
PASSED=0
FAILED=0
SKIPPED=0
TOTAL=0

# Run the preprocess_pragmas test
echo "Running preprocess_pragmas test..."
if python3 tools/tests/test_preprocess_pragmas.py > /tmp/test_output.txt 2>&1; then
    PASSED=$((PASSED + 1))
    echo "✓ test_preprocess_pragmas PASSED"
else
    FAILED=$((FAILED + 1))
    echo "✗ test_preprocess_pragmas FAILED"
    cat /tmp/test_output.txt
fi
TOTAL=$((TOTAL + 1))

# Output the final JSON result
echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $SKIPPED, \"total\": $TOTAL}"
