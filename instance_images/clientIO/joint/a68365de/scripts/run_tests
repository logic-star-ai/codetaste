#!/bin/bash
# Test execution script for JointJS project
# Runs tests and outputs JSON with test results

set -e

cd /testbed

# Create temporary file for test output
TEST_OUTPUT=$(mktemp)

# Run tests and capture output
# We run the full test suite which includes:
# - shell:rollup-test-bundle (builds test bundle)
# - test:server (mocha tests - Node.js)
# - test:client (karma tests - browser tests via Chromium)
# - ts:test (TypeScript tests)

yarn run test > "$TEST_OUTPUT" 2>&1 || true

# Parse the output
# Mocha output format: "[jointjs]:   12 passing (13ms)"
# Karma output format: "[jointjs]: TOTAL: 1 FAILED, 1475 SUCCESS" or "[jointjs]: TOTAL: 346 SUCCESS"

MOCHA_PASSING=0
KARMA_SUCCESS=0
KARMA_FAILED=0
TS_TESTS=0

# Extract mocha passing tests (with [jointjs]: prefix)
MOCHA_LINE=$(grep -E "passing" "$TEST_OUTPUT" | tail -1 || true)
if [ -n "$MOCHA_LINE" ]; then
    MOCHA_PASSING=$(echo "$MOCHA_LINE" | grep -oE "[0-9]+" | head -1)
fi

# Extract karma results
# Get all TOTAL lines and sum them up
while IFS= read -r KARMA_LINE; do
    if [ -n "$KARMA_LINE" ]; then
        # Parse "TOTAL: 1 FAILED, 1475 SUCCESS" or "TOTAL: 346 SUCCESS"
        FAILED=$(echo "$KARMA_LINE" | grep -oE "[0-9]+ FAILED" | grep -oE "[0-9]+" || echo "0")
        SUCCESS=$(echo "$KARMA_LINE" | grep -oE "[0-9]+ SUCCESS" | grep -oE "[0-9]+" || echo "0")
        KARMA_FAILED=$((KARMA_FAILED + FAILED))
        KARMA_SUCCESS=$((KARMA_SUCCESS + SUCCESS))
    fi
done < <(grep "TOTAL:" "$TEST_OUTPUT" || true)

# Check if TypeScript tests ran (they compile TypeScript test files)
# TypeScript tests don't produce test count output, they just check compilation
# If the test command completes without TS errors, we count it as 1 successful test check
if grep -q "ts:test" "$TEST_OUTPUT"; then
    # Check if there are TypeScript errors
    if ! grep -q "error TS[0-9]" "$TEST_OUTPUT"; then
        TS_TESTS=1
    fi
fi

# Calculate totals
PASSED=$((MOCHA_PASSING + KARMA_SUCCESS + TS_TESTS))
FAILED=$KARMA_FAILED
SKIPPED=0
TOTAL=$((PASSED + FAILED + SKIPPED))

# Output JSON result
echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $SKIPPED, \"total\": $TOTAL}"

# Clean up
rm -f "$TEST_OUTPUT"

# Exit with appropriate code
if [ "$FAILED" -gt 0 ]; then
    exit 1
else
    exit 0
fi
