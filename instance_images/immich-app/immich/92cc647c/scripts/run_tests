#!/bin/bash
# Test runner script - executes the test suite
# Assumes setup_shell.sh has been sourced

set -e

cd /testbed/server

# Run tests with JSON reporter, using limited workers for reliability
# We use --json flag to get structured output
npm test -- --json --testLocationInResults --verbose=false --maxWorkers=2 2>&1 | tee /tmp/test_output.json

# Parse the JSON output from Jest
# Jest outputs multiple JSON objects, we need the last one which contains the summary
python3 << 'EOF'
import json
import sys

# Read the test output
with open('/tmp/test_output.json', 'r') as f:
    content = f.read()

# Jest outputs JSON, but may have other text mixed in
# Try to find the last valid JSON object
lines = content.strip().split('\n')
test_result = None

for line in reversed(lines):
    line = line.strip()
    if line.startswith('{') and line.endswith('}'):
        try:
            test_result = json.loads(line)
            # Check if this looks like a Jest summary
            if 'numTotalTests' in test_result or 'success' in test_result:
                break
        except json.JSONDecodeError:
            continue

if test_result and 'numTotalTests' in test_result:
    # Jest summary format
    passed = test_result.get('numPassedTests', 0)
    failed = test_result.get('numFailedTests', 0)
    skipped = test_result.get('numPendingTests', 0) + test_result.get('numTodoTests', 0)
    total = test_result.get('numTotalTests', 0)

    result = {
        "passed": passed,
        "failed": failed,
        "skipped": skipped,
        "total": total
    }
    print(json.dumps(result))

    # Exit with error code if any tests failed
    if failed > 0:
        sys.exit(1)
else:
    # Fallback: try to parse from text output
    print(json.dumps({"passed": 0, "failed": 0, "skipped": 0, "total": 0}))
    sys.exit(1)
EOF
