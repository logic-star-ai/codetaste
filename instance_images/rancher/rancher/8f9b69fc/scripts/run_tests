#!/bin/bash
set -e

cd /testbed

# Cleanup function to kill the Rancher server on exit
cleanup() {
    EXIT=$?
    if [ ! -z "$RANCHER_PID" ]; then
        kill $RANCHER_PID 2>/dev/null || true
        wait $RANCHER_PID 2>/dev/null || true
    fi
    return $EXIT
}

trap cleanup EXIT

# Prepare test data directory
rm -rf build/testdata
mkdir -p build/testdata
cd build/testdata

# Start Rancher server in the background
echo "Starting Rancher server..."
KUBECONFIG= ../../bin/rancher --add-local > rancher.log 2>&1 &
RANCHER_PID=$!

# Wait for server to be ready (check HTTP endpoint)
echo "Waiting for Rancher server to be ready..."
TIMEOUT=120
ELAPSED=0
cd ../..

while ! curl -sf http://localhost:8080/ping > /dev/null 2>&1; do
    if [ $ELAPSED -ge $TIMEOUT ]; then
        echo "ERROR: Rancher server failed to start within ${TIMEOUT}s"
        echo "Last log entries:"
        tail -n 50 build/testdata/rancher.log || true
        exit 1
    fi
    sleep 2
    ELAPSED=$((ELAPSED + 2))
    echo "Waiting... ($ELAPSED/${TIMEOUT}s)"
done

echo "Rancher server is ready!"

# Also wait a bit for HTTPS endpoint
sleep 5

# Run the tests
cd tests

# Run pytest with output captured
echo "Running tests..."

# Run pytest and capture results
set +e
python -m pytest -v --tb=short -n auto 2>&1 | tee /tmp/pytest_output.txt
PYTEST_EXIT=$?
set -e

# Parse pytest output to extract test counts
# Look for the summary line like: "7 passed in 10.23s" or "5 passed, 2 failed in 10.23s"
if [ -f /tmp/pytest_output.txt ]; then
    # Extract the last line that contains test results
    SUMMARY=$(grep -E "=+ .* (passed|failed|skipped|error)" /tmp/pytest_output.txt | tail -1 || echo "")

    # Initialize counts
    PASSED=0
    FAILED=0
    SKIPPED=0

    # Parse the summary line
    if echo "$SUMMARY" | grep -q "passed"; then
        PASSED=$(echo "$SUMMARY" | grep -oP '\d+(?= passed)' || echo "0")
    fi
    if echo "$SUMMARY" | grep -q "failed"; then
        FAILED=$(echo "$SUMMARY" | grep -oP '\d+(?= failed)' || echo "0")
    fi
    if echo "$SUMMARY" | grep -q "skipped"; then
        SKIPPED=$(echo "$SUMMARY" | grep -oP '\d+(?= skipped)' || echo "0")
    fi

    # Calculate total
    TOTAL=$((PASSED + FAILED + SKIPPED))

    # If we couldn't parse anything, try to count from verbose output
    if [ "$TOTAL" -eq 0 ]; then
        PASSED=$(grep -c "PASSED" /tmp/pytest_output.txt || echo "0")
        FAILED=$(grep -c "FAILED" /tmp/pytest_output.txt || echo "0")
        SKIPPED=$(grep -c "SKIPPED" /tmp/pytest_output.txt || echo "0")
        TOTAL=$((PASSED + FAILED + SKIPPED))
    fi
else
    PASSED=0
    FAILED=0
    SKIPPED=0
    TOTAL=0
fi

# Output JSON result
echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $SKIPPED, \"total\": $TOTAL}"

# Exit with the pytest exit code
exit $PYTEST_EXIT
