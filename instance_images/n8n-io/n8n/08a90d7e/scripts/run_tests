#!/bin/bash
# Test runner script - executes tests and outputs JSON results
# Assumes environment is already configured by setup_shell.sh

cd /testbed

# Create a temporary file for capturing output
OUTPUT_FILE=$(mktemp)

# Run tests - capture all output to temp file
# We'll run the main package tests (cli, core, workflow) which are the most representative
pnpm test --filter=n8n --filter=n8n-core --filter=n8n-workflow > "$OUTPUT_FILE" 2>&1 || true

# Parse the results and extract test counts using node
node -e "
const fs = require('fs');
let passed = 0, failed = 0, skipped = 0, total = 0;

try {
    const output = fs.readFileSync('$OUTPUT_FILE', 'utf8');

    // Look for the test summary from each package
    // Pattern: 'Tests:       6 failed, 5 skipped, 399 passed, 410 total'
    const lines = output.split('\n');

    for (const line of lines) {
        if (line.includes('Tests:') && line.includes('total')) {
            // Extract numbers from the summary line
            const failedMatch = line.match(/(\d+)\s+failed/);
            const skippedMatch = line.match(/(\d+)\s+(?:skipped|pending)/);
            const passedMatch = line.match(/(\d+)\s+passed/);
            const totalMatch = line.match(/(\d+)\s+total/);

            if (failedMatch) failed += parseInt(failedMatch[1], 10);
            if (skippedMatch) skipped += parseInt(skippedMatch[1], 10);
            if (passedMatch) passed += parseInt(passedMatch[1], 10);
            if (totalMatch) total += parseInt(totalMatch[1], 10);
        }
    }

    // If we found no summary, try alternative patterns
    if (total === 0) {
        // Look for alternative patterns
        const passedSuites = output.match(/Test Suites:.*?(\d+)\s+passed/);
        if (passedSuites) {
            // Get the last Tests: line
            const testLines = output.match(/Tests:.*?\d+\s+total/g);
            if (testLines && testLines.length > 0) {
                const lastLine = testLines[testLines.length - 1];
                const failedMatch = lastLine.match(/(\d+)\s+failed/);
                const skippedMatch = lastLine.match(/(\d+)\s+(?:skipped|pending)/);
                const passedMatch = lastLine.match(/(\d+)\s+passed/);
                const totalMatch = lastLine.match(/(\d+)\s+total/);

                if (failedMatch) failed = parseInt(failedMatch[1], 10);
                if (skippedMatch) skipped = parseInt(skippedMatch[1], 10);
                if (passedMatch) passed = parseInt(passedMatch[1], 10);
                if (totalMatch) total = parseInt(totalMatch[1], 10);
            }
        }
    }
} catch (e) {
    // Return zeros on error
}

console.log(JSON.stringify({passed, failed, skipped, total}));
"

# Clean up
rm -f "$OUTPUT_FILE"
