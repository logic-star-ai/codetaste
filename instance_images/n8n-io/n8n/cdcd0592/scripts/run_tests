#!/bin/bash
# Test execution script for n8n
# This script runs the test suite and outputs results in JSON format
# Assumes environment is already set up via setup_shell.sh

set -e

cd /testbed

# Set environment variables for testing
export JEST_JUNIT_CLASSNAME="{filepath}"
export N8N_LOG_LEVEL=silent
export DB_TYPE=sqlite
export CI=false
export COVERAGE_ENABLED=false

# Run a representative subset of backend tests that completes within 15 minutes
# We test core packages to ensure the build is working correctly
# The full test:backend suite takes 30+ minutes, so we run key packages only

echo "Running representative subset of backend tests..."

# Initialize log file
> /tmp/test_output.log

# Array of packages to test (representative subset)
PACKAGES_TO_TEST=(
    "@n8n/decorators"
    "@n8n/di"
    "@n8n/config"
    "@n8n/api-types"
    "@n8n/client-oauth2"
    "@n8n/permissions"
    "n8n-workflow"
    "n8n-core"
)

# Run tests for each package and aggregate output
for package in "${PACKAGES_TO_TEST[@]}"; do
    echo "Testing $package..." | tee -a /tmp/test_output.log
    pnpm --filter="$package" test 2>&1 | tee -a /tmp/test_output.log || true
done

# Parse the test output and aggregate results from all test runs
# Jest output format includes lines like:
# "Tests:       1 failed, 2 passed, 3 total"

# Initialize counters
PASSED=0
FAILED=0
SKIPPED=0
TOTAL=0

if [ -f /tmp/test_output.log ]; then
    # Extract all "Tests:" lines from the log (one per package)
    while IFS= read -r line; do
        # Extract numbers from each summary line
        # Format: "Tests: X failed, Y skipped, Z passed, W total"
        P=$(echo "$line" | grep -oP '\d+(?= passed)' || echo "0")
        F=$(echo "$line" | grep -oP '\d+(?= failed)' || echo "0")
        S=$(echo "$line" | grep -oP '\d+(?= skipped)' || echo "0")
        T=$(echo "$line" | grep -oP '\d+(?= total)' || echo "0")

        # Aggregate the counts
        PASSED=$((PASSED + P))
        FAILED=$((FAILED + F))
        SKIPPED=$((SKIPPED + S))
        TOTAL=$((TOTAL + T))
    done < <(grep -E "^Tests:" /tmp/test_output.log || true)
fi

# Output the required JSON format
echo "{\"passed\": ${PASSED:-0}, \"failed\": ${FAILED:-0}, \"skipped\": ${SKIPPED:-0}, \"total\": ${TOTAL:-0}}"
