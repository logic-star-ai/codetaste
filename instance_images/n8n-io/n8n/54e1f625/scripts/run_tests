#!/bin/bash
# Run test suite and output JSON results
# Must be run after setup_shell.sh has been sourced

set -e

cd /testbed

# Capture test output to temporary file
TEMP_OUTPUT=$(mktemp)

# Run backend tests with JSON reporter
# Use turbo to run tests with concurrency=1 as per package.json
pnpm test:backend 2>&1 | tee "$TEMP_OUTPUT" >/dev/null

# Parse the test output to extract test counts
# The output contains lines like:
# @n8n/imap:test: Test Suites: 1 passed, 1 total
# @n8n/imap:test: Tests:       11 passed, 11 total
# n8n:test: Test Suites: 203 passed, 203 total
# n8n:test: Tests:       2021 passed, 2021 total

# Extract all test counts and sum them
PASSED=$(grep -E "Tests:.*passed" "$TEMP_OUTPUT" | grep -oP '\d+(?= passed)' | awk '{s+=$1} END {print s}')
FAILED=$(grep -E "Tests:.*failed" "$TEMP_OUTPUT" | grep -oP '\d+(?= failed)' | awk '{s+=$1} END {print s}')
SKIPPED=$(grep -E "Tests:.*skipped" "$TEMP_OUTPUT" | grep -oP '\d+(?= skipped)' | awk '{s+=$1} END {print s}')
TOTAL=$(grep -E "Tests:.*total$" "$TEMP_OUTPUT" | grep -oP '\d+ total$' | grep -oP '\d+' | awk '{s+=$1} END {print s}')

# Default to 0 if any value is empty
PASSED=${PASSED:-0}
FAILED=${FAILED:-0}
SKIPPED=${SKIPPED:-0}
TOTAL=${TOTAL:-0}

# Output JSON result
echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $SKIPPED, \"total\": $TOTAL}"

# Clean up
rm -f "$TEMP_OUTPUT"

# Exit with appropriate code
if [ "$FAILED" -gt 0 ]; then
    exit 1
fi

exit 0
