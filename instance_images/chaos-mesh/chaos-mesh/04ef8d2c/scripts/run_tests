#!/bin/bash
set -e

cd /testbed

# Initialize counters
total_passed=0
total_failed=0
total_skipped=0
total_tests=0

# Run tests and parse verbose output
run_and_parse_tests() {
    local module_path=$1
    local packages=$2

    cd "$module_path"

    # Run tests and capture output
    local test_output
    test_output=$(CGO_ENABLED=1 go test -v $packages 2>&1 || true)

    # Count results from verbose output
    local passed
    local failed
    local skipped

    passed=$(echo "$test_output" | grep -c "^--- PASS:" || true)
    failed=$(echo "$test_output" | grep -c "^--- FAIL:" || true)
    skipped=$(echo "$test_output" | grep -c "^--- SKIP:" || true)

    # Default to 0 if empty
    passed=${passed:-0}
    failed=${failed:-0}
    skipped=${skipped:-0}

    total_passed=$((total_passed + passed))
    total_failed=$((total_failed + failed))
    total_skipped=$((total_skipped + skipped))
    total_tests=$((total_tests + passed + failed + skipped))

    # Print the output for debugging
    echo "$test_output" >&2
}

# Test API module
echo "Running API module tests..." >&2
run_and_parse_tests "/testbed/api" "./..."

# Test main module packages (exclude some problematic ones)
echo "Running main module tests..." >&2

# Run subset of tests (to complete in reasonable time)
# Focus on key packages
key_packages=(
    "./pkg/webhook/..."
    "./pkg/workflow/..."
    "./pkg/selector/..."
    "./pkg/dashboard/..."
    "./controllers/..."
    "./cmd/chaos-builder/..."
)

cd /testbed
for pkg in "${key_packages[@]}"; do
    if go list "$pkg" > /dev/null 2>&1; then
        echo "Testing $pkg..." >&2
        run_and_parse_tests "/testbed" "$pkg"
    fi
done

# Output final JSON result
echo "{\"passed\": $total_passed, \"failed\": $total_failed, \"skipped\": $total_skipped, \"total\": $total_tests}"
