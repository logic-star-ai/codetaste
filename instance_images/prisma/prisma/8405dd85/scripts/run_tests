#!/bin/bash
# Note: Do not use 'set -e' because we want to collect results from all tests
# even if some fail

# This script runs a representative subset of tests
# It assumes the environment has been set up by setup_shell.sh

cd /testbed

# We'll run tests from several key packages to get a representative sample
# We focus on unit tests that don't require databases

echo "Running Prisma test suite..."

# Initialize counters
TOTAL_PASSED=0
TOTAL_FAILED=0
TOTAL_SKIPPED=0
TOTAL_TESTS=0

# Function to run tests for a package and collect results
run_package_tests() {
    local package_name=$1
    local package_path=$2
    shift 2
    local extra_args="$@"

    echo ""
    echo "=== Running $package_name tests ==="
    cd "$package_path"

    # Run tests with Jest and capture JSON output
    local temp_output=$(mktemp)
    local test_status=0

    if [ -n "$extra_args" ]; then
        pnpm test -- $extra_args --json > "$temp_output" 2>&1 || test_status=$?
    else
        pnpm test -- --json > "$temp_output" 2>&1 || test_status=$?
    fi

    # Try to parse the JSON from the output
    # Jest outputs JSON as the last complete JSON object in stdout
    local json_data=$(tac "$temp_output" | grep -m 1 "^{" | tac)

    if [ -n "$json_data" ]; then
        local passed=$(echo "$json_data" | jq '.numPassedTests // 0' 2>/dev/null || echo "0")
        local failed=$(echo "$json_data" | jq '.numFailedTests // 0' 2>/dev/null || echo "0")
        local skipped=$(echo "$json_data" | jq '.numPendingTests // 0' 2>/dev/null || echo "0")
        local total=$(echo "$json_data" | jq '.numTotalTests // 0' 2>/dev/null || echo "0")

        TOTAL_PASSED=$((TOTAL_PASSED + passed))
        TOTAL_FAILED=$((TOTAL_FAILED + failed))
        TOTAL_SKIPPED=$((TOTAL_SKIPPED + skipped))
        TOTAL_TESTS=$((TOTAL_TESTS + total))

        echo "  $package_name: passed=$passed, failed=$failed, skipped=$skipped, total=$total"
    else
        echo "  $package_name: Could not parse test results"
        # Show last few lines for debugging
        tail -5 "$temp_output"
    fi

    rm -f "$temp_output"
    cd /testbed
}

# Run tests for select packages
# These are fast unit tests that don't require database setup

run_package_tests "@prisma/debug" "/testbed/packages/debug"
run_package_tests "@prisma/config" "/testbed/packages/config"
run_package_tests "@prisma/engines" "/testbed/packages/engines"

# For larger packages, run a subset of tests
echo ""
echo "=== Running @prisma/cli tests (subset) ==="
cd /testbed/packages/cli
temp_output=$(mktemp)
pnpm test -- --testPathPattern="(Format|Version)\\.test" --json > "$temp_output" 2>&1 || true
json_data=$(tac "$temp_output" | grep -m 1 "^{" | tac)
if [ -n "$json_data" ]; then
    passed=$(echo "$json_data" | jq '.numPassedTests // 0' 2>/dev/null || echo "0")
    failed=$(echo "$json_data" | jq '.numFailedTests // 0' 2>/dev/null || echo "0")
    skipped=$(echo "$json_data" | jq '.numPendingTests // 0' 2>/dev/null || echo "0")
    total=$(echo "$json_data" | jq '.numTotalTests // 0' 2>/dev/null || echo "0")
    TOTAL_PASSED=$((TOTAL_PASSED + passed))
    TOTAL_FAILED=$((TOTAL_FAILED + failed))
    TOTAL_SKIPPED=$((TOTAL_SKIPPED + skipped))
    TOTAL_TESTS=$((TOTAL_TESTS + total))
    echo "  @prisma/cli: passed=$passed, failed=$failed, skipped=$skipped, total=$total"
else
    echo "  @prisma/cli: Could not parse test results"
fi
rm -f "$temp_output"

echo ""
echo "==================================="
echo "Test Summary:"
echo "==================================="
echo "Passed:  $TOTAL_PASSED"
echo "Failed:  $TOTAL_FAILED"
echo "Skipped: $TOTAL_SKIPPED"
echo "Total:   $TOTAL_TESTS"
echo "==================================="

# Output the final JSON result to stdout as the LAST line
echo "{\"passed\": $TOTAL_PASSED, \"failed\": $TOTAL_FAILED, \"skipped\": $TOTAL_SKIPPED, \"total\": $TOTAL_TESTS}"

# Exit with error if there were failures
if [ $TOTAL_FAILED -gt 0 ]; then
    exit 1
fi
