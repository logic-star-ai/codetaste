#!/bin/bash
set -euo pipefail

cd /testbed

# Initialize counters
total_passed=0
total_failed=0
total_skipped=0

# Temporary files for test output
GO_TEST_OUTPUT=$(mktemp)
JQ_TEST_OUTPUT=$(mktemp)
CLI_TEST_OUTPUT=$(mktemp)

cleanup() {
    rm -f "$GO_TEST_OUTPUT" "$JQ_TEST_OUTPUT" "$CLI_TEST_OUTPUT"
}
trap cleanup EXIT

# Run Go tests with JSON output
echo "Running Go tests..." >&2
PKGS=$(find . -name "*_test.go" | xargs -n 1 dirname | sort | uniq)
go test -timeout 20m -json ${PKGS} > "$GO_TEST_OUTPUT" 2>&1 || true

# Parse Go test results
go_passed=0
go_failed=0
go_skipped=0

while IFS= read -r line; do
    if echo "$line" | grep -q '"Action":"pass"' && echo "$line" | grep -q '"Test":"'; then
        go_passed=$((go_passed + 1))
    elif echo "$line" | grep -q '"Action":"fail"' && echo "$line" | grep -q '"Test":"'; then
        go_failed=$((go_failed + 1))
    elif echo "$line" | grep -q '"Action":"skip"' && echo "$line" | grep -q '"Test":"'; then
        go_skipped=$((go_skipped + 1))
    fi
done < "$GO_TEST_OUTPUT"

echo "Go tests: passed=$go_passed, failed=$go_failed, skipped=$go_skipped" >&2

# Run jq tests
echo "Running jq tests..." >&2
jq_passed=0
jq_failed=0
jq_skipped=0

for test_file in $(find . -name "*.jq.test"); do
    if ./fq -rRs -L pkg/interp 'include "jqtest"; run_tests' "$test_file" > "$JQ_TEST_OUTPUT" 2>&1; then
        # Count the number of test cases in the file (each test is a pair of lines)
        test_count=$(grep -c "^#" "$test_file" 2>/dev/null || true)
        if [ -z "$test_count" ] || [ "$test_count" = "0" ]; then
            test_count=1
        fi
        jq_passed=$((jq_passed + test_count))
    else
        # If it fails, count as one failed test per file for simplicity
        jq_failed=$((jq_failed + 1))
    fi
done

echo "jq tests: passed=$jq_passed, failed=$jq_failed, skipped=$jq_skipped" >&2

# Run CLI tests
echo "Running CLI tests..." >&2
cli_passed=0
cli_failed=0

for exp_file in pkg/cli/test_repl.exp pkg/cli/test_cli_ctrlc.exp pkg/cli/test_cli_ctrld.exp; do
    if [ -f "$exp_file" ]; then
        if pkg/cli/test_exp.sh ./fq "$exp_file" > "$CLI_TEST_OUTPUT" 2>&1; then
            cli_passed=$((cli_passed + 1))
        else
            # Check if it was skipped due to missing expect
            if grep -q "skip as expect is not installed" "$CLI_TEST_OUTPUT"; then
                echo "CLI test skipped (expect not installed)" >&2
            else
                cli_failed=$((cli_failed + 1))
            fi
        fi
    fi
done

echo "CLI tests: passed=$cli_passed, failed=$cli_failed" >&2

# Calculate totals
total_passed=$((go_passed + jq_passed + cli_passed))
total_failed=$((go_failed + jq_failed + cli_failed))
total_skipped=$((go_skipped + jq_skipped))
total=$((total_passed + total_failed + total_skipped))

# Output final JSON result
echo "{\"passed\": $total_passed, \"failed\": $total_failed, \"skipped\": $total_skipped, \"total\": $total}"
