#!/bin/bash
# Run tests and output JSON results
# Must be run after sourcing setup_shell.sh

set -e

cd /testbed

# Run unit tests for greenDebug variant (default variant with test code)
# Using --continue to run all tests even if some fail
./gradlew testGreenDebugUnitTest --continue --no-daemon 2>&1 | tee /tmp/test_output.log || true

# Parse test results from XML reports
TEST_RESULTS_DIR="/testbed/app/build/test-results/testGreenDebugUnitTest"

if [ -d "$TEST_RESULTS_DIR" ]; then
    # Use Python to parse XML test results
    python3 << 'EOF'
import xml.etree.ElementTree as ET
import os
import glob
import json

test_results_dir = "/testbed/app/build/test-results/testGreenDebugUnitTest"
passed = 0
failed = 0
skipped = 0
total = 0

# Parse all XML test result files
xml_files = glob.glob(os.path.join(test_results_dir, "TEST-*.xml"))

for xml_file in xml_files:
    try:
        tree = ET.parse(xml_file)
        root = tree.getroot()

        # Get test suite statistics
        tests = int(root.get('tests', 0))
        failures = int(root.get('failures', 0))
        errors = int(root.get('errors', 0))
        skips = int(root.get('skipped', 0))

        total += tests
        failed += failures + errors
        skipped += skips
        passed += tests - failures - errors - skips
    except Exception as e:
        print(f"Error parsing {xml_file}: {e}", file=__import__('sys').stderr)

# Output final JSON result
result = {
    "passed": passed,
    "failed": failed,
    "skipped": skipped,
    "total": total
}
print(json.dumps(result))
EOF
else
    # No test results found, output zero results
    echo '{"passed": 0, "failed": 0, "skipped": 0, "total": 0}'
fi
