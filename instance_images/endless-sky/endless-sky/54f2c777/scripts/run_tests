#!/bin/bash
# Run tests for Endless Sky
# This script runs the test suite and outputs results in JSON format

set -e

cd /testbed

# Run the unit tests directly with Catch2
echo "Running unit tests..." >&2

# The test executable is located in the build directory
TEST_EXEC="/testbed/build/linux/tests/Debug/endless-sky-tests"

# Run the tests with XML reporter which gives us detailed results
TEST_OUTPUT=$($TEST_EXEC --reporter xml 2>&1)

# Display summary to stderr for debugging
echo "$TEST_OUTPUT" | grep -E "All tests passed|test cases" | head -5 >&2

# Parse the XML output to count test cases
# Each <TestCase> element represents one test case
TOTAL=$(echo "$TEST_OUTPUT" | grep -c '<TestCase name=' || echo "0")

# Count failed tests by looking for TestCase elements with failures > 0
# We look for the top-level OverallResults which is at the end of the XML
FAILED=$(echo "$TEST_OUTPUT" | grep -oP '<OverallResult.*?failures="\K[0-9]+' | tail -1 || echo "0")
if [ "$FAILED" = "" ]; then
    FAILED=0
fi

# Count skipped tests
SKIPPED=$(echo "$TEST_OUTPUT" | grep -oP 'skipped="true"' | wc -l || echo "0")

# Calculate passed tests
PASSED=$((TOTAL - FAILED - SKIPPED))

# Ensure we have valid numbers
[ -z "$TOTAL" ] && TOTAL=0
[ -z "$FAILED" ] && FAILED=0
[ -z "$PASSED" ] && PASSED=0
[ -z "$SKIPPED" ] && SKIPPED=0

# Output the JSON result
echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $SKIPPED, \"total\": $TOTAL}"
