#!/bin/bash
# Test runner script - executes tests and outputs JSON results
# Assumes setup_shell.sh has been sourced

cd /testbed

# Run unit tests with JSON output, excluding e2e and conformance tests
# We run a representative subset of packages to keep within 15 minute time limits
# Focus on the main packages: pkg (main codebase), cmd (commands), and internal

EXIT_CODE=0
# Run tests, parse output, and save the final JSON result
# Using -timeout=14m to ensure we have buffer for parsing
RESULT=$(go test -json -timeout=14m -mod=vendor ./pkg/... ./cmd/... ./internal/... 2>&1 | python3 /scripts/parse_test_results.py) || EXIT_CODE=$?

# Output the result
echo "$RESULT"

# Exit with the same code as the tests (if it failed)
exit $EXIT_CODE
