#!/usr/bin/env bash
#   Copyright The containerd Authors.
#   Licensed under the Apache License, Version 2.0 (the "License");

# Run nerdctl unit tests and output JSON results
# This script must be run after sourcing setup_shell.sh

set -e

# Change to testbed directory
cd /testbed

# Create temporary file for test output
TMPFILE=$(mktemp)
trap "rm -f $TMPFILE" EXIT

# Run unit tests with go test
# We'll capture the output and parse it to generate JSON
echo "Running unit tests..."
go test -v ./pkg/... 2>&1 | tee "$TMPFILE" || true

# Parse the test results
PASSED=0
FAILED=0
SKIPPED=0

# Count passing tests
PASSED=$(grep -c "^--- PASS:" "$TMPFILE" || echo 0)

# Count failing tests
FAILED=$(grep -c "^--- FAIL:" "$TMPFILE" || echo 0)

# Count skipped tests
SKIPPED=$(grep -c "^--- SKIP:" "$TMPFILE" || echo 0)

# Calculate total
TOTAL=$((PASSED + FAILED + SKIPPED))

# Output JSON result as the final line
echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $SKIPPED, \"total\": $TOTAL}"
