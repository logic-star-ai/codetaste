#!/bin/bash
# Test execution script for webpack
# Runs a subset of tests and outputs JSON results

cd /testbed

# Set Node.js options for compatibility with older OpenSSL algorithms
export NODE_OPTIONS="--openssl-legacy-provider"

# Run basic tests (ConfigTestCases, StatsTestCases, TestCasesNormal)
# These are relatively fast and representative of the test suite
# Use --json flag to get JSON output from Jest
# Allow test to fail so we can still capture results
node --max-old-space-size=4096 --trace-deprecation node_modules/jest-cli/bin/jest \
    --testMatch "<rootDir>/test/{TestCasesNormal,StatsTestCases,ConfigTestCases}.test.js" \
    --json --no-coverage 2>&1 > /tmp/test_output.txt || true

# Extract and parse JSON output using python
python3 << 'PYTHON_EOF'
import json
import sys

# Read the test output file
with open('/tmp/test_output.txt', 'r') as f:
    lines = f.readlines()

# Find the line with the Jest JSON summary (it contains numTotalTests)
json_line = None
for line in lines:
    line = line.strip()
    if line.startswith('{') and '"numTotalTests"' in line:
        # Try to parse the entire line as JSON
        try:
            data = json.loads(line)
            if 'numTotalTests' in data:
                json_line = line
                break
        except json.JSONDecodeError:
            continue

if json_line:
    try:
        data = json.loads(json_line)
        result = {
            'passed': data.get('numPassedTests', 0),
            'failed': data.get('numFailedTests', 0),
            'skipped': data.get('numPendingTests', 0),
            'total': data.get('numTotalTests', 0)
        }
        print(json.dumps(result))
    except json.JSONDecodeError as e:
        print('{"passed": 0, "failed": 0, "skipped": 0, "total": 0}')
        print(f'Error parsing JSON: {e}', file=sys.stderr)
        sys.exit(1)
else:
    print('{"passed": 0, "failed": 0, "skipped": 0, "total": 0}')
    print('Error: Could not find test results JSON', file=sys.stderr)
    sys.exit(1)
PYTHON_EOF
