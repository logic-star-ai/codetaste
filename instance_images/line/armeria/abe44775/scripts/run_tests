#!/bin/bash
# Test runner script for Armeria
# This script runs tests and outputs JSON format results

set -e

cd /testbed

# Run tests on the core module which contains most of the tests
# We skip checkstyle to save time and focus on actual tests
echo "Running Armeria tests..."
./gradlew :core:test --continue 2>&1 || true

# Parse the test results from JUnit XML files
echo "Parsing test results..."

# Create a Python script to parse XML test results
cat > /tmp/parse_tests.py << 'PYEOF'
import xml.etree.ElementTree as ET
import sys
import json
import os
from glob import glob

passed = 0
failed = 0
skipped = 0
errors = 0

# Find all TEST-*.xml files
test_results_dir = '/testbed/core/build/test-results/test'
if os.path.exists(test_results_dir):
    xml_files = glob(os.path.join(test_results_dir, 'TEST-*.xml'))

    for xml_file in xml_files:
        try:
            tree = ET.parse(xml_file)
            root = tree.getroot()

            # Get test counts from testsuite attributes
            tests = int(root.get('tests', 0))
            suite_failures = int(root.get('failures', 0))
            suite_errors = int(root.get('errors', 0))
            suite_skipped = int(root.get('skipped', 0))

            # Calculate passed tests for this suite
            suite_passed = tests - suite_failures - suite_errors - suite_skipped

            passed += suite_passed
            failed += suite_failures
            errors += suite_errors
            skipped += suite_skipped
        except Exception as e:
            print(f"Error parsing {xml_file}: {e}", file=sys.stderr)
            continue

# Errors are counted as failures
total_failed = failed + errors
total = passed + total_failed + skipped

# Output JSON result
result = {
    "passed": passed,
    "failed": total_failed,
    "skipped": skipped,
    "total": total
}

print(json.dumps(result))
PYEOF

# Run the parser
python3 /tmp/parse_tests.py
