#!/bin/bash
# run_tests - Run Cilium test suite and output results in JSON format
# This script expects the environment to be already set up via setup_shell.sh

set -e
cd /testbed

# Test packages to run - a representative subset that completes in reasonable time
# We'll focus on unit tests in the pkg directory
TEST_PKGS=(
    "./pkg/alignchecker/..."
    "./pkg/allocator/..."
    "./pkg/annotation/..."
    "./pkg/api/..."
    "./pkg/checker/..."
    "./pkg/cidr/..."
    "./pkg/client/..."
    "./pkg/clustermesh/..."
    "./pkg/command/..."
    "./pkg/comparator/..."
    "./pkg/completion/..."
    "./pkg/components/..."
    "./pkg/controller/..."
    "./pkg/counter/..."
    "./pkg/defaults/..."
    "./pkg/endpoint/..."
    "./pkg/endpointmanager/..."
    "./pkg/envoy/..."
    "./pkg/fqdn/..."
    "./pkg/identity/..."
    "./pkg/ipcache/..."
    "./pkg/ipam/..."
    "./pkg/k8s/..."
    "./pkg/labels/..."
    "./pkg/lock/..."
    "./pkg/logging/..."
    "./pkg/mac/..."
    "./pkg/maps/..."
    "./pkg/metrics/..."
    "./pkg/monitor/..."
    "./pkg/node/..."
    "./pkg/option/..."
    "./pkg/policy/..."
    "./pkg/proxy/..."
    "./pkg/service/..."
    "./pkg/spanstat/..."
    "./pkg/tuple/..."
    "./pkg/u8proto/..."
    "./pkg/version/..."
)

# Temporary file for test output
TEMP_OUTPUT=$(mktemp)
trap "rm -f $TEMP_OUTPUT" EXIT

# Variables to track test results
PASSED=0
FAILED=0
SKIPPED=0
TOTAL=0

# Run tests and capture output
echo "Running Cilium unit tests..." >&2

for pkg in "${TEST_PKGS[@]}"; do
    # Run go test with verbose output
    if go test -v -timeout=300s "$pkg" 2>&1 | tee -a "$TEMP_OUTPUT"; then
        : # Test passed
    else
        : # Test may have failed, we'll parse the results
    fi
done

# Parse test results from output
# Count PASS lines
PASSED=$(grep -c "^--- PASS:" "$TEMP_OUTPUT" 2>/dev/null) || PASSED=0
PASSED=$(echo "$PASSED" | tr -d '\n' | tr -d ' ')
PASSED=${PASSED:-0}

# Count FAIL lines
FAILED=$(grep -c "^--- FAIL:" "$TEMP_OUTPUT" 2>/dev/null) || FAILED=0
FAILED=$(echo "$FAILED" | tr -d '\n' | tr -d ' ')
FAILED=${FAILED:-0}

# Count SKIP lines
SKIPPED=$(grep -c "^--- SKIP:" "$TEMP_OUTPUT" 2>/dev/null) || SKIPPED=0
SKIPPED=$(echo "$SKIPPED" | tr -d '\n' | tr -d ' ')
SKIPPED=${SKIPPED:-0}

# Calculate total
TOTAL=$((PASSED + FAILED + SKIPPED))

# If we didn't capture individual test results, count package-level results
if [ "$TOTAL" -eq 0 ]; then
    # Count "ok" lines (package passed)
    PKG_PASSED=$(grep -c "^ok  " "$TEMP_OUTPUT" 2>/dev/null) || PKG_PASSED=0
    PKG_PASSED=$(echo "$PKG_PASSED" | tr -d '\n' | tr -d ' ')
    PKG_PASSED=${PKG_PASSED:-0}

    # Count "FAIL" lines (package failed)
    PKG_FAILED=$(grep -c "^FAIL" "$TEMP_OUTPUT" 2>/dev/null) || PKG_FAILED=0
    PKG_FAILED=$(echo "$PKG_FAILED" | tr -d '\n' | tr -d ' ')
    PKG_FAILED=${PKG_FAILED:-0}

    # Count "?" lines (no test files)
    PKG_SKIPPED=$(grep -c "^\?" "$TEMP_OUTPUT" 2>/dev/null) || PKG_SKIPPED=0
    PKG_SKIPPED=$(echo "$PKG_SKIPPED" | tr -d '\n' | tr -d ' ')
    PKG_SKIPPED=${PKG_SKIPPED:-0}

    PASSED=$PKG_PASSED
    FAILED=$PKG_FAILED
    SKIPPED=$PKG_SKIPPED
    TOTAL=$((PASSED + FAILED + SKIPPED))
fi

# Output JSON result as the last line
echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $SKIPPED, \"total\": $TOTAL}"
