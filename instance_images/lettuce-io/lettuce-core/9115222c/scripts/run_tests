#!/bin/bash
# Test execution script for Lettuce Redis Client
# Runs unit tests only (not integration tests which require Redis servers)
# Outputs JSON with test results

cd /testbed

# Run unit tests using Maven Surefire
# According to pom.xml:
# - Includes: **/*UnitTests, **/*Tests
# - Excludes: **/*Test, **/*IntegrationTests
# We run with -B (batch mode) for cleaner output
# Disable jacoco due to Java 21 compatibility issues
# Don't exit on error so we can parse results
mvn -B test -Djacoco.skip=true 2>&1 | tee /tmp/test_output.txt || true

# Parse the Maven output to extract test results
# Maven Surefire outputs a summary like:
# Tests run: X, Failures: Y, Errors: Z, Skipped: W

# Extract test results from Maven output
if grep -q "Tests run:" /tmp/test_output.txt; then
    # Get the last occurrence of the test summary line
    SUMMARY=$(grep "Tests run:" /tmp/test_output.txt | tail -1)

    # Extract numbers using sed/awk
    TOTAL=$(echo "$SUMMARY" | sed -n 's/.*Tests run: \([0-9]*\).*/\1/p')
    FAILURES=$(echo "$SUMMARY" | sed -n 's/.*Failures: \([0-9]*\).*/\1/p')
    ERRORS=$(echo "$SUMMARY" | sed -n 's/.*Errors: \([0-9]*\).*/\1/p')
    SKIPPED=$(echo "$SUMMARY" | sed -n 's/.*Skipped: \([0-9]*\).*/\1/p')

    # Calculate passed tests
    FAILED=$((FAILURES + ERRORS))
    PASSED=$((TOTAL - FAILED - SKIPPED))

    # Output JSON
    echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $SKIPPED, \"total\": $TOTAL}"
else
    # No tests found or run
    echo "{\"passed\": 0, \"failed\": 0, \"skipped\": 0, \"total\": 0}"
fi
