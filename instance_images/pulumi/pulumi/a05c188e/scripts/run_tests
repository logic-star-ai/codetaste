#!/usr/bin/env python3
"""
Run Pulumi tests and output results in JSON format.
This script runs a representative subset of fast unit tests.
"""

import json
import os
import subprocess
import sys
import re

def run_go_tests(module_dir, packages):
    """Run go test on specified packages and parse results."""
    os.chdir(module_dir)

    # Build the test command
    cmd = [
        'go', 'test',
        '-short',  # Run only short tests
        '-count=1',  # Disable test caching
        '-timeout', '15m',  # 15 minute timeout
        '-race=false',  # Disable race detector for speed
        '-json',  # Output JSON for easier parsing
    ] + packages

    try:
        result = subprocess.run(cmd, capture_output=True, text=True, timeout=900)
        return result.stdout, result.stderr, result.returncode
    except subprocess.TimeoutExpired:
        return "", "Tests timed out", 1

def parse_test_results(json_output):
    """Parse go test JSON output to extract test statistics."""
    passed = 0
    failed = 0
    skipped = 0

    # Track unique test outcomes
    test_results = {}

    for line in json_output.split('\n'):
        if not line.strip():
            continue
        try:
            event = json.loads(line)
            action = event.get('Action', '')
            test_name = event.get('Test', '')

            if not test_name:
                continue

            # Track test outcomes
            if action == 'pass':
                test_results[test_name] = 'pass'
            elif action == 'fail':
                test_results[test_name] = 'fail'
            elif action == 'skip':
                test_results[test_name] = 'skip'
        except json.JSONDecodeError:
            continue

    # Count results
    for result in test_results.values():
        if result == 'pass':
            passed += 1
        elif result == 'fail':
            failed += 1
        elif result == 'skip':
            skipped += 1

    total = passed + failed + skipped
    return passed, failed, skipped, total

def main():
    # Set environment to reduce verbosity
    os.environ['GO_TEST_PARALLELISM'] = '8'
    os.environ['GO_TEST_PKG_PARALLELISM'] = '2'

    # Test packages from pkg module - these are fast unit tests
    # We'll select a representative subset that covers core functionality
    test_packages = [
        './backend/...',
        './resource/...',
        './resource/stack/...',
        './util/...',
        './workspace/...',
    ]

    print("Running Pulumi unit tests...", file=sys.stderr)

    # Run tests from pkg module
    stdout, stderr, returncode = run_go_tests('/testbed/pkg', test_packages)

    # Parse results
    passed, failed, skipped, total = parse_test_results(stdout)

    # If we got no results, something went wrong
    if total == 0:
        # Try to extract info from stderr
        if stderr:
            print(f"Test execution error: {stderr[:500]}", file=sys.stderr)

        # Parse traditional go test output as fallback
        for line in stdout.split('\n') + stderr.split('\n'):
            if 'PASS' in line or 'FAIL' in line or 'SKIP' in line:
                print(line, file=sys.stderr)

        # If there's clearly an error, report it
        if returncode != 0 and failed == 0:
            failed = 1  # At least mark as failed
            total = 1

    # Output the final JSON result
    result = {
        "passed": passed,
        "failed": failed,
        "skipped": skipped,
        "total": total
    }

    print(json.dumps(result))

    # Exit with appropriate code
    sys.exit(0 if failed == 0 else 1)

if __name__ == '__main__':
    main()
