#!/bin/bash

# /scripts/run_tests
# This script runs the test suite and outputs results in JSON format
# Prerequisites: /scripts/setup_shell.sh must have been sourced

set -e

cd /testbed

# Run vitest with --run flag (non-watch mode)
# Temporarily rename vitest.workspace.ts to avoid running electron tests
# The workspace includes electron which requires native modules to be built

# Create a temporary file for the test output
TEMP_OUTPUT=$(mktemp)

# Temporarily hide the workspace config to only run root tests
if [ -f "vitest.workspace.ts" ]; then
    mv vitest.workspace.ts vitest.workspace.ts.bak
fi

# Run tests and capture output
yarn vitest --run 2>&1 | tee "$TEMP_OUTPUT" || true

# Restore the workspace config
if [ -f "vitest.workspace.ts.bak" ]; then
    mv vitest.workspace.ts.bak vitest.workspace.ts
fi

# Parse the output to extract test counts
# Vitest outputs a summary like:
# Test Files  X failed | Y passed (Z)
# Tests  A failed | B passed | C skipped (D)

# Extract passed tests
passed=$(grep -oP 'Tests\s+.*?(\d+)\s+passed' "$TEMP_OUTPUT" | grep -oP '\d+(?=\s+passed)' | tail -1 || echo "0")

# Extract failed tests
failed=$(grep -oP 'Tests\s+.*?(\d+)\s+failed' "$TEMP_OUTPUT" | grep -oP '\d+(?=\s+failed)' | head -1 || echo "0")

# Extract skipped tests
skipped=$(grep -oP 'Tests\s+.*?(\d+)\s+skipped' "$TEMP_OUTPUT" | grep -oP '\d+(?=\s+skipped)' | tail -1 || echo "0")

# If we couldn't extract values, default to 0
[ -z "$passed" ] && passed=0
[ -z "$failed" ] && failed=0
[ -z "$skipped" ] && skipped=0

# Calculate total
total=$((passed + failed + skipped))

# Output the required JSON format
echo "{\"passed\": $passed, \"failed\": $failed, \"skipped\": $skipped, \"total\": $total}"

# Cleanup
rm -f "$TEMP_OUTPUT"
