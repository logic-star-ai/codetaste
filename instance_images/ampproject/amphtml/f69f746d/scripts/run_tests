#!/bin/bash
# Run tests for AMP HTML project
# This script assumes the environment has been set up via setup_shell.sh

set -e

cd /testbed

# Run ava tests and capture output
echo "Running ava tests..." >&2
AVA_OUTPUT=$(gulp ava 2>&1)
AVA_EXIT_CODE=$?

# Parse ava test results (TAP format)
# Extract from lines like: "# pass 7" and "# fail 0"
AVA_PASS=$(echo "$AVA_OUTPUT" | grep "^# pass" | awk '{print $3}')
AVA_FAIL=$(echo "$AVA_OUTPUT" | grep "^# fail" | awk '{print $3}')
AVA_TOTAL=$(echo "$AVA_OUTPUT" | grep "^# tests" | awk '{print $3}')

# Default to 0 if parsing failed
AVA_PASS=${AVA_PASS:-0}
AVA_FAIL=${AVA_FAIL:-0}
AVA_TOTAL=${AVA_TOTAL:-0}

# Run jest tests and capture output
echo "Running jest tests..." >&2
JEST_OUTPUT=$(node node_modules/jest/bin/jest.js 2>&1)
JEST_EXIT_CODE=$?

# Parse jest test results
# Jest output format: "✔ 17 passing"
JEST_PASS=$(echo "$JEST_OUTPUT" | grep -oP '✔ \K\d+(?= passing)' || echo "0")

# Get total from "Found X test suites" or "Ran X tests"
JEST_TOTAL=$(echo "$JEST_OUTPUT" | grep -oP 'Ran \K\d+(?= tests)' || echo "0")
JEST_FAIL=0

# Calculate totals
TOTAL_PASS=$((AVA_PASS + JEST_PASS))
TOTAL_FAIL=$((AVA_FAIL + JEST_FAIL))
TOTAL_TESTS=$((AVA_TOTAL + JEST_TOTAL))

# Output JSON result
echo "{\"passed\": $TOTAL_PASS, \"failed\": $TOTAL_FAIL, \"skipped\": 0, \"total\": $TOTAL_TESTS}"

# Exit with error if any tests failed
if [ $TOTAL_FAIL -gt 0 ] || [ $AVA_EXIT_CODE -ne 0 ] || [ $JEST_EXIT_CODE -ne 0 ]; then
    exit 1
fi

exit 0
