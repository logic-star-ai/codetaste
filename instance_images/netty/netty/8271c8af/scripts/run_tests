#!/bin/bash
# Test runner script for Netty project
# This script runs the test suite and outputs results in JSON format

set -e

cd /testbed

# Set Java 8 environment (same as setup_shell.sh)
export JAVA_HOME=/usr/lib/jvm/java-8-openjdk-amd64
export PATH=$JAVA_HOME/bin:$PATH
export MAVEN_OPTS="-Xmx1024m"

# Run tests on a subset of core modules to complete within 15 minutes
# We'll test the most critical modules: common, buffer, codec, transport, handler
MODULES="common buffer codec transport handler"

# Create a temporary file for test output
TEST_OUTPUT=$(mktemp)

# Run Maven tests and capture output
echo "Running tests..." >&2
if mvn test -pl "${MODULES// /,}" 2>&1 | tee "$TEST_OUTPUT" >&2; then
    TEST_STATUS=0
else
    TEST_STATUS=$?
fi

# Parse the Maven output to extract test statistics
# Maven Surefire outputs a summary like:
# Tests run: 123, Failures: 4, Errors: 5, Skipped: 6

# Initialize counters
TOTAL=0
PASSED=0
FAILED=0
SKIPPED=0

# Extract test results from each module
while IFS= read -r line; do
    if [[ "$line" =~ Tests\ run:\ ([0-9]+),\ Failures:\ ([0-9]+),\ Errors:\ ([0-9]+),\ Skipped:\ ([0-9]+) ]]; then
        run="${BASH_REMATCH[1]}"
        failures="${BASH_REMATCH[2]}"
        errors="${BASH_REMATCH[3]}"
        skipped="${BASH_REMATCH[4]}"

        TOTAL=$((TOTAL + run))
        FAILED=$((FAILED + failures + errors))
        SKIPPED=$((SKIPPED + skipped))
    fi
done < "$TEST_OUTPUT"

# Calculate passed tests
PASSED=$((TOTAL - FAILED - SKIPPED))

# Clean up temporary file
rm -f "$TEST_OUTPUT"

# Output JSON result
echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $SKIPPED, \"total\": $TOTAL}"
