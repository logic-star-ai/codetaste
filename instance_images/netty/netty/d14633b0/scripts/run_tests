#!/bin/bash
# Test execution script for Netty project
# Runs a representative subset of tests from core modules

set -e

cd /testbed

# Define core modules to test (to complete within ~15 minutes)
# These are the most fundamental and widely used modules
MODULES="common,buffer,codec,codec-http,transport,handler,resolver"

echo "Running tests for modules: $MODULES"
echo "This may take several minutes..."

# Run tests with maven-surefire-plugin
# -pl: project list (modules to test)
# -am: also make dependencies
# -Dmaven.test.failure.ignore=true: continue testing even if some tests fail
# -Dsurefire.useFile=false: output directly to console
./mvnw test -pl $MODULES -am \
    -Dmaven.test.failure.ignore=true \
    -Dsurefire.useFile=false \
    -T 1C \
    2>&1 | tee /tmp/test_output.log

# Parse the test results from the Maven output
# Look for lines like "Tests run: X, Failures: Y, Errors: Z, Skipped: W"
# Maven provides a summary at the end with aggregate results

# Extract the final summary line
SUMMARY_LINE=$(grep -E "^(\[INFO\]|\[WARNING\]) Tests run:" /tmp/test_output.log | tail -1)

if [ -z "$SUMMARY_LINE" ]; then
    echo "Error: Could not find test summary in output"
    echo '{"passed": 0, "failed": 0, "skipped": 0, "total": 0}'
    exit 1
fi

# Parse the numbers from the summary line
# Example: "[INFO] Tests run: 647, Failures: 0, Errors: 0, Skipped: 8"
TESTS_RUN=$(echo "$SUMMARY_LINE" | sed -n 's/.*Tests run: \([0-9]*\).*/\1/p')
FAILURES=$(echo "$SUMMARY_LINE" | sed -n 's/.*Failures: \([0-9]*\).*/\1/p')
ERRORS=$(echo "$SUMMARY_LINE" | sed -n 's/.*Errors: \([0-9]*\).*/\1/p')
SKIPPED=$(echo "$SUMMARY_LINE" | sed -n 's/.*Skipped: \([0-9]*\).*/\1/p')

# Calculate passed tests
FAILED=$((FAILURES + ERRORS))
PASSED=$((TESTS_RUN - FAILED - SKIPPED))

# Output JSON result
echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $SKIPPED, \"total\": $TESTS_RUN}"
