#!/bin/bash
# Test execution script for Netty project
# Runs tests and outputs results in JSON format

set -e

cd /testbed

# Run Maven tests excluding the tarball module which has dependency issues
# The testsuite module has some flaky tests, but we'll run them anyway
echo "Running tests..."
mvn test -Dmaven.test.failure.ignore=true 2>&1 | tee /tmp/maven_test_output.log > /dev/null

# Parse the surefire XML reports to get accurate test counts
echo "Parsing test results..."

# Initialize counters
total_tests=0
total_failures=0
total_errors=0
total_skipped=0

# Find all surefire XML test reports
for xml_file in $(find /testbed -name "TEST-*.xml" -path "*/surefire-reports/*" 2>/dev/null); do
    if [ -f "$xml_file" ]; then
        # Extract test counts from XML using grep and sed
        tests=$(grep -oP 'testsuite.*?tests="\K[0-9]+' "$xml_file" | head -1)
        failures=$(grep -oP 'testsuite.*?failures="\K[0-9]+' "$xml_file" | head -1)
        errors=$(grep -oP 'testsuite.*?errors="\K[0-9]+' "$xml_file" | head -1)
        skipped=$(grep -oP 'testsuite.*?skipped="\K[0-9]+' "$xml_file" | head -1)

        # Add to totals (default to 0 if not found)
        total_tests=$((total_tests + ${tests:-0}))
        total_failures=$((total_failures + ${failures:-0}))
        total_errors=$((total_errors + ${errors:-0}))
        total_skipped=$((total_skipped + ${skipped:-0}))
    fi
done

# Calculate passed tests (total - failures - errors - skipped)
total_passed=$((total_tests - total_failures - total_errors - total_skipped))

# Ensure non-negative passed count
if [ $total_passed -lt 0 ]; then
    total_passed=0
fi

# Output JSON result
echo "{\"passed\": $total_passed, \"failed\": $((total_failures + total_errors)), \"skipped\": $total_skipped, \"total\": $total_tests}"
