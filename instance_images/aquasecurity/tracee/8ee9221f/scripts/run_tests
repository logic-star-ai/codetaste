#!/bin/bash
# Test execution script for Tracee
# Runs the test suite and outputs results in JSON format
# Must be run after setup_shell.sh has been sourced

set -e

cd /testbed

# Run unit tests with JSON output
# We use go test -json to get structured output, then parse it

echo "Running unit tests..." >&2

# Create a temporary file for test output
TMPFILE=$(mktemp)
trap "rm -f $TMPFILE" EXIT

# Run tests with JSON output
# -short: skip long-running tests
# -tags ebpf: include eBPF-specific code
# We exclude integration tests and run only unit tests for speed
go test -json -tags ebpf -short ./cmd/... ./pkg/... ./signatures/... 2>&1 | tee "$TMPFILE" >&2

# Parse JSON output to count results
# The go test -json format emits lines like:
# {"Time":"...","Action":"pass","Package":"...","Test":"TestName","Elapsed":...}
# {"Time":"...","Action":"fail","Package":"...","Test":"TestName","Elapsed":...}
# {"Time":"...","Action":"skip","Package":"...","Test":"TestName","Elapsed":...}
# We need to count only lines that have "Test" field (individual test results)

PASSED=$(grep '"Action":"pass"' "$TMPFILE" | grep -c '"Test":' || true)
FAILED=$(grep '"Action":"fail"' "$TMPFILE" | grep -c '"Test":' || true)
SKIPPED=$(grep '"Action":"skip"' "$TMPFILE" | grep -c '"Test":' || true)
TOTAL=$((PASSED + FAILED + SKIPPED))

# Output the required JSON format to stdout
echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $SKIPPED, \"total\": $TOTAL}"
