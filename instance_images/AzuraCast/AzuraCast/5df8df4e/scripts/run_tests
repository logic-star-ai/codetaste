#!/bin/bash
set -e

cd /testbed

# Run Unit tests using Codeception
# The unit tests are simpler and don't require database setup

# Create a temporary file for codeception output
TEMP_OUTPUT=$(mktemp)

# Run only Unit tests to keep execution time reasonable
vendor/bin/codecept run Unit --no-interaction 2>&1 | tee "$TEMP_OUTPUT" || true

# Parse the test output
# Codeception outputs in format:
# "Tests: X, Assertions: Y, Errors: Z, Failures: W."
# or "Tests: X, Assertions: Y, Errors: Z, Failures: W, Skipped: S."

python3 - "$TEMP_OUTPUT" <<'PYEOF'
import sys
import json
import re

try:
    with open(sys.argv[1], 'r') as f:
        content = f.read()

    passed = 0
    failed = 0
    errors = 0
    skipped = 0
    total = 0

    # Look for the summary line at the end
    # Format: "Tests: 7, Assertions: 10, Errors: 3."
    # or "ERRORS!" followed by "Tests: 7, Assertions: 10, Errors: 3."

    # Try to find the test summary
    tests_match = re.search(r'Tests:\s*(\d+)', content)
    if tests_match:
        total = int(tests_match.group(1))

    failures_match = re.search(r'Failures:\s*(\d+)', content)
    if failures_match:
        failed = int(failures_match.group(1))

    errors_match = re.search(r'Errors:\s*(\d+)', content)
    if errors_match:
        errors = int(errors_match.group(1))

    skipped_match = re.search(r'Skipped:\s*(\d+)', content)
    if skipped_match:
        skipped = int(skipped_match.group(1))

    # Calculate passed tests
    # Total = passed + failed + errors + skipped
    passed = max(0, total - failed - errors - skipped)

    # Combine failures and errors into failed count
    total_failed = failed + errors

    print(json.dumps({
        "passed": passed,
        "failed": total_failed,
        "skipped": skipped,
        "total": total
    }))
except Exception as e:
    # Fallback: return zero results
    print(json.dumps({
        "passed": 0,
        "failed": 0,
        "skipped": 0,
        "total": 0
    }))
    sys.exit(0)
PYEOF

# Cleanup
rm -f "$TEMP_OUTPUT"
