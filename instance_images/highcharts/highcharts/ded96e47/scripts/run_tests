#!/bin/bash
# Test runner script for Highcharts
# This script runs the ts-node-unit-tests and outputs results in JSON format

set -e

cd /testbed

# Create a temporary file for TAP output
TAP_OUTPUT=$(mktemp)

# Run the ts-node-unit-tests with CI environment variable set
# This ensures TAP reporter is used
export CI=true
export NODE_ENV=test

# Run the tests and capture output
npm run test-node > "$TAP_OUTPUT" 2>&1 || true

# Parse TAP output to extract test results
# TAP format includes lines like:
# ok 1 - test name
# not ok 2 - test name
# # tests 10
# # pass 8
# # fail 2
# # skip 0

# Initialize counters
PASSED=0
FAILED=0
SKIPPED=0
TOTAL=0

# Parse the TAP output
while IFS= read -r line; do
    # Check for summary lines at the end
    if [[ $line =~ ^#[[:space:]]*tests[[:space:]]+([0-9]+) ]]; then
        TOTAL="${BASH_REMATCH[1]}"
    fi
    if [[ $line =~ ^#[[:space:]]*pass[[:space:]]+([0-9]+) ]]; then
        PASSED="${BASH_REMATCH[1]}"
    fi
    if [[ $line =~ ^#[[:space:]]*fail[[:space:]]+([0-9]+) ]]; then
        FAILED="${BASH_REMATCH[1]}"
    fi
    if [[ $line =~ ^#[[:space:]]*skip[[:space:]]+([0-9]+) ]]; then
        SKIPPED="${BASH_REMATCH[1]}"
    fi
done < "$TAP_OUTPUT"

# If we didn't find summary lines, try counting individual results
if [ "$TOTAL" -eq 0 ]; then
    # Count ok/not ok lines
    PASSED=$(grep -c "^ok [0-9]" "$TAP_OUTPUT" || echo 0)
    FAILED=$(grep -c "^not ok [0-9]" "$TAP_OUTPUT" || echo 0)
    SKIPPED=$(grep -c "# SKIP" "$TAP_OUTPUT" || echo 0)
    TOTAL=$((PASSED + FAILED + SKIPPED))
fi

# Clean up temp file
rm -f "$TAP_OUTPUT"

# Output JSON result
echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $SKIPPED, \"total\": $TOTAL}"
