#!/bin/bash
# Test execution script for Actual Budget
# Runs the test suite and outputs JSON results

set -e

cd /testbed

# Ensure we're using the right node version
export NVM_DIR="/opt/nvm"
if [ -s "$NVM_DIR/nvm.sh" ]; then
    source "$NVM_DIR/nvm.sh"
    nvm use 18.16.0 >/dev/null 2>&1
fi

# Initialize counters
TOTAL_PASSED=0
TOTAL_FAILED=0
TOTAL_SKIPPED=0
TOTAL_TESTS=0

# Function to parse Jest output and extract test counts
parse_jest_output() {
    local output="$1"
    # Look for the "Tests:" line which has the format: "Tests:       N failed, M skipped, K passed, L total"
    local tests_line=$(echo "$output" | grep -E "^Tests:" || echo "")

    if [ -n "$tests_line" ]; then
        local passed=$(echo "$tests_line" | grep -oP '(\d+) passed' | grep -oP '\d+' || echo "0")
        local failed=$(echo "$tests_line" | grep -oP '(\d+) failed' | grep -oP '\d+' || echo "0")
        local skipped=$(echo "$tests_line" | grep -oP '(\d+) skipped' | grep -oP '\d+' || echo "0")

        TOTAL_PASSED=$((TOTAL_PASSED + passed))
        TOTAL_FAILED=$((TOTAL_FAILED + failed))
        TOTAL_SKIPPED=$((TOTAL_SKIPPED + skipped))
    fi
}

# Run loot-core tests (both node and web)
echo "Running loot-core tests..."
LOOT_OUTPUT=$(node .yarn/releases/yarn-4.3.1.cjs workspace loot-core test:node 2>&1 || true)
parse_jest_output "$LOOT_OUTPUT"

# Run crdt tests
echo "Running crdt tests..."
CRDT_OUTPUT=$(node .yarn/releases/yarn-4.3.1.cjs workspace @actual-app/crdt test 2>&1 || true)
parse_jest_output "$CRDT_OUTPUT"

# Run sync-server tests
echo "Running sync-server tests..."
SYNC_OUTPUT=$(node .yarn/releases/yarn-4.3.1.cjs workspace @actual-app/sync-server test 2>&1 || true)
parse_jest_output "$SYNC_OUTPUT"

# Run API tests
echo "Running API tests..."
API_OUTPUT=$(node .yarn/releases/yarn-4.3.1.cjs workspace @actual-app/api test 2>&1 || true)
parse_jest_output "$API_OUTPUT"

# Calculate totals
TOTAL_TESTS=$((TOTAL_PASSED + TOTAL_FAILED + TOTAL_SKIPPED))

# Output JSON result
echo "{\"passed\": $TOTAL_PASSED, \"failed\": $TOTAL_FAILED, \"skipped\": $TOTAL_SKIPPED, \"total\": $TOTAL_TESTS}"
