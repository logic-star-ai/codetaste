#!/bin/bash
# Test runner script for NSQ
# This script runs the NSQ test suite and outputs results as JSON

set -e

cd /testbed

# Build and run nsqlookupd in background
LOOKUP_LOGFILE=$(mktemp -t nsqlookupd.XXXXXXX)
echo "Building and starting nsqlookupd..." >&2
go build -o /tmp/nsqlookupd ./apps/nsqlookupd/ 2>&1 >&2
/tmp/nsqlookupd --broadcast-address=127.0.0.1 >$LOOKUP_LOGFILE 2>&1 &
LOOKUPD_PID=$!

# Build and run nsqd in background
NSQD_LOGFILE=$(mktemp -t nsqd.XXXXXXX)
echo "Building and starting nsqd..." >&2
go build -o /tmp/nsqd ./apps/nsqd 2>&1 >&2
/tmp/nsqd --data-path=/tmp/nsq-test-data --broadcast-address=127.0.0.1 \
    --lookupd-tcp-address=127.0.0.1:4160 \
    --tls-cert=nsqd/test/certs/cert.pem \
    --tls-key=nsqd/test/certs/key.pem \
    --tls-min-version=tls1.0 >$NSQD_LOGFILE 2>&1 &
NSQD_PID=$!

# Wait for services to start
sleep 0.5

# Run tests and capture output
TEST_OUTPUT=$(mktemp)

# Cleanup function to kill background services
cleanup() {
    # Parse test results before cleanup
    if [ -f "$TEST_OUTPUT" ]; then
        # Count passed, failed, and skipped tests
        # Use cat to avoid issues with binary characters
        PASSED=$(cat $TEST_OUTPUT | grep -a "^--- PASS:" | wc -l)
        FAILED=$(cat $TEST_OUTPUT | grep -a "^--- FAIL:" | wc -l)
        SKIPPED=$(cat $TEST_OUTPUT | grep -a "^--- SKIP:" | wc -l)

        # Ensure we have valid numbers (trim whitespace)
        PASSED=$(echo $PASSED | tr -d '[:space:]')
        FAILED=$(echo $FAILED | tr -d '[:space:]')
        SKIPPED=$(echo $SKIPPED | tr -d '[:space:]')

        # Default to 0 if empty
        PASSED=${PASSED:-0}
        FAILED=${FAILED:-0}
        SKIPPED=${SKIPPED:-0}

        TOTAL=$((PASSED + FAILED + SKIPPED))

        # Output JSON result
        echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $SKIPPED, \"total\": $TOTAL}"

        # Clean up temp file
        rm -f $TEST_OUTPUT
    fi

    echo "Cleaning up..." >&2
    if [ ! -z "$NSQD_PID" ]; then
        kill -s TERM $NSQD_PID 2>/dev/null || true
        wait $NSQD_PID 2>/dev/null || true
    fi
    if [ ! -z "$LOOKUPD_PID" ]; then
        kill -s TERM $LOOKUPD_PID 2>/dev/null || true
        wait $LOOKUPD_PID 2>/dev/null || true
    fi
    rm -rf /tmp/nsq-test-data 2>/dev/null || true
    rm -f $LOOKUP_LOGFILE $NSQD_LOGFILE 2>/dev/null || true
}
trap cleanup INT TERM EXIT

# Run go test on all packages
echo "Running tests..." >&2
set +e  # Don't exit on test failures
go test -timeout 60s -v ./... 2>&1 | tee $TEST_OUTPUT
TEST_EXIT_CODE=$?
set -e

# The cleanup trap will handle parsing and output
