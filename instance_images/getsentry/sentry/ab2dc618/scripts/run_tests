#!/bin/bash
# Test execution script for Sentry
# This script runs a representative subset of tests and outputs results in JSON format
set -e

cd /testbed

# Run a subset of tests that are representative and finish within 15 minutes
# We'll focus on core utility and model tests that don't require external services

# Select a good representative subset of fast unit tests
TEST_PATHS=(
    "tests/sentry/utils/test_strings.py"
    "tests/sentry/utils/test_json.py"
    "tests/sentry/utils/test_dates.py"
    "tests/sentry/utils/test_email"
    "tests/sentry/models/test_organization.py"
    "tests/sentry/models/test_project.py"
    "tests/sentry/models/test_user.py"
    "tests/sentry/api/test_utils.py"
    "tests/sentry/testutils"
)

# Create a temporary file for pytest JSON output
TEMP_JSON=$(mktemp)

# Run pytest with JSON report
echo "Running tests..."
python -m pytest \
    tests/sentry/utils/test_strings.py \
    tests/sentry/utils/test_json.py \
    tests/sentry/utils/test_dates.py \
    tests/sentry/models/test_organization.py \
    tests/sentry/models/test_project.py \
    tests/sentry/testutils \
    -v \
    --tb=short \
    --maxfail=50 \
    --json-report \
    --json-report-file="$TEMP_JSON" \
    --json-report-omit=log \
    -p no:warnings \
    --nomigrations \
    2>&1 | tail -20 || true

# Parse the JSON report and output the required format
if [ -f "$TEMP_JSON" ]; then
    python3 << 'PYTHON_SCRIPT'
import json
import sys

try:
    with open(sys.argv[1], 'r') as f:
        data = json.load(f)

    summary = data.get('summary', {})

    # Extract test counts
    passed = summary.get('passed', 0)
    failed = summary.get('failed', 0)
    skipped = summary.get('skipped', 0)
    total = summary.get('total', 0)

    # Output the required JSON format
    result = {
        "passed": passed,
        "failed": failed,
        "skipped": skipped,
        "total": total
    }

    print(json.dumps(result))

except Exception as e:
    # Fallback output if parsing fails
    print(json.dumps({"passed": 0, "failed": 0, "skipped": 0, "total": 0}))
    sys.exit(1)

PYTHON_SCRIPT
    PYTHON_SCRIPT_EXIT=$?

    # Clean up temp file
    rm -f "$TEMP_JSON"

    exit $PYTHON_SCRIPT_EXIT
else
    echo '{"passed": 0, "failed": 0, "skipped": 0, "total": 0}'
    exit 1
fi
