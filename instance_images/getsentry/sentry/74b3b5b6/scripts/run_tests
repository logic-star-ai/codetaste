#!/bin/bash
# Test execution script
# This script runs tests and outputs results in JSON format

set -euo pipefail

cd /testbed

# Ensure we're in the virtual environment
if [ -z "${VIRTUAL_ENV:-}" ]; then
    echo "ERROR: Virtual environment not activated. Please run: source /scripts/setup_shell.sh"
    exit 1
fi

# Unset DJANGO_SETTINGS_MODULE - pytest will use test settings
unset DJANGO_SETTINGS_MODULE

# Create artifacts directory
mkdir -p .artifacts

echo "==> Running Python tests..."

# Run a representative subset of tests that should complete within 15 minutes
# We'll run tests from a few key modules to get a good sample
# Focus on unit tests that don't require heavy setup

# Using pytest with json-report plugin to capture results
# Run a subset of tests - focused on utils and auth which are more standalone
python3 -b -m pytest \
    tests/sentry/utils/test_json.py \
    tests/sentry/utils/test_snowflake.py \
    tests/sentry/utils/test_codecs.py \
    tests/sentry/utils/test_geo.py \
    tests/sentry/auth \
    --tb=short \
    --nomigrations \
    --json-report \
    --json-report-file=".artifacts/pytest.json" \
    --json-report-omit=log \
    -v \
    2>&1 | tee .artifacts/test_output.log || true

# Parse the JSON report to extract test counts
if [ -f ".artifacts/pytest.json" ]; then
    python3 << 'PYEOF'
import json
import sys

try:
    with open(".artifacts/pytest.json", "r") as f:
        data = json.load(f)

    summary = data.get("summary", {})
    # Get counts with defaults - not all keys are present if count is 0
    passed = summary.get("passed", 0)
    failed = summary.get("failed", 0)
    error = summary.get("error", 0)
    skipped = summary.get("skipped", 0)
    total = summary.get("total", summary.get("collected", 0))
    
    # Errors and failures are both considered failed tests
    failed_total = failed + error

    # Output the required JSON format
    result = {
        "passed": passed,
        "failed": failed_total,
        "skipped": skipped,
        "total": total
    }
    print(json.dumps(result))
except Exception as e:
    print(f'{{"passed": 0, "failed": 0, "skipped": 0, "total": 0}}', file=sys.stderr)
    print(f"Error parsing test results: {e}", file=sys.stderr)
    sys.exit(1)
PYEOF
else
    echo "ERROR: Test report not generated"
    echo '{"passed": 0, "failed": 0, "skipped": 0, "total": 0}'
    exit 1
fi
