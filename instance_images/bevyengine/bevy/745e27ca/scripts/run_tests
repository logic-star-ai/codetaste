#!/bin/bash
# Test execution script for Bevy
# Runs the test suite and outputs JSON results

set -e

cd /testbed

# Create a temporary file for test output
TEMP_OUTPUT=$(mktemp)

# Run tests and capture output
# Use --no-fail-fast to run all tests even if some fail
# We capture both stdout and stderr
# Run a representative subset of core crates to keep test time under 15 minutes
# This includes the most important crates: ecs, math, utils, transform, etc.
# Note: bevy_mikktspace excluded due to compilation issues on HEAD
cargo test \
  -p bevy_math \
  -p bevy_utils \
  -p bevy_reflect \
  -p bevy_ecs \
  -p bevy_transform \
  -p bevy_hierarchy \
  -p bevy_time \
  -p bevy_tasks \
  -p bevy_log \
  -p bevy_ptr \
  --lib --bins --tests --benches --no-fail-fast 2>&1 | tee "$TEMP_OUTPUT" || true

# Parse the output to count test results
# Cargo test output includes a summary line like:
# "test result: ok. 123 passed; 0 failed; 5 ignored; 0 measured; 0 filtered out; finished in 1.23s"

# Try to find the summary line(s) and extract counts
# There may be multiple test result lines for different test binaries
PASSED=0
FAILED=0
SKIPPED=0

# Extract all test result lines and sum them
# Updated regex to ensure we match the full number (word boundary)
while IFS= read -r line; do
    if [[ "$line" =~ test\ result:.*[^0-9]([0-9]+)\ passed\;\ ([0-9]+)\ failed\;\ ([0-9]+)\ ignored ]]; then
        P="${BASH_REMATCH[1]}"
        F="${BASH_REMATCH[2]}"
        S="${BASH_REMATCH[3]}"
        PASSED=$((PASSED + P))
        FAILED=$((FAILED + F))
        SKIPPED=$((SKIPPED + S))
    fi
done < "$TEMP_OUTPUT"

TOTAL=$((PASSED + FAILED + SKIPPED))

# If we didn't find any results, check for individual test lines
if [ "$TOTAL" -eq 0 ]; then
    # Count individual test result lines
    PASSED=$(grep -c "^test .* \.\.\. ok$" "$TEMP_OUTPUT" 2>/dev/null || echo 0)
    FAILED=$(grep -c "^test .* \.\.\. FAILED$" "$TEMP_OUTPUT" 2>/dev/null || echo 0)
    SKIPPED=$(grep -c "^test .* \.\.\. ignored$" "$TEMP_OUTPUT" 2>/dev/null || echo 0)
    TOTAL=$((PASSED + FAILED + SKIPPED))
fi

# Clean up
rm -f "$TEMP_OUTPUT"

# Output the final JSON result
echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $SKIPPED, \"total\": $TOTAL}"
