#!/bin/bash
# This script runs the test suite and outputs results in JSON format.
# It relies on the environment being set up by setup_shell.sh

set -e
cd /testbed

# Run tests with standard output
# According to tools/ci/src/commands/test.rs, the main test command is:
# cargo test --workspace --lib --bins --tests --benches

# For a representative subset that finishes in ~15 minutes, we'll run:
# - All library tests (--lib)
# - All integration tests in the tests/ directory (--tests)
# Skip bins and benches to keep it reasonable

echo "Running Bevy test suite..." >&2

# Create a temporary file for the test output
TEMP_OUTPUT=$(mktemp)

# Run tests and capture output
# We'll run without --no-fail-fast so we can see all results
set +e
cargo test --workspace --lib --tests 2>&1 | tee "$TEMP_OUTPUT" >&2
TEST_EXIT_CODE=$?
set -e

# Parse the output to extract test results
# Look for all the test result summary lines like: "test result: ok. 123 passed; 0 failed; 5 ignored; 0 measured; 0 filtered out"
# There will be multiple such lines (one per test binary), so we need to sum them up

PASSED=0
FAILED=0
SKIPPED=0

# Extract all result lines and sum up the numbers
while IFS= read -r line; do
    if [[ "$line" =~ test\ result: ]]; then
        # Extract passed count
        if [[ "$line" =~ ([0-9]+)\ passed ]]; then
            PASSED=$((PASSED + ${BASH_REMATCH[1]}))
        fi
        # Extract failed count
        if [[ "$line" =~ ([0-9]+)\ failed ]]; then
            FAILED=$((FAILED + ${BASH_REMATCH[1]}))
        fi
        # Extract ignored count
        if [[ "$line" =~ ([0-9]+)\ ignored ]]; then
            SKIPPED=$((SKIPPED + ${BASH_REMATCH[1]}))
        fi
    fi
done < "$TEMP_OUTPUT"

# Calculate total
TOTAL=$((PASSED + FAILED + SKIPPED))

# Clean up
rm -f "$TEMP_OUTPUT"

# Output the final JSON result to stdout
echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $SKIPPED, \"total\": $TOTAL}"

# Exit with the test exit code
exit $TEST_EXIT_CODE
