#!/bin/bash
# Test execution script
# This script runs a representative subset of tests and outputs JSON results

set -e

cd /testbed

# Run unit tests and capture output in JSON format
# We'll run tests from a representative subset that finishes within 15 minutes

# Select representative unit test directories from the codebase
# These packages represent the core functionality without running lengthy integration tests
UNIT_TEST_PACKAGES=(
    "./common/cache"
    "./common/clock"
    "./common/cluster"
    "./common/collection"
    "./common/convert"
    "./common/dynamicconfig"
    "./common/headers"
    "./common/log"
    "./common/membership"
    "./common/metrics"
    "./common/namespace"
    "./common/primitives"
    "./common/quotas"
    "./common/rpc"
    "./common/searchattribute"
    "./common/util"
    "./service/history/configs"
    "./service/history/queues"
    "./service/matching/configs"
    "./client"
    "./temporal"
    "./temporaltest"
)

# Prepare temporary output file
TEMP_OUTPUT=$(mktemp)

# Function to clean up temporary files
cleanup() {
    rm -f "$TEMP_OUTPUT"
}
trap cleanup EXIT

# Run tests with JSON output
# Use timeout of 12 minutes for safety
# Disable race detector to speed up tests
# Run tests with count=1 to disable caching
go test -json \
    -timeout=12m \
    -tags=,test_dep, \
    -count=1 \
    "${UNIT_TEST_PACKAGES[@]}" 2>&1 | tee "$TEMP_OUTPUT"

# Parse the JSON output to count test results
# Count unique test names with each action (pass/fail/skip)
# Note: A test result looks like {"Action":"pass","Package":"...","Test":"TestName","Elapsed":0.01}
# We filter out subtests (those with /) to only count top-level tests
PASSED=$(jq -r 'select(.Action == "pass" and .Test and (.Test | startswith("Test")) and (.Test | contains("/") | not)) | .Package + "::" + .Test' "$TEMP_OUTPUT" 2>/dev/null | sort -u | wc -l || echo "0")
FAILED=$(jq -r 'select(.Action == "fail" and .Test and (.Test | startswith("Test")) and (.Test | contains("/") | not)) | .Package + "::" + .Test' "$TEMP_OUTPUT" 2>/dev/null | sort -u | wc -l || echo "0")
SKIPPED=$(jq -r 'select(.Action == "skip" and .Test and (.Test | startswith("Test")) and (.Test | contains("/") | not)) | .Package + "::" + .Test' "$TEMP_OUTPUT" 2>/dev/null | sort -u | wc -l || echo "0")

# Calculate total tests run
TOTAL=$((PASSED + FAILED + SKIPPED))

# Output the JSON result as the last line
echo "{\"passed\": $PASSED, \"failed\": $FAILED, \"skipped\": $SKIPPED, \"total\": $TOTAL}"
