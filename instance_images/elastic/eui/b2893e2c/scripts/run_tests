#!/bin/bash
# Run tests for Elastic UI
# This script runs the test suite and outputs results in JSON format

cd /testbed

# Run Jest tests with JSON reporter
# We'll run test-unit which is the unit test suite
# Capture the output to parse later
yarn test-unit --json --outputFile=/tmp/jest-output.json --testTimeout=30000 2>&1 | tee /tmp/test-run.log || true

# Parse the Jest JSON output
if [ -f "/tmp/jest-output.json" ]; then
    # Extract test counts from Jest JSON output
    node -e "
    const fs = require('fs');
    try {
        const data = JSON.parse(fs.readFileSync('/tmp/jest-output.json', 'utf8'));
        const passed = data.numPassedTests || 0;
        const failed = data.numFailedTests || 0;
        const skipped = data.numPendingTests || 0;
        const total = data.numTotalTests || 0;
        console.log(JSON.stringify({passed, failed, skipped, total}));
    } catch (e) {
        // JSON parsing failed, fall back to log parsing
        const log = fs.readFileSync('/tmp/test-run.log', 'utf8');
        const passedMatch = log.match(/(\d+) passed/);
        const failedMatch = log.match(/(\d+) failed/);
        const skippedMatch = log.match(/(\d+) (skipped|pending)/);
        const totalMatch = log.match(/Tests:.*?(\d+) total/);

        const passed = passedMatch ? parseInt(passedMatch[1]) : 0;
        const failed = failedMatch ? parseInt(failedMatch[1]) : 0;
        const skipped = skippedMatch ? parseInt(skippedMatch[1]) : 0;
        const total = totalMatch ? parseInt(totalMatch[1]) : 0;

        console.log(JSON.stringify({passed, failed, skipped, total}));
    }
    "
else
    # Fallback: try to parse from console output
    echo "Warning: Jest JSON output not found, parsing from console output" >&2

    # Try to extract from the test run log
    if [ -f "/tmp/test-run.log" ]; then
        node -e "
        const fs = require('fs');
        const log = fs.readFileSync('/tmp/test-run.log', 'utf8');

        // Try to parse Jest summary line
        const passedMatch = log.match(/(\d+) passed/);
        const failedMatch = log.match(/(\d+) failed/);
        const skippedMatch = log.match(/(\d+) (skipped|pending)/);
        const totalMatch = log.match(/Tests:.*?(\d+) total/);

        const passed = passedMatch ? parseInt(passedMatch[1]) : 0;
        const failed = failedMatch ? parseInt(failedMatch[1]) : 0;
        const skipped = skippedMatch ? parseInt(skippedMatch[1]) : 0;
        const total = totalMatch ? parseInt(totalMatch[1]) : 0;

        console.log(JSON.stringify({passed, failed, skipped, total}));
        "
    else
        # If all else fails, return zeros
        echo '{"passed": 0, "failed": 0, "skipped": 0, "total": 0}'
    fi
fi
