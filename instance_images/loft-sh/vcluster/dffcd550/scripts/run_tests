#!/bin/bash
# Test runner script for vcluster project
# Runs unit tests and outputs results in JSON format

set -e

# Navigate to testbed directory
cd /testbed

# Set Go environment variables (inherited from setup_shell.sh but set here for safety)
export GO111MODULE=on
export GOFLAGS=-mod=vendor

# Get list of packages to test (excluding vendor and e2e test directories)
PKGS=$(go list ./... | grep -v -e /vendor/ -e /test/)

# Run tests with JSON output
TEST_OUTPUT=$(mktemp)
TEST_RESULTS=$(mktemp)

# Run all tests and capture JSON output
echo "Running unit tests..." >&2
go test -json $PKGS 2>&1 | tee "$TEST_OUTPUT" >&2

# Parse the JSON output to count test results
# We need to count unique test results (not subtests)
passed=0
failed=0
skipped=0

# Process JSON output line by line
while IFS= read -r line; do
    # Check if line is valid JSON
    if echo "$line" | jq -e . >/dev/null 2>&1; then
        action=$(echo "$line" | jq -r '.Action // empty')
        test_name=$(echo "$line" | jq -r '.Test // empty')

        # Only count top-level tests (ones without / in the name after removing subtests)
        # We count when Action is "pass", "fail", or "skip"
        if [ "$action" = "pass" ] && [ -n "$test_name" ]; then
            # Only count if it's not a subtest (no "/" in name)
            if [[ ! "$test_name" =~ "/" ]]; then
                passed=$((passed + 1))
            fi
        elif [ "$action" = "fail" ] && [ -n "$test_name" ]; then
            if [[ ! "$test_name" =~ "/" ]]; then
                failed=$((failed + 1))
            fi
        elif [ "$action" = "skip" ] && [ -n "$test_name" ]; then
            if [[ ! "$test_name" =~ "/" ]]; then
                skipped=$((skipped + 1))
            fi
        fi
    fi
done < "$TEST_OUTPUT"

# Calculate total
total=$((passed + failed + skipped))

# Clean up temp files
rm -f "$TEST_OUTPUT" "$TEST_RESULTS"

# Output the final JSON result (to stdout)
echo "{\"passed\": $passed, \"failed\": $failed, \"skipped\": $skipped, \"total\": $total}"

# Exit with error code if any tests failed
if [ $failed -gt 0 ]; then
    exit 1
fi

exit 0
