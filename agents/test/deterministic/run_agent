#!/bin/bash
set -euo pipefail

DESC_FILE="/task_description/description.md"
OUT_DIR="/output"

if [ ! -f "$DESC_FILE" ]; then
  echo "Missing description at $DESC_FILE" >&2
  exit 1
fi

if grep -q "refactoring_plans" "$DESC_FILE"; then
  mkdir -p "$OUT_DIR/refactoring_plans"
  for i in 0 1 2 3 4; do
    echo "# Plan $i" > "$OUT_DIR/refactoring_plans/refactoring_plan${i}.md"
    echo "This is a deterministic multiplan output." >> "$OUT_DIR/refactoring_plans/refactoring_plan${i}.md"
  done
  echo "{\"finish_reason\":\"success\"}" > "$OUT_DIR/inference_metadata.json"
elif grep -q "refactoring_plan.md" "$DESC_FILE"; then
  echo "# Plan" > "$OUT_DIR/refactoring_plan.md"
  echo "This is a deterministic plan output." >> "$OUT_DIR/refactoring_plan.md"
  echo "{\"finish_reason\":\"success\"}" > "$OUT_DIR/inference_metadata.json"
else
  for candidate in README.md LICENSE go.mod; do
    if [ -f "$candidate" ]; then
      rm "$candidate"
      break
    fi
  done
  echo "{\"finish_reason\":\"success\"}" > "$OUT_DIR/inference_metadata.json"
fi
