#!/bin/bash

set -o pipefail

echo $OPENAI_API_KEY | codex login --with-api-key

export MAX_LINES=1000

echo "The following is the prompt being sent to Codex:"
printf "Perform the task described below. You are required to implement the required changes.\n\n"
cat /task_description/description.md

(printf "Perform the task described below. You are required to implement the required changes.\n\n";
cat /task_description/description.md) | python /agent/codex_wrapper.py \
  --skip-git-repo-check \
  --dangerously-bypass-approvals-and-sandbox \
  --json \
  --model gpt-5.1-codex \
  -c model_reasoning_effort="medium" 2>&1 | tee /tmp/output_log.json

# Capture the exit status of the pipeline
STATUS=$?

if [ $STATUS -eq 0 ]; then
    tail -n 1 /tmp/output_log.json > /output/inference_metadata.json
else
    # This means that prediction.diff won't be saved either.
    echo "Task failed with exit code $STATUS. Metadata not saved." >&2 
    exit $STATUS
fi