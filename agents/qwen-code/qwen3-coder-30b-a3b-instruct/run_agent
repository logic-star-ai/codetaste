#!/bin/bash

set -o pipefail


[ -s "/opt/nvm/nvm.sh" ] && source "/opt/nvm/nvm.sh"
nvm use 22

export MAX_BUDGET_USD=2.5
export INPUT_TOKEN_PRICE=0.07e-6
export OUTPUT_TOKEN_PRICE=0.27e-6

export OPENAI_API_KEY="$OPENROUTER_API_KEY"
export OPENAI_BASE_URL="https://openrouter.ai/api/v1"
export OPENAI_MODEL="qwen/qwen3-coder-30b-a3b-instruct"

echo "The following instruction is being sent to the agent:"
cat /task_description/description.md
echo "----------------------------------------"


cat /task_description/description.md | python -u /agent/qwen_code_wrapper.py \
  --output-format stream-json \
  -y | tee /tmp/output_log.json

STATUS=$?


tail -n 1 /tmp/output_log.json > /output/inference_metadata.json


chmod 666 /output/inference_metadata.json

exit $STATUS