+import { i18nInstance } from '@/plugins/i18n';
+import { useRootStore } from '@/stores/root.store';
+
+export function useI18nGlobal() {
+	const rootStore = useRootStore();
+	
+	const t = (key: string, options?: { adjustToNumber?: number; interpolate?: Record<string, string | number> }) => {
+		if (options?.adjustToNumber !== undefined) {
+			return i18nInstance.global.tc(key, options.adjustToNumber, options?.interpolate ?? {}).toString();
+		}
+		return i18nInstance.global.t(key, options?.interpolate ?? {}).toString();
+	};
+
+	const baseText = (key: string, options?: { adjustToNumber?: number; interpolate?: Record<string, string | number> }) => {
+		return t(key, options);
+	};
+
+	const exists = (key: string) => {
+		return i18nInstance.global.te(key);
+	};
+
+	const displayTimer = (msPassed: number, showMs = false) => {
+		if (msPassed < 60000) {
+			if (!showMs) {
+				return `${Math.floor(msPassed / 1000)}${t('genericHelpers.secShort')}`;
+			}
+
+			return `${msPassed / 1000}${t('genericHelpers.secShort')}`;
+		}
+
+		const secondsPassed = Math.floor(msPassed / 1000);
+		const minutesPassed = Math.floor(secondsPassed / 60);
+		const secondsLeft = (secondsPassed - minutesPassed * 60).toString().padStart(2, '0');
+
+		return `${minutesPassed}:${secondsLeft}${t('genericHelpers.minShort')}`;
+	};
+
+	const localizeNodeName = (nodeName: string, type: string) => {
+		const isEnglishLocale = rootStore.defaultLocale === 'en';
+
+		if (isEnglishLocale) return nodeName;
+
+		const shortNodeType = type.replace('n8n-nodes-base.', '');
+
+		return i18nInstance.global.te(`headers.${shortNodeType}.displayName`) 
+			? i18nInstance.global.t(`headers.${shortNodeType}.displayName`).toString() 
+			: nodeName;
+	};
+
+	// Return all the translation functions we need to access in components
+	return {
+		t,
+		baseText,
+		exists,
+		displayTimer,
+		localizeNodeName,
+	};
+}
