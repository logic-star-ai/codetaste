@@ -0,0 +1,55 @@
+import { i18nInstance } from '@/plugins/i18n';
+import { useRootStore } from '@/stores/root.store';
+
+// Create a global instance compatible with Vue 3 options API
+// This will be removed after ejecting Vue 2 -> 3 migration
+export const globalI18n = {
+	// We can keep some methods to maintain compatibility
+	get i18n() {
+		return i18nInstance.global;
+	},
+
+	exists(key: string) {
+		return this.i18n.te(key);
+	},
+
+	shortNodeType(longNodeType: string) {
+		return longNodeType.replace('n8n-nodes-base.', '');
+	},
+
+	baseText(key: string, options?: { adjustToNumber?: number; interpolate?: Record<string, string | number> }) {
+		if (options?.adjustToNumber !== undefined) {
+			return this.i18n.tc(key, options.adjustToNumber, options?.interpolate ?? {}).toString();
+		}
+		return this.i18n.t(key, options?.interpolate ?? {}).toString();
+	},
+
+	displayTimer(msPassed: number, showMs = false) {
+		if (msPassed < 60000) {
+			if (!showMs) {
+				return `${Math.floor(msPassed / 1000)}${this.baseText('genericHelpers.secShort')}`;
+			}
+
+			return `${msPassed / 1000}${this.baseText('genericHelpers.secShort')}`;
+		}
+
+		const secondsPassed = Math.floor(msPassed / 1000);
+		const minutesPassed = Math.floor(secondsPassed / 60);
+		const secondsLeft = (secondsPassed - minutesPassed * 60).toString().padStart(2, '0');
+
+		return `${minutesPassed}:${secondsLeft}${this.baseText('genericHelpers.minShort')}`;
+	},
+
+	localizeNodeName(nodeName: string, type: string) {
+		const rootStore = useRootStore();
+		const isEnglishLocale = rootStore.defaultLocale === 'en';
+
+		if (isEnglishLocale) return nodeName;
+
+		const nodeTypeName = this.shortNodeType(type);
+
+		return this.i18n.te(`headers.${nodeTypeName}.displayName`) 
+			? this.i18n.t(`headers.${nodeTypeName}.displayName`).toString() 
+			: nodeName;
+	},
+};
