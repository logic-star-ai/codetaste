+#!/usr/bin/env python3
+"""
+Fix files where useI18n is imported but const i18n declaration is missing
+"""
+import re
+from pathlib import Path
+
+def fix_missing_i18n_declaration(file_path):
+    """Fix a file where useI18n is imported but const i18n is missing"""
+
+    with open(file_path, 'r', encoding='utf-8') as f:
+        content = f.read()
+
+    # Check if file imports useI18n
+    if 'useI18n' not in content:
+        return False, "No useI18n import"
+
+    # Check if file already has const i18n declaration
+    if re.search(r'\bconst\s+i18n\s*=\s*useI18n\(\)', content):
+        return False, "Already has const i18n"
+
+    # Check if file uses i18n in template
+    if 'i18n.' not in content:
+        return False, "No i18n usage found"
+
+    original_content = content
+
+    # Find the script section
+    script_match = re.search(r'<script([^>]*)>(.*?)</script>', content, re.DOTALL)
+    if not script_match:
+        return False, "No script section"
+
+    script_attrs = script_match.group(1)
+    script_content = script_match.group(2)
+
+    # Check if it's a setup script
+    if 'setup' not in script_attrs:
+        # This is Options API, need different handling
+        return False, "Not a setup script"
+
+    # Find where to insert const i18n declaration
+    # Look for the useI18n import line
+    import_match = re.search(r"^import.*useI18n.*from.*@/composables/useI18n.*;?\s*$", script_content, re.MULTILINE)
+    if not import_match:
+        return False, "Cannot find useI18n import"
+
+    # Find the next empty line or next const declaration after the imports
+    import_end = import_match.end()
+
+    # Look for other const declarations using use* pattern
+    remaining_content = script_content[import_end:]
+    const_pattern = re.compile(r'^const\s+\w+\s*=\s*use\w+\([^)]*\);?\s*$', re.MULTILINE)
+    const_matches = list(const_pattern.finditer(remaining_content))
+
+    if const_matches:
+        # Insert after the last const use* declaration
+        last_const = const_matches[-1]
+        insert_pos = import_end + last_const.end()
+        declaration = "\nconst i18n = useI18n();"
+    else:
+        # Insert after imports section - find first blank line or first code line
+        lines_after_import = remaining_content.split('\n')
+        blank_line_count = 0
+        insert_offset = 0
+        for line in lines_after_import:
+            if line.strip() == '':
+                blank_line_count += 1
+                insert_offset += len(line) + 1
+                if blank_line_count >= 1:
+                    break
+            else:
+                break
+
+        insert_pos = import_end + insert_offset
+        declaration = "\nconst i18n = useI18n();"
+
+    # Insert the declaration
+    modified_script = script_content[:insert_pos] + declaration + script_content[insert_pos:]
+
+    # Replace the script section
+    new_script_tag = f'<script{script_attrs}>{modified_script}</script>'
+    full_script_tag = script_match.group(0)
+    content = content.replace(full_script_tag, new_script_tag)
+
+    if content == original_content:
+        return False, "No changes made"
+
+    # Write back
+    with open(file_path, 'w', encoding='utf-8') as f:
+        f.write(content)
+
+    return True, "Successfully fixed"
+
+def main():
+    base_path = Path('/testbed/packages/editor-ui/src')
+
+    # Get all Vue files that import useI18n
+    vue_files = []
+    for vue_file in base_path.rglob('*.vue'):
+        try:
+            with open(vue_file, 'r', encoding='utf-8') as f:
+                content = f.read()
+                if 'useI18n' in content and 'i18n.' in content:
+                    vue_files.append(vue_file)
+        except:
+            pass
+
+    print(f"Found {len(vue_files)} Vue files with useI18n and i18n usage")
+
+    success_count = 0
+    skip_count = 0
+
+    for vue_file in vue_files:
+        try:
+            success, message = fix_missing_i18n_declaration(vue_file)
+            if success:
+                print(f"✓ {vue_file.relative_to(base_path)}: {message}")
+                success_count += 1
+            else:
+                # Only print if it looks like it might need fixing
+                if message not in ["Already has const i18n", "No useI18n import"]:
+                    print(f"- {vue_file.relative_to(base_path)}: {message}")
+                skip_count += 1
+        except Exception as e:
+            print(f"✗ {vue_file.relative_to(base_path)}: Error - {e}")
+
+    print(f"\nSummary:")
+    print(f"  Successfully fixed: {success_count}")
+    print(f"  Skipped: {skip_count}")
+    print(f"  Total: {len(vue_files)}")
+
+if __name__ == '__main__':
+    main()
