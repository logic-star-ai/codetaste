+#!/usr/bin/env python3
+"""
+Migration script to replace $locale global property with i18n composable
+"""
+import re
+import os
+import sys
+from pathlib import Path
+
+def process_vue_file(file_path):
+    """Process a single Vue file to migrate from $locale to i18n"""
+
+    with open(file_path, 'r', encoding='utf-8') as f:
+        content = f.read()
+
+    # Check if file uses $locale
+    if '$locale' not in content:
+        return False, "No $locale found"
+
+    original_content = content
+
+    # Split content into script and template sections
+    script_match = re.search(r'<script[^>]*>(.*?)</script>', content, re.DOTALL)
+    template_match = re.search(r'<template>(.*?)</template>', content, re.DOTALL)
+
+    if not script_match:
+        return False, "No script section found"
+
+    script_start = script_match.start(1)
+    script_end = script_match.end(1)
+    script_content = script_match.group(1)
+    script_tag = script_match.group(0)
+
+    # Check if already using useI18n
+    has_use_i18n = 'useI18n' in script_content
+
+    # Replace this.$locale with i18n in script section
+    modified_script = script_content
+    if 'this.$locale' in script_content:
+        modified_script = re.sub(r'\bthis\.\$locale\b', 'i18n', script_content)
+
+    # If using $locale but doesn't have useI18n import, add it
+    needs_import = False
+    if '$locale' in content and not has_use_i18n:
+        needs_import = True
+
+        # Find the import section
+        import_pattern = re.compile(r"^import\s+", re.MULTILINE)
+        imports = list(import_pattern.finditer(modified_script))
+
+        if imports:
+            # Add after the last import
+            last_import = imports[-1]
+            last_import_line_end = modified_script.find('\n', last_import.start())
+            if last_import_line_end == -1:
+                last_import_line_end = len(modified_script)
+
+            # Check if we're in a setup script
+            is_setup_script = 'setup' in script_match.group(0).split('>')[0]
+
+            if is_setup_script:
+                # Add useI18n import and declare i18n variable
+                import_line = "\nimport { useI18n } from '@/composables/useI18n';"
+                modified_script = (
+                    modified_script[:last_import_line_end] +
+                    import_line +
+                    modified_script[last_import_line_end:]
+                )
+
+                # Find where to add the i18n declaration (after other composable/store declarations)
+                # Look for patterns like "const store = useStore();" or "const telemetry = useTelemetry();"
+                const_pattern = re.compile(r'^const\s+\w+\s*=\s*use\w+\(\);?\s*$', re.MULTILINE)
+                const_matches = list(const_pattern.finditer(modified_script))
+
+                if const_matches:
+                    # Add after the last const declaration
+                    last_const = const_matches[-1]
+                    insert_pos = last_const.end()
+                    declaration = "\nconst i18n = useI18n();"
+                    modified_script = (
+                        modified_script[:insert_pos] +
+                        declaration +
+                        modified_script[insert_pos:]
+                    )
+
+    # Replace $locale with i18n in template section
+    if template_match:
+        template_content = template_match.group(1)
+        modified_template = re.sub(r'\$locale\b', 'i18n', template_content)
+
+        # Reconstruct the content
+        content = (
+            content[:script_start] +
+            modified_script +
+            content[script_end:template_match.start(1)] +
+            modified_template +
+            content[template_match.end(1):]
+        )
+    else:
+        # No template, just update script
+        content = (
+            content[:script_start] +
+            modified_script +
+            content[script_end:]
+        )
+
+    # Check if anything changed
+    if content == original_content:
+        return False, "No changes made"
+
+    # Write back
+    with open(file_path, 'w', encoding='utf-8') as f:
+        f.write(content)
+
+    return True, "Successfully migrated"
+
+def main():
+    base_path = Path('/testbed/packages/editor-ui/src')
+
+    # Get all Vue files that contain $locale
+    vue_files = []
+    for vue_file in base_path.rglob('*.vue'):
+        with open(vue_file, 'r', encoding='utf-8') as f:
+            if '$locale' in f.read():
+                vue_files.append(vue_file)
+
+    print(f"Found {len(vue_files)} Vue files with $locale")
+
+    success_count = 0
+    skip_count = 0
+
+    for vue_file in vue_files:
+        try:
+            success, message = process_vue_file(vue_file)
+            if success:
+                print(f"✓ {vue_file.relative_to(base_path)}: {message}")
+                success_count += 1
+            else:
+                print(f"- {vue_file.relative_to(base_path)}: {message}")
+                skip_count += 1
+        except Exception as e:
+            print(f"✗ {vue_file.relative_to(base_path)}: Error - {e}")
+
+    print(f"\nSummary:")
+    print(f"  Successfully migrated: {success_count}")
+    print(f"  Skipped: {skip_count}")
+    print(f"  Total: {len(vue_files)}")
+
+if __name__ == '__main__':
+    main()
