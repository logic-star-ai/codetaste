+#!/usr/bin/env python3
+"""
+Migration script to replace $locale global property with i18n composable - Version 2
+"""
+import re
+import os
+import sys
+from pathlib import Path
+
+def process_vue_file(file_path):
+    """Process a single Vue file to migrate from $locale to i18n"""
+
+    with open(file_path, 'r', encoding='utf-8') as f:
+        content = f.read()
+
+    # Check if file uses $locale
+    if '$locale' not in content:
+        return False, "No $locale found"
+
+    original_content = content
+
+    # Parse script section
+    script_pattern = r'<script([^>]*)>(.*?)</script>'
+    script_match = re.search(script_pattern, content, re.DOTALL)
+
+    if not script_match:
+        return False, "No script section found"
+
+    script_attrs = script_match.group(1)
+    script_content = script_match.group(2)
+    full_script_tag = script_match.group(0)
+
+    # Check if already using useI18n
+    has_use_i18n_import = re.search(r"import.*useI18n.*from.*@/composables/useI18n", script_content)
+    has_i18n_const = re.search(r"const\s+i18n\s*=\s*useI18n\(\)", script_content)
+
+    # Replace this.$locale with i18n in script section
+    modified_script = re.sub(r'\bthis\.\$locale\b', 'i18n', script_content)
+
+    # If using $locale but doesn't have useI18n setup, add it
+    needs_setup = (not has_use_i18n_import or not has_i18n_const) and ('$locale' in content or 'this.$locale' in script_content)
+
+    if needs_setup:
+        # Add import if not present
+        if not has_use_i18n_import:
+            # Find where to add import - after the last import statement
+            import_matches = list(re.finditer(r'^import\s+.*?;?\s*$', modified_script, re.MULTILINE))
+            if import_matches:
+                last_import = import_matches[-1]
+                insert_pos = last_import.end()
+                import_line = "\nimport { useI18n } from '@/composables/useI18n';"
+                modified_script = (
+                    modified_script[:insert_pos] +
+                    import_line +
+                    modified_script[insert_pos:]
+                )
+
+        # Add const i18n declaration if not present (for setup script)
+        if not has_i18n_const and 'setup' in script_attrs:
+            # Find where to add the const - look for other const declarations with use* pattern
+            const_pattern = re.compile(r'^const\s+\w+\s*=\s*use\w+\([^)]*\);?\s*$', re.MULTILINE)
+            const_matches = list(const_pattern.finditer(modified_script))
+
+            if const_matches:
+                # Add after the last const use* declaration
+                last_const = const_matches[-1]
+                insert_pos = last_const.end()
+                declaration = "\nconst i18n = useI18n();"
+                modified_script = (
+                    modified_script[:insert_pos] +
+                    declaration +
+                    modified_script[insert_pos:]
+                )
+            else:
+                # No other composable declarations, add after imports
+                import_matches = list(re.finditer(r'^import\s+.*?;?\s*$', modified_script, re.MULTILINE))
+                if import_matches:
+                    last_import = import_matches[-1]
+                    insert_pos = last_import.end()
+                    # Add some spacing and the declaration
+                    declaration = "\n\nconst i18n = useI18n();"
+                    modified_script = (
+                        modified_script[:insert_pos] +
+                        declaration +
+                        modified_script[insert_pos:]
+                    )
+
+    # Replace the script section in the content
+    new_script_tag = f'<script{script_attrs}>{modified_script}</script>'
+    content = content.replace(full_script_tag, new_script_tag)
+
+    # Replace ALL instances of $locale with i18n in template section
+    # Use word boundary to ensure we don't replace $localeCompare or similar
+    content = re.sub(r'\$locale\b', 'i18n', content)
+
+    # Check if anything changed
+    if content == original_content:
+        return False, "No changes made"
+
+    # Write back
+    with open(file_path, 'w', encoding='utf-8') as f:
+        f.write(content)
+
+    return True, "Successfully migrated"
+
+def main():
+    base_path = Path('/testbed/packages/editor-ui/src')
+
+    # Get all Vue files that contain $locale
+    vue_files = []
+    for vue_file in base_path.rglob('*.vue'):
+        try:
+            with open(vue_file, 'r', encoding='utf-8') as f:
+                if '$locale' in f.read():
+                    vue_files.append(vue_file)
+        except:
+            pass
+
+    print(f"Found {len(vue_files)} Vue files with $locale")
+
+    success_count = 0
+    skip_count = 0
+    error_count = 0
+
+    for vue_file in vue_files:
+        try:
+            success, message = process_vue_file(vue_file)
+            if success:
+                print(f"✓ {vue_file.relative_to(base_path)}: {message}")
+                success_count += 1
+            else:
+                print(f"- {vue_file.relative_to(base_path)}: {message}")
+                skip_count += 1
+        except Exception as e:
+            print(f"✗ {vue_file.relative_to(base_path)}: Error - {e}")
+            error_count += 1
+
+    print(f"\nSummary:")
+    print(f"  Successfully migrated: {success_count}")
+    print(f"  Skipped: {skip_count}")
+    print(f"  Errors: {error_count}")
+    print(f"  Total: {len(vue_files)}")
+
+if __name__ == '__main__':
+    main()
