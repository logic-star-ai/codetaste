diff --git a/misc/cgo/test/issue_misc.go b/misc/cgo/test/issue_misc.go
new file mode 100644
index 0000000..63c992e
--- /dev/null
+++ b/misc/cgo/test/issue_misc.go
@@ -0,0 +1,316 @@
+// Copyright 2024 The Go Authors. All rights reserved.
+// Use of this source code is governed by a BSD-style
+// license that can be found in the LICENSE file.
+
+// This file consolidates various cgo issue tests that are compile-only
+// (no runtime test required). These tests verify that certain cgo constructs
+// compile correctly.
+
+package cgotest
+
+/*
+#include <stdarg.h>
+#include <stddef.h>
+#include <stdlib.h>
+#include <complex.h>
+#include "issue8331.h"
+
+// issue 1222
+typedef union {
+	long align;
+} xxpthread_mutex_t;
+
+struct ibv_async_event {
+	union {
+		int x;
+	} element;
+};
+
+struct ibv_context {
+	xxpthread_mutex_t mutex;
+};
+
+// issue4054a and issue4054b
+// Note: We need to use different names to avoid conflicts
+typedef enum {
+	A4054a = 0,
+	B4054a,
+	C4054a,
+	D4054a,
+	E4054a,
+	F4054a,
+	G4054a,
+	H4054a,
+	I4054a,
+	J4054a,
+} issue4054a;
+
+typedef enum {
+	A4054b = 0,
+	B4054b,
+	C4054b,
+	D4054b,
+	E4054b,
+	F4054b,
+	G4054b,
+	H4054b,
+	I4054b,
+	J4054b,
+} issue4054b;
+
+// issue 8148
+typedef struct { int i8148; } T8148;
+int issue8148Callback(T8148*);
+static int issue8148Get() {
+	T8148 t;
+	t.i8148 = 42;
+	return issue8148Callback(&t);
+}
+
+// issue 8368 and 8441
+typedef struct one one;
+typedef struct two two;
+struct one {
+	two *x;
+};
+struct two {
+	one *x;
+};
+
+// issue 21668
+#define issue21668_x 42
+
+// issue 22958
+typedef struct {
+	unsigned long long f8  : 8;
+	unsigned long long f16 : 16;
+	unsigned long long f24 : 24;
+	unsigned long long f32 : 32;
+	unsigned long long f40 : 40;
+	unsigned long long f48 : 48;
+	unsigned long long f56 : 56;
+	unsigned long long f64 : 64;
+} issue22958Type;
+
+// issue 23720
+typedef int *issue23720A;
+typedef const int *issue23720B;
+static inline void issue23720F(issue23720B a) {}
+
+// issue 26517
+typedef va_list TypeOne;
+typedef char *TypeTwo;
+
+// issue 28545 and 28772
+#define issue28772Constant 1
+#define issue28772Constant2 2
+static void issue28545F(char **p, int n, complex double a) {}
+
+// issue 29748
+typedef struct { char **p; } S29748;
+static int f29748(S29748 *p) { return 0; }
+
+// issue 29781
+static void issue29781F(char **p, int n) {}
+#define ISSUE29781C 0
+*/
+import "C"
+
+import "testing"
+
+// -----
+// issue 1222: typedef of union and unnamed struct
+// -----
+
+type AsyncEvent struct {
+	event C.struct_ibv_async_event
+}
+
+// -----
+// issue 3741: exported functions with slice parameters
+// -----
+
+//export exportSliceIn
+func exportSliceIn(s []byte) bool {
+	return len(s) == cap(s)
+}
+
+//export exportSliceOut
+func exportSliceOut() []byte {
+	return []byte{1}
+}
+
+//export exportSliceInOut
+func exportSliceInOut(s []byte) []byte {
+	return s
+}
+
+// -----
+// issue 4054: enums with duplicate names across files
+// -----
+
+var issue4054a = []int{C.A4054a, C.B4054a, C.C4054a, C.D4054a, C.E4054a, C.F4054a, C.G4054a, C.H4054a, C.I4054a, C.J4054a}
+var issue4054b = []int{C.A4054b, C.B4054b, C.C4054b, C.D4054b, C.E4054b, C.F4054b, C.G4054b, C.H4054b, C.I4054b, C.J4054b}
+
+// -----
+// issue 7234: string constant with -linkmode=external
+// -----
+
+var v7234 = [...]string{"runtime/cgo"}
+
+func Test7234(t *testing.T) {
+	if v7234[0] != "runtime/cgo" {
+		t.Errorf("bad string constant %q", v7234[0])
+	}
+}
+
+// -----
+// issue 8148: typedef of unnamed struct with exported Go function
+// -----
+
+//export issue8148Callback
+func issue8148Callback(t *C.T8148) C.int {
+	return t.i8148
+}
+
+func Issue8148() int {
+	return int(C.issue8148Get())
+}
+
+// -----
+// issue 8331: typedef of unnamed struct #include'd twice
+// -----
+
+var issue8331Var C.issue8331
+
+func issue8331a() C.issue8331 {
+	return issue8331Var
+}
+
+// -----
+// issue 8368 and 8441: recursive struct definitions
+// -----
+
+func issue8368(one *C.struct_one, two *C.struct_two) {
+}
+
+func issue8441(one *C.one, two *C.two) {
+	issue8441(two.x, one.x)
+}
+
+// -----
+// issue 13402: complex float and double types
+// -----
+
+var _ C.complexfloat
+var _ C.complexdouble
+
+// -----
+// issue 13930: cgo's multiple-value special form in variable declarations
+// -----
+
+var _, _ = C.abs(0)
+
+// -----
+// issue 21668: const int constant
+// -----
+
+var issue21668_X = C.issue21668_x
+
+// -----
+// issue 22958: bitfield handling
+// -----
+
+var Vissue22958 C.issue22958Type
+
+// -----
+// issue 23720: passing compatible typedefs
+// -----
+
+func Issue23720F() {
+	var x C.issue23720A
+	C.issue23720F(x)
+}
+
+// -----
+// issue 26517: pointer types with same base type
+// -----
+
+// Introduce two pointer types which are distinct, but have the same
+// base type. Make sure that both of those pointer types get resolved
+// correctly. Before the fix for 26517 if one of these pointer types
+// was resolved before the other one was processed, the second one
+// would never be resolved.
+// Before this issue was fixed this test failed on Windows,
+// where va_list expands to a named char* type.
+
+var issue26517a C.TypeOne
+var issue26517b C.TypeTwo
+
+// -----
+// issue 28545: type conversion for negative constant
+// issue 28772: type conversion for Go constant set to C constant
+// -----
+
+const issue28772Constant = C.issue28772Constant
+const issue28772Constant2 = C.issue28772Constant2
+
+func issue28545G(p **C.char) {
+	C.issue28545F(p, -1, (0))
+	C.issue28545F(p, 2+3, complex(1, 1))
+	C.issue28545F(p, issue28772Constant, issue28772Constant2)
+}
+
+// -----
+// issue 29383: /*line*/ comments after '/'
+// -----
+
+func Issue29383(n, size uint) int {
+	if ^C.size_t(0)/C.size_t(n) < C.size_t(size) {
+		return 0
+	}
+	return 0
+}
+
+// -----
+// issue 29748: struct initializer requiring pointer checking
+// -----
+
+var Vissue29748 = C.f29748(&C.S29748{
+	nil,
+})
+
+func Fissue299748() {
+	C.f29748(&C.S29748{
+		nil,
+	})
+}
+
+// -----
+// issue 29781: newline in constant expression
+// -----
+
+var issue29781X struct{ X int }
+
+func issue29781F(...int) int { return 0 }
+
+func issue29781G() {
+	var p *C.char
+	C.issue29781F(&p, C.ISSUE29781C+1)
+	C.issue29781F(nil, (C.int)(
+		0))
+	C.issue29781F(&p, (C.int)(0))
+	C.issue29781F(&p, (C.int)(
+		0))
+	C.issue29781F(&p, (C.int)(issue29781X.
+		X))
+}
+
+// -----
+// issue 29878: export function with specific signature
+// -----
+
+//export issue29878exported
+func issue29878exported(arg int8) uint64 {
+	return uint64(arg)
+}
