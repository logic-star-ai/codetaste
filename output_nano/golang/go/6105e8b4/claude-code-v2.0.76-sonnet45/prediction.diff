index 0000000..c28a1c6
--- /dev/null
+++ b/misc/cgo/test/issue_simple.go
@@ -0,0 +1,199 @@
+// Copyright 2024 The Go Authors. All rights reserved.
+// Use of this source code is governed by a BSD-style
+// license that can be found in the LICENSE file.
+
+// This file consolidates various simple cgo issue tests.
+
+package cgotest
+
+/*
+#include <stdint.h>
+#include <stdlib.h>
+
+// issue 6128: Test handling of #defined names in clang.
+// NOTE: Must use hex, or else a shortcut for decimals
+// in cgo avoids trying to pass this to clang.
+#define X6128 0x1
+
+// issue 6472: nested anonymous struct
+typedef struct
+{
+        struct
+        {
+            int x;
+        } y[16];
+} z6472;
+
+// issue 20369: UINT64_MAX constant
+#define UINT64_MAX_20369        18446744073709551615ULL
+
+// issue 21708: cast to int64
+#define CAST_TO_INT64 (int64_t)(-1)
+
+// issue 23356: simple C functions
+static inline int a23356(void) { return 5; }
+static inline int r23356(void) { return 3; }
+
+// issue 26066: Wrong type of constant with GCC 8 and newer
+enum { issue26066 = (const unsigned long long) -1 };
+
+// issue 5242: alignment of structs with no Go accessible fields
+typedef struct {
+} foo5242;
+
+typedef struct {
+	int x : 1;
+} bar5242;
+
+static inline int issue5242(foo5242 f, bar5242 b) {
+	return 5242;
+}
+
+// issue 7665: export function pointer
+extern void f7665(void);
+
+// issue 8811: initialization check
+extern int issue8811Initialized;
+extern void issue8811Init();
+
+static inline void issue8811Execute() {
+	if(!issue8811Initialized)
+		issue8811Init();
+}
+
+// issue 18126: void function returning errno
+static inline void Issue18126C(void **p) {
+}
+*/
+import "C"
+
+import (
+	"math"
+	"testing"
+	"unsafe"
+)
+
+// -----
+// issue 6128: Test handling of #defined names in clang
+// -----
+
+func test6128() {
+	// nothing to run, just make sure this compiles.
+	_ = C.X6128
+}
+
+// -----
+// issue 6390: C.malloc(0) should not return nil
+// -----
+
+func test6390(t *testing.T) {
+	p1 := C.malloc(1024)
+	if p1 == nil {
+		t.Fatalf("C.malloc(1024) returned nil")
+	}
+	p2 := C.malloc(0)
+	if p2 == nil {
+		t.Fatalf("C.malloc(0) returned nil")
+	}
+	C.free(p1)
+	C.free(p2)
+}
+
+// -----
+// issue 6472: nested anonymous struct
+// -----
+
+func test6472() {
+	// nothing to run, just make sure this compiles
+	s := new(C.z6472)
+	println(s.y[0].x)
+}
+
+// -----
+// issue 20369: UINT64_MAX constant
+// -----
+
+func test20369(t *testing.T) {
+	if C.UINT64_MAX_20369 != math.MaxUint64 {
+		t.Fatalf("got %v, want %v", uint64(C.UINT64_MAX_20369), uint64(math.MaxUint64))
+	}
+}
+
+// -----
+// issue 21708: cast to int64
+// -----
+
+func test21708(t *testing.T) {
+	if got, want := C.CAST_TO_INT64, -1; got != want {
+		t.Errorf("C.CAST_TO_INT64 == %v, expected %v", got, want)
+	}
+}
+
+// -----
+// issue 23356: simple C function calls
+// -----
+
+func test23356(t *testing.T) {
+	if got, want := C.a23356(), C.int(5); got != want {
+		t.Errorf("C.a23356() == %v, expected %v", got, want)
+	}
+	if got, want := C.r23356(), C.int(3); got != want {
+		t.Errorf("C.r23356() == %v, expected %v", got, want)
+	}
+}
+
+// -----
+// issue 26066: Wrong type of constant with GCC 8 and newer
+// -----
+
+func test26066(t *testing.T) {
+	var i = int64(C.issue26066)
+	if i != -1 {
+		t.Errorf("got %d, want -1", i)
+	}
+}
+
+// -----
+// issue 5242: alignment of structs with no Go accessible fields
+// -----
+
+func test5242(t *testing.T) {
+	if got := C.issue5242(C.foo5242{}, C.bar5242{}); got != 5242 {
+		t.Errorf("got %v", got)
+	}
+}
+
+// -----
+// issue 7665: export function pointer
+// -----
+
+//export f7665
+func f7665() {}
+
+var bad7665 unsafe.Pointer = C.f7665
+var good7665 uintptr = uintptr(C.f7665)
+
+func test7665(t *testing.T) {
+	if bad7665 == nil || uintptr(bad7665) != good7665 {
+		t.Errorf("ptrs = %p, %#x, want same non-nil pointer", bad7665, good7665)
+	}
+}
+
+// -----
+// issue 8811: initialization check
+// -----
+
+func test8811(t *testing.T) {
+	C.issue8811Execute()
+}
+
+// -----
+// issue 18126: void function returning errno
+// -----
+
+func test18126(t *testing.T) {
+	p := C.malloc(1)
+	_, err := C.Issue18126C(&p)
+	C.free(p)
+	_ = err
+}
