+//! Chroma specific error types.
+
+use thiserror::Error;
+
+/// Chroma Error
+#[derive(Error, Debug)]
+pub enum ChromaError {
+    #[error("Config error: {0}")]
+    Config(String),
+    #[error("Storage error: {0}")]
+    Storage(String),
+    #[error("System error: {0}")]
+    System(String),
+    #[error("Assignment error: {0}")]
+    Assignment(String),
+    #[error("Blockstore error: {0}")]
+    Blockstore(String),
+    #[error("Compaction error: {0}")]
+    Compaction(String),
+    #[error("Execution error: {0}")]
+    Execution(String),
+    #[error("Index error: {0}")]
+    Index(String),
+    #[error("Log error: {0}")]
+    Log(String),
+    #[error("Memberlist error: {0}")]
+    Memberlist(String),
+    #[error("Segment error: {0}")]
+    Segment(String),
+    #[error("Sysdb error: {0}")]
+    Sysdb(String),
+    #[error("Tracing error: {0}")]
+    Tracing(String),
+    #[error("Utils error: {0}")]
+    Utils(String),
+    #[error("Unknown error: {0}")]
+    Unknown(String),
+}
