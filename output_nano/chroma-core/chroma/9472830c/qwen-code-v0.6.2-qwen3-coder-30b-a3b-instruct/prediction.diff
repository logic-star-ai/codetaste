+use uuid::Uuid;
+
+/// A unique identifier for a segment
+#[derive(Debug, Clone, serde::Deserialize, serde::Serialize, PartialEq, Eq, Hash)]
+pub struct SegmentId(pub Uuid);
+
+impl From<Uuid> for SegmentId {
+    fn from(uuid: Uuid) -> Self {
+        SegmentId(uuid)
+    }
+}
+
+impl From<SegmentId> for Uuid {
+    fn from(segment_id: SegmentId) -> Self {
+        segment_id.0
+    }
+}
+
+impl Default for SegmentId {
+    fn default() -> Self {
+        SegmentId(Uuid::new_v4())
+    }
+}
+
+/// A unique identifier for a collection
+#[derive(Debug, Clone, serde::Deserialize, serde::Serialize, PartialEq, Eq, Hash)]
+pub struct CollectionId(pub Uuid);
+
+impl From<Uuid> for CollectionId {
+    fn from(uuid: Uuid) -> Self {
+        CollectionId(uuid)
+    }
+}
+
+impl From<CollectionId> for Uuid {
+    fn from(collection_id: CollectionId) -> Self {
+        collection_id.0
+    }
+}
+
+impl Default for CollectionId {
+    fn default() -> Self {
+        CollectionId(Uuid::new_v4())
+    }
+}
