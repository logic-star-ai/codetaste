+use async_trait::async_trait;
+use chroma_error::ChromaError;
+use figment::providers::{Env, Format, Yaml};
+use serde::Deserialize;
+
+pub const DEFAULT_CONFIG_PATH: &str = "./chroma_config.yaml";
+pub const ENV_PREFIX: &str = "CHROMA_";
+
+/// # Description
+/// A trait for configuring a struct from a config object.
+/// # Notes
+/// This trait is used to configure structs from the config object.
+/// Components that need to be configured from the config object should implement this trait.
+#[async_trait]
+pub trait Configurable<T> {
+    async fn try_from_config(config: &T) -> Result<Self, Box<dyn ChromaError>>
+    where
+        Self: Sized;
+}
+
+/// Helper function to load configuration from a YAML file with environment variable overrides.
+/// Environment variables are prefixed with CHROMA_ and are uppercase.
+/// Values in the environment variables take precedence over values in the YAML file.
+pub fn load_config<'de, T: Deserialize<'de>>(path: &str) -> T {
+    // Unfortunately, figment doesn't support environment variables with underscores. So we have to map and replace them.
+    // Excluding our own environment variables, which are prefixed with CHROMA_.
+    let mut f = figment::Figment::from(Env::prefixed(ENV_PREFIX).map(|k| match k {
+        k if k == "my_member_id" => k.into(),
+        k => k.as_str().replace("__", ".").into(),
+    }));
+    if std::path::Path::new(path).exists() {
+        f = figment::Figment::from(Yaml::file(path)).merge(f);
+    }
+    let res = f.extract();
+    match res {
+        Ok(config) => config,
+        Err(e) => panic!("Error loading config: {}", e),
+    }
+}
