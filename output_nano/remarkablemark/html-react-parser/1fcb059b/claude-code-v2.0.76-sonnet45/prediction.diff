+import * as domhandler from 'domhandler';
+import { ChildNode } from 'domhandler';
+import htmlToDOM from 'html-dom-parser';
+import attributesToProps = require('./lib/attributes-to-props');
+import domToReact = require('./lib/dom-to-react');
+
+// support backwards compatibility for ES Module
+const htmlToDOMParser =
+  /* istanbul ignore next */
+  typeof (htmlToDOM as any).default === 'function' ? (htmlToDOM as any).default : htmlToDOM;
+
+const domParserOptions = { lowerCaseAttributeNames: false };
+
+interface HTMLReactParserOptions {
+  htmlparser2?: any;
+  library?: {
+    cloneElement: (
+      element: JSX.Element,
+      props?: Record<string, any>,
+      ...children: any[]
+    ) => JSX.Element;
+    createElement: (
+      type: any,
+      props?: Record<string, any>,
+      ...children: any[]
+    ) => JSX.Element;
+    isValidElement: (element: any) => boolean;
+    [key: string]: any;
+  };
+  replace?: (domNode: ChildNode) => JSX.Element | object | void | undefined | null | false;
+  transform?: (
+    reactNode: string | JSX.Element,
+    domNode: ChildNode,
+    index: number
+  ) => string | JSX.Element | null;
+  trim?: boolean;
+}
+
+/**
+ * Converts HTML string to React elements.
+ *
+ * @param html - HTML string.
+ * @param options - Parser options.
+ * @returns React element(s), empty array, or string.
+ */
+function HTMLReactParser(
+  html: string,
+  options?: HTMLReactParserOptions
+): string | JSX.Element | (string | JSX.Element)[] {
+  if (typeof html !== 'string') {
+    throw new TypeError('First argument must be a string');
+  }
+  if (html === '') {
+    return [];
+  }
+  options = options || {};
+  return domToReact(
+    htmlToDOMParser(html, options.htmlparser2 || domParserOptions),
+    options
+  );
+}
+
+// Attach static properties
+Object.assign(HTMLReactParser, {
+  domToReact,
+  htmlToDOM: htmlToDOMParser,
+  attributesToProps,
+  Comment: domhandler.Comment,
+  Element: domhandler.Element,
+  ProcessingInstruction: domhandler.ProcessingInstruction,
+  Text: domhandler.Text
+});
+
+// Export for both CommonJS and ES Modules
+(HTMLReactParser as any).default = HTMLReactParser;
+export = HTMLReactParser;
