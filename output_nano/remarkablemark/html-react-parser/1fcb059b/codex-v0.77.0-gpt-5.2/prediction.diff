diff --git a/scripts/sync-build.mjs b/scripts/sync-build.mjs
new file mode 100644
index 0000000..93cac64
--- /dev/null
+++ b/scripts/sync-build.mjs
@@ -0,0 +1,22 @@
+import { copyFileSync, mkdirSync, rmSync } from 'node:fs';
+import { dirname } from 'node:path';
+import { fileURLToPath } from 'node:url';
+
+const buildRoot = new URL('../build/', import.meta.url);
+const projectRoot = new URL('../', import.meta.url);
+
+const files = [
+  'index.js',
+  'lib/attributes-to-props.js',
+  'lib/dom-to-react.js',
+  'lib/utilities.js'
+];
+
+for (const relativePath of files) {
+  const sourcePath = new URL(relativePath, buildRoot);
+  const destinationPath = new URL(relativePath, projectRoot);
+  mkdirSync(dirname(fileURLToPath(destinationPath)), { recursive: true });
+  copyFileSync(fileURLToPath(sourcePath), fileURLToPath(destinationPath));
+}
+
+rmSync(fileURLToPath(buildRoot), { recursive: true, force: true });
diff --git a/src/index.ts b/src/index.ts
new file mode 100644
index 0000000..413aff0
--- /dev/null
+++ b/src/index.ts
@@ -0,0 +1,54 @@
+import * as domhandler from 'domhandler';
+import attributesToProps = require('./lib/attributes-to-props');
+import domToReact = require('./lib/dom-to-react');
+
+const htmlToDOMImport = require('html-dom-parser') as any;
+
+// support backwards compatibility for ES Module
+const htmlToDOM: any =
+  /* istanbul ignore next */
+  typeof htmlToDOMImport.default === 'function'
+    ? htmlToDOMImport.default
+    : htmlToDOMImport;
+
+const domParserOptions = { lowerCaseAttributeNames: false };
+
+/**
+ * Converts HTML string to React elements.
+ *
+ * @param {string} html - HTML string.
+ * @param {object} [options] - Parser options.
+ * @param {object} [options.htmlparser2] - htmlparser2 options.
+ * @param {object} [options.library] - Library for React, Preact, etc.
+ * @param {Function} [options.replace] - Replace method.
+ * @returns {JSX.Element|JSX.Element[]|string} - React element(s), empty array, or string.
+ */
+function HTMLReactParser(html: string, options?: any) {
+  if (typeof html !== 'string') {
+    throw new TypeError('First argument must be a string');
+  }
+  if (html === '') {
+    return [];
+  }
+  options = options || {};
+  return domToReact(
+    htmlToDOM(html, options.htmlparser2 || domParserOptions),
+    options
+  );
+}
+
+(HTMLReactParser as any).domToReact = domToReact;
+(HTMLReactParser as any).htmlToDOM = htmlToDOM;
+(HTMLReactParser as any).attributesToProps = attributesToProps;
+
+// domhandler
+(HTMLReactParser as any).Comment = (domhandler as any).Comment;
+(HTMLReactParser as any).Element = (domhandler as any).Element;
+(HTMLReactParser as any).ProcessingInstruction = (
+  domhandler as any
+).ProcessingInstruction;
+(HTMLReactParser as any).Text = (domhandler as any).Text;
+
+// support CommonJS and ES Modules
+module.exports = HTMLReactParser;
+(HTMLReactParser as any).default = HTMLReactParser;
