@@ -0,0 +1,92 @@
+import domhandler = require('domhandler');
+import htmlDomParser = require('html-dom-parser');
+
+import attributesToProps = require('./attributes-to-props');
+import domToReact = require('./dom-to-react');
+
+type HtmlToDom = (html: string, options?: unknown) => unknown[];
+
+// support backwards compatibility for ES Module
+let htmlToDOM: HtmlToDom =
+  // eslint-disable-next-line @typescript-eslint/no-unsafe-member-access
+  ((htmlDomParser as unknown as { default?: HtmlToDom }).default ||
+    (htmlDomParser as unknown as HtmlToDom)) as HtmlToDom;
+
+// eslint-disable-next-line @typescript-eslint/no-unsafe-member-access
+htmlToDOM =
+  /* istanbul ignore next */
+  typeof (htmlToDOM as unknown as { default?: unknown }).default === 'function'
+    ? // eslint-disable-next-line @typescript-eslint/no-unsafe-member-access
+      ((htmlToDOM as unknown as { default: HtmlToDom }).default as HtmlToDom)
+    : htmlToDOM;
+
+const domParserOptions = { lowerCaseAttributeNames: false };
+
+type HTMLReactParserOptions = {
+  htmlparser2?: unknown;
+  library?: {
+    cloneElement: (...args: any[]) => any;
+    createElement: (...args: any[]) => any;
+    isValidElement: (element: unknown) => boolean;
+    [key: string]: any;
+  };
+  replace?: (domNode: unknown) => unknown;
+  transform?: (reactNode: unknown, domNode: unknown, index: number) => unknown;
+  trim?: boolean;
+};
+
+type HTMLReactParserModule = {
+  (
+    html: string,
+    options?: HTMLReactParserOptions
+  ): ReturnType<typeof domToReact>;
+  domToReact: typeof domToReact;
+  htmlToDOM: HtmlToDom;
+  attributesToProps: typeof attributesToProps;
+  Comment: typeof domhandler.Comment;
+  Element: typeof domhandler.Element;
+  ProcessingInstruction: typeof domhandler.ProcessingInstruction;
+  Text: typeof domhandler.Text;
+  default: HTMLReactParserModule;
+};
+
+/**
+ * Converts HTML string to React elements.
+ *
+ * @param {string} html - HTML string.
+ * @param {object} [options] - Parser options.
+ * @param {object} [options.htmlparser2] - htmlparser2 options.
+ * @param {object} [options.library] - Library for React, Preact, etc.
+ * @param {Function} [options.replace] - Replace method.
+ * @returns {JSX.Element|JSX.Element[]|string} - React element(s), empty array, or string.
+ */
+const HTMLReactParser = function HTMLReactParser(
+  html: string,
+  options?: HTMLReactParserOptions
+) {
+  if (typeof html !== 'string') {
+    throw new TypeError('First argument must be a string');
+  }
+  if (html === '') {
+    return [];
+  }
+  options = options || {};
+  return domToReact(
+    htmlToDOM(html, options.htmlparser2 || domParserOptions),
+    options
+  );
+} as unknown as HTMLReactParserModule;
+
+HTMLReactParser.domToReact = domToReact;
+HTMLReactParser.htmlToDOM = htmlToDOM;
+HTMLReactParser.attributesToProps = attributesToProps;
+
+// domhandler
+HTMLReactParser.Comment = domhandler.Comment;
+HTMLReactParser.Element = domhandler.Element;
+HTMLReactParser.ProcessingInstruction = domhandler.ProcessingInstruction;
+HTMLReactParser.Text = domhandler.Text;
+
+// support CommonJS and ES Modules
+HTMLReactParser.default = HTMLReactParser;
+export = HTMLReactParser;
