diff --git a/modules/templates/mirror_test.go b/modules/templates/mirror_test.go
new file mode 100644
index 0000000..ac2c498
--- /dev/null
+++ b/modules/templates/mirror_test.go
@@ -0,0 +1,70 @@
+// Copyright 2024 The Gitea Authors. All rights reserved.
+// SPDX-License-Identifier: MIT
+
+package templates
+
+import (
+	"context"
+	"testing"
+
+	repo_model "code.gitea.io/gitea/models/repo"
+	"github.com/stretchr/testify/assert"
+)
+
+func TestMirrorRemoteAddress(t *testing.T) {
+	// Test the mirrorRemoteAddress function with explicit context
+	ctx := context.Background()
+
+	repo := &repo_model.Repository{
+		OriginalURL: "https://user:password@github.com/test/repo.git",
+	}
+
+	addr := mirrorRemoteAddress(ctx, repo, "origin", false)
+
+	assert.Equal(t, "https://github.com/test/repo.git", addr.Address)
+	assert.Equal(t, "user", addr.Username)
+	assert.Equal(t, "password", addr.Password)
+}
+
+func TestMirrorRemoteAddressSSH(t *testing.T) {
+	// Test SSH URL which should not extract credentials
+	ctx := context.Background()
+
+	repo := &repo_model.Repository{
+		OriginalURL: "ssh://git@github.com/test/repo.git",
+	}
+
+	addr := mirrorRemoteAddress(ctx, repo, "origin", false)
+
+	assert.Equal(t, "ssh://git@github.com/test/repo.git", addr.Address)
+	assert.Equal(t, "", addr.Username)
+	assert.Equal(t, "", addr.Password)
+}
+
+func TestMirrorRemoteAddressWithContextWrapper(t *testing.T) {
+	// Test the wrapper function that accepts interface{}
+	ctx := context.Background()
+
+	repo := &repo_model.Repository{
+		OriginalURL: "https://user:password@github.com/test/repo.git",
+	}
+
+	result := mirrorRemoteAddressWithContext(ctx, repo, "origin", false)
+
+	addr, ok := result.(remoteAddress)
+	assert.True(t, ok, "Result should be of type remoteAddress")
+	assert.Equal(t, "https://github.com/test/repo.git", addr.Address)
+	assert.Equal(t, "user", addr.Username)
+	assert.Equal(t, "password", addr.Password)
+}
+
+func TestMirrorRemoteAddressWithInvalidType(t *testing.T) {
+	// Test the wrapper with invalid type
+	ctx := context.Background()
+
+	result := mirrorRemoteAddressWithContext(ctx, "invalid", "origin", false)
+
+	addr, ok := result.(remoteAddress)
+	assert.True(t, ok, "Result should be of type remoteAddress")
+	assert.Equal(t, "", addr.Address, "Address should be empty for invalid input")
+}
