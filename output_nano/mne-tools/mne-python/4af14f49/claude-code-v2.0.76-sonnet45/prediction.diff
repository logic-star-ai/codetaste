+++ b/tools/check_circular_imports.py
@@ -0,0 +1,280 @@
+#!/usr/bin/env python
+"""
+Check for circular imports in the MNE-Python codebase.
+
+This script analyzes top-level imports (imports at module level, not inside
+functions) to detect circular dependencies. It's designed to catch accidental
+circular imports while allowing intentional ones that are properly handled
+with deferred imports.
+
+Usage:
+    python tools/check_circular_imports.py
+
+Exit codes:
+    0 - No circular imports found at module level
+    1 - Circular imports detected or error occurred
+"""
+
+import ast
+import os
+import sys
+from collections import defaultdict
+from pathlib import Path
+
+
+def get_top_level_imports(filepath):
+    """
+    Extract top-level imports from a Python file.
+
+    Parameters
+    ----------
+    filepath : str
+        Path to the Python file to analyze.
+
+    Returns
+    -------
+    list of str
+        List of module names imported at the top level (not inside functions).
+    """
+    try:
+        with open(filepath, 'r', encoding='utf-8') as f:
+            content = f.read()
+            tree = ast.parse(content, filename=filepath)
+
+        imports = []
+
+        # Walk only top-level nodes, not nested ones
+        for node in tree.body:
+            if isinstance(node, ast.Import):
+                for alias in node.names:
+                    if alias.name.startswith('mne'):
+                        imports.append(alias.name)
+            elif isinstance(node, ast.ImportFrom):
+                if node.module and node.module.startswith('mne'):
+                    imports.append(node.module)
+                elif node.level > 0:
+                    # Handle relative imports
+                    # Calculate the absolute module name
+                    module_name = module_path_to_name(filepath, '/testbed')
+                    parts = module_name.split('.')
+                    if node.level <= len(parts):
+                        base = '.'.join(parts[:-node.level] if node.level > 0 else parts)
+                        if node.module:
+                            imports.append(f"{base}.{node.module}")
+                        else:
+                            imports.append(base)
+
+        return imports
+    except SyntaxError as e:
+        print(f"Warning: Syntax error in {filepath}: {e}", file=sys.stderr)
+        return []
+    except Exception as e:
+        print(f"Warning: Error parsing {filepath}: {e}", file=sys.stderr)
+        return []
+
+
+def module_path_to_name(filepath, root):
+    """
+    Convert a file path to a Python module name.
+
+    Parameters
+    ----------
+    filepath : str
+        Path to the Python file.
+    root : str
+        Root directory of the package.
+
+    Returns
+    -------
+    str
+        Module name (e.g., 'mne.io.base').
+    """
+    rel_path = os.path.relpath(filepath, root)
+    if rel_path.endswith('__init__.py'):
+        module = rel_path[:-12].replace(os.sep, '.')
+    elif rel_path.endswith('.py'):
+        module = rel_path[:-3].replace(os.sep, '.')
+    else:
+        return ''
+    return module.rstrip('.')
+
+
+def build_import_graph(package_root):
+    """
+    Build a directed graph of module imports.
+
+    Parameters
+    ----------
+    package_root : str
+        Root directory of the package to analyze.
+
+    Returns
+    -------
+    dict
+        Dictionary mapping module names to sets of imported module names.
+    """
+    import_graph = defaultdict(set)
+    module_files = {}
+
+    for root, dirs, files in os.walk(package_root):
+        # Skip test directories and cache
+        dirs[:] = [d for d in dirs if d not in ('tests', '__pycache__', '.pytest_cache')]
+
+        for file in files:
+            if file.endswith('.py') and not file.startswith('test_'):
+                filepath = os.path.join(root, file)
+                module_name = module_path_to_name(filepath, '/testbed')
+
+                if not module_name or not module_name.startswith('mne'):
+                    continue
+
+                module_files[module_name] = filepath
+                imports = get_top_level_imports(filepath)
+
+                for imp in imports:
+                    # Normalize import to base module name
+                    if imp and imp != module_name:
+                        import_graph[module_name].add(imp)
+
+    return import_graph, module_files
+
+
+def find_circular_imports(import_graph):
+    """
+    Find circular imports in the import graph.
+
+    Parameters
+    ----------
+    import_graph : dict
+        Dictionary mapping module names to sets of imported modules.
+
+    Returns
+    -------
+    list of tuple
+        List of (module_a, module_b) pairs that have circular dependencies.
+    """
+    circular_pairs = set()
+
+    for module_a in sorted(import_graph.keys()):
+        for module_b in import_graph[module_a]:
+            # Check if module_b imports module_a
+            if module_a in import_graph.get(module_b, set()):
+                # Normalize the pair to avoid duplicates (a,b) and (b,a)
+                pair = tuple(sorted([module_a, module_b]))
+                circular_pairs.add(pair)
+
+    return sorted(circular_pairs)
+
+
+def find_cycles_dfs(import_graph):
+    """
+    Find all circular dependency chains using DFS.
+
+    Parameters
+    ----------
+    import_graph : dict
+        Dictionary mapping module names to sets of imported modules.
+
+    Returns
+    -------
+    list of list
+        List of circular dependency chains.
+    """
+    def dfs(node, path, visited, rec_stack):
+        visited.add(node)
+        rec_stack.add(node)
+        path.append(node)
+
+        for neighbor in import_graph.get(node, set()):
+            if neighbor not in visited:
+                result = dfs(neighbor, path[:], visited, rec_stack)
+                if result:
+                    return result
+            elif neighbor in rec_stack:
+                # Found a cycle
+                cycle_start = path.index(neighbor)
+                return path[cycle_start:] + [neighbor]
+
+        rec_stack.remove(node)
+        return None
+
+    cycles = []
+    visited = set()
+
+    for node in sorted(import_graph.keys()):
+        if node not in visited:
+            rec_stack = set()
+            cycle = dfs(node, [], visited, rec_stack)
+            if cycle:
+                cycles.append(cycle)
+
+    return cycles
+
+
+def main():
+    """Main entry point for the circular import checker."""
+    print("Checking for circular imports in MNE-Python...")
+    print("=" * 70)
+
+    package_root = '/testbed/mne'
+    if not os.path.exists(package_root):
+        print(f"Error: Package root {package_root} not found", file=sys.stderr)
+        return 1
+
+    # Build import graph
+    print("Building import graph...")
+    import_graph, module_files = build_import_graph(package_root)
+    print(f"Analyzed {len(module_files)} modules")
+    print()
+
+    # Find direct circular imports (A imports B, B imports A)
+    circular_pairs = find_circular_imports(import_graph)
+
+    if circular_pairs:
+        print(f"⚠️  Found {len(circular_pairs)} direct circular import pair(s):")
+        print()
+        for module_a, module_b in circular_pairs:
+            print(f"  {module_a}")
+            print(f"    ↔ {module_b}")
+            print()
+
+            # Show file locations
+            if module_a in module_files:
+                print(f"    File A: {module_files[module_a]}")
+            if module_b in module_files:
+                print(f"    File B: {module_files[module_b]}")
+            print()
+
+        print("=" * 70)
+        print("❌ Circular imports detected!")
+        print()
+        print("These circular imports should be resolved by using deferred imports")
+        print("(importing inside functions rather than at module level).")
+        print()
+        print("See /testbed/mne/IMPORT_HIERARCHY.md for guidelines.")
+        return 1
+
+    # Find longer circular chains (A -> B -> C -> A)
+    print("Checking for circular dependency chains...")
+    cycles = find_cycles_dfs(import_graph)
+
+    if cycles:
+        print(f"⚠️  Found {len(cycles)} circular dependency chain(s):")
+        print()
+        for cycle in cycles:
+            print("  " + " → ".join(cycle))
+            print()
+
+        print("=" * 70)
+        print("❌ Circular dependency chains detected!")
+        return 1
+
+    print("✅ No circular imports found at module level!")
+    print()
+    print("All imports are properly structured. Deferred imports (inside functions)")
+    print("are being used correctly to avoid circular dependencies.")
+    return 0
+
+
+if __name__ == '__main__':
+    sys.exit(main())
