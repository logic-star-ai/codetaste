@@ -0,0 +1,272 @@
+#!/usr/bin/env python
+"""
+Check if imports in a file respect the MNE-Python module hierarchy.
+
+This script helps developers verify that their code follows the established
+import hierarchy before committing changes.
+
+Usage:
+    python tools/check_import_hierarchy.py <file_path>
+    python tools/check_import_hierarchy.py mne/my_new_module.py
+
+The script will check if imports in the specified file follow the hierarchy
+defined in /testbed/mne/IMPORT_HIERARCHY.md
+"""
+
+import ast
+import sys
+from pathlib import Path
+
+# Module hierarchy levels (lower number = lower in hierarchy, can be imported by higher levels)
+HIERARCHY_LEVELS = {
+    # Level 1: Foundation
+    'mne.utils': 1,
+    'mne.fixes': 1,
+    'mne.defaults': 1,
+    'mne._fiff.constants': 1,
+
+    # Level 2: Low-level I/O and structures
+    'mne._fiff': 2,
+    'mne.transforms': 2,
+    'mne.surface': 2,
+    'mne.baseline': 2,
+    'mne.filter': 2,
+
+    # Level 3: Core data structures
+    'mne.io.base': 3,
+    'mne.io.meas_info': 3,
+    'mne.epochs': 3,
+    'mne.evoked': 3,
+    'mne.cov': 3,
+    'mne.bem': 3,
+    'mne.source_space': 3,
+    'mne.source_estimate': 3,
+    'mne.dipole': 3,
+    'mne.proj': 3,
+    'mne.event': 3,
+
+    # Level 4: I/O implementations
+    'mne.io': 4,
+
+    # Level 5: Processing and analysis
+    'mne.channels': 5,
+    'mne.preprocessing': 5,
+    'mne.forward': 5,
+    'mne.time_frequency': 5,
+    'mne.beamformer': 5,
+    'mne.minimum_norm': 5,
+    'mne.inverse_sparse': 5,
+    'mne.decoding': 5,
+
+    # Level 6: Visualization and high-level operations
+    'mne.viz': 6,
+    'mne.stats': 6,
+    'mne.simulation': 6,
+    'mne.report': 6,
+
+    # Level 7: User interface
+    'mne.commands': 7,
+}
+
+
+def get_module_level(module_name):
+    """
+    Get the hierarchy level of a module.
+
+    Parameters
+    ----------
+    module_name : str
+        Fully qualified module name (e.g., 'mne.io.base').
+
+    Returns
+    -------
+    int or None
+        Hierarchy level, or None if not found.
+    """
+    # Try exact match first
+    if module_name in HIERARCHY_LEVELS:
+        return HIERARCHY_LEVELS[module_name]
+
+    # Try parent modules
+    parts = module_name.split('.')
+    for i in range(len(parts), 0, -1):
+        parent = '.'.join(parts[:i])
+        if parent in HIERARCHY_LEVELS:
+            return HIERARCHY_LEVELS[parent]
+
+    return None
+
+
+def get_top_level_imports(filepath):
+    """
+    Extract top-level imports from a Python file.
+
+    Parameters
+    ----------
+    filepath : str
+        Path to the Python file.
+
+    Returns
+    -------
+    list of tuple
+        List of (module_name, line_number) tuples.
+    """
+    try:
+        with open(filepath, 'r', encoding='utf-8') as f:
+            content = f.read()
+            tree = ast.parse(content, filename=filepath)
+
+        imports = []
+
+        # Only check top-level imports
+        for node in tree.body:
+            if isinstance(node, ast.Import):
+                for alias in node.names:
+                    if alias.name.startswith('mne'):
+                        imports.append((alias.name, node.lineno))
+            elif isinstance(node, ast.ImportFrom):
+                if node.module and node.module.startswith('mne'):
+                    imports.append((node.module, node.lineno))
+
+        return imports
+    except Exception as e:
+        print(f"Error parsing {filepath}: {e}", file=sys.stderr)
+        return []
+
+
+def module_path_to_name(filepath):
+    """
+    Convert a file path to a Python module name.
+
+    Parameters
+    ----------
+    filepath : str
+        Path to the Python file.
+
+    Returns
+    -------
+    str
+        Module name (e.g., 'mne.io.base').
+    """
+    path = Path(filepath).resolve()
+    testbed = Path('/testbed')
+
+    try:
+        rel_path = path.relative_to(testbed)
+    except ValueError:
+        # File is not in testbed
+        return None
+
+    if str(rel_path).endswith('__init__.py'):
+        module = str(rel_path)[:-12].replace('/', '.')
+    elif str(rel_path).endswith('.py'):
+        module = str(rel_path)[:-3].replace('/', '.')
+    else:
+        return None
+
+    return module.rstrip('.')
+
+
+def check_file_imports(filepath):
+    """
+    Check if imports in a file respect the hierarchy.
+
+    Parameters
+    ----------
+    filepath : str
+        Path to the Python file to check.
+
+    Returns
+    -------
+    bool
+        True if all imports respect hierarchy, False otherwise.
+    """
+    module_name = module_path_to_name(filepath)
+
+    if not module_name:
+        print(f"Could not determine module name for {filepath}")
+        return True
+
+    if not module_name.startswith('mne'):
+        print(f"File {filepath} is not part of the mne package")
+        return True
+
+    module_level = get_module_level(module_name)
+
+    if module_level is None:
+        print(f"⚠️  Module {module_name} not in hierarchy definition")
+        print("This might be a new module. Please update HIERARCHY_LEVELS in this script.")
+        print()
+        return True
+
+    print(f"Checking imports in: {module_name}")
+    print(f"Module hierarchy level: {module_level}")
+    print()
+
+    imports = get_top_level_imports(filepath)
+
+    if not imports:
+        print("No top-level imports from mne package found.")
+        return True
+
+    violations = []
+
+    for imported_module, line_no in imports:
+        imported_level = get_module_level(imported_module)
+
+        if imported_level is None:
+            print(f"  ⚠️  Line {line_no}: Unknown module {imported_module}")
+            continue
+
+        # A module can import from lower levels (lower number)
+        # or same level (with caution about circular imports)
+        if imported_level > module_level:
+            violations.append((line_no, imported_module, imported_level))
+        else:
+            print(f"  ✓ Line {line_no}: {imported_module} (level {imported_level})")
+
+    if violations:
+        print()
+        print("❌ Hierarchy violations found:")
+        print()
+        for line_no, imported_module, imported_level in violations:
+            print(f"  Line {line_no}: Cannot import {imported_module} (level {imported_level})")
+            print(f"             from {module_name} (level {module_level})")
+            print(f"             Higher-level modules cannot import from lower-level modules.")
+            print()
+
+        print("Solution: Use deferred imports (import inside functions) for these imports.")
+        print("See /testbed/mne/IMPORT_HIERARCHY.md for guidelines.")
+        return False
+
+    print()
+    print("✅ All imports respect the hierarchy!")
+    return True
+
+
+def main():
+    """Main entry point."""
+    if len(sys.argv) != 2:
+        print("Usage: python tools/check_import_hierarchy.py <file_path>")
+        print()
+        print("Example:")
+        print("  python tools/check_import_hierarchy.py mne/my_module.py")
+        return 1
+
+    filepath = sys.argv[1]
+
+    if not Path(filepath).exists():
+        print(f"Error: File {filepath} not found", file=sys.stderr)
+        return 1
+
+    print("Checking import hierarchy...")
+    print("=" * 70)
+
+    if check_file_imports(filepath):
+        return 0
+    else:
+        return 1
+
+
+if __name__ == '__main__':
+    sys.exit(main())
