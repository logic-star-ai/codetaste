+#!/usr/bin/env python
+"""Test script for refactored plot grid and model architecture."""
+
+import sys
+import os
+
+print("Testing refactored OutputContainer and GridLayout...")
+print("=" * 60)
+
+# Test 1: Test OutputContainer imports and basic functionality
+print("\n1. Testing OutputContainer refactoring...")
+try:
+    # Import dependencies directly
+    from abc import ABC, abstractmethod
+    from typing import List, Optional, Any
+    from pandas import DataFrame
+
+    # Read and execute the file
+    with open('beakerx/beakerx/output_container/outputcontainer.py', 'r') as f:
+        code = f.read()
+
+    # Create a minimal mock environment
+    class MockWidget:
+        def __init__(self):
+            pass
+        def _ipython_display_(self):
+            pass
+
+    class BeakerxHTML(MockWidget):
+        value = ""
+
+    class BeakerxHTMLPre(MockWidget):
+        value = ""
+
+    class BeakerxHBox(MockWidget):
+        def __init__(self, children=None):
+            super().__init__()
+            self.children = children or []
+
+    class Tab(MockWidget):
+        def __init__(self, widgets, labels):
+            super().__init__()
+            self.widgets = widgets
+            self.labels = labels
+
+    class CyclingDisplayBox(MockWidget):
+        def __init__(self, widgets):
+            super().__init__()
+            self.widgets = widgets
+        def setPeriod(self, period):
+            self.period = period
+
+    class GridView(MockWidget):
+        def __init__(self, rows):
+            super().__init__()
+            self.rows = rows
+
+    class TableDisplay(MockWidget):
+        def __init__(self, df):
+            super().__init__()
+            self.df = df
+
+    # Execute the refactored code with our mocks
+    namespace = {
+        'ABC': ABC,
+        'abstractmethod': abstractmethod,
+        'List': List,
+        'Optional': Optional,
+        'Any': Any,
+        'Widget': MockWidget,
+        'DataFrame': DataFrame,
+        'BeakerxHTML': BeakerxHTML,
+        'BeakerxHTMLPre': BeakerxHTMLPre,
+        'BeakerxHBox': BeakerxHBox,
+        'Tab': Tab,
+        'CyclingDisplayBox': CyclingDisplayBox,
+        'GridView': GridView,
+        'TableDisplay': TableDisplay,
+    }
+
+    exec(code, namespace)
+
+    # Get the classes from namespace
+    OutputContainer = namespace['OutputContainer']
+    GridOutputContainerLayoutManager = namespace['GridOutputContainerLayoutManager']
+    SimpleLayoutManager = namespace['SimpleLayoutManager']
+    CyclingOutputContainerLayoutManager = namespace['CyclingOutputContainerLayoutManager']
+
+    # Test OutputContainer
+    container = OutputContainer()
+    print("   ✓ OutputContainer instantiation successful")
+
+    # Test method chaining
+    container.add_item('test1').add_item('test2')
+    assert len(container.items) == 2
+    print("   ✓ Method chaining works")
+
+    # Test backward compatibility
+    container.addItem('test3')
+    assert len(container.items) == 3
+    print("   ✓ Backward compatibility (addItem) works")
+
+    # Test layout manager property
+    assert container.layoutManager is not None
+    print("   ✓ Layout manager property works")
+
+    print("\n2. Testing GridOutputContainerLayoutManager refactoring...")
+
+    # Test GridOutputContainerLayoutManager
+    grid_mgr = GridOutputContainerLayoutManager(columns=3)
+    assert grid_mgr.columns == 3
+    print("   ✓ GridOutputContainerLayoutManager instantiation successful")
+
+    # Test validation
+    try:
+        bad_grid = GridOutputContainerLayoutManager(columns=0)
+        print("   ✗ Should have raised ValueError for columns=0")
+        sys.exit(1)
+    except ValueError as e:
+        assert "at least 1" in str(e)
+        print("   ✓ Validation works: columns must be >= 1")
+
+    # Test grid row creation
