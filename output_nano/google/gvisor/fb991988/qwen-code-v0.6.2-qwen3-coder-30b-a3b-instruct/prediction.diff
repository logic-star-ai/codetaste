+// Package kernel provides kernel functionality for the sentry.
+package kernel
+
+import (
+	"sync"
+
+	"gvisor.googlesource.com/gvisor/pkg/sentry/mm"
+	"gvisor.googlesource.com/gvisor/pkg/sentry/platform"
+)
+
+// MemoryManager manages memory allocation outside of the platform abstraction.
+type MemoryManager struct {
+	// mutex protects the memory allocator
+	mutex sync.Mutex
+
+	// allocator is the memory allocator used for all memory allocations.
+	allocator mm.MemoryAllocator
+}
+
+// NewMemoryManager creates a new MemoryManager with a default allocator.
+func NewMemoryManager(p platform.Platform) (*MemoryManager, error) {
+	// Create a FileMem-based allocator that's decoupled from platform
+	allocator, err := mm.NewFileMemAllocator("sentry-memory")
+	if err != nil {
+		return nil, err
+	}
+
+	return &MemoryManager{
+		allocator: allocator,
+	}, nil
+}
+
+// MemoryAllocator returns the memory allocator for this memory manager.
+func (mm *MemoryManager) MemoryAllocator() mm.MemoryAllocator {
+	mm.mutex.Lock()
+	defer mm.mutex.Unlock()
+	return mm.allocator
+}
+
+// Destroy cleans up resources used by the memory manager.
+func (mm *MemoryManager) Destroy() {
+	mm.mutex.Lock()
+	defer mm.mutex.Unlock()
+	if mm.allocator != nil {
+		mm.allocator.Destroy()
+		mm.allocator = nil
+	}
+}
