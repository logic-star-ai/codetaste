+
+/// \brief Create an ExecBatch from arrays
+inline ExecBatch MakeExecBatch(const std::vector<std::shared_ptr<Array>>& arrays) {
+  if (arrays.empty()) {
+    return ExecBatch({}, 0);
+  }
+  std::vector<Datum> values;
+  values.reserve(arrays.size());
+  for (const auto& array : arrays) {
+    values.emplace_back(array);
+  }
+  return ExecBatch(std::move(values), arrays[0]->length());
+}
+
+/// \brief Create an ExecBatch from JSON strings
+inline ExecBatch ExecBatchFromJSON(const std::vector<std::shared_ptr<DataType>>& types,
+                                   const std::vector<std::string>& json_strings) {
+  DCHECK_EQ(types.size(), json_strings.size());
+  std::vector<std::shared_ptr<Array>> arrays;
+  arrays.reserve(types.size());
+  for (size_t i = 0; i < types.size(); ++i) {
+    arrays.push_back(ArrayFromJSON(types[i], json_strings[i]));
+  }
+  return MakeExecBatch(arrays);
+}
+
+/// \brief Helper to validate group IDs
+inline void ValidateGroupIds(const Datum& group_ids, int64_t expected_length,
+                             uint32_t max_group_id) {
+  ASSERT_TRUE(group_ids.is_array());
+  ASSERT_EQ(group_ids.length(), expected_length);
+  ASSERT_EQ(group_ids.type()->id(), Type::UINT32);
+
+  const auto& id_array = checked_cast<const UInt32Array&>(*group_ids.make_array());
+  for (int64_t i = 0; i < id_array.length(); ++i) {
+    ASSERT_FALSE(id_array.IsNull(i));
+    ASSERT_LT(id_array.Value(i), max_group_id);
+  }
+}
+
+/// \brief Helper to create test key types
+inline std::vector<TypeHolder> MakeKeyTypes(
+    const std::vector<std::shared_ptr<DataType>>& types) {
+  std::vector<TypeHolder> key_types;
+  key_types.reserve(types.size());
+  for (const auto& type : types) {
+    key_types.emplace_back(type);
+  }
+  return key_types;
+}
+
+/// \brief Helper to verify segment properties
+inline void ValidateSegment(const Segment& segment, int64_t expected_offset,
+                           int64_t expected_length, bool expected_is_open,
+                           bool expected_extends) {
+  ASSERT_EQ(segment.offset, expected_offset);
+  ASSERT_EQ(segment.length, expected_length);
+  ASSERT_EQ(segment.is_open, expected_is_open);
+  ASSERT_EQ(segment.extends, expected_extends);
+}
+
+/// \brief Helper to verify all segments cover the batch without gaps or overlaps
+inline void ValidateSegmentsCoverBatch(const std::vector<Segment>& segments,
+                                      int64_t batch_length) {
+  if (batch_length == 0) {
+    ASSERT_TRUE(segments.empty());
+    return;
+  }
+
+  ASSERT_FALSE(segments.empty());
+
+  int64_t current_offset = 0;
+  for (const auto& segment : segments) {
+    ASSERT_EQ(segment.offset, current_offset)
+        << "Segments must be contiguous without gaps";
+    ASSERT_GT(segment.length, 0) << "Segments must have positive length";
+    current_offset += segment.length;
+  }
+  ASSERT_EQ(current_offset, batch_length)
+      << "Segments must cover entire batch exactly";
+}
+
+/// \brief Generate random ExecBatch for testing
+inline ExecBatch GenerateRandomBatch(random::RandomArrayGenerator& rng,
+                                    const std::vector<std::shared_ptr<DataType>>& types,
+                                    int64_t length, double null_probability = 0.1) {
+  std::vector<std::shared_ptr<Array>> arrays;
+  arrays.reserve(types.size());
+  for (const auto& type : types) {
+    arrays.push_back(rng.ArrayOf(type, length, null_probability));
+  }
+  return MakeExecBatch(arrays);
+}
