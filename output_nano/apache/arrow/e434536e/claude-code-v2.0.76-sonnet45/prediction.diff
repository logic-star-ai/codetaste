+                                        default_exec_context()));
+
+  ASSERT_OK_AND_ASSIGN(auto segments, segmenter->GetSegments(span));
+
+  // With no keys, entire batch is one segment
+  ASSERT_EQ(segments.size(), 1);
+  ValidateSegment(segments[0], 0, 10, true, true);
+}
+
 }  // namespace compute
 }  // namespace arrow
