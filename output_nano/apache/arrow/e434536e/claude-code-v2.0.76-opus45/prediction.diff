+/// \param[in] row_alignment Alignment for row data.
+/// \param[in] string_alignment Alignment for variable-length string data.
+/// \return A RowTableImpl containing the encoded column data.
+Result<RowTableImpl> MakeRowTableFromColumn(const std::shared_ptr<Array>& column,
+                                            int64_t num_rows, int row_alignment,
+                                            int string_alignment);
+
+/// \brief Create a RowTableImpl from an ExecBatch.
+///
+/// \param[in] batch The ExecBatch containing columns to encode.
+/// \param[in] row_alignment Alignment for row data (default: sizeof(uint64_t)).
+/// \param[in] string_alignment Alignment for variable-length string data (default:
+/// sizeof(uint64_t)).
+/// \return A RowTableImpl containing the encoded batch data.
+Result<RowTableImpl> MakeRowTableFromExecBatch(
+    const ExecBatch& batch, int row_alignment = sizeof(uint64_t),
+    int string_alignment = sizeof(uint64_t));
+
+/// \brief Repeat a row table until it reaches the specified number of rows.
+///
+/// This is useful for creating large row tables for testing purposes,
+/// particularly for testing behavior with data exceeding 2GB or 4GB boundaries.
+///
+/// \param[in] seed The seed row table to repeat.
+/// \param[in] num_rows Target number of rows for the resulting table.
+/// \return A RowTableImpl with at least num_rows rows.
+Result<RowTableImpl> RepeatRowTableUntil(const RowTableImpl& seed, int64_t num_rows);
