+#pragma once
+
+#include <string_view>
+#include <vector>
+
+#include "arrow/compute/exec.h"
+#include "arrow/type.h"
+
+namespace arrow {
+namespace compute {
+
+/// Indicates whether a value should be treated as an array or scalar when
+/// constructing ExecBatch instances from JSON.
+enum class ArgShape { ANY, ARRAY, SCALAR };
+
+/// Construct an ExecBatch from a schema derived from @p types and the provided
+/// JSON representation of the rows.
+ExecBatch ExecBatchFromJSON(const std::vector<TypeHolder>& types, std::string_view json);
+
+/// Like ExecBatchFromJSON, but override the argument shapes so that the
+/// corresponding entries are scalars instead of arrays.
+ExecBatch ExecBatchFromJSON(const std::vector<TypeHolder>& types,
+                            const std::vector<ArgShape>& shapes, std::string_view json);
+
+}  // namespace compute
+}  // namespace arrow
