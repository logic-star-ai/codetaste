--- /dev/null
+++ b/llama_index/prompts/prompt_template.py
@@ -0,0 +1,88 @@
+"""Lightweight prompt template primitives (no LangChain dependency)."""
+
+from __future__ import annotations
+
+from dataclasses import dataclass
+from string import Formatter
+from typing import Any, List, Sequence, Set
+
+from llama_index.llms.base import ChatMessage, MessageRole
+
+
+def _extract_template_vars(template: str) -> List[str]:
+    """Extract top-level python-format variables from a template string."""
+
+    variables: Set[str] = set()
+    for _literal_text, field_name, _format_spec, _conversion in Formatter().parse(
+        template
+    ):
+        if not field_name:
+            continue
+        # field_name may include indexing/attributes (e.g. "foo.bar" or "foo[0]")
+        base = field_name.split(".", 1)[0].split("[", 1)[0]
+        if base:
+            variables.add(base)
+    return sorted(variables)
+
+
+class BasePromptTemplate:
+    """Base interface for prompt templates."""
+
+    input_variables: List[str]
+
+    def format(self, **kwargs: Any) -> str:  # pragma: no cover - interface
+        raise NotImplementedError
+
+
+@dataclass
+class PromptTemplate(BasePromptTemplate):
+    """A python-format string prompt template."""
+
+    template: str
+
+    def __post_init__(self) -> None:
+        self.input_variables = _extract_template_vars(self.template)
+
+    def format(self, **kwargs: Any) -> str:
+        return self.template.format(**kwargs)
+
+
+@dataclass(frozen=True)
+class ChatMessagePromptTemplate:
+    """A single chat message template."""
+
+    role: MessageRole
+    template: str
+
+    @property
+    def input_variables(self) -> List[str]:
+        return _extract_template_vars(self.template)
+
+    def format_message(self, **kwargs: Any) -> ChatMessage:
+        return ChatMessage(role=self.role, content=self.template.format(**kwargs))
+
+
+class ChatPromptTemplate(BasePromptTemplate):
+    """A list of message templates that can be formatted into chat messages."""
+
+    def __init__(self, messages: Sequence[ChatMessagePromptTemplate]) -> None:
+        self.messages: List[ChatMessagePromptTemplate] = list(messages)
+        variables: Set[str] = set()
+        for message in self.messages:
+            variables.update(message.input_variables)
+        self.input_variables = sorted(variables)
+
+    @classmethod
+    def from_messages(
+        cls, messages: Sequence[ChatMessagePromptTemplate]
+    ) -> "ChatPromptTemplate":
+        return cls(messages)
+
+    def format(self, **kwargs: Any) -> str:
+        # Best-effort: join messages for token counting/logging.
+        formatted = [m.format_message(**kwargs) for m in self.messages]
+        return "\n".join(f"{m.role.value}: {m.content}" for m in formatted)
+
+    def format_messages(self, **kwargs: Any) -> List[ChatMessage]:
+        return [m.format_message(**kwargs) for m in self.messages]
+
