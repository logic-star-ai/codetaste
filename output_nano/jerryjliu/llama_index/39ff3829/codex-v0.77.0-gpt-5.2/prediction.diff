diff --git a/llama_index/prompts/template.py b/llama_index/prompts/template.py
new file mode 100644
index 0000000..a92b7fb
--- /dev/null
+++ b/llama_index/prompts/template.py
@@ -0,0 +1,104 @@
+"""Prompt templates used by LlamaIndex.
+
+This module intentionally avoids importing LangChain. Templates here provide a small
+subset of the functionality needed by the rest of the codebase:
+- extracting input variables from `{var}` placeholders
+- formatting into a string
+- (optionally) formatting into a list of chat messages
+"""
+
+from __future__ import annotations
+
+import re
+import string
+from abc import ABC, abstractmethod
+from dataclasses import dataclass
+from typing import Any, List, Optional, Sequence, Set
+
+from llama_index.llms.base import ChatMessage, MessageRole
+
+
+_FIELD_RE = re.compile(r"^([a-zA-Z_][a-zA-Z0-9_]*)")
+
+
+def _extract_input_variables(template: str) -> List[str]:
+    """Extract top-level `{var}` placeholders from a format string."""
+    formatter = string.Formatter()
+    variables: Set[str] = set()
+    for _literal_text, field_name, _format_spec, _conversion in formatter.parse(
+        template
+    ):
+        if not field_name:
+            continue
+        # Support format strings like `{foo.bar}` or `{foo[0]}` by extracting
+        # the top-level identifier (`foo`).
+        match = _FIELD_RE.match(field_name)
+        if match:
+            variables.add(match.group(1))
+    return sorted(variables)
+
+
+class BasePromptTemplate(ABC):
+    """Minimal prompt template interface used throughout the codebase."""
+
+    @property
+    @abstractmethod
+    def input_variables(self) -> List[str]:
+        raise NotImplementedError
+
+    @abstractmethod
+    def format(self, **kwargs: Any) -> str:
+        raise NotImplementedError
+
+
+class PromptTemplate(BasePromptTemplate):
+    """A simple `str.format`-based prompt template."""
+
+    def __init__(
+        self, template: str, input_variables: Optional[Sequence[str]] = None
+    ) -> None:
+        self.template = template
+        self._input_variables = list(input_variables or _extract_input_variables(template))
+
+    @property
+    def input_variables(self) -> List[str]:
+        return list(self._input_variables)
+
+    def format(self, **kwargs: Any) -> str:
+        return self.template.format(**kwargs)
+
+
+@dataclass
+class ChatMessageTemplate:
+    role: MessageRole
+    template: str
+
+    @property
+    def input_variables(self) -> List[str]:
+        return _extract_input_variables(self.template)
+
+    def format_message(self, **kwargs: Any) -> ChatMessage:
+        return ChatMessage(role=self.role, content=self.template.format(**kwargs))
+
+
+class ChatPromptTemplate(BasePromptTemplate):
+    """A prompt made of multiple templated chat messages."""
+
+    def __init__(self, messages: Sequence[ChatMessageTemplate]) -> None:
+        self.messages = list(messages)
+        variables: Set[str] = set()
+        for msg in self.messages:
+            variables.update(msg.input_variables)
+        self._input_variables = sorted(variables)
+
+    @property
+    def input_variables(self) -> List[str]:
+        return list(self._input_variables)
+
+    def format_messages(self, **kwargs: Any) -> List[ChatMessage]:
+        return [msg.format_message(**kwargs) for msg in self.messages]
+
+    def format(self, **kwargs: Any) -> str:
+        # Best-effort string representation for token counting/debugging.
+        formatted = self.format_messages(**kwargs)
+        return "\n".join([(m.content or "") for m in formatted])
