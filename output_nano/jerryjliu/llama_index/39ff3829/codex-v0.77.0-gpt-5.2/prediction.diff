+++ b/llama_index/prompts/template.py
@@ -0,0 +1,87 @@
+"""Prompt template primitives.
+
+These are lightweight, dependency-free alternatives to LangChain's prompt
+templates. They intentionally support only the functionality LlamaIndex needs:
+- extracting input variables from `{var}` placeholders
+- formatting into strings (completion prompts)
+- formatting into chat messages (chat prompts)
+"""
+
+from __future__ import annotations
+
+from dataclasses import dataclass
+from string import Formatter
+from typing import Any, Iterable, List, Sequence, Set
+
+from llama_index.llms.base import ChatMessage, MessageRole
+
+
+def _get_template_vars(template: str) -> List[str]:
+    """Extract template variables from a python format string."""
+    vars_: Set[str] = set()
+    for _literal, field_name, _fmt, _conv in Formatter().parse(template):
+        if not field_name:
+            continue
+        # Support basic `{var}` as well as `{var.attr}` / `{var[idx]}` patterns.
+        root = field_name.split(".", 1)[0].split("[", 1)[0]
+        if root:
+            vars_.add(root)
+    return sorted(vars_)
+
+
+class BasePromptTemplate:
+    """Common base class for prompt templates."""
+
+    @property
+    def input_variables(self) -> List[str]:
+        raise NotImplementedError
+
+
+@dataclass
+class PromptTemplate(BasePromptTemplate):
+    """A plain string prompt template."""
+
+    template: str
+
+    @property
+    def input_variables(self) -> List[str]:
+        return _get_template_vars(self.template)
+
+    def format(self, **kwargs: Any) -> str:
+        return self.template.format(**kwargs)
+
+
+@dataclass(frozen=True)
+class ChatMessageTemplate:
+    role: MessageRole
+    template: str
+
+    @property
+    def input_variables(self) -> List[str]:
+        return _get_template_vars(self.template)
+
+    def format(self, **kwargs: Any) -> ChatMessage:
+        return ChatMessage(role=self.role, content=self.template.format(**kwargs))
+
+
+@dataclass
+class ChatPromptTemplate(BasePromptTemplate):
+    """A chat prompt template made of role-tagged message templates."""
+
+    message_templates: Sequence[ChatMessageTemplate]
+
+    @property
+    def input_variables(self) -> List[str]:
+        vars_: Set[str] = set()
+        for msg in self.message_templates:
+            vars_.update(msg.input_variables)
+        return sorted(vars_)
+
+    def format_messages(self, **kwargs: Any) -> List[ChatMessage]:
+        return [msg.format(**kwargs) for msg in self.message_templates]
+
+    @classmethod
+    def from_messages(
+        cls, messages: Iterable[ChatMessageTemplate]
+    ) -> "ChatPromptTemplate":
+        return cls(message_templates=list(messages))
