diff --git a/test_prompt_refactor.py b/test_prompt_refactor.py
new file mode 100644
index 0000000..3b4aad1
--- /dev/null
+++ b/test_prompt_refactor.py
@@ -0,0 +1,42 @@
+#!/usr/bin/env python
+"""Test for our refactored prompt system."""
+
+from llama_index.prompts.base import Prompt
+from llama_index.prompts.prompt_type import PromptType
+
+
+def test_simple_prompt():
+    """Test basic functionality of the simplified prompt system."""
+    # Create a basic prompt
+    template = "Hello {name}, how are you {feeling} today?"
+    prompt = Prompt(template=template, prompt_type=PromptType.SIMPLE_INPUT)
+    
+    # Format the prompt
+    result = prompt.format(name="Alice", feeling="doing well")
+    
+    # Check results
+    expected = "Hello Alice, how are you doing well today?"
+    assert result == expected
+    print("✓ Basic prompt formatting works")
+    
+    # Test partial formatting
+    partial_prompt = prompt.partial_format(name="Bob")
+    result2 = partial_prompt.format(feeling="fine")
+    expected2 = "Hello Bob, how are you fine today?"
+    assert result2 == expected2
+    print("✓ Partial formatting works")
+    
+    # Test prompt type
+    assert prompt.prompt_type == PromptType.SIMPLE_INPUT
+    print("✓ Prompt type works")
+    
+    # Test metadata
+    prompt_with_metadata = Prompt(template="Test", metadata={"key": "value"})
+    assert prompt_with_metadata.metadata["key"] == "value"
+    print("✓ Metadata works")
+    
+    print("All tests passed!")
+
+
+if __name__ == "__main__":
+    test_simple_prompt()
\ No newline at end of file
