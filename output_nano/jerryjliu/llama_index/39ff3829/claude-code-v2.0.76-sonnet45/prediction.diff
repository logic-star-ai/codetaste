+"""Simplified prompt template system without LangChain dependency."""
+import re
+from abc import ABC, abstractmethod
+from typing import Any, Dict, List, Optional
+
+from llama_index.llms.base import ChatMessage, MessageRole
+
+
+class BasePromptTemplate(ABC):
+    """Base class for all prompt templates."""
+
+    @abstractmethod
+    def format(self, **kwargs: Any) -> str:
+        """Format the template with the given keyword arguments."""
+        pass
+
+    @abstractmethod
+    def get_input_variables(self) -> List[str]:
+        """Get list of input variables in the template."""
+        pass
+
+    @abstractmethod
+    def format_messages(self, **kwargs: Any) -> List[ChatMessage]:
+        """Format the template into a list of chat messages."""
+        pass
+
+
+class PromptTemplate(BasePromptTemplate):
+    """Simple string-based prompt template.
+
+    Uses Python string formatting with {variable} placeholders.
+    """
+
+    def __init__(self, template: str, **kwargs: Any) -> None:
+        """Initialize prompt template.
+
+        Args:
+            template: Template string with {variable} placeholders
+            **kwargs: Additional keyword arguments (for compatibility)
+        """
+        self.template = template
+        self._input_variables = self._extract_variables(template)
+        self.kwargs = kwargs
+
+    @staticmethod
+    def _extract_variables(template: str) -> List[str]:
+        """Extract variable names from template string.
+
+        Args:
+            template: Template string with {variable} placeholders
+
+        Returns:
+            List of variable names found in template
+        """
+        # Find all {variable} patterns in the template
+        pattern = r'\{([a-zA-Z_][a-zA-Z0-9_]*)\}'
+        matches = re.findall(pattern, template)
+        # Remove duplicates while preserving order
+        seen = set()
+        variables = []
+        for match in matches:
+            if match not in seen:
+                seen.add(match)
+                variables.append(match)
+        return variables
+
+    @classmethod
+    def from_template(cls, template: str, **kwargs: Any) -> "PromptTemplate":
+        """Create a PromptTemplate from a template string.
+
+        Args:
+            template: Template string with {variable} placeholders
+            **kwargs: Additional keyword arguments
+
+        Returns:
+            PromptTemplate instance
+        """
+        return cls(template=template, **kwargs)
+
+    def format(self, **kwargs: Any) -> str:
+        """Format the template with the given keyword arguments.
+
+        Args:
+            **kwargs: Values for template variables
+
+        Returns:
+            Formatted string
+        """
+        return self.template.format(**kwargs)
+
+    def get_input_variables(self) -> List[str]:
+        """Get list of input variables in the template.
+
+        Returns:
+            List of variable names
+        """
+        return self._input_variables
+
+    @property
+    def input_variables(self) -> List[str]:
+        """Get list of input variables (property for compatibility).
+
+        Returns:
+            List of variable names
+        """
+        return self._input_variables
+
+    def format_messages(self, **kwargs: Any) -> List[ChatMessage]:
+        """Format the template into a list of chat messages.
+
+        For simple templates, returns a single user message.
+
+        Args:
+            **kwargs: Values for template variables
+
+        Returns:
+            List containing a single ChatMessage
+        """
+        content = self.format(**kwargs)
+        return [ChatMessage(role=MessageRole.USER, content=content)]
+
+    def format_prompt(self, **kwargs: Any) -> "FormattedPrompt":
+        """Format the prompt and return a FormattedPrompt object.
+
+        Args:
+            **kwargs: Values for template variables
+
+        Returns:
+            FormattedPrompt instance
+        """
+        return FormattedPrompt(template=self, kwargs=kwargs)
+
+
+class FormattedPrompt:
+    """Represents a formatted prompt that can be converted to messages."""
+
+    def __init__(self, template: BasePromptTemplate, kwargs: Dict[str, Any]) -> None:
+        """Initialize formatted prompt.
+
+        Args:
+            template: The template that was formatted
+            kwargs: The keyword arguments used for formatting
+        """
+        self.template = template
+        self.kwargs = kwargs
+
+    def to_string(self) -> str:
+        """Convert to string format.
+
+        Returns:
+            Formatted string
+        """
+        return self.template.format(**self.kwargs)
+
+    def to_messages(self) -> List[ChatMessage]:
+        """Convert to list of chat messages.
+
+        Returns:
+            List of ChatMessage objects
+        """
+        return self.template.format_messages(**self.kwargs)
+
+
+class BaseMessagePromptTemplate(ABC):
+    """Base class for message prompt templates."""
+
+    def __init__(self, prompt: PromptTemplate) -> None:
+        """Initialize message template.
+
+        Args:
+            prompt: The underlying prompt template
+        """
+        self.prompt = prompt
+
+    @classmethod
+    def from_template(cls, template: str, **kwargs: Any) -> "BaseMessagePromptTemplate":
+        """Create from a template string.
+
+        Args:
+            template: Template string with {variable} placeholders
+            **kwargs: Additional keyword arguments
+
+        Returns:
+            Message template instance
+        """
+        prompt = PromptTemplate.from_template(template, **kwargs)
+        return cls(prompt=prompt)
+
+    @abstractmethod
+    def format_messages(self, **kwargs: Any) -> List[ChatMessage]:
+        """Format into chat messages.
+
+        Args:
+            **kwargs: Values for template variables
+
+        Returns:
+            List of ChatMessage objects
+        """
+        pass
+
+    def get_input_variables(self) -> List[str]:
+        """Get list of input variables.
+
+        Returns:
+            List of variable names
+        """
+        return self.prompt.get_input_variables()
+
+    @property
+    def input_variables(self) -> List[str]:
+        """Get list of input variables (property for compatibility).
+
+        Returns:
+            List of variable names
+        """
+        return self.prompt.input_variables
+
+
+class SystemMessagePromptTemplate(BaseMessagePromptTemplate):
+    """Template for system messages."""
+
+    def format_messages(self, **kwargs: Any) -> List[ChatMessage]:
+        """Format into system message.
+
+        Args:
+            **kwargs: Values for template variables
+
+        Returns:
+            List containing a single system ChatMessage
+        """
+        content = self.prompt.format(**kwargs)
+        return [ChatMessage(role=MessageRole.SYSTEM, content=content)]
+
+
+class HumanMessagePromptTemplate(BaseMessagePromptTemplate):
+    """Template for human/user messages."""
+
+    def format_messages(self, **kwargs: Any) -> List[ChatMessage]:
+        """Format into user message.
+
+        Args:
+            **kwargs: Values for template variables
+
+        Returns:
+            List containing a single user ChatMessage
+        """
+        content = self.prompt.format(**kwargs)
+        return [ChatMessage(role=MessageRole.USER, content=content)]
+
+
+class AIMessagePromptTemplate(BaseMessagePromptTemplate):
+    """Template for AI/assistant messages."""
+
+    def format_messages(self, **kwargs: Any) -> List[ChatMessage]:
+        """Format into assistant message.
+
+        Args:
+            **kwargs: Values for template variables
+
+        Returns:
+            List containing a single assistant ChatMessage
+        """
+        content = self.prompt.format(**kwargs)
+        return [ChatMessage(role=MessageRole.ASSISTANT, content=content)]
+
+
+class ChatPromptTemplate(BasePromptTemplate):
+    """Template for chat conversations with multiple messages."""
+
+    def __init__(self, messages: List[BaseMessagePromptTemplate]) -> None:
+        """Initialize chat prompt template.
+
+        Args:
+            messages: List of message templates
+        """
+        self.messages = messages
+        self._input_variables = self._collect_input_variables()
+
+    def _collect_input_variables(self) -> List[str]:
+        """Collect all input variables from all message templates.
+
+        Returns:
+            List of unique variable names
+        """
+        variables = []
+        seen = set()
+        for message in self.messages:
+            for var in message.get_input_variables():
+                if var not in seen:
+                    seen.add(var)
+                    variables.append(var)
+        return variables
+
+    @classmethod
+    def from_messages(
+        cls, messages: List[BaseMessagePromptTemplate], **kwargs: Any
+    ) -> "ChatPromptTemplate":
+        """Create from a list of message templates.
+
+        Args:
+            messages: List of message templates
+            **kwargs: Additional keyword arguments
+
+        Returns:
+            ChatPromptTemplate instance
+        """
+        return cls(messages=messages)
+
+    def format(self, **kwargs: Any) -> str:
+        """Format all messages into a single string.
+
+        Args:
+            **kwargs: Values for template variables
+
+        Returns:
+            Formatted string with all messages concatenated
+        """
+        messages = self.format_messages(**kwargs)
+        parts = []
+        for msg in messages:
+            role_str = msg.role.value if hasattr(msg.role, 'value') else str(msg.role)
+            parts.append(f"{role_str}: {msg.content}")
+        return "\n".join(parts)
+
+    def get_input_variables(self) -> List[str]:
+        """Get list of all input variables.
+
+        Returns:
+            List of variable names
+        """
+        return self._input_variables
+
+    @property
+    def input_variables(self) -> List[str]:
+        """Get list of input variables (property for compatibility).
+
+        Returns:
+            List of variable names
+        """
+        return self._input_variables
+
+    def format_messages(self, **kwargs: Any) -> List[ChatMessage]:
+        """Format all message templates into chat messages.
+
+        Args:
+            **kwargs: Values for template variables
+
+        Returns:
+            List of ChatMessage objects
+        """
+        all_messages = []
+        for message_template in self.messages:
+            messages = message_template.format_messages(**kwargs)
+            all_messages.extend(messages)
+        return all_messages
+
+    def format_prompt(self, **kwargs: Any) -> FormattedPrompt:
+        """Format the prompt and return a FormattedPrompt object.
+
+        Args:
+            **kwargs: Values for template variables
+
+        Returns:
+            FormattedPrompt instance
+        """
+        return FormattedPrompt(template=self, kwargs=kwargs)
