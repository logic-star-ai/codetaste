+package com.linecorp.armeria.client;
+
+import static java.util.Objects.requireNonNull;
+
+import java.net.InetSocketAddress;
+import java.time.Duration;
+import java.util.Optional;
+import java.util.function.Consumer;
+import java.util.function.Function;
+
+import javax.annotation.Nullable;
+
+import com.linecorp.armeria.client.pool.KeyedChannelPoolHandler;
+import com.linecorp.armeria.client.pool.PoolKey;
+import com.linecorp.armeria.common.Flags;
+
+import io.netty.channel.EventLoop;
+import io.netty.channel.EventLoopGroup;
+import io.netty.handler.ssl.SslContextBuilder;
+import io.netty.resolver.AddressResolverGroup;
+
+/**
+ * A builder for creating a {@link ClientFactory} with custom session-layer options.
+ */
+public final class ClientFactoryBuilder {
+
+    private static final Duration DEFAULT_CONNECT_TIMEOUT = Duration.ofMillis(3200);
+    private static final Duration DEFAULT_IDLE_TIMEOUT = Duration.ofSeconds(10);
+
+    @Nullable
+    private Duration connectTimeout;
+    @Nullable
+    private Duration idleTimeout;
+    @Nullable
+    private Consumer<SslContextBuilder> sslContextCustomizer;
+    @Nullable
+    private AddressResolverGroup<? extends InetSocketAddress> addressResolverGroup;
+    @Nullable
+    private EventLoopGroup eventLoopGroup;
+    @Nullable
+    private Function<KeyedChannelPoolHandler<PoolKey>, KeyedChannelPoolHandler<PoolKey>> poolHandlerDecorator;
+    @Nullable
+    private Boolean useHttp2Preface;
+    @Nullable
+    private Boolean useHttp1Pipelining;
+
+    /**
+     * Creates a new builder with default settings.
+     */
+    public ClientFactoryBuilder() {}
+
+    /**
+     * Sets the timeout of a socket connection attempt.
+     *
+     * @param connectTimeout the connection timeout (must be positive)
+     */
+    public ClientFactoryBuilder connectTimeout(Duration connectTimeout) {
+        requireNonNull(connectTimeout, "connectTimeout");
+        if (connectTimeout.isNegative() || connectTimeout.isZero()) {
+            throw new IllegalArgumentException(
+                    "connectTimeout: " + connectTimeout + " (expected: > 0)");
+        }
+        this.connectTimeout = connectTimeout;
+        return this;
+    }
+
+    /**
+     * Sets the timeout of a socket connection attempt in milliseconds.
+     *
+     * @param connectTimeoutMillis the connection timeout in milliseconds (must be positive)
+     */
+    public ClientFactoryBuilder connectTimeoutMillis(long connectTimeoutMillis) {
+        if (connectTimeoutMillis <= 0) {
+            throw new IllegalArgumentException(
+                    "connectTimeoutMillis: " + connectTimeoutMillis + " (expected: > 0)");
+        }
+        return connectTimeout(Duration.ofMillis(connectTimeoutMillis));
+    }
+
+    /**
+     * Sets the idle timeout of a socket connection. The connection is closed if there is no invocation
+     * in progress for this amount of time.
+     *
+     * @param idleTimeout the idle timeout (must be non-negative; 0 to disable)
+     */
+    public ClientFactoryBuilder idleTimeout(Duration idleTimeout) {
+        requireNonNull(idleTimeout, "idleTimeout");
+        if (idleTimeout.isNegative()) {
+            throw new IllegalArgumentException(
+                    "idleTimeout: " + idleTimeout + " (expected: >= 0)");
+        }
+        this.idleTimeout = idleTimeout;
+        return this;
+    }
+
+    /**
+     * Sets the idle timeout of a socket connection in milliseconds. The connection is closed if there is
+     * no invocation in progress for this amount of time.
+     *
+     * @param idleTimeoutMillis the idle timeout in milliseconds (must be non-negative; 0 to disable)
+     */
+    public ClientFactoryBuilder idleTimeoutMillis(long idleTimeoutMillis) {
+        if (idleTimeoutMillis < 0) {
+            throw new IllegalArgumentException(
+                    "idleTimeoutMillis: " + idleTimeoutMillis + " (expected: >= 0)");
+        }
+        return idleTimeout(Duration.ofMillis(idleTimeoutMillis));
+    }
+
+    /**
+     * Sets a {@link Consumer} which can arbitrarily configure the {@link SslContextBuilder} that will be
+     * applied to the SSL session. For example, use {@link SslContextBuilder#trustManager} to configure
+     * a custom server CA or {@link SslContextBuilder#keyManager} to configure a client certificate for
+     * SSL authorization.
+     */
+    public ClientFactoryBuilder sslContextCustomizer(Consumer<SslContextBuilder> sslContextCustomizer) {
+        this.sslContextCustomizer = requireNonNull(sslContextCustomizer, "sslContextCustomizer");
+        return this;
+    }
+
+    /**
+     * Sets the {@link AddressResolverGroup} to use to resolve remote addresses into
+     * {@link InetSocketAddress}es.
+     */
+    public ClientFactoryBuilder addressResolverGroup(
+            AddressResolverGroup<? extends InetSocketAddress> addressResolverGroup) {
+        this.addressResolverGroup = requireNonNull(addressResolverGroup, "addressResolverGroup");
+        return this;
+    }
+
+    /**
+     * Sets the {@link EventLoopGroup} that will provide the {@link EventLoop} for I/O and
+     * asynchronous invocations. If unspecified, a new one is created automatically.
+     */
+    public ClientFactoryBuilder eventLoopGroup(EventLoopGroup eventLoopGroup) {
+        this.eventLoopGroup = requireNonNull(eventLoopGroup, "eventLoopGroup");
+        return this;
+    }
+
+    /**
+     * Sets the {@link Function} that decorates the {@link KeyedChannelPoolHandler}.
+     */
+    public ClientFactoryBuilder poolHandlerDecorator(
+            Function<KeyedChannelPoolHandler<PoolKey>, KeyedChannelPoolHandler<PoolKey>> poolHandlerDecorator) {
+        this.poolHandlerDecorator = requireNonNull(poolHandlerDecorator, "poolHandlerDecorator");
+        return this;
+    }
+
+    /**
+     * Sets whether to send an HTTP/2 preface string instead of an HTTP/1 upgrade request to negotiate
+     * the protocol version of a cleartext HTTP connection.
+     */
+    public ClientFactoryBuilder useHttp2Preface(boolean useHttp2Preface) {
+        this.useHttp2Preface = useHttp2Preface;
+        return this;
+    }
+
+    /**
+     * Sets whether to use <a href="https://en.wikipedia.org/wiki/HTTP_pipelining">HTTP pipelining</a>
+     * for HTTP/1 connections.
+     */
+    public ClientFactoryBuilder useHttp1Pipelining(boolean useHttp1Pipelining) {
+        this.useHttp1Pipelining = useHttp1Pipelining;
+        return this;
+    }
+
+    /**
+     * Returns the connection timeout duration, or the default if not set.
+     */
+    public Duration connectTimeout() {
+        return connectTimeout != null ? connectTimeout : DEFAULT_CONNECT_TIMEOUT;
+    }
+
+    /**
+     * Returns the connection timeout in milliseconds.
+     */
+    public long connectTimeoutMillis() {
+        return connectTimeout().toMillis();
+    }
+
+    /**
+     * Returns the idle timeout duration, or the default if not set.
+     */
+    public Duration idleTimeout() {
+        return idleTimeout != null ? idleTimeout : DEFAULT_IDLE_TIMEOUT;
+    }
+
+    /**
+     * Returns the idle timeout in milliseconds.
+     */
+    public long idleTimeoutMillis() {
+        return idleTimeout().toMillis();
+    }
+
+    /**
+     * Returns the SSL context customizer if set.
+     */
+    public Optional<Consumer<SslContextBuilder>> sslContextCustomizer() {
+        return Optional.ofNullable(sslContextCustomizer);
+    }
+
+    /**
+     * Returns the address resolver group if set.
+     */
+    public Optional<AddressResolverGroup<InetSocketAddress>> addressResolverGroup() {
+        @SuppressWarnings("unchecked")
+        final Optional<AddressResolverGroup<InetSocketAddress>> result =
+                (Optional<AddressResolverGroup<InetSocketAddress>>) (Optional<?>) Optional.ofNullable(addressResolverGroup);
+        return result;
+    }
+
+    /**
+     * Returns the event loop group if set.
+     */
+    public Optional<EventLoopGroup> eventLoopGroup() {
+        return Optional.ofNullable(eventLoopGroup);
+    }
+
+    /**
+     * Returns the pool handler decorator.
+     */
+    public Function<KeyedChannelPoolHandler<PoolKey>, KeyedChannelPoolHandler<PoolKey>> poolHandlerDecorator() {
+        return poolHandlerDecorator != null ? poolHandlerDecorator : Function.identity();
+    }
+
+    /**
+     * Returns whether to use HTTP/2 preface.
+     */
+    public boolean useHttp2Preface() {
+        return useHttp2Preface != null ? useHttp2Preface : Flags.defaultUseHttp2Preface();
+    }
+
+    /**
+     * Returns whether to use HTTP/1 pipelining.
+     */
+    public boolean useHttp1Pipelining() {
+        return useHttp1Pipelining != null ? useHttp1Pipelining : Flags.defaultUseHttp1Pipelining();
+    }
+
+    /**
+     * Builds a new {@link HttpClientFactory} with the configured options.
+     *
+     * @return a new {@link ClientFactory}
+     */
+    public ClientFactory build() {
+        return new AllInOneClientFactory(this);
+    }
+
+    /**
+     * Builds a new {@link HttpClientFactory} with the configured options.
+     *
+     * @param useDaemonThreads whether to create I/O event loop threads as daemon threads
+     * @return a new {@link ClientFactory}
+     */
+    public ClientFactory build(boolean useDaemonThreads) {
+        return new AllInOneClientFactory(this, useDaemonThreads);
+    }
+
+    /**
+     * Returns a copy of this builder with values from the specified builder overlaid.
+     * Values that are set in the specified builder take precedence.
+     */
+    public ClientFactoryBuilder merge(ClientFactoryBuilder other) {
+        requireNonNull(other, "other");
+        final ClientFactoryBuilder merged = new ClientFactoryBuilder();
+
+        merged.connectTimeout = other.connectTimeout != null ? other.connectTimeout : this.connectTimeout;
+        merged.idleTimeout = other.idleTimeout != null ? other.idleTimeout : this.idleTimeout;
+        merged.sslContextCustomizer = other.sslContextCustomizer != null
+                                      ? other.sslContextCustomizer : this.sslContextCustomizer;
+        merged.addressResolverGroup = other.addressResolverGroup != null
+                                      ? other.addressResolverGroup : this.addressResolverGroup;
+        merged.eventLoopGroup = other.eventLoopGroup != null ? other.eventLoopGroup : this.eventLoopGroup;
+        merged.poolHandlerDecorator = other.poolHandlerDecorator != null
+                                      ? other.poolHandlerDecorator : this.poolHandlerDecorator;
+        merged.useHttp2Preface = other.useHttp2Preface != null ? other.useHttp2Preface : this.useHttp2Preface;
+        merged.useHttp1Pipelining = other.useHttp1Pipelining != null
+                                    ? other.useHttp1Pipelining : this.useHttp1Pipelining;
+
+        return merged;
+    }
+}
