+
+package com.linecorp.armeria.client;
+
+import static java.util.Objects.requireNonNull;
+
+import java.net.InetSocketAddress;
+import java.time.Duration;
+import java.util.ArrayList;
+import java.util.List;
+import java.util.function.Consumer;
+import java.util.function.Function;
+
+import javax.annotation.Nullable;
+import javax.net.ssl.TrustManagerFactory;
+
+import com.linecorp.armeria.client.pool.KeyedChannelPoolHandler;
+import com.linecorp.armeria.client.pool.PoolKey;
+import com.linecorp.armeria.common.Flags;
+
+import io.netty.channel.EventLoopGroup;
+import io.netty.handler.ssl.SslContextBuilder;
+import io.netty.resolver.AddressResolverGroup;
+
+/**
+ * Builds a {@link ClientFactory} with the specified properties.
+ */
+public final class ClientFactoryBuilder {
+
+    private Duration connectTimeout = SessionOptions.DEFAULT.connectTimeout();
+    private Duration idleTimeout = SessionOptions.DEFAULT.idleTimeout();
+    private boolean useDaemonThreads = true;
+    private boolean useHttp2Preface = Flags.defaultUseHttp2Preface();
+    private boolean useHttp1Pipelining = Flags.defaultUseHttp1Pipelining();
+    private Function<KeyedChannelPoolHandler<PoolKey>, KeyedChannelPoolHandler<PoolKey>>
+            poolHandlerDecorator = Function.identity();
+
+    @Nullable
+    private EventLoopGroup eventLoopGroup;
+    @Nullable
+    private AddressResolverGroup<? extends InetSocketAddress> addressResolverGroup;
+    @Nullable
+    private Consumer<SslContextBuilder> sslContextCustomizer;
+    @Nullable
+    private TrustManagerFactory trustManagerFactory;
+
+    /**
+     * Sets the connection timeout.
+     */
+    public ClientFactoryBuilder connectTimeout(Duration connectTimeout) {
+        this.connectTimeout = validateConnectTimeout(connectTimeout);
+        return this;
+    }
+
+    /**
+     * Sets whether to create I/O threads as daemon threads.
+     */
+    public ClientFactoryBuilder useDaemonThreads(boolean useDaemonThreads) {
+        this.useDaemonThreads = useDaemonThreads;
+        return this;
+    }
+
+    /**
+     * Sets the idle timeout.
+     */
+    public ClientFactoryBuilder idleTimeout(Duration idleTimeout) {
+        this.idleTimeout = validateIdleTimeout(idleTimeout);
+        return this;
+    }
+
+    /**
+     * Sets the {@link EventLoopGroup} to use. If not set, a new group will be created.
+     */
+    public ClientFactoryBuilder eventLoopGroup(EventLoopGroup eventLoopGroup) {
+        this.eventLoopGroup = requireNonNull(eventLoopGroup, "eventLoopGroup");
+        return this;
+    }
+
+    /**
+     * Sets the {@link AddressResolverGroup} to use.
+     */
+    public ClientFactoryBuilder addressResolverGroup(
+            AddressResolverGroup<? extends InetSocketAddress> addressResolverGroup) {
+        this.addressResolverGroup = requireNonNull(addressResolverGroup, "addressResolverGroup");
+        return this;
+    }
+
+    /**
+     * Sets the {@link TrustManagerFactory} to use when creating SSL contexts.
+     *
+     * @deprecated Use {@link #sslContextCustomizer(Consumer)} instead.
+     */
+    @Deprecated
+    public ClientFactoryBuilder trustManagerFactory(TrustManagerFactory trustManagerFactory) {
+        this.trustManagerFactory = requireNonNull(trustManagerFactory, "trustManagerFactory");
+        return this;
+    }
+
+    /**
+     * Sets a customizer that mutates the {@link SslContextBuilder} used by clients.
+     */
+    public ClientFactoryBuilder sslContextCustomizer(Consumer<SslContextBuilder> sslContextCustomizer) {
+        this.sslContextCustomizer = requireNonNull(sslContextCustomizer, "sslContextCustomizer");
+        return this;
+    }
+
+    /**
+     * Sets a decorator that wraps the {@link KeyedChannelPoolHandler}.
+     */
+    public ClientFactoryBuilder poolHandlerDecorator(
+            Function<KeyedChannelPoolHandler<PoolKey>, KeyedChannelPoolHandler<PoolKey>> poolHandlerDecorator) {
+        this.poolHandlerDecorator = requireNonNull(poolHandlerDecorator, "poolHandlerDecorator");
+        return this;
+    }
+
+    /**
+     * Sets whether to use HTTP/2 preface.
+     */
+    public ClientFactoryBuilder useHttp2Preface(boolean useHttp2Preface) {
+        this.useHttp2Preface = useHttp2Preface;
+        return this;
+    }
+
+    /**
+     * Sets whether to enable HTTP/1 pipelining.
+     */
+    public ClientFactoryBuilder useHttp1Pipelining(boolean useHttp1Pipelining) {
+        this.useHttp1Pipelining = useHttp1Pipelining;
+        return this;
+    }
+
+    /**
+     * Returns the {@link SessionOptions} built from the configured properties.
+     */
+    public SessionOptions options() {
+        final List<SessionOptionValue<?>> optionValues = new ArrayList<>();
+        optionValues.add(SessionOption.CONNECT_TIMEOUT.newValue(connectTimeout));
+        optionValues.add(SessionOption.IDLE_TIMEOUT.newValue(idleTimeout));
+        optionValues.add(SessionOption.POOL_HANDLER_DECORATOR.newValue(poolHandlerDecorator));
+        optionValues.add(SessionOption.USE_HTTP2_PREFACE.newValue(useHttp2Preface));
+        optionValues.add(SessionOption.USE_HTTP1_PIPELINING.newValue(useHttp1Pipelining));
+
+        if (eventLoopGroup != null) {
+            optionValues.add(SessionOption.EVENT_LOOP_GROUP.newValue(eventLoopGroup));
+        }
+
+        if (addressResolverGroup != null) {
+            optionValues.add(SessionOption.ADDRESS_RESOLVER_GROUP.newValue(addressResolverGroup));
+        }
+
+        if (trustManagerFactory != null) {
+            optionValues.add(SessionOption.TRUST_MANAGER_FACTORY.newValue(trustManagerFactory));
+        }
+
+        if (sslContextCustomizer != null) {
+            optionValues.add(SessionOption.SSL_CONTEXT_CUSTOMIZER.newValue(sslContextCustomizer));
+        }
+
+        return SessionOptions.of(optionValues);
+    }
+
+    /**
+     * Returns whether daemon threads will be used for I/O event loops.
+     */
+    public boolean useDaemonThreads() {
+        return useDaemonThreads;
+    }
+
+    /**
+     * Builds a new {@link ClientFactory}.
+     */
+    public ClientFactory build() {
+        return new AllInOneClientFactory(options(), useDaemonThreads);
+    }
+
+    private static Duration validateConnectTimeout(Duration connectTimeout) {
+        requireNonNull(connectTimeout, "connectTimeout");
+        if (connectTimeout.isNegative() || connectTimeout.isZero()) {
+            throw new IllegalArgumentException(
+                    "connectTimeout: " + connectTimeout + " (expected: > 0)");
+        }
+        return connectTimeout;
+    }
+
+    private static Duration validateIdleTimeout(Duration idleTimeout) {
+        requireNonNull(idleTimeout, "idleTimeout");
+        if (idleTimeout.isNegative()) {
+            throw new IllegalArgumentException(
+                    "idleTimeout: " + idleTimeout + " (expected: >= 0)");
+        }
+        return idleTimeout;
+    }
+}
