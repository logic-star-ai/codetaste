+package com.linecorp.armeria.client;
+
+import static java.util.Objects.requireNonNull;
+
+import java.net.InetSocketAddress;
+import java.time.Duration;
+import java.util.function.Consumer;
+import java.util.function.Function;
+
+import javax.net.ssl.TrustManagerFactory;
+
+import com.linecorp.armeria.client.pool.KeyedChannelPoolHandler;
+import com.linecorp.armeria.client.pool.PoolKey;
+import com.linecorp.armeria.common.Flags;
+
+import io.netty.channel.EventLoopGroup;
+import io.netty.handler.ssl.SslContextBuilder;
+import io.netty.resolver.AddressResolverGroup;
+
+/**
+ * Builds a {@link ClientFactory} with session-layer options.
+ */
+public final class ClientFactoryBuilder {
+
+    private Duration connectTimeout = Duration.ofMillis(3200);
+    private Duration idleTimeout = Duration.ofSeconds(10);
+    private EventLoopGroup eventLoopGroup;
+    private TrustManagerFactory trustManagerFactory;
+    private Consumer<SslContextBuilder> sslContextCustomizer;
+    private AddressResolverGroup<? extends InetSocketAddress> addressResolverGroup;
+    private Function<KeyedChannelPoolHandler<PoolKey>, KeyedChannelPoolHandler<PoolKey>> poolHandlerDecorator =
+            Function.identity();
+    private Boolean useHttp2Preface;
+    private Boolean useHttp1Pipelining;
+
+    /**
+     * Creates a new {@link ClientFactoryBuilder} with default options.
+     */
+    public ClientFactoryBuilder() {}
+
+    /**
+     * Creates a new {@link ClientFactoryBuilder} with the specified base options.
+     */
+    public ClientFactoryBuilder(SessionOptions options) {
+        requireNonNull(options, "options");
+        connectTimeout = options.connectTimeout();
+        idleTimeout = options.idleTimeout();
+        options.eventLoopGroup().ifPresent(this::eventLoopGroup);
+        options.trustManagerFactory().ifPresent(this::trustManagerFactory);
+        options.sslContextCustomizer().ifPresent(this::sslContextCustomizer);
+        options.addressResolverGroup().ifPresent(this::addressResolverGroup);
+        poolHandlerDecorator = options.poolHandlerDecorator();
+        useHttp2Preface = options.useHttp2Preface();
+        useHttp1Pipelining = options.useHttp1Pipelining();
+    }
+
+    /**
+     * Sets the timeout of a socket connection attempt.
+     *
+     * @param connectTimeout the timeout. Must be positive.
+     */
+    public ClientFactoryBuilder connectTimeout(Duration connectTimeout) {
+        requireNonNull(connectTimeout, "connectTimeout");
+        if (connectTimeout.isNegative() || connectTimeout.isZero()) {
+            throw new IllegalArgumentException(
+                    "connectTimeout: " + connectTimeout + " (expected: > 0)");
+        }
+        this.connectTimeout = connectTimeout;
+        return this;
+    }
+
+    /**
+     * Sets the timeout of a socket connection attempt in milliseconds.
+     *
+     * @param connectTimeoutMillis the timeout in milliseconds. Must be positive.
+     */
+    public ClientFactoryBuilder connectTimeoutMillis(long connectTimeoutMillis) {
+        return connectTimeout(Duration.ofMillis(connectTimeoutMillis));
+    }
+
+    /**
+     * Sets the idle timeout of a socket connection. The connection is closed if there is no invocation
+     * in progress for this amount of time.
+     *
+     * @param idleTimeout the timeout. {@code 0} disables the timeout.
+     */
+    public ClientFactoryBuilder idleTimeout(Duration idleTimeout) {
+        requireNonNull(idleTimeout, "idleTimeout");
+        if (idleTimeout.isNegative()) {
+            throw new IllegalArgumentException(
+                    "idleTimeout: " + idleTimeout + " (expected: >= 0)");
+        }
+        this.idleTimeout = idleTimeout;
+        return this;
+    }
+
+    /**
+     * Sets the idle timeout of a socket connection in milliseconds.
+     *
+     * @param idleTimeoutMillis the timeout in milliseconds. {@code 0} disables the timeout.
+     */
+    public ClientFactoryBuilder idleTimeoutMillis(long idleTimeoutMillis) {
+        return idleTimeout(Duration.ofMillis(idleTimeoutMillis));
+    }
+
+    /**
+     * Sets the {@link EventLoopGroup} that will provide the {@link io.netty.channel.EventLoop} for I/O and
+     * asynchronous invocations. If unspecified, a new one is created automatically.
+     */
+    public ClientFactoryBuilder eventLoopGroup(EventLoopGroup eventLoopGroup) {
+        this.eventLoopGroup = requireNonNull(eventLoopGroup, "eventLoopGroup");
+        return this;
+    }
+
+    /**
+     * Sets the {@link TrustManagerFactory} of a TLS connection.
+     *
+     * @deprecated Use {@link #sslContextCustomizer(Consumer)} instead.
+     */
+    @Deprecated
+    public ClientFactoryBuilder trustManagerFactory(TrustManagerFactory trustManagerFactory) {
+        this.trustManagerFactory = requireNonNull(trustManagerFactory, "trustManagerFactory");
+        return this;
+    }
+
+    /**
+     * Sets a {@link Consumer} which can arbitrarily configure the {@link SslContextBuilder} that will be
+     * applied to this session. For example, use {@link SslContextBuilder#trustManager} to configure a custom
+     * server CA or {@link SslContextBuilder#keyManager} to configure a client certificate for SSL
+     * authorization.
+     */
+    public ClientFactoryBuilder sslContextCustomizer(Consumer<SslContextBuilder> sslContextCustomizer) {
+        this.sslContextCustomizer = requireNonNull(sslContextCustomizer, "sslContextCustomizer");
+        return this;
+    }
+
+    /**
+     * Sets the {@link AddressResolverGroup} to use to resolve remote addresses into
+     * {@link InetSocketAddress}es.
+     */
+    public ClientFactoryBuilder addressResolverGroup(
+            AddressResolverGroup<? extends InetSocketAddress> addressResolverGroup) {
+        this.addressResolverGroup = requireNonNull(addressResolverGroup, "addressResolverGroup");
+        return this;
+    }
+
+    /**
+     * Sets the {@link Function} that decorates the {@link KeyedChannelPoolHandler}.
+     */
+    public ClientFactoryBuilder poolHandlerDecorator(
+            Function<KeyedChannelPoolHandler<PoolKey>, KeyedChannelPoolHandler<PoolKey>> poolHandlerDecorator) {
+        this.poolHandlerDecorator = requireNonNull(poolHandlerDecorator, "poolHandlerDecorator");
+        return this;
+    }
+
+    /**
+     * Sets whether to send an HTTP/2 preface string instead of an HTTP/1 upgrade request to negotiate
+     * the protocol version of a cleartext HTTP connection.
+     */
+    public ClientFactoryBuilder useHttp2Preface(boolean useHttp2Preface) {
+        this.useHttp2Preface = useHttp2Preface;
+        return this;
+    }
+
+    /**
+     * Sets whether to use <a href="https://en.wikipedia.org/wiki/HTTP_pipelining">HTTP pipelining</a> for
+     * HTTP/1 connections. This does not affect HTTP/2 connections. This option is enabled by default.
+     */
+    public ClientFactoryBuilder useHttp1Pipelining(boolean useHttp1Pipelining) {
+        this.useHttp1Pipelining = useHttp1Pipelining;
+        return this;
+    }
+
+    /**
+     * Builds a {@link SessionOptions} with the configured options.
+     * This method is provided for backward compatibility with code that expects {@link SessionOptions}.
+     *
+     * @return the {@link SessionOptions}
+     */
+    public SessionOptions buildSessionOptions() {
+        final SessionOptionValue<?>[] values = {
+                SessionOption.CONNECT_TIMEOUT.newValue(connectTimeout),
+                SessionOption.IDLE_TIMEOUT.newValue(idleTimeout)
+        };
+
+        SessionOptions options = SessionOptions.of(values);
+
+        if (eventLoopGroup != null) {
+            options = SessionOptions.of(options, SessionOption.EVENT_LOOP_GROUP.newValue(eventLoopGroup));
+        }
+        if (trustManagerFactory != null) {
+            options = SessionOptions.of(options,
+                                        SessionOption.TRUST_MANAGER_FACTORY.newValue(trustManagerFactory));
+        }
+        if (sslContextCustomizer != null) {
+            options = SessionOptions.of(options,
+                                        SessionOption.SSL_CONTEXT_CUSTOMIZER.newValue(sslContextCustomizer));
+        }
+        if (addressResolverGroup != null) {
+            options = SessionOptions.of(options,
+                                        SessionOption.ADDRESS_RESOLVER_GROUP.newValue(addressResolverGroup));
+        }
+        if (poolHandlerDecorator != Function.identity()) {
+            options = SessionOptions.of(options,
+                                        SessionOption.POOL_HANDLER_DECORATOR.newValue(poolHandlerDecorator));
+        }
+        if (useHttp2Preface != null) {
+            options = SessionOptions.of(options, SessionOption.USE_HTTP2_PREFACE.newValue(useHttp2Preface));
+        } else {
+            options = SessionOptions.of(options,
+                                        SessionOption.USE_HTTP2_PREFACE.newValue(Flags.defaultUseHttp2Preface()));
+        }
+        if (useHttp1Pipelining != null) {
+            options = SessionOptions.of(options,
+                                        SessionOption.USE_HTTP1_PIPELINING.newValue(useHttp1Pipelining));
+        }
+
+        return options;
+    }
+
+    /**
+     * Builds a new {@link ClientFactory} with the configured options.
+     *
+     * @return the {@link ClientFactory}
+     */
+    public ClientFactory build() {
+        return new AllInOneClientFactory(buildSessionOptions());
+    }
+}
