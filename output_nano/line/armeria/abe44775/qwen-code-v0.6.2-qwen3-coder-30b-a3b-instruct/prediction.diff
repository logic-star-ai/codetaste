+import io.netty.resolver.AddressResolverGroup;
+
+/**
+ * A set of {@link ClientFactoryOption}s and their respective values.
+ */
+public final class ClientFactoryBuilder extends AbstractOptions {
+    
+    private static final Duration DEFAULT_CONNECTION_TIMEOUT = Duration.ofMillis(3200);
+    private static final Duration DEFAULT_IDLE_TIMEOUT = Duration.ofSeconds(10);
+    
+    private static final ClientFactoryOptionValue<?>[] DEFAULT_OPTION_VALUES = {
+            CONNECT_TIMEOUT.newValue(DEFAULT_CONNECTION_TIMEOUT),
+            IDLE_TIMEOUT.newValue(DEFAULT_IDLE_TIMEOUT),
+            USE_HTTP2_PREFACE.newValue(Flags.defaultUseHttp2Preface())
+    };
+
+    /**
+     * The default {@link ClientFactoryBuilder}.
+     */
+    public static final ClientFactoryBuilder DEFAULT = new ClientFactoryBuilder(DEFAULT_OPTION_VALUES);
+
+    /**
+     * Creates a new {@link ClientFactoryBuilder} with the specified {@link ClientFactoryOptionValue}s.
+     */
+    public static ClientFactoryBuilder of(ClientFactoryOptionValue<?>... options) {
+        return new ClientFactoryBuilder(DEFAULT, options);
+    }
+
+    /**
+     * Returns the {@link ClientFactoryBuilder} with the specified {@link ClientFactoryOptionValue}s.
+     */
+    public static ClientFactoryBuilder of(Iterable<ClientFactoryOptionValue<?>> options) {
+        return new ClientFactoryBuilder(DEFAULT, options);
+    }
+
+    /**
+     * Merges the specified {@link ClientFactoryBuilder} and {@link ClientFactoryOptionValue}s.
+     *
+     * @return the merged {@link ClientFactoryBuilder}
+     */
+    public static ClientFactoryBuilder of(ClientFactoryBuilder baseOptions, ClientFactoryOptionValue<?>... options) {
+        // TODO(trustin): Reduce the cost of creating a derived ClientFactoryBuilder.
+        requireNonNull(baseOptions, "baseOptions");
+        requireNonNull(options, "options");
+        if (options.length == 0) {
+            return baseOptions;
+        }
+        return new ClientFactoryBuilder(baseOptions, options);
+    }
+
+    /**
+     * Merges the specified {@link ClientFactoryBuilder} and {@link ClientFactoryOptionValue}s.
+     *
+     * @return the merged {@link ClientFactoryBuilder}
+     */
+    public static ClientFactoryBuilder of(ClientFactoryBuilder baseOptions, Iterable<ClientFactoryOptionValue<?>> options) {
+        // TODO(trustin): Reduce the cost of creating a derived ClientFactoryBuilder.
+        requireNonNull(baseOptions, "baseOptions");
+        requireNonNull(options, "options");
+        return new ClientFactoryBuilder(baseOptions, options);
+    }
+
+    /**
+     * Merges the specified two {@link ClientFactoryBuilder} into one.
+     *
+     * @return the merged {@link ClientFactoryBuilder}
+     */
+    public static ClientFactoryBuilder of(ClientFactoryBuilder baseOptions, ClientFactoryBuilder options) {
+        // TODO(trustin): Reduce the cost of creating a derived ClientFactoryBuilder.
+        requireNonNull(baseOptions, "baseOptions");
+        requireNonNull(options, "options");
+        return new ClientFactoryBuilder(baseOptions, options);
+    }
+
+    private static <T> ClientFactoryOptionValue<T> validateValue(ClientFactoryOptionValue<T> optionValue) {
+        requireNonNull(optionValue, "value");
+
+        ClientFactoryOption<?> option = optionValue.option();
+        T value = optionValue.value();
+
+        if (option == CONNECT_TIMEOUT) {
+            validateConnectionTimeout((Duration) value);
+        } else if (option == IDLE_TIMEOUT) {
+            validateIdleTimeout((Duration) value);
+        }
+
+        return optionValue;
+    }
+
+    private static Duration validateConnectionTimeout(Duration connectionTimeout) {
+        requireNonNull(connectionTimeout, "connectionTimeout");
+        if (connectionTimeout.isNegative() || connectionTimeout.isZero()) {
+            throw new IllegalArgumentException(
+                    "connectTimeout: " + connectionTimeout + " (expected: > 0)");
+        }
+        return connectionTimeout;
+    }
+
+    private static Duration validateIdleTimeout(Duration idleTimeout) {
+        requireNonNull(idleTimeout, "idleTimeout");
+        if (idleTimeout.isNegative()) {
+            throw new IllegalArgumentException(
+                    "idleTimeout: " + idleTimeout + " (expected: >= 0)");
+        }
+        return idleTimeout;
+    }
+
+    private ClientFactoryBuilder(ClientFactoryOptionValue<?>... options) {
+        super(ClientFactoryBuilder::validateValue, options);
+    }
+
+    private ClientFactoryBuilder(ClientFactoryBuilder baseOptions, ClientFactoryOptionValue<?>... options) {
+        super(ClientFactoryBuilder::validateValue, baseOptions, options);
+    }
+
+    private ClientFactoryBuilder(
+            ClientFactoryBuilder baseOptions, Iterable<ClientFactoryOptionValue<?>> options) {
+        super(ClientFactoryBuilder::validateValue, baseOptions, options);
+    }
+
+    private ClientFactoryBuilder(ClientFactoryBuilder clientOptions, ClientFactoryBuilder options) {
+        super(clientOptions, options);
+    }
+
+    /**
+     * Returns the value of the specified {@link ClientFactoryOption}.
+     *
+     * @return the value of the {@link ClientFactoryOption}, or
+     *         {@link Optional#empty()} if the default value of the specified {@link ClientFactoryOption} is
+     *         not available
+     */
+    public <T> Optional<T> get(ClientFactoryOption<T> option) {
+        return get0(option);
+    }
+
+    /**
+     * Returns the value of the specified {@link ClientFactoryOption}.
+     *
+     * @return the value of the {@link ClientFactoryOption}, or
+     *         {@code defaultValue} if the specified {@link ClientFactoryOption} is not set.
+     */
+    public <T> T getOrElse(ClientFactoryOption<T> option, T defaultValue) {
+        return getOrElse0(option, defaultValue);
+    }
+
+    /**
+     * Converts this {@link ClientFactoryBuilder} to a {@link Map}.
+     */
+    public Map<ClientFactoryOption<Object>, ClientFactoryOptionValue<Object>> asMap() {
+        return asMap0();
+    }
+
+    /**
+     * Returns the {@link ClientFactoryOption#CONNECT_TIMEOUT} value.
+     */
+    public Duration connectTimeout() {
+        return getOrElse(CONNECT_TIMEOUT, DEFAULT_CONNECTION_TIMEOUT);
+    }
+
+    /**
+     * Returns the {@link ClientFactoryOption#CONNECT_TIMEOUT} value as milliseconds.
+     */
+    public long connectTimeoutMillis() {
+        return connectTimeout().toMillis();
+    }
+
+    /**
+     * Returns the {@link ClientFactoryOption#EVENT_LOOP_GROUP} if non-default was specified.
+     */
+    public Optional<EventLoopGroup> eventLoopGroup() {
+        return get(EVENT_LOOP_GROUP);
+    }
+
+    /**
+     * Returns the {@link ClientFactoryOption#TRUST_MANAGER_FACTORY} if non-default was specified.
+     *
+     * @deprecated Use {@link ClientFactoryBuilder#sslContextCustomizer()} instead.
+     */
+    @Deprecated
+    public Optional<TrustManagerFactory> trustManagerFactory() {
+        return get(TRUST_MANAGER_FACTORY);
+    }
+
+    /**
+     * Returns the {@link ClientFactoryOption#SSL_CONTEXT_CUSTOMIZER} if non-default was specified.
+     */
+    public Optional<Consumer<SslContextBuilder>> sslContextCustomizer() {
+        return get(SSL_CONTEXT_CUSTOMIZER);
+    }
+
+    /**
+     * Returns the {@link ClientFactoryOption#ADDRESS_RESOLVER_GROUP} if non-default was specified.
+     */
+    public Optional<AddressResolverGroup<InetSocketAddress>> addressResolverGroup() {
+        final Optional<AddressResolverGroup<? extends InetSocketAddress>> value = get(ADDRESS_RESOLVER_GROUP);
+
+        @SuppressWarnings("unchecked")
+        final Optional<AddressResolverGroup<InetSocketAddress>> castValue =
+                (Optional<AddressResolverGroup<InetSocketAddress>>) (Optional<?>) value;
+
+        return castValue;
+    }
+
+    /**
+     * Returns the {@link ClientFactoryOption#IDLE_TIMEOUT} value.
+     */
+    public Duration idleTimeout() {
+        return getOrElse(IDLE_TIMEOUT, DEFAULT_IDLE_TIMEOUT);
+    }
+
+    /**
+     * Returns the {@link ClientFactoryOption#IDLE_TIMEOUT} value as milliseconds.
+     */
+    public long idleTimeoutMillis() {
+        return idleTimeout().toMillis();
+    }
+
+    /**
+     * Returns the {@link ClientFactoryOption#POOL_HANDLER_DECORATOR}.
+     */
+    public Function<KeyedChannelPoolHandler<PoolKey>, KeyedChannelPoolHandler<PoolKey>> poolHandlerDecorator() {
+        return getOrElse(POOL_HANDLER_DECORATOR, Function.identity());
+    }
+
+    /**
+     * Returns whether {@link ClientFactoryOption#USE_HTTP2_PREFACE} is enabled or not.
+     */
+    public boolean useHttp2Preface() {
+        return getOrElse(USE_HTTP2_PREFACE, Flags.defaultUseHttp2Preface());
+    }
+
+    /**
+     * Returns whether {@link ClientFactoryOption#USE_HTTP1_PIPELINING} is enabled or not.
+     */
+    public boolean useHttp1Pipelining() {
+        return getOrElse(USE_HTTP1_PIPELINING, Flags.defaultUseHttp1Pipelining());
+    }
+}
