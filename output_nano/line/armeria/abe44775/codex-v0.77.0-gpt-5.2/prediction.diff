+package com.linecorp.armeria.client;
+
+import static java.util.Objects.requireNonNull;
+
+import java.net.InetSocketAddress;
+import java.time.Duration;
+import java.util.function.Consumer;
+import java.util.function.Function;
+
+import javax.net.ssl.TrustManagerFactory;
+
+import com.linecorp.armeria.client.pool.KeyedChannelPoolHandler;
+import com.linecorp.armeria.client.pool.PoolKey;
+import com.linecorp.armeria.common.Flags;
+
+import io.netty.channel.EventLoopGroup;
+import io.netty.handler.ssl.SslContextBuilder;
+import io.netty.resolver.AddressResolverGroup;
+
+/**
+ * Builds a {@link ClientFactory}.
+ */
+public final class ClientFactoryBuilder {
+
+    private Duration connectTimeout = ClientFactoryOptions.DEFAULT_CONNECT_TIMEOUT;
+    private Duration idleTimeout = ClientFactoryOptions.DEFAULT_IDLE_TIMEOUT;
+    private boolean useHttp2Preface = Flags.defaultUseHttp2Preface();
+    private boolean useHttp1Pipelining = Flags.defaultUseHttp1Pipelining();
+
+    private EventLoopGroup eventLoopGroup;
+    private TrustManagerFactory trustManagerFactory;
+    private Consumer<SslContextBuilder> sslContextCustomizer;
+    private AddressResolverGroup<? extends InetSocketAddress> addressResolverGroup;
+    private Function<KeyedChannelPoolHandler<PoolKey>, KeyedChannelPoolHandler<PoolKey>> poolHandlerDecorator =
+            Function.identity();
+
+    /**
+     * Creates a new instance with the default settings.
+     */
+    public ClientFactoryBuilder() {}
+
+    /**
+     * Creates a new instance which has the same configuration with the specified {@code builder}.
+     */
+    public ClientFactoryBuilder(ClientFactoryBuilder builder) {
+        requireNonNull(builder, "builder");
+        connectTimeout = builder.connectTimeout;
+        idleTimeout = builder.idleTimeout;
+        useHttp2Preface = builder.useHttp2Preface;
+        useHttp1Pipelining = builder.useHttp1Pipelining;
+        eventLoopGroup = builder.eventLoopGroup;
+        trustManagerFactory = builder.trustManagerFactory;
+        sslContextCustomizer = builder.sslContextCustomizer;
+        addressResolverGroup = builder.addressResolverGroup;
+        poolHandlerDecorator = builder.poolHandlerDecorator;
+    }
+
+    /**
+     * Sets the timeout of a socket connection attempt.
+     */
+    public ClientFactoryBuilder connectTimeout(Duration connectTimeout) {
+        this.connectTimeout = ClientFactoryOptions.validateConnectTimeout(connectTimeout);
+        return this;
+    }
+
+    /**
+     * Sets the idle timeout of a socket connection.
+     */
+    public ClientFactoryBuilder idleTimeout(Duration idleTimeout) {
+        this.idleTimeout = ClientFactoryOptions.validateIdleTimeout(idleTimeout);
+        return this;
+    }
+
+    /**
+     * Sets the {@link TrustManagerFactory} for a TLS connection.
+     *
+     * @deprecated Use {@link #sslContextCustomizer(Consumer)} instead.
+     */
+    @Deprecated
+    public ClientFactoryBuilder trustManagerFactory(TrustManagerFactory trustManagerFactory) {
+        this.trustManagerFactory = requireNonNull(trustManagerFactory, "trustManagerFactory");
+        return this;
+    }
+
+    /**
+     * Sets a {@link Consumer} which can arbitrarily configure the {@link SslContextBuilder}.
+     */
+    public ClientFactoryBuilder sslContextCustomizer(Consumer<SslContextBuilder> sslContextCustomizer) {
+        this.sslContextCustomizer = requireNonNull(sslContextCustomizer, "sslContextCustomizer");
+        return this;
+    }
+
+    /**
+     * Sets the {@link AddressResolverGroup} to use to resolve remote addresses into {@link InetSocketAddress}es.
+     */
+    public ClientFactoryBuilder addressResolverGroup(
+            AddressResolverGroup<? extends InetSocketAddress> addressResolverGroup) {
+        this.addressResolverGroup = requireNonNull(addressResolverGroup, "addressResolverGroup");
+        return this;
+    }
+
+    /**
+     * Sets the {@link EventLoopGroup} that will provide I/O {@link io.netty.channel.EventLoop}s.
+     */
+    public ClientFactoryBuilder eventLoopGroup(EventLoopGroup eventLoopGroup) {
+        this.eventLoopGroup = requireNonNull(eventLoopGroup, "eventLoopGroup");
+        return this;
+    }
+
+    /**
+     * Sets the {@link Function} that decorates the {@link KeyedChannelPoolHandler}.
+     */
+    public ClientFactoryBuilder poolHandlerDecorator(
+            Function<KeyedChannelPoolHandler<PoolKey>, KeyedChannelPoolHandler<PoolKey>> poolHandlerDecorator) {
+        this.poolHandlerDecorator = requireNonNull(poolHandlerDecorator, "poolHandlerDecorator");
+        return this;
+    }
+
+    /**
+     * Sets whether to send an HTTP/2 preface string instead of an HTTP/1 upgrade request.
+     */
+    public ClientFactoryBuilder useHttp2Preface(boolean useHttp2Preface) {
+        this.useHttp2Preface = useHttp2Preface;
+        return this;
+    }
+
+    /**
+     * Sets whether to use HTTP pipelining for HTTP/1 connections.
+     */
+    public ClientFactoryBuilder useHttp1Pipelining(boolean useHttp1Pipelining) {
+        this.useHttp1Pipelining = useHttp1Pipelining;
+        return this;
+    }
+
+    /**
+     * Builds a new {@link ClientFactory}.
+     */
+    public ClientFactory build() {
+        return new AllInOneClientFactory(this);
+    }
+
+    /**
+     * Builds a new {@link HttpClientFactory}.
+     */
+    public HttpClientFactory buildHttp() {
+        return new HttpClientFactory(this);
+    }
+
+    ClientFactoryOptions buildOptions() {
+        return new ClientFactoryOptions(connectTimeout, idleTimeout, useHttp2Preface, useHttp1Pipelining,
+                                        eventLoopGroup, trustManagerFactory, sslContextCustomizer,
+                                        addressResolverGroup, poolHandlerDecorator);
+    }
+}
+
