+package io.netty.handler.codec.dns;
+
+import io.netty.buffer.ByteBuf;
+import io.netty.channel.ChannelHandlerContext;
+import io.netty.handler.codec.ByteToMessageDecoder;
+import io.netty.handler.codec.CorruptedFrameException;
+import io.netty.util.CharsetUtil;
+
+import java.net.InetSocketAddress;
+import java.util.List;
+
+/**
+ * Decodes DNS responses from TCP transport.
+ * <p>
+ * TCP DNS messages are prefixed with a 2-byte length field (RFC 1035 section 4.2.2).
+ */
+public class TcpDnsResponseDecoder extends ByteToMessageDecoder {
+
+    @Override
+    protected void decode(ChannelHandlerContext ctx, ByteBuf in, List<Object> out) throws Exception {
+        // Need at least 2 bytes for length prefix
+        if (in.readableBytes() < 2) {
+            return;
+        }
+
+        in.markReaderIndex();
+        int length = in.readUnsignedShort();
+
+        // Validate length
+        if (length < 12) {
+            throw new DnsCodecException("DNS message too short: " + length + " < 12 bytes");
+        }
+
+        // Wait for complete message
+        if (in.readableBytes() < length) {
+            in.resetReaderIndex();
+            return;
+        }
+
+        // Decode the DNS message
+        decodeMessage(in, length, out, null);
+    }
+
+    private static void decodeMessage(ByteBuf buf, int length, List<Object> out, Object sender) {
+        int endIndex = buf.readerIndex() + length;
+
+        int id = buf.readUnsignedShort();
+
+        // For TCP, use a placeholder address as the sender information comes from the channel
+        DnsResponse response = new DnsResponse(id, new InetSocketAddress(0));
+        DnsResponseHeader header = response.header();
+        int flags = buf.readUnsignedShort();
+        header.setType(flags >> 15);
+        header.setOpcode(flags >> 11 & 0xf);
+        header.setRecursionDesired((flags >> 8 & 1) == 1);
+        header.setAuthoritativeAnswer((flags >> 10 & 1) == 1);
+        header.setTruncated((flags >> 9 & 1) == 1);
+        header.setRecursionAvailable((flags >> 7 & 1) == 1);
+        header.setZ(flags >> 4 & 0x7);
+        header.setResponseCode(DnsResponseCode.valueOf(flags & 0xf));
+
+        int questions = buf.readUnsignedShort();
+        int answers = buf.readUnsignedShort();
+        int authorities = buf.readUnsignedShort();
+        int additionals = buf.readUnsignedShort();
+
+        boolean release = true;
+        try {
+            for (int i = 0; i < questions; i++) {
+                response.addQuestion(decodeQuestion(buf));
+            }
+
+            for (int i = 0; i < answers; i++) {
+                response.addAnswer(decodeResource(buf));
+            }
+            for (int i = 0; i < authorities; i++) {
+                response.addAuthorityResource(decodeResource(buf));
+            }
+            for (int i = 0; i < additionals; i++) {
+                response.addAdditionalResource(decodeResource(buf));
+            }
+
+            // Verify we read exactly the expected amount
+            if (buf.readerIndex() != endIndex) {
+                throw new DnsCodecException(
+                    "DNS message length mismatch: expected " + length + " bytes, but read " +
+                    (buf.readerIndex() - (endIndex - length)));
+            }
+
+            out.add(response);
+            release = false;
+        } catch (IndexOutOfBoundsException e) {
+            throw new DnsCodecException("Malformed DNS message: unexpected end of data", e);
+        } finally {
+            if (release) {
+                releaseDnsResources(response.answers());
+                releaseDnsResources(response.authorityResources());
+                releaseDnsResources(response.additionalResources());
+            }
+        }
+    }
+
+    private static void releaseDnsResources(List<DnsResource> resources) {
+        int size = resources.size();
+        for (int i = 0; i < size; i++) {
+            DnsResource resource = resources.get(i);
+            resource.release();
+        }
+    }
+
+    private static String readName(ByteBuf buf) {
+        int position = -1;
+        int checked = 0;
+        int length = buf.writerIndex();
+        StringBuilder name = new StringBuilder();
+
+        for (int len = buf.readUnsignedByte(); buf.isReadable() && len != 0; len = buf.readUnsignedByte()) {
+            boolean pointer = (len & 0xc0) == 0xc0;
+            if (pointer) {
+                if (!buf.isReadable()) {
+                    throw new DnsCodecException("Malformed DNS name: pointer extends beyond packet");
+                }
+                if (position == -1) {
+                    position = buf.readerIndex() + 1;
+                }
+                int offset = (len & 0x3f) << 8 | buf.readUnsignedByte();
+
+                if (offset >= length) {
+                    throw new DnsCodecException(
+                        "Invalid DNS name pointer: offset " + offset + " >= packet length " + length);
+                }
+
+                buf.readerIndex(offset);
+                checked += 2;
+                if (checked >= length) {
+                    throw new DnsCodecException("DNS name contains a loop");
+                }
+            } else {
+                if (len > DnsNameValidator.MAX_LABEL_LENGTH) {
+                    throw new DnsCodecException(
+                        "DNS label length exceeds maximum: " + len + " > " + DnsNameValidator.MAX_LABEL_LENGTH);
+                }
+
+                if (buf.readableBytes() < len) {
+                    throw new DnsCodecException(
+                        "Malformed DNS name: label length " + len + " exceeds remaining bytes " + buf.readableBytes());
+                }
+
+                name.append(buf.toString(buf.readerIndex(), len, CharsetUtil.UTF_8)).append('.');
+                buf.skipBytes(len);
+
+                if (name.length() > DnsNameValidator.MAX_NAME_LENGTH) {
+                    throw new DnsCodecException(
+                        "DNS name length exceeds maximum: " + name.length() + " > " + DnsNameValidator.MAX_NAME_LENGTH);
+                }
+            }
+        }
+        if (position != -1) {
+            buf.readerIndex(position);
+        }
+        if (name.length() == 0) {
+            return "";
+        }
+
+        return name.substring(0, name.length() - 1);
+    }
+
+    private static DnsQuestion decodeQuestion(ByteBuf buf) {
+        String name = readName(buf);
+        DnsType type = DnsType.valueOf(buf.readUnsignedShort());
+        DnsClass qClass = DnsClass.valueOf(buf.readUnsignedShort());
+        return new DnsQuestion(name, type, qClass);
+    }
+
+    private static DnsResource decodeResource(ByteBuf buf) {
+        String name = readName(buf);
+        DnsType type = DnsType.valueOf(buf.readUnsignedShort());
+        int classValue = buf.readUnsignedShort();
+        long ttl = buf.readUnsignedInt();
+        int len = buf.readUnsignedShort();
+
+        int readerIndex = buf.readerIndex();
+        ByteBuf payload = buf.duplicate().setIndex(readerIndex, readerIndex + len).retain();
+        buf.readerIndex(readerIndex + len);
+
+        DnsClass aClass = DnsClass.valueOf(classValue);
+        return new DnsResource(name, type, aClass, ttl, payload);
+    }
+}
