+ * License for the specific language governing permissions and limitations
+ * under the License.
+ */
+package io.netty.handler.codec.dns;
+
+/**
+ * Validates DNS names according to RFC 1035.
+ */
+public final class DnsNameValidator {
+
+    /**
+     * Maximum length of a DNS label (63 octets per RFC 1035).
+     */
+    public static final int MAX_LABEL_LENGTH = 63;
+
+    /**
+     * Maximum length of a DNS name (255 octets per RFC 1035).
+     */
+    public static final int MAX_NAME_LENGTH = 255;
+
+    private DnsNameValidator() {
+        // Utility class
+    }
+
+    /**
+     * Validates a DNS name according to RFC 1035.
+     *
+     * @param name the DNS name to validate
+     * @throws DnsValidationException if the name is invalid
+     */
+    public static void validateName(String name) {
+        if (name == null) {
+            throw new DnsValidationException("DNS name cannot be null");
+        }
+
+        if (name.isEmpty()) {
+            // Empty name is valid (root domain)
+            return;
+        }
+
+        // Check total length (including length octets)
+        // Each label has 1 byte length prefix, plus 1 byte for final zero
+        int totalLength = name.length() + 1; // +1 for the final zero octet
+        if (totalLength > MAX_NAME_LENGTH) {
+            throw new DnsValidationException(
+                "DNS name length exceeds maximum: " + totalLength + " > " + MAX_NAME_LENGTH);
+        }
+
+        // Split and validate each label
+        String[] labels = name.split("\\.");
+        for (String label : labels) {
+            if (label.isEmpty()) {
+                // Allow empty labels (e.g., trailing dot)
+                continue;
+            }
+
+            int labelLength = label.length();
+            if (labelLength > MAX_LABEL_LENGTH) {
+                throw new DnsValidationException(
+                    "DNS label length exceeds maximum: '" + label + "' (" +
+                    labelLength + " > " + MAX_LABEL_LENGTH + ")");
+            }
+
+            // Validate characters (RFC 1035 allows letters, digits, hyphens)
+            // First character must be a letter or digit
+            char firstChar = label.charAt(0);
+            if (!isLetterOrDigit(firstChar)) {
+                throw new DnsValidationException(
+                    "DNS label must start with a letter or digit: '" + label + "'");
+            }
+
+            // Check remaining characters
+            for (int i = 0; i < labelLength; i++) {
+                char c = label.charAt(i);
+                if (!isValidLabelChar(c)) {
+                    throw new DnsValidationException(
+                        "Invalid character in DNS label '" + label + "': '" + c + "'");
+                }
+            }
+
+            // Last character must be a letter or digit (not hyphen)
+            char lastChar = label.charAt(labelLength - 1);
+            if (lastChar == '-') {
+                throw new DnsValidationException(
+                    "DNS label cannot end with hyphen: '" + label + "'");
+            }
+        }
+    }
+
+    /**
+     * Checks if a character is a letter or digit (a-z, A-Z, 0-9).
+     */
+    private static boolean isLetterOrDigit(char c) {
+        return (c >= 'a' && c <= 'z') || (c >= 'A' && c <= 'Z') || (c >= '0' && c <= '9');
+    }
+
+    /**
+     * Checks if a character is valid in a DNS label (letter, digit, or hyphen).
+     */
+    private static boolean isValidLabelChar(char c) {
+        return isLetterOrDigit(c) || c == '-';
+    }
+
+    /**
+     * Checks if a DNS name is valid without throwing an exception.
+     *
+     * @param name the DNS name to check
+     * @return true if the name is valid, false otherwise
+     */
+    public static boolean isValidName(String name) {
+        try {
+            validateName(name);
+            return true;
+        } catch (DnsValidationException e) {
+            return false;
+        }
+    }
+}
