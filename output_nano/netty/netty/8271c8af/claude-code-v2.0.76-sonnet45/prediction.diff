+ * WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied. See the
+ * License for the specific language governing permissions and limitations
+ * under the License.
+ */
+package io.netty.handler.codec.dns;
+
+/**
+ * Validates DNS messages for RFC compliance.
+ */
+public final class DnsMessageValidator {
+
+    private DnsMessageValidator() {
+        // Utility class
+    }
+
+    /**
+     * Validates a DNS query message.
+     *
+     * @param query the query to validate
+     * @throws DnsValidationException if the query is invalid
+     */
+    public static void validateQuery(DnsQuery query) {
+        if (query == null) {
+            throw new DnsValidationException("DNS query cannot be null");
+        }
+
+        DnsHeader header = query.header();
+
+        // Query must have QR bit = 0
+        if (header.type() != DnsHeader.TYPE_QUERY) {
+            throw new DnsValidationException(
+                "DNS query must have QR bit = 0, got: " + header.type());
+        }
+
+        // Opcode should be QUERY (0) for standard queries
+        if (header.opcode() != DnsHeader.OPCODE_QUERY) {
+            // Allow other opcodes but they're less common
+        }
+
+        // Must have at least one question
+        if (query.questions().isEmpty()) {
+            throw new DnsValidationException("DNS query must have at least one question");
+        }
+
+        // Validate question names
+        for (DnsQuestion question : query.questions()) {
+            DnsNameValidator.validateName(question.name());
+        }
+
+        // Validate additional resource names
+        for (DnsResource resource : query.additionalResources()) {
+            DnsNameValidator.validateName(resource.name());
+        }
+    }
+
+    /**
+     * Validates a DNS response message.
+     *
+     * @param response the response to validate
+     * @throws DnsValidationException if the response is invalid
+     */
+    public static void validateResponse(DnsResponse response) {
+        if (response == null) {
+            throw new DnsValidationException("DNS response cannot be null");
+        }
+
+        DnsResponseHeader header = response.header();
+
+        // Response must have QR bit = 1
+        if (header.type() != DnsHeader.TYPE_RESPONSE) {
+            throw new DnsValidationException(
+                "DNS response must have QR bit = 1, got: " + header.type());
+        }
+
+        // Validate all names in the response
+        for (DnsQuestion question : response.questions()) {
+            DnsNameValidator.validateName(question.name());
+        }
+
+        for (DnsResource resource : response.answers()) {
+            DnsNameValidator.validateName(resource.name());
+        }
+
+        for (DnsResource resource : response.authorityResources()) {
+            DnsNameValidator.validateName(resource.name());
+        }
+
+        for (DnsResource resource : response.additionalResources()) {
+            DnsNameValidator.validateName(resource.name());
+        }
+    }
+
+    /**
+     * Checks if a DNS query is valid without throwing an exception.
+     *
+     * @param query the query to check
+     * @return true if the query is valid, false otherwise
+     */
+    public static boolean isValidQuery(DnsQuery query) {
+        try {
+            validateQuery(query);
+            return true;
+        } catch (DnsValidationException e) {
+            return false;
+        }
+    }
+
+    /**
+     * Checks if a DNS response is valid without throwing an exception.
+     *
+     * @param response the response to check
+     * @return true if the response is valid, false otherwise
+     */
+    public static boolean isValidResponse(DnsResponse response) {
+        try {
+            validateResponse(response);
+            return true;
+        } catch (DnsValidationException e) {
+            return false;
+        }
+    }
+}
