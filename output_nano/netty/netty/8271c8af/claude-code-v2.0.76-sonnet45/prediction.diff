+package io.netty.handler.codec.dns;
+
+import io.netty.buffer.ByteBuf;
+import io.netty.util.CharsetUtil;
+import io.netty.util.internal.StringUtil;
+
+import java.nio.charset.Charset;
+
+/**
+ * Default implementation of {@link DnsRecordEncoder} that handles standard DNS records.
+ */
+public class DefaultDnsRecordEncoder implements DnsRecordEncoder {
+
+    /**
+     * Shared instance of the default encoder.
+     */
+    public static final DefaultDnsRecordEncoder INSTANCE = new DefaultDnsRecordEncoder();
+
+    @Override
+    public void encodeRecord(DnsResource resource, Charset charset, ByteBuf buf) throws Exception {
+        encodeStandardRecord(resource, charset, buf);
+    }
+
+    @Override
+    public boolean canEncode(DnsResource resource) {
+        return true; // Default encoder can handle all records
+    }
+
+    /**
+     * Encodes a standard DNS resource record.
+     */
+    private void encodeStandardRecord(DnsResource resource, Charset charset, ByteBuf buf) {
+        encodeName(resource.name(), charset, buf);
+        buf.writeShort(resource.type().intValue());
+        buf.writeShort(resource.dnsClass().intValue());
+        buf.writeInt((int) resource.timeToLive());
+
+        ByteBuf content = resource.content();
+        int contentLen = content.readableBytes();
+
+        buf.writeShort(contentLen);
+        buf.writeBytes(content, content.readerIndex(), contentLen);
+    }
+
+    /**
+     * Encodes a DNS name using label format.
+     */
+    private void encodeName(String name, Charset charset, ByteBuf buf) {
+        // Validate the name according to RFC 1035
+        DnsNameValidator.validateName(name);
+
+        String[] parts = StringUtil.split(name, '.');
+        for (String part : parts) {
+            final int partLen = part.length();
+            if (partLen == 0) {
+                continue;
+            }
+            if (partLen > DnsNameValidator.MAX_LABEL_LENGTH) {
+                throw new DnsValidationException(
+                    "DNS label length exceeds maximum: " + partLen + " > " + DnsNameValidator.MAX_LABEL_LENGTH);
+            }
+            buf.writeByte(partLen);
+            buf.writeBytes(part.getBytes(charset));
+        }
+        buf.writeByte(0); // marks end of name field
+    }
+}
