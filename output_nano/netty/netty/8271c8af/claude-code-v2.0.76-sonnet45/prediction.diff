+package io.netty.handler.codec.dns;
+
+import io.netty.buffer.ByteBuf;
+import io.netty.buffer.Unpooled;
+import io.netty.channel.embedded.EmbeddedChannel;
+import org.junit.Test;
+
+import java.net.InetSocketAddress;
+import java.util.List;
+
+import static org.junit.Assert.*;
+
+public class TcpDnsCodecTest {
+
+    @Test
+    public void testTcpQueryEncoding() {
+        EmbeddedChannel channel = new EmbeddedChannel(new TcpDnsQueryEncoder());
+
+        DnsQuery query = new DnsQuery(1234, new InetSocketAddress("8.8.8.8", 53));
+        query.addQuestion(new DnsQuestion("example.com", DnsType.A, DnsClass.IN));
+
+        assertTrue(channel.writeOutbound(query));
+
+        ByteBuf encoded = channel.readOutbound();
+        assertNotNull(encoded);
+
+        // First 2 bytes should be the length
+        int length = encoded.readUnsignedShort();
+        assertTrue("Length should be at least 12 (header)", length >= 12);
+
+        // Verify we can read the header
+        int id = encoded.readUnsignedShort();
+        assertEquals(1234, id);
+
+        encoded.release();
+        assertFalse(channel.finish());
+    }
+
+    @Test
+    public void testTcpResponseDecoding() {
+        EmbeddedChannel channel = new EmbeddedChannel(new TcpDnsResponseDecoder());
+
+        // Create a simple DNS response
+        ByteBuf response = Unpooled.buffer();
+
+        // Length prefix (to be filled)
+        int lengthIndex = response.writerIndex();
+        response.writeShort(0);
+
+        int startIndex = response.writerIndex();
+
+        // Header
+        response.writeShort(1234); // ID
+        response.writeShort(0x8180); // Flags: response, recursion desired, recursion available
+        response.writeShort(1); // Questions
+        response.writeShort(1); // Answers
+        response.writeShort(0); // Authority
+        response.writeShort(0); // Additional
+
+        // Question
+        response.writeByte(7); // length
+        response.writeBytes("example".getBytes());
+        response.writeByte(3); // length
+        response.writeBytes("com".getBytes());
+        response.writeByte(0); // end of name
+        response.writeShort(1); // Type A
+        response.writeShort(1); // Class IN
+
+        // Answer
+        response.writeByte(7); // length
+        response.writeBytes("example".getBytes());
+        response.writeByte(3); // length
+        response.writeBytes("com".getBytes());
+        response.writeByte(0); // end of name
+        response.writeShort(1); // Type A
+        response.writeShort(1); // Class IN
+        response.writeInt(300); // TTL
+        response.writeShort(4); // RDLENGTH
+        response.writeBytes(new byte[]{8, 8, 8, 8}); // IP address
+
+        // Fill in length
+        int messageLength = response.writerIndex() - startIndex;
+        response.setShort(lengthIndex, messageLength);
+
+        assertTrue(channel.writeInbound(response));
+
+        DnsResponse decoded = channel.readInbound();
+        assertNotNull(decoded);
+        assertEquals(1234, decoded.header().id());
+        assertEquals(1, decoded.questions().size());
+        assertEquals(1, decoded.answers().size());
+
+        DnsQuestion question = decoded.questions().get(0);
+        assertEquals("example.com", question.name());
+        assertEquals(DnsType.A, question.type());
+
+        decoded.release();
+        assertFalse(channel.finish());
+    }
+
+    @Test
+    public void testTcpPartialMessage() {
+        EmbeddedChannel channel = new EmbeddedChannel(new TcpDnsResponseDecoder());
+
+        // Create a partial message
+        ByteBuf partial = Unpooled.buffer();
+        partial.writeShort(100); // Length = 100 bytes
+        partial.writeShort(1234); // ID
+        partial.writeShort(0x8000); // Flags
+
+        // Write partial message
+        assertFalse(channel.writeInbound(partial));
+
+        // Nothing should be decoded yet
+        assertNull(channel.readInbound());
+
+        assertFalse(channel.finish());
+    }
+
+    @Test
+    public void testTcpQueryWithMultipleQuestions() {
+        EmbeddedChannel channel = new EmbeddedChannel(new TcpDnsQueryEncoder());
+
+        DnsQuery query = new DnsQuery(1234, new InetSocketAddress("8.8.8.8", 53));
+        query.addQuestion(new DnsQuestion("example.com", DnsType.A, DnsClass.IN));
+        query.addQuestion(new DnsQuestion("example.org", DnsType.AAAA, DnsClass.IN));
+
+        assertTrue(channel.writeOutbound(query));
+
+        ByteBuf encoded = channel.readOutbound();
+        assertNotNull(encoded);
+
+        // Verify length prefix exists
+        int length = encoded.readUnsignedShort();
+        assertTrue(length > 12);
+
+        encoded.release();
+        assertFalse(channel.finish());
+    }
+}
