+package io.netty.handler.codec.dns;
+
+/**
+ * Exception thrown when DNS message validation fails.
+ */
+public class DnsValidationException extends DnsCodecException {
+
+    private static final long serialVersionUID = -5267619826494989540L;
+
+    public DnsValidationException(String message) {
+        super(message);
+    }
+
+    public DnsValidationException(String message, Throwable cause) {
+        super(message, cause);
+    }
+}
