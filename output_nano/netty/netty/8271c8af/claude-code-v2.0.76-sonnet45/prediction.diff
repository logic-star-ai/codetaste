+package io.netty.handler.codec.dns;
+
+import io.netty.buffer.ByteBuf;
+
+import java.nio.charset.Charset;
+
+/**
+ * Interface for encoding DNS resource records.
+ * <p>
+ * This interface allows for extensible encoding of different DNS record types.
+ * Implementations can provide type-specific encoding logic for various DNS record types.
+ */
+public interface DnsRecordEncoder {
+
+    /**
+     * Encodes a DNS resource record to the specified buffer.
+     *
+     * @param resource the resource record to encode
+     * @param charset the charset to use for encoding names
+     * @param buf the buffer to write the encoded data to
+     * @throws Exception if encoding fails
+     */
+    void encodeRecord(DnsResource resource, Charset charset, ByteBuf buf) throws Exception;
+
+    /**
+     * Returns whether this encoder can encode the given resource record.
+     *
+     * @param resource the resource record to check
+     * @return true if this encoder can encode the record, false otherwise
+     */
+    boolean canEncode(DnsResource resource);
+}
