+package io.netty.handler.codec.dns;
+
+import org.junit.Test;
+
+import static org.junit.Assert.*;
+
+public class DnsNameValidatorTest {
+
+    @Test
+    public void testValidNames() {
+        // These should all pass without exception
+        DnsNameValidator.validateName("example.com");
+        DnsNameValidator.validateName("www.example.com");
+        DnsNameValidator.validateName("sub.domain.example.com");
+        DnsNameValidator.validateName("test-domain.com");
+        DnsNameValidator.validateName("123.example.com");
+        DnsNameValidator.validateName("");  // Root domain
+        DnsNameValidator.validateName("a.b.c.d.e.f.g.h");
+
+        assertTrue(DnsNameValidator.isValidName("example.com"));
+    }
+
+    @Test
+    public void testLabelTooLong() {
+        // Label with 64 characters (exceeds max of 63)
+        String longLabel = "a123456789012345678901234567890123456789012345678901234567890123";
+        assertEquals(64, longLabel.length());
+
+        try {
+            DnsNameValidator.validateName(longLabel + ".com");
+            fail("Should have thrown DnsValidationException");
+        } catch (DnsValidationException e) {
+            assertTrue(e.getMessage().contains("label length exceeds maximum"));
+        }
+
+        assertFalse(DnsNameValidator.isValidName(longLabel + ".com"));
+    }
+
+    @Test
+    public void testMaxLabelLength() {
+        // Label with exactly 63 characters (should be valid)
+        String maxLabel = "a12345678901234567890123456789012345678901234567890123456789012";
+        assertEquals(63, maxLabel.length());
+
+        DnsNameValidator.validateName(maxLabel + ".com");
+        assertTrue(DnsNameValidator.isValidName(maxLabel + ".com"));
+    }
+
+    @Test
+    public void testNameTooLong() {
+        // Create a name that exceeds 255 characters
+        StringBuilder longName = new StringBuilder();
+        for (int i = 0; i < 10; i++) {
+            longName.append("averylonglabelname").append(i).append(".");
+        }
+        longName.append("com");
+
+        String name = longName.toString();
+        if (name.length() > 255) {
+            try {
+                DnsNameValidator.validateName(name);
+                fail("Should have thrown DnsValidationException");
+            } catch (DnsValidationException e) {
+                assertTrue(e.getMessage().contains("name length exceeds maximum"));
+            }
+        }
+    }
+
+    @Test
+    public void testInvalidCharacters() {
+        try {
+            DnsNameValidator.validateName("invalid_domain.com");
+            fail("Should have thrown DnsValidationException");
+        } catch (DnsValidationException e) {
+            assertTrue(e.getMessage().contains("Invalid character"));
+        }
+
+        try {
+            DnsNameValidator.validateName("invalid@domain.com");
+            fail("Should have thrown DnsValidationException");
+        } catch (DnsValidationException e) {
+            assertTrue(e.getMessage().contains("Invalid character") ||
+                      e.getMessage().contains("must start with"));
+        }
+    }
+
+    @Test
+    public void testLabelStartingWithHyphen() {
+        try {
+            DnsNameValidator.validateName("-invalid.com");
+            fail("Should have thrown DnsValidationException");
+        } catch (DnsValidationException e) {
+            assertTrue(e.getMessage().contains("must start with"));
+        }
+    }
+
+    @Test
+    public void testLabelEndingWithHyphen() {
+        try {
+            DnsNameValidator.validateName("invalid-.com");
+            fail("Should have thrown DnsValidationException");
+        } catch (DnsValidationException e) {
+            assertTrue(e.getMessage().contains("cannot end with hyphen"));
+        }
+    }
+
+    @Test
+    public void testNullName() {
+        try {
+            DnsNameValidator.validateName(null);
+            fail("Should have thrown DnsValidationException");
+        } catch (DnsValidationException e) {
+            assertTrue(e.getMessage().contains("cannot be null"));
+        }
+    }
+}
