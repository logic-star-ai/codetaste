+package io.netty.handler.codec.dns;
+
+import io.netty.buffer.ByteBuf;
+import io.netty.buffer.Unpooled;
+import io.netty.channel.embedded.EmbeddedChannel;
+import io.netty.channel.socket.DatagramPacket;
+import io.netty.handler.codec.CorruptedFrameException;
+import org.junit.Assert;
+import org.junit.Test;
+
+import java.net.InetSocketAddress;
+
+public class DnsCodecComplianceTest {
+
+    @Test
+    public void queryHeaderEncodesOpcodeInCorrectBitRange() throws Exception {
+        InetSocketAddress addr = new InetSocketAddress(0);
+        DnsQuery query = new DnsQuery(0x1234, addr);
+        query.header().setRecursionDesired(false).setOpcode(0xA).setZ(0x5);
+        query.addQuestion(new DnsQuestion("www.example.com", DnsType.A));
+
+        EmbeddedChannel ch = new EmbeddedChannel(new DnsQueryEncoder());
+        ch.writeOutbound(query);
+        DatagramPacket packet = ch.readOutbound();
+        ByteBuf content = packet.content();
+
+        Assert.assertEquals(0x1234, content.getUnsignedShort(0));
+        int flags = content.getUnsignedShort(2);
+        int expectedFlags = (0xA << 11) | (0x5 << 4);
+        Assert.assertEquals(expectedFlags, flags);
+
+        packet.release();
+        Assert.assertNull(ch.readOutbound());
+    }
+
+    @Test(expected = CorruptedFrameException.class)
+    public void nameDecoderRejectsUnsupportedLabelType() {
+        // 0x40 indicates an "extended label type" (RFC 1035) which we don't support.
+        DnsNameDecoder.decodeName(Unpooled.wrappedBuffer(new byte[] { 0x40, 0 }));
+    }
+
+    @Test(expected = CorruptedFrameException.class)
+    public void nameDecoderRejectsTooLongLabel() {
+        byte[] bytes = new byte[1 + 64 + 1];
+        bytes[0] = 64;
+        bytes[bytes.length - 1] = 0;
+        DnsNameDecoder.decodeName(Unpooled.wrappedBuffer(bytes));
+    }
+
+    @Test(expected = CorruptedFrameException.class)
+    public void responseDecoderRejectsTruncatedResourcePayload() throws Exception {
+        byte[] header = {
+                0, 1, (byte) 0x81, (byte) 0x80,
+                0, 0, 0, 1,
+                0, 0, 0, 0
+        };
+
+        ByteBuf buf = Unpooled.buffer();
+        buf.writeBytes(header);
+        buf.writeByte(0);      // root name
+        buf.writeShort(1);     // A
+        buf.writeShort(1);     // IN
+        buf.writeInt(0);       // TTL
+        buf.writeShort(4);     // RDLENGTH
+        buf.writeBytes(new byte[] { 1, 2, 3 }); // truncated
+
+        EmbeddedChannel ch = new EmbeddedChannel(new DnsResponseDecoder());
+        ch.writeInbound(new DatagramPacket(buf, null, new InetSocketAddress(0)));
+    }
+
+    @Test
+    public void queryEncoderSupportsOptionalNameCompression() throws Exception {
+        InetSocketAddress addr = new InetSocketAddress(0);
+
+        DnsQuery queryNoComp = new DnsQuery(1, addr)
+                .addQuestion(new DnsQuestion("www.example.com", DnsType.A))
+                .addAdditionalResource(new DnsResource(
+                        "example.com", DnsType.A, DnsClass.IN, 0, Unpooled.EMPTY_BUFFER));
+
+        EmbeddedChannel chNoComp = new EmbeddedChannel(new DnsQueryEncoder(false));
+        chNoComp.writeOutbound(queryNoComp);
+        DatagramPacket noComp = chNoComp.readOutbound();
+        int noCompLen = noComp.content().readableBytes();
+        Assert.assertEquals(-1, noComp.content().bytesBefore((byte) 0xC0));
+        noComp.release();
+
+        DnsQuery queryComp = new DnsQuery(1, addr)
+                .addQuestion(new DnsQuestion("www.example.com", DnsType.A))
+                .addAdditionalResource(new DnsResource(
+                        "example.com", DnsType.A, DnsClass.IN, 0, Unpooled.EMPTY_BUFFER));
+
+        EmbeddedChannel chComp = new EmbeddedChannel(new DnsQueryEncoder(true));
+        chComp.writeOutbound(queryComp);
+        DatagramPacket comp = chComp.readOutbound();
+        int compLen = comp.content().readableBytes();
+        Assert.assertTrue(comp.content().bytesBefore((byte) 0xC0) >= 0);
+        Assert.assertTrue(compLen < noCompLen);
+        comp.release();
+    }
+}
