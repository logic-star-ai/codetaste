+package io.netty.handler.codec.dns;
+
+import io.netty.buffer.ByteBuf;
+import io.netty.util.internal.StringUtil;
+
+import java.nio.charset.Charset;
+import java.util.HashMap;
+import java.util.Map;
+
+/**
+ * Encodes a domain name as defined in RFC 1035, section 4.1.4.
+ */
+final class DnsNameEncoder {
+
+    private static final int MAX_LABEL_LENGTH = 63;
+    private static final int MAX_NAME_LENGTH = 255;
+    private static final int MAX_POINTER = 0x3fff;
+
+    private final Charset charset;
+    private final boolean compress;
+    private final Map<String, Integer> nameOffsets = new HashMap<String, Integer>(32);
+
+    DnsNameEncoder(Charset charset, boolean compress) {
+        this.charset = charset;
+        this.compress = compress;
+    }
+
+    void encodeName(String name, ByteBuf buf) {
+        if (name == null) {
+            throw new NullPointerException("name");
+        }
+
+        if (name.isEmpty() || ".".equals(name)) {
+            buf.writeByte(0);
+            return;
+        }
+
+        if (name.charAt(name.length() - 1) == '.') {
+            name = name.substring(0, name.length() - 1);
+            if (name.isEmpty()) {
+                buf.writeByte(0);
+                return;
+            }
+        }
+
+        String[] labels = StringUtil.split(name, '.');
+        int labelsLen = 0;
+        for (String label : labels) {
+            if (label.isEmpty()) {
+                continue;
+            }
+            int labelBytes = label.getBytes(charset).length;
+            if (labelBytes > MAX_LABEL_LENGTH) {
+                throw new IllegalArgumentException("label length exceeds 63: " + label);
+            }
+            labelsLen += 1 + labelBytes;
+        }
+        // includes the trailing root label (0).
+        if (labelsLen + 1 > MAX_NAME_LENGTH) {
+            throw new IllegalArgumentException("name length exceeds 255: " + name);
+        }
+
+        int pointerOffset = -1;
+        int pointerIndex = -1;
+        if (compress) {
+            for (int i = 0; i < labels.length; i++) {
+                String suffix = suffix(labels, i);
+                Integer offset = nameOffsets.get(suffix);
+                if (offset != null && offset <= MAX_POINTER) {
+                    pointerOffset = offset;
+                    pointerIndex = i;
+                    break;
+                }
+            }
+        }
+
+        int last = labels.length - 1;
+        for (int i = 0; i < labels.length; i++) {
+            if (pointerIndex != -1 && i == pointerIndex) {
+                buf.writeShort(0xC000 | pointerOffset);
+                return;
+            }
+
+            String label = labels[i];
+            if (label.isEmpty()) {
+                continue;
+            }
+
+            final int offset = buf.writerIndex();
+            if (offset <= MAX_POINTER) {
+                String suffix = suffix(labels, i);
+                if (!nameOffsets.containsKey(suffix)) {
+                    nameOffsets.put(suffix, offset);
+                }
+            }
+
+            byte[] bytes = label.getBytes(charset);
+            buf.writeByte(bytes.length);
+            buf.writeBytes(bytes);
+
+            if (i == last) {
+                buf.writeByte(0);
+            }
+        }
+    }
+
+    private static String suffix(String[] labels, int start) {
+        StringBuilder sb = new StringBuilder(64);
+        for (int i = start; i < labels.length; i++) {
+            if (labels[i].isEmpty()) {
+                continue;
+            }
+            sb.append(labels[i]).append('.');
+        }
+        if (sb.length() == 0) {
+            return "";
+        }
+        sb.setLength(sb.length() - 1);
+        return sb.toString();
+    }
+}
