+package io.netty.handler.codec.dns;
+
+import io.netty.buffer.ByteBuf;
+import io.netty.handler.codec.CorruptedFrameException;
+import io.netty.util.CharsetUtil;
+
+/**
+ * Decodes a domain name as defined in RFC 1035, section 4.1.4.
+ */
+public final class DnsNameDecoder {
+
+    private static final int MAX_LABEL_LENGTH = 63;
+    private static final int MAX_NAME_LENGTH = 255;
+
+    private DnsNameDecoder() {
+    }
+
+    /**
+     * Decodes a domain name starting at {@link ByteBuf#readerIndex()}.
+     * <p>
+     * The returned string uses {@code '.'} as label separators. The root name is represented as {@code ""}.
+     *
+     * @throws CorruptedFrameException if the name is malformed, truncated, contains an unsupported label type,
+     *                                 or contains a compression loop.
+     */
+    public static String decodeName(ByteBuf buf) {
+        int position = -1;
+        int checked = 0;
+        final int length = buf.writerIndex();
+
+        StringBuilder name = new StringBuilder(64);
+        int nameLength = 1; // includes the trailing root label (0)
+
+        while (true) {
+            if (!buf.isReadable()) {
+                throw new CorruptedFrameException("truncated name");
+            }
+
+            final int len = buf.readUnsignedByte();
+            if (len == 0) {
+                break;
+            }
+
+            final int labelType = len & 0xC0;
+            if (labelType == 0) {
+                if (len > MAX_LABEL_LENGTH) {
+                    throw new CorruptedFrameException("label length exceeds 63: " + len);
+                }
+                if (buf.readableBytes() < len) {
+                    throw new CorruptedFrameException("truncated label: " + len);
+                }
+                nameLength += 1 + len;
+                if (nameLength > MAX_NAME_LENGTH) {
+                    throw new CorruptedFrameException("name length exceeds 255: " + nameLength);
+                }
+                name.append(buf.toString(buf.readerIndex(), len, CharsetUtil.UTF_8)).append('.');
+                buf.skipBytes(len);
+            } else if (labelType == 0xC0) {
+                if (buf.readableBytes() < 1) {
+                    throw new CorruptedFrameException("truncated pointer");
+                }
+                if (position == -1) {
+                    position = buf.readerIndex() + 1;
+                }
+                final int pointer = (len & 0x3f) << 8 | buf.readUnsignedByte();
+                if (pointer >= length) {
+                    throw new CorruptedFrameException("name pointer out of bounds: " + pointer);
+                }
+                buf.readerIndex(pointer);
+                checked += 2;
+                if (checked >= length) {
+                    throw new CorruptedFrameException("name contains a loop.");
+                }
+            } else {
+                throw new CorruptedFrameException("unsupported label type: " + labelType);
+            }
+        }
+
+        if (position != -1) {
+            buf.readerIndex(position);
+        }
+
+        if (name.length() == 0) {
+            return "";
+        }
+        name.setLength(name.length() - 1);
+        return name.toString();
+    }
+}
