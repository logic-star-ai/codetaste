+
+/**
+ * Decodes a domain name from a DNS message.
+ */
+public interface DnsNameDecoder {
+
+    /**
+     * Decode a DNS domain name at the current {@link ByteBuf#readerIndex()}, advancing the index past the name.
+     *
+     * @param in the DNS message buffer
+     * @param dnsMessageStartIndex the absolute start index of the DNS message within {@code in}
+     * @param dnsMessageEndIndex the absolute end index of the DNS message within {@code in}
+     * @return the decoded name without a trailing dot (root is {@code ""})
+     */
+    String decodeName(ByteBuf in, int dnsMessageStartIndex, int dnsMessageEndIndex);
+}
