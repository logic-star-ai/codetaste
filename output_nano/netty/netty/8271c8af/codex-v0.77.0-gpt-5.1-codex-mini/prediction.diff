+ * License for the specific language governing permissions and limitations
+ * under the License.
+ */
+package io.netty.handler.codec.dns;
+
+import io.netty.buffer.ByteBuf;
+import io.netty.handler.codec.CorruptedFrameException;
+
+/**
+ * The default {@link DnsRecordDecoder} which decodes into {@link DnsQuestion} and {@link DnsResource}.
+ */
+public final class DefaultDnsRecordDecoder implements DnsRecordDecoder {
+
+    private final DnsNameDecoder nameDecoder;
+
+    public DefaultDnsRecordDecoder() {
+        this(new DefaultDnsNameDecoder());
+    }
+
+    public DefaultDnsRecordDecoder(DnsNameDecoder nameDecoder) {
+        if (nameDecoder == null) {
+            throw new NullPointerException("nameDecoder");
+        }
+        this.nameDecoder = nameDecoder;
+    }
+
+    @Override
+    public DnsQuestion decodeQuestion(ByteBuf in, int dnsMessageStartIndex, int dnsMessageEndIndex) {
+        final String name = nameDecoder.decodeName(in, dnsMessageStartIndex, dnsMessageEndIndex);
+        if (in.readableBytes() < 4) {
+            throw new CorruptedFrameException("truncated question");
+        }
+        final DnsType type = DnsType.valueOf(in.readUnsignedShort());
+        final DnsClass qClass = DnsClass.valueOf(in.readUnsignedShort());
+        return new DnsQuestion(name, type, qClass);
+    }
+
+    @Override
+    public DnsResource decodeResource(ByteBuf in, int dnsMessageStartIndex, int dnsMessageEndIndex) {
+        final String name = nameDecoder.decodeName(in, dnsMessageStartIndex, dnsMessageEndIndex);
+        if (in.readableBytes() < 10) {
+            throw new CorruptedFrameException("truncated resource record");
+        }
+        final DnsType type = DnsType.valueOf(in.readUnsignedShort());
+        final DnsClass aClass = DnsClass.valueOf(in.readUnsignedShort());
+        final long ttl = in.readUnsignedInt();
+        final int len = in.readUnsignedShort();
+
+        if (in.readableBytes() < len) {
+            throw new CorruptedFrameException("truncated resource record payload (len: " + len + ')');
+        }
+
+        final int readerIndex = in.readerIndex();
+        final ByteBuf payload = in.duplicate().setIndex(readerIndex, readerIndex + len).retain();
+        in.skipBytes(len);
+        return new DnsResource(name, type, aClass, ttl, payload);
+    }
+}
