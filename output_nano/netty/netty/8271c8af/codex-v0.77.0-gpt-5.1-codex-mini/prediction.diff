+package io.netty.handler.codec.dns;
+
+import io.netty.buffer.ByteBuf;
+import io.netty.handler.codec.CorruptedFrameException;
+import io.netty.util.CharsetUtil;
+
+/**
+ * RFC 1035 name decoder with pointer validation.
+ */
+public final class DefaultDnsNameDecoder implements DnsNameDecoder {
+
+    private static final int MAX_LABEL_LENGTH = 63;
+    private static final int MAX_NAME_WIRE_LENGTH = 255;
+
+    @Override
+    public String decodeName(ByteBuf in, int dnsMessageStartIndex, int dnsMessageEndIndex) {
+        if (dnsMessageStartIndex < 0 || dnsMessageEndIndex < dnsMessageStartIndex ||
+                dnsMessageEndIndex > in.capacity()) {
+            throw new IllegalArgumentException(
+                    "Invalid DNS message bounds: " + dnsMessageStartIndex + ".." + dnsMessageEndIndex);
+        }
+
+        final int readerIndex = in.readerIndex();
+        int currentIndex = readerIndex;
+        int nextIndex = -1;
+        int checked = 0;
+        int wireLength = 0;
+
+        StringBuilder name = new StringBuilder(64);
+
+        for (;;) {
+            if (currentIndex >= dnsMessageEndIndex) {
+                throw new CorruptedFrameException("truncated name (index: " + currentIndex + ')');
+            }
+
+            final int len = in.getUnsignedByte(currentIndex++);
+            wireLength++;
+
+            if (len == 0) {
+                if (nextIndex == -1) {
+                    in.readerIndex(currentIndex);
+                } else {
+                    in.readerIndex(nextIndex);
+                }
+                return name.toString();
+            }
+
+            final int labelType = len & 0xC0;
+            if (labelType == 0xC0) {
+                if (currentIndex >= dnsMessageEndIndex) {
+                    throw new CorruptedFrameException("truncated name pointer (index: " + currentIndex + ')');
+                }
+                final int pointerOffset = (len & 0x3F) << 8 | in.getUnsignedByte(currentIndex++);
+                wireLength++;
+
+                final int pointerIndex = dnsMessageStartIndex + pointerOffset;
+                if (pointerIndex < dnsMessageStartIndex || pointerIndex >= dnsMessageEndIndex) {
+                    throw new CorruptedFrameException("name pointer out of bounds: " + pointerOffset);
+                }
+
+                if (nextIndex == -1) {
+                    nextIndex = currentIndex;
+                }
+
+                checked += 2;
+                if (checked >= dnsMessageEndIndex - dnsMessageStartIndex) {
+                    throw new CorruptedFrameException("name contains a loop.");
+                }
+
+                currentIndex = pointerIndex;
+                continue;
+            }
+
+            if (labelType != 0) {
+                throw new CorruptedFrameException("invalid label type: " + labelType);
+            }
+
+            if (len > MAX_LABEL_LENGTH) {
+                throw new CorruptedFrameException("label too long: " + len);
+            }
+
+            if (currentIndex + len > dnsMessageEndIndex) {
+                throw new CorruptedFrameException("truncated label (len: " + len + ')');
+            }
+
+            wireLength += len;
+            if (wireLength > MAX_NAME_WIRE_LENGTH) {
+                throw new CorruptedFrameException("name too long: " + wireLength);
+            }
+
+            if (name.length() > 0) {
+                name.append('.');
+            }
+            name.append(in.toString(currentIndex, len, CharsetUtil.US_ASCII));
+            currentIndex += len;
+        }
+    }
+}
