+ * distributed under the License is distributed on an "AS IS" BASIS, WITHOUT
+ * WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied. See the
+ * License for the specific language governing permissions and limitations
+ * under the License.
+ */
+package io.netty.handler.codec.dns;
+
+import io.netty.buffer.ByteBuf;
+
+/**
+ * The default {@link DnsRecordEncoder} which encodes {@link DnsQuestion} and {@link DnsResource}.
+ */
+public final class DefaultDnsRecordEncoder implements DnsRecordEncoder {
+
+    @Override
+    public void encodeQuestion(DnsQuestion question, ByteBuf out, DnsNameEncoder nameEncoder) {
+        if (question == null) {
+            throw new NullPointerException("question");
+        }
+        if (nameEncoder == null) {
+            throw new NullPointerException("nameEncoder");
+        }
+        nameEncoder.encodeName(out, question.name());
+        out.writeShort(question.type().intValue());
+        out.writeShort(question.dnsClass().intValue());
+    }
+
+    @Override
+    public void encodeResource(DnsResource resource, ByteBuf out, DnsNameEncoder nameEncoder) {
+        if (resource == null) {
+            throw new NullPointerException("resource");
+        }
+        if (nameEncoder == null) {
+            throw new NullPointerException("nameEncoder");
+        }
+
+        nameEncoder.encodeName(out, resource.name());
+
+        out.writeShort(resource.type().intValue());
+        out.writeShort(resource.dnsClass().intValue());
+
+        final long ttl = resource.timeToLive();
+        if (ttl < 0 || ttl > 0xFFFFFFFFL) {
+            throw new IllegalArgumentException("timeToLive: " + ttl + " (expected: 0 ~ 4294967295)");
+        }
+        out.writeInt((int) ttl);
+
+        final ByteBuf content = resource.content();
+        final int contentLen = content.readableBytes();
+        if (contentLen > 0xFFFF) {
+            throw new IllegalArgumentException("resource payload too large: " + contentLen);
+        }
+
+        out.writeShort(contentLen);
+        out.writeBytes(content, content.readerIndex(), contentLen);
+    }
+}
