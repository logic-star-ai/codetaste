+ */
+package io.netty.handler.codec.dns;
+
+import io.netty.buffer.ByteBuf;
+import io.netty.util.CharsetUtil;
+
+import java.util.HashMap;
+import java.util.Map;
+
+/**
+ * Encodes names per RFC 1035, optionally using name compression.
+ */
+public final class DefaultDnsNameEncoder implements DnsNameEncoder {
+
+    private static final int MAX_LABEL_LENGTH = 63;
+    private static final int MAX_NAME_WIRE_LENGTH = 255;
+    private static final int MAX_POINTER = 0x3FFF;
+
+    private final int dnsMessageStartIndex;
+    private final boolean compressionEnabled;
+    private final Map<String, Integer> nameOffsets;
+
+    public DefaultDnsNameEncoder(int dnsMessageStartIndex, boolean compressionEnabled) {
+        if (dnsMessageStartIndex < 0) {
+            throw new IllegalArgumentException("dnsMessageStartIndex: " + dnsMessageStartIndex);
+        }
+        this.dnsMessageStartIndex = dnsMessageStartIndex;
+        this.compressionEnabled = compressionEnabled;
+        nameOffsets = compressionEnabled ? new HashMap<String, Integer>(16) : null;
+    }
+
+    @Override
+    public void encodeName(ByteBuf out, String name) {
+        if (name == null) {
+            throw new NullPointerException("name");
+        }
+
+        if (name.isEmpty()) {
+            out.writeByte(0);
+            return;
+        }
+
+        final String normalizedName = normalizeName(name);
+        final String[] labels = splitLabels(normalizedName);
+
+        int wireLength = 1; // terminal 0
+        for (int i = 0; i < labels.length; i++) {
+            final int len = labels[i].length();
+            if (len == 0) {
+                throw new IllegalArgumentException("empty label in name: " + name);
+            }
+            if (len > MAX_LABEL_LENGTH) {
+                throw new IllegalArgumentException("label too long: " + len);
+            }
+            wireLength += 1 + len;
+        }
+        if (wireLength > MAX_NAME_WIRE_LENGTH) {
+            throw new IllegalArgumentException("name too long: " + wireLength);
+        }
+
+        if (!compressionEnabled) {
+            writeLabels(out, labels, 0, labels.length);
+            out.writeByte(0);
+            return;
+        }
+
+        int pointerOffset = -1;
+        int pointerIndex = -1;
+        for (int i = 0; i < labels.length; i++) {
+            final String suffix = joinLabels(labels, i);
+            final Integer existingOffset = nameOffsets.get(suffix);
+            if (existingOffset != null) {
+                pointerOffset = existingOffset.intValue();
+                pointerIndex = i;
+                break;
+            }
+        }
+
+        if (pointerOffset != -1) {
+            writeLabels(out, labels, 0, pointerIndex);
+            out.writeShort(0xC000 | pointerOffset);
+            return;
+        }
+
+        writeLabels(out, labels, 0, labels.length);
+        out.writeByte(0);
+    }
+
+    private void writeLabels(ByteBuf out, String[] labels, int start, int end) {
+        for (int i = start; i < end; i++) {
+            final int offset = out.writerIndex() - dnsMessageStartIndex;
+            if (compressionEnabled && offset <= MAX_POINTER) {
+                nameOffsets.put(joinLabels(labels, i), Integer.valueOf(offset));
+            }
+
+            final String label = labels[i];
+            final int len = label.length();
+            out.writeByte(len);
+            out.writeBytes(label.getBytes(CharsetUtil.US_ASCII));
+        }
+    }
+
+    private static String normalizeName(String name) {
+        int end = name.length();
+        while (end > 0 && name.charAt(end - 1) == '.') {
+            end--;
+        }
+        if (end == name.length()) {
+            return name;
+        }
+        return name.substring(0, end);
+    }
+
+    private static String[] splitLabels(String name) {
+        int labels = 1;
+        for (int i = 0; i < name.length(); i++) {
+            if (name.charAt(i) == '.') {
+                labels++;
+            } else if (name.charAt(i) > 0x7F) {
+                throw new IllegalArgumentException("non-ASCII character in name: " + name);
+            }
+        }
+
+        String[] parts = new String[labels];
+        int partIndex = 0;
+        int lastDot = -1;
+        for (int i = 0; i <= name.length(); i++) {
+            if (i == name.length() || name.charAt(i) == '.') {
+                parts[partIndex++] = name.substring(lastDot + 1, i);
+                lastDot = i;
+            }
+        }
+        return parts;
+    }
+
+    private static String joinLabels(String[] labels, int from) {
+        int len = 0;
+        for (int i = from; i < labels.length; i++) {
+            len += labels[i].length();
+        }
+        len += labels.length - from - 1;
+
+        StringBuilder sb = new StringBuilder(len);
+        for (int i = from; i < labels.length; i++) {
+            if (i != from) {
+                sb.append('.');
+            }
+            sb.append(labels[i]);
+        }
+        return sb.toString();
+    }
+}
