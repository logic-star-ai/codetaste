+    @Test
+    public void testCopyWithId() {
+        InetSocketAddress addr = new InetSocketAddress(0);
+        DnsQuery original = new DnsQuery(1, addr)
+                .addQuestion(new DnsQuestion("example.com", DnsType.A))
+                .addAnswer(new DnsResource("example.com", DnsType.A, DnsClass.IN, 3600, null))
+                .addAuthorityResource(new DnsResource("example.com", DnsType.A, DnsClass.IN, 3600, null));
+
+        // Copy the query with a different ID
+        DnsQuery copy = original.copyWithId(2);
+
+        // Verify that the copy has new ID
+        Assert.assertEquals(2, copy.header().id());
+
+        // Verify that the copy has same properties
+        Assert.assertEquals(original.questions(), copy.questions());
+        Assert.assertEquals(original.answers(), copy.answers());
+        Assert.assertEquals(original.authorityResources(), copy.authorityResources());
+        Assert.assertEquals(original.additionalResources(), copy.additionalResources());
+
+        // Verify header properties
+        Assert.assertEquals(original.header().isRecursionDesired(), copy.header().isRecursionDesired());
+        Assert.assertEquals(original.header().opcode(), copy.header().opcode());
+        Assert.assertEquals(original.header().z(), copy.header().z());
+        Assert.assertEquals(original.header().isAuthoritativeAnswer(), copy.header().isAuthoritativeAnswer());
+        Assert.assertEquals(original.header().isTruncated(), copy.header().isTruncated());
+        Assert.assertEquals(original.header().isRecursionAvailable(), copy.header().isRecursionAvailable());
