+package io.netty.channel;
+
+/**
+ * EventLoopGroup is a group abstraction for managing multiple {@link EventLoop}s.
+ * It extends {@link EventExecutorGroup} and provides channel registration capabilities.
+ */
+public interface EventLoopGroup extends EventExecutorGroup {
+    /**
+     * Returns one of the {@link EventLoop}s that belong to this group.
+     */
+    @Override
+    EventLoop next();
+
+    /**
+     * Register a {@link Channel} with this {@link EventLoopGroup}. The registered {@link Channel}
+     * will be handled by one of the {@link EventLoop}s in this group.
+     */
+    ChannelFuture register(Channel channel);
+
+    /**
+     * Register a {@link Channel} with this {@link EventLoopGroup} using the given {@link ChannelFuture}.
+     * The registered {@link Channel} will be handled by one of the {@link EventLoop}s in this group.
+     */
+    ChannelFuture register(Channel channel, ChannelFuture future);
+}
