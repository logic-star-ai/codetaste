+package io.netty.channel;
+
+import java.util.concurrent.ThreadFactory;
+import java.util.concurrent.TimeUnit;
+
+public class MultithreadEventLoopGroup extends MultithreadEventExecutor implements EventLoopGroup {
+
+    public MultithreadEventLoopGroup() {
+        this(0);
+    }
+
+    public MultithreadEventLoopGroup(int nThreads) {
+        this(nThreads, new DefaultThreadFactory());
+    }
+
+    public MultithreadEventLoopGroup(int nThreads, ThreadFactory threadFactory) {
+        super(nThreads, threadFactory);
+    }
+
+    @Override
+    public EventLoop next() {
+        return (EventLoop) unsafe().nextChild();
+    }
+
+    @Override
+    public EventLoop[] children() {
+        return (EventLoop[]) children;
+    }
+
+    @Override
+    public void shutdownGracefully() {
+        shutdownGracefully(2, 15, TimeUnit.SECONDS);
+    }
+
+    @Override
+    public void shutdownGracefully(long quietPeriod, long timeout, TimeUnit unit) {
+        // In a real implementation, this would gracefully shut down all event loops
+        // For now, we'll delegate to the parent implementation
+        shutdown();
+    }
+}
