+# Generated migration to simplify product-attribute relation
+
+from django.contrib.postgres.indexes import BTreeIndex
+from django.db import migrations
+
+
+class Migration(migrations.Migration):
+    dependencies = [
+        ("attribute", "0037_remove_assignedpageattribute"),
+    ]
+
+    operations = [
+        # Remove the BTree index first
+        migrations.RemoveIndex(
+            model_name="assignedproductattributevalue",
+            name="assignedprodattrval_product_idx",
+        ),
+        # Remove the denormalized product field
+        migrations.RemoveField(
+            model_name="assignedproductattributevalue",
+            name="product",
+        ),
+    ]
