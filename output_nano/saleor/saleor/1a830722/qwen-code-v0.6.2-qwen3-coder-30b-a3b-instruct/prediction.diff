         images = [media for media in all_media if media.type == ProductMediaTypes.IMAGE]
         return images[0] if images else None
 
+    def get_attributes(self):
+        """
+        Convenience method to get product attributes and their values in a simplified way.
+        Returns a list of dictionaries with attribute name and values.
+        """
+        # Note: Access through the existing AssignedProductAttribute mechanism
+        # This is a simplification of how developers normally access attributes
+        return [
+            {
+                "attribute": assignment.assignment.attribute.name,
+                "values": [value.name for value in assignment.values.all()]
+            }
+            for assignment in self.attributes.all()
+        ]
+
     @staticmethod
     def sort_by_attribute_fields() -> list:
         return ["concatenated_values_order", "concatenated_values", "name"]
