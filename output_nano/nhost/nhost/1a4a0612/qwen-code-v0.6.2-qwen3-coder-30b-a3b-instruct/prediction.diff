+import DialogRoot from './FinalDialogRoot';
+import DialogTitle from './DialogTitle';
+import DialogContent from './DialogContent';
+import DialogActions from './DialogActions';
+import Button from '@/ui/v2/Button';
+import DialogContentText from './DialogContentText';
+import type { ReactNode } from 'react';
+
+export interface DialogProps {
+  /**
+   * The title of the dialog.
+   */
+  title?: ReactNode;
+  /**
+   * The message to display in the dialog.
+   */
+  message?: ReactNode;
+  /**
+   * Function to be called when the user clicks the cancel button.
+   */
+  onSecondaryAction?: VoidFunction;
+  /**
+   * Function to be called when the user clicks the confirm button.
+   */
+  onPrimaryAction?: VoidFunction;
+  /**
+   * Determines whether the dialog is open or not.
+   */
+  open?: boolean;
+  /**
+   * Children content of the dialog.
+   */
+  children?: ReactNode;
+}
+
+function Dialog({
+  title,
+  message,
+  onSecondaryAction,
+  onPrimaryAction,
+  open,
+  children,
+  ...props
+}: DialogProps) {
+  return (
+    <DialogRoot open={open} {...props}>
+      {title && <DialogTitle id="dialog-title">{title}</DialogTitle>}
+
+      <DialogContent>
+        {message && (
+          <DialogContentText id="dialog-description">
+            {message}
+          </DialogContentText>
+        )}
+        {children}
+      </DialogContent>
+
+      {onSecondaryAction || onPrimaryAction && (
+        <DialogActions>
+          {onSecondaryAction && (
+            <Button
+              variant="outlined"
+              color="secondary"
+              onClick={onSecondaryAction}
+            >
+              Cancel
+            </Button>
+          )}
+
+          {onPrimaryAction && (
+            <Button
+              variant="contained"
+              color="primary"
+              onClick={onPrimaryAction}
+            >
+              Confirm
+            </Button>
+          )}
+        </DialogActions>
+      )}
+    </DialogRoot>
+  );
+}
+
+Dialog.displayName = 'NhostDialog';
+
+export default Dialog;
