@@ -0,0 +1,21 @@
+import { styled } from '@mui/material';
+import type { BoxProps } from '@mui/material/Box';
+import Box from '@mui/material/Box';
+
+export interface DrawerContentProps extends BoxProps {}
+
+const StyledDrawerContent = styled(Box)(({ theme }) => ({
+  display: 'flex',
+  flexDirection: 'column',
+  flex: 1,
+  overflow: 'auto',
+  padding: theme.spacing(0, 3, 3, 3),
+}));
+
+function DrawerContent({ children, ...props }: DrawerContentProps) {
+  return <StyledDrawerContent {...props}>{children}</StyledDrawerContent>;
+}
+
+DrawerContent.displayName = 'NhostDrawerContent';
+
+export default DrawerContent;
