@@ -0,0 +1,28 @@
+import Backdrop from '@/ui/v2/Backdrop';
+import { styled } from '@mui/material';
+import type { DrawerProps as MaterialDrawerProps } from '@mui/material/Drawer';
+import MaterialDrawer, { drawerClasses } from '@mui/material/Drawer';
+
+export interface DrawerRootProps extends MaterialDrawerProps {}
+
+const StyledDrawer = styled(MaterialDrawer)(({ theme }) => ({
+  [`& .${drawerClasses.paper}`]: {
+    display: 'flex',
+    boxShadow:
+      '0px 1px 4px rgba(14, 24, 39, 0.1), 0px 8px 24px rgba(14, 24, 39, 0.1)',
+    backgroundColor: theme.palette.background.paper,
+    backgroundImage: 'none',
+  },
+}));
+
+function DrawerRoot({ children, ...props }: DrawerRootProps) {
+  return (
+    <StyledDrawer components={{ Backdrop }} {...props}>
+      {children}
+    </StyledDrawer>
+  );
+}
+
+DrawerRoot.displayName = 'NhostDrawerRoot';
+
+export default DrawerRoot;
