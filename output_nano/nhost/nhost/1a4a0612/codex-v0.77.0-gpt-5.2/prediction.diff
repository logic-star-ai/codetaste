diff --git a/dashboard/src/components/ui/v2/Drawer/DrawerTitle.tsx b/dashboard/src/components/ui/v2/Drawer/DrawerTitle.tsx
new file mode 100644
index 0000000..55ffe0d
--- /dev/null
+++ b/dashboard/src/components/ui/v2/Drawer/DrawerTitle.tsx
@@ -0,0 +1,34 @@
+import DialogTitle from '@/ui/v2/Dialog/DialogTitle';
+import type { DialogTitleProps } from '@/ui/v2/Dialog/DialogTitle';
+import type { DrawerProps as MaterialDrawerProps } from '@mui/material/Drawer';
+import type { MouseEvent } from 'react';
+
+export interface DrawerTitleProps extends Omit<DialogTitleProps, 'onClose'> {
+  /**
+   * Function to be called when the user clicks the close button.
+   */
+  onClose?: MaterialDrawerProps['onClose'];
+}
+
+function DrawerTitle({ onClose, ...props }: DrawerTitleProps) {
+  const mergedSx = [
+    { padding: (theme) => theme.spacing(2.5, 3) },
+    ...(Array.isArray(props.sx) ? props.sx : [props.sx]),
+  ];
+
+  return (
+    <DialogTitle
+      {...props}
+      sx={mergedSx}
+      onClose={
+        onClose
+          ? (event: MouseEvent) => onClose(event, 'escapeKeyDown')
+          : undefined
+      }
+    />
+  );
+}
+
+DrawerTitle.displayName = 'NhostDrawerTitle';
+
+export default DrawerTitle;
