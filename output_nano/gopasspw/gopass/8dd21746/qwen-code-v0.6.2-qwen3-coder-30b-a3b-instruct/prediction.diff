@@ -0,0 +1,22 @@
+package commands
+
+import (
+	"context"
+
+	"github.com/gopasspw/gopass/pkg/ctxutil"
+	"github.com/urfave/cli/v2"
+)
+
+// withGlobalFlags is a helper to add global flags to a context
+func withGlobalFlags(ctx context.Context, c *cli.Context) context.Context {
+	if c.Bool("yes") {
+		ctx = ctxutil.WithAlwaysYes(ctx, true)
+	}
+	if c.Bool("clip") {
+		ctx = ctxutil.WithClip(ctx, true)
+	}
+	if c.Bool("alsoclip") {
+		ctx = ctxutil.WithAlsoClip(ctx, true)
+	}
+	return ctx
+}
