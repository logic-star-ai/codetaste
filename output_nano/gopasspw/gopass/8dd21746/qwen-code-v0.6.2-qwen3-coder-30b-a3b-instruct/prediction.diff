@@ -0,0 +1,49 @@
+package commands
+
+import (
+	"context"
+
+	ap "github.com/gopasspw/gopass/pkg/action"
+	"github.com/urfave/cli/v2"
+)
+
+// GetCommands returns the list of all commands, broken down by type
+func GetCommands(ctx context.Context, action *ap.Action, app *cli.App) []*cli.Command {
+	commands := []*cli.Command{}
+
+	// Add all commands
+	commands = append(commands, auditCommand(ctx, action))
+	commands = append(commands, binaryCommand(ctx, action))
+	commands = append(commands, cloneCommand(ctx, action))
+	commands = append(commands, completionCommand(ctx, action, app))
+	commands = append(commands, configCommand(ctx, action))
+	commands = append(commands, copyCommand(ctx, action))
+	commands = append(commands, createCommand(ctx, action))
+	commands = append(commands, deleteCommand(ctx, action))
+	commands = append(commands, editCommand(ctx, action))
+	commands = append(commands, findCommand(ctx, action))
+	commands = append(commands, fsckCommand(ctx, action))
+	commands = append(commands, generateCommand(ctx, action))
+	commands = append(commands, gitCredentialCommand(ctx, action))
+	commands = append(commands, jsonapiCommand(ctx, action))
+	commands = append(commands, otpCommand(ctx, action))
+	commands = append(commands, gitCommand(ctx, action))
+	commands = append(commands, grepCommand(ctx, action))
+	commands = append(commands, historyCommand(ctx, action))
+	commands = append(commands, initCommand(ctx, action))
+	commands = append(commands, insertCommand(ctx, action))
+	commands = append(commands, listCommand(ctx, action))
+	commands = append(commands, moveCommand(ctx, action))
+	commands = append(commands, mountsCommand(ctx, action))
+	commands = append(commands, recipientsCommand(ctx, action))
+	commands = append(commands, setupCommand(ctx, action))
+	commands = append(commands, showCommand(ctx, action))
+	commands = append(commands, syncCommand(ctx, action))
+	commands = append(commands, templatesCommand(ctx, action))
+	commands = append(commands, unclipCommand(ctx, action))
+	commands = append(commands, updateCommand(ctx, action))
+	commands = append(commands, versionCommand(ctx, action))
+	commands = append(commands, xcCommand(ctx, action))
+
+	return commands
+}
