diff --git a/cli_helpers.go b/cli_helpers.go
new file mode 100644
index 0000000..f29a443
--- /dev/null
+++ b/cli_helpers.go
@@ -0,0 +1,33 @@
+package main
+
+import (
+	"context"
+
+	ap "github.com/gopasspw/gopass/pkg/action"
+	"github.com/urfave/cli/v2"
+)
+
+type cliActionFunc func(context.Context, *cli.Context) error
+type cliCompleteFunc func(context.Context, *cli.Context)
+
+func cliAction(ctx context.Context, fn cliActionFunc) func(*cli.Context) error {
+	return func(c *cli.Context) error {
+		return fn(withGlobalFlags(ctx, c), c)
+	}
+}
+
+func cliBefore(ctx context.Context, fn cliActionFunc) func(*cli.Context) error {
+	return func(c *cli.Context) error {
+		return fn(withGlobalFlags(ctx, c), c)
+	}
+}
+
+func cliBeforeInitialized(ctx context.Context, action *ap.Action) func(*cli.Context) error {
+	return cliBefore(ctx, action.Initialized)
+}
+
+func cliComplete(ctx context.Context, fn cliCompleteFunc) func(*cli.Context) {
+	return func(c *cli.Context) {
+		fn(ctx, c)
+	}
+}
