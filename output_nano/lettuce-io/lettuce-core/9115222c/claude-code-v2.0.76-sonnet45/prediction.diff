     }
+
+    /**
+     * Create a {@link Promise} that aggregates multiple Netty {@link Promise}s. The aggregate promise completes when all
+     * promises complete successfully, or fails fast if any promise fails.
+     *
+     * @param target the target {@link Promise} to complete.
+     * @param promises the {@link Promise}s to aggregate.
+     * @param <V> the promise value type.
+     * @return the {@link GenericFutureListener} for cleanup purposes if needed.
+     * @since 6.0
+     */
+    @SafeVarargs
+    public static <V> GenericFutureListener<io.netty.util.concurrent.Future<V>> promiseAllOf(Promise<V> target,
+            Promise<V>... promises) {
+
+        LettuceAssert.notNull(target, "Target promise must not be null");
+        LettuceAssert.notNull(promises, "Promises must not be null");
+
+        if (promises.length == 0) {
+            target.setSuccess(null);
+            return null;
+        }
+
+        PromiseAggregator<V> aggregator = new PromiseAggregator<>(target, promises.length);
+
+        for (Promise<V> promise : promises) {
+            if (promise != null) {
+                promise.addListener(aggregator);
+            }
+        }
+
+        return aggregator;
+    }
+
+    /**
+     * Retrieve the exception from a {@link Future}.
+     *
+     * @param future the future to extract the exception from.
+     * @return the exception or {@literal null} if the future completed successfully.
+     * @since 6.0
+     */
+    public static Throwable getException(Future<?> future) {
+
+        try {
+            future.get();
+        } catch (InterruptedException e) {
+            throw new RedisCommandInterruptedException(e);
+        } catch (ExecutionException e) {
+            return e.getCause();
+        }
+
+        return null;
+    }
+
+    /**
+     * Internal aggregator for Netty promises.
+     */
+    private static class PromiseAggregator<V> implements GenericFutureListener<io.netty.util.concurrent.Future<V>> {
+
+        private final Promise<V> target;
+
+        private final int expectedCount;
+
+        private int successCount = 0;
+
+        private boolean failed = false;
+
+        PromiseAggregator(Promise<V> target, int expectedCount) {
+            this.target = target;
+            this.expectedCount = expectedCount;
+        }
+
+        @Override
+        public synchronized void operationComplete(io.netty.util.concurrent.Future<V> future) {
+
+            if (failed) {
+                return;
+            }
+
+            if (!future.isSuccess()) {
+                failed = true;
+                target.setFailure(future.cause());
+                return;
+            }
+
+            successCount++;
+
+            if (successCount == expectedCount) {
+                target.setSuccess(null);
+            }
+        }
+
+    }
+
 }
