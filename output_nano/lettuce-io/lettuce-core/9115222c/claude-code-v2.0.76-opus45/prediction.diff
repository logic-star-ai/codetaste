+package io.lettuce.core.internal;
+
+import static org.assertj.core.api.Assertions.assertThat;
+import static org.assertj.core.api.Assertions.assertThatThrownBy;
+
+import java.util.concurrent.CompletableFuture;
+
+import org.junit.jupiter.api.Test;
+
+import io.lettuce.test.Wait;
+import io.netty.util.concurrent.DefaultPromise;
+import io.netty.util.concurrent.GlobalEventExecutor;
+import io.netty.util.concurrent.ImmediateEventExecutor;
+import io.netty.util.concurrent.Promise;
+
+/**
+ * Unit tests for {@link Futures}.
+ *
+ * @author Mark Paluch
+ */
+class FuturesUnitTests {
+
+    @Test
+    void toBooleanPromiseShouldCompleteSuccessfully() {
+
+        DefaultPromise<Object> nettyPromise = new DefaultPromise<>(GlobalEventExecutor.INSTANCE);
+        CompletableFuture<Boolean> result = Futures.toBooleanPromise(nettyPromise);
+
+        assertThat(result.isDone()).isFalse();
+
+        nettyPromise.setSuccess(null);
+
+        Wait.untilTrue(result::isDone).waitOrTimeout();
+
+        assertThat(result.isDone()).isTrue();
+        assertThat(result.join()).isTrue();
+    }
+
+    @Test
+    void toBooleanPromiseShouldPropagateFailure() {
+
+        DefaultPromise<Object> nettyPromise = new DefaultPromise<>(GlobalEventExecutor.INSTANCE);
+        CompletableFuture<Boolean> result = Futures.toBooleanPromise(nettyPromise);
+
+        assertThat(result.isDone()).isFalse();
+
+        nettyPromise.setFailure(new RuntimeException("test error"));
+
+        Wait.untilTrue(result::isDone).waitOrTimeout();
+
+        assertThat(result.isDone()).isTrue();
+        assertThat(result.isCompletedExceptionally()).isTrue();
+    }
+
+    @Test
+    void toBooleanPromiseShouldHandleAlreadyCompletedFuture() {
+
+        DefaultPromise<Object> nettyPromise = new DefaultPromise<>(ImmediateEventExecutor.INSTANCE);
+        nettyPromise.setSuccess("value");
+
+        CompletableFuture<Boolean> result = Futures.toBooleanPromise(nettyPromise);
+
+        assertThat(result.isDone()).isTrue();
+        assertThat(result.join()).isTrue();
+    }
+
+    @Test
+    void toNettyPromiseShouldCompleteSuccessfully() {
+
+        CompletableFuture<String> completableFuture = new CompletableFuture<>();
+        Promise<String> result = Futures.toNettyPromise(completableFuture);
+
+        assertThat(result.isDone()).isFalse();
+
+        completableFuture.complete("success");
+
+        Wait.untilTrue(result::isDone).waitOrTimeout();
+
+        assertThat(result.isDone()).isTrue();
+        assertThat(result.isSuccess()).isTrue();
+        assertThat(result.getNow()).isEqualTo("success");
+    }
+
+    @Test
+    void toNettyPromiseShouldPropagateFailure() {
+
+        CompletableFuture<String> completableFuture = new CompletableFuture<>();
+        Promise<String> result = Futures.toNettyPromise(completableFuture);
+
+        assertThat(result.isDone()).isFalse();
+
+        completableFuture.completeExceptionally(new RuntimeException("test error"));
+
+        Wait.untilTrue(result::isDone).waitOrTimeout();
+
+        assertThat(result.isDone()).isTrue();
+        assertThat(result.isSuccess()).isFalse();
+        assertThat(result.cause()).isInstanceOf(RuntimeException.class);
+    }
+
+    @Test
+    void toNettyPromiseShouldRejectNull() {
+        assertThatThrownBy(() -> Futures.toNettyPromise(null)).isInstanceOf(IllegalArgumentException.class);
+    }
+}
