+     *
+     * @param futures must not be {@literal null}.
+     * @return the composed {@link CompletableFuture}.
+     */
+    @SuppressWarnings({ "rawtypes" })
+    public static CompletableFuture<Boolean> allOf(Future<?>... futures) {
+
+        LettuceAssert.notNull(futures, "Futures must not be null");
+
+        return CompletableFuture.allOf(Stream.of(futures).map(Futures::toBooleanPromise).toArray(CompletableFuture[]::new))
+                .thenApply(v -> true);
+    }
+
+    /**
+     * Create a Netty {@link Promise} that completes when the given {@link CompletableFuture} completes. This method bridges
+     * {@link CompletableFuture} to Netty's {@link Future} API.
+     *
+     * @param completableFuture must not be {@literal null}.
+     * @param <T> value type.
+     * @return a Netty {@link Promise} that completes when the {@link CompletableFuture} completes.
+     */
+    public static <T> Promise<T> toNettyPromise(CompletableFuture<T> completableFuture) {
+
+        LettuceAssert.notNull(completableFuture, "CompletableFuture must not be null");
