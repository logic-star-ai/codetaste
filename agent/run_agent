#!/bin/bash

echo $PATH

(echo "Perform the task described, do not plan for the task but actually execute it and do the changes! Here is the task.";
cat /task_description/description.md) | claude -p \
  --dangerously-skip-permissions \
  --verbose \
  --output-format stream-json \
  --model claude-haiku-4-5-20251001 \
  --max-budget-usd 5 2>&1 | tee /tmp/output_log.json

tail -n 1 /tmp/output_log.json > /output/inference_metadata.json